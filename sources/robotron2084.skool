 $F2DA DEFB $13,$01           ; BRIGHT: #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $F2DC DEFB $1A,$01           ; Select font: #N(#PEEK(#PC+$01)).
 $F2DE DEFB $16,$53,$12       ; PRINT AT #N(#PEEK(#PC+$01)),
                              ; #N(#PEEK(#PC+$02)).
 $F2E1 DEFB $10,$01           ; Set INK: #INK(#PEEK(#PC+$01)).
 $F2E3 DEFB $11,$00           ; Set PAPER: #INK(#PEEK(#PC+$01)).
 $F2E5 DEFM "ROBOTRON HEROES"
 $F2F4 DEFB $13,$00           ; BRIGHT: #MAP(#PEEK(#PC+$01))(OFF,1:ON).
