 $DAC9 RL B          ; }
 $DACB PUSH BC       ; Stash the scaled Y and row stride on the stack.
 $DACC INC HL        ; {Read the X position and derive the column address via
 $DACD LD A,(HL)     ; three-step rotation.
 $DACE AND A         ;
 $DACF LD HL,$0000   ;
 $DAD2 RRA           ;
 $DAD3 RR L          ;
 $DAD5 RRA           ;
 $DAD6 RR L          ;
 $DAD8 RRA           ;
 $DAD9 RR L          ; }
 $DADB EXX           ; {Save the sub-column pixel offset in #REGc'.
 $DADC LD C,A        ;
 $DADD EXX           ; }
 $DADE LD A,L        ; {Adjust the column address to align with two-byte row table
 $DADF RRCA          ; entries.
 $DAE0 ADD A,L       ;
 $DAE1 LD L,A        ;
 $DAE2 LD A,H        ;
