 $ED86 CPIR          ;
 $ED88 JR NZ,$ED8C   ;
 $ED8A LD A,(HL)     ;
 $ED8B LD (DE),A     ;
*$ED8C INC DE        ;
 $ED8D LD A,D        ;
 $ED8E CP $5B        ;
 $ED90 JR NZ,$ED7F   ;
 $ED92 RET           ;
; This entry point is used by the routine at #R$EBC8.
*$ED93 LD A,(DE)     ;
 $ED94 LD HL,$EE5B   ;
 $ED97 LD BC,$000A   ;
 $ED9A CPIR          ;
 $ED9C JR NZ,$EDA0   ;
 $ED9E LD A,(HL)     ;
 $ED9F LD (DE),A     ;
*$EDA0 INC DE        ;
 $EDA1 PUSH IX       ;
 $EDA3 POP HL        ;
 $EDA4 AND A         ;
 $EDA5 SBC HL,DE     ;
 $EDA7 JR NZ,$ED93   ;
 $EDA9 RET           ;
; This entry point is used by the routine at #R$EBC8.
*$EDAA PUSH IX       ;
 $EDAC POP HL        ;
 $EDAD LD A,E        ;
 $EDAE PUSH BC       ;
 $EDAF CALL $EE02    ;
 $EDB2 POP BC        ;
 $EDB3 RET NZ        ;
