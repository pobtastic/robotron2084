; Print State: Y Position
@label=PrintState_Y
g$8000 DEFB $BB      ; Current Y (vertical) pixel position.

; Print State: X Position
@label=PrintState_X
g$8001 DEFB $93      ; Current X (horizontal) pixel position.

; Print State: Bit-Shift Count
@label=PrintState_BitShift
g$8002 DEFB $07      ; Sub-byte bit-shift count for the character currently
                     ; being rendered.

; Print State: Character Code
@label=PrintState_Char
g$8003 DEFB $30      ; Character code of the glyph currently being rendered.

; Print State: Attribute Byte
@label=PrintState_Attr
g$8004 DEFB $07      ; Current attribute byte (INK, PAPER, BRIGHT and FLASH).

; Print State: Left Margin
@label=PrintState_LeftMargin
g$8005 DEFB $00      ; Left margin X position; X resets here on a carriage
                     ; return.

; Print State: Right Margin
@label=PrintState_RightMargin
g$8006 DEFB $FF      ; Right margin X position; a line wrap occurs when X would
                     ; exceed this.

; Print State: Flags
@label=PrintState_Flags
g$8007 DEFB $01      ; Flags; bit 0 = control code parameter was out of range.

; Print State: Font Bitmap Pointer
@label=PrintState_FontPtr
g$8008 DEFB $00,$83  ; Font bitmap data pointer; base address for character
                     ; glyph lookups.

; Print State: Handler Pointer
@label=PrintState_Handler
g$800A DEFB $E3,$8D  ; Current byte handler; pointer into the print state
                     ; machine (default #R$8DE3).

; Print State: Normal Width
@label=PrintState_Width
g$800C DEFB $06      ; Normal character pixel width.

; Print State: Narrow Width
@label=PrintState_NarrowWidth
g$800D DEFB $05      ; Narrow character pixel width (used for "#CHR$49").

; Print State: Wide Width
@label=PrintState_WideWidth
g$800E DEFB $06      ; Wide character pixel width (used for "#CHR$4D" and
                     ; "#CHR$57").

; Print State: Space Width
@label=PrintState_SpaceWidth
g$800F DEFB $05      ; Space character pixel width.

; Print State: Line Height
@label=PrintState_LineHeight
g$8010 DEFB $09      ; Font line height in pixels; Y advances by this on a
                     ; carriage return.

; Print State: Row Count
@label=PrintState_RowCount
g$8011 DEFB $06                             ; Number of pixel rows per
                                            ; character glyph.
