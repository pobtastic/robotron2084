; Clear Screen Buffer
;
; Used by the routines at #R$D30C, #R$D317, #R$F4EC and #R$F5DA.
@label=ClearScreenBuffer
c$D070 LD HL,$4000   ; {Clear #N$1800 bytes of data from #N$4000 to #N$5B00.
 $D073 LD (HL),$00   ;
 $D075 LD DE,$4001   ;
 $D078 LD BC,$17FF   ;
 $D07B LDIR          ; }
 $D07D RET           ; Return.

; Set Background Colour
;
; Used by the routines at #R$D30C, #R$D317 and #R$F4EC.
;
; A Attribute byte to fill the entire attribute area with
@label=SetBackgroundColour
c$D07E LD HL,$5800   ; {Write #REGa to #N$02FF bytes of data from #N$5800 to
 $D081 LD (HL),A     ; #N$5AFF.
 $D082 LD DE,$5801   ;
 $D085 LD BC,$02FF   ;
 $D088 LDIR          ; }
 $D08A RET           ; Return.

; Swap Player State
;
; Used by the routines at #R$D317, #R$D367 and #R$D3F8.
; .
; Swaps the active and inactive player's #N$44-byte state blocks between
; the player 1 slot at #R$C403 and the player 2 slot at #R$C447, using
; #R$C48B as a scratch buffer. Called each time the game switches between
; the two players. The swap is a three-step rotate through the scratch
; buffer: save active, overwrite active with inactive, restore saved.
@label=Swap_Player_State
c$D08B LD HL,$C403   ; {Save the active player's #N$44-byte state block to the scratch buffer
 $D08E LD DE,$C48B   ; at #R$C48B.
 $D091 LD BC,$0044   ;
 $D094 LDIR          ; }
 $D096 LD DE,$C403   ; {Copy the other player's state block from #R$C447 into the active
 $D099 LD BC,$0044   ; player's slot at #R$C403.
 $D09C LDIR          ; }
 $D09E LD HL,$C48B   ; {Copy the saved state block from #R$C48B into the other player's slot
 $D0A1 LD BC,$0044   ; at #R$C447.
 $D0A4 LDIR          ; }
 $D0A6 RET           ; Return.

; Print Wave Number
;
; Used by the routine at #R$D317.
; .
; Prints the current wave number at pixel position X=*#R$C41D, Y=#N$BB
; using the print dispatch system at #R$8DCC. The wave number is stored in
; packed BCD at #R$C408: the high nibble holds the tens digit and the low
; nibble holds the units digit; each is OR'd with #N$30 to convert it to
; an ASCII decimal character before dispatch. Font #N$00 is selected for
; rendering and font #N$01 is restored on return.
@label=PrintWaveNumber
c$D0A7 LD A,$1A      ; {Call #R$8DCC with #N$1A (Select Font control code).
 $D0A9 CALL $8DCC    ; }
 $D0AC LD A,$00      ; {Call #R$8DCC with #N$00 (font #N$00).
 $D0AE CALL $8DCC    ; }
 $D0B1 LD A,$16      ; {Call #R$8DCC with #N$16 (PRINT AT control code).
 $D0B3 CALL $8DCC    ; }
 $D0B6 LD A,($C41D)  ; #REGa=*#R$C41D (X pixel position for the wave number
                     ; display).
 $D0B9 CALL $8DCC    ; Call #R$8DCC; the PRINT AT X handler stores the X
                     ; position and installs the Y handler.
 $D0BC LD A,$BB      ; #REGa=#N$BB (Y pixel position).
 $D0BE CALL $8DCC    ; Call #R$8DCC; the PRINT AT Y handler stores the Y
                     ; position and restores the default handler.
 $D0C1 LD A,($C408)  ; #REGa=*#R$C408 (BCD wave number).
 $D0C4 SRL A         ; {Shift #REGa right four positions to isolate the tens digit
 $D0C6 SRL A         ; (high nibble, #N$00–#N$09).
 $D0C8 SRL A         ;
 $D0CA SRL A         ; }
 $D0CC OR %00110000  ; Convert the tens digit to its ASCII character
                     ; ("#CHR$30"–"#CHR$39").
 $D0CE CALL $8DCC    ; Call #R$8DCC to print the tens digit.
 $D0D1 LD A,($C408)  ; #REGa=*#R$C408 (BCD wave number again).
 $D0D4 AND %00001111 ; Isolate the units digit (low nibble, #N$00–#N$09).
 $D0D6 OR %00110000  ; Convert the units digit to its ASCII character
                     ; ("#CHR$30"–"#CHR$39").
 $D0D8 CALL $8DCC    ; Call #R$8DCC to print the units digit.
 $D0DB LD A,$1A      ; {Call #R$8DCC with #N$1A (Select Font control code).
 $D0DD CALL $8DCC    ; }
 $D0E0 LD A,$01      ; {Call #R$8DCC with #N$01 (restore font #N$01).
 $D0E2 CALL $8DCC    ; }
 $D0E5 RET           ; Return.

; Messaging: Wave
@label=Messaging_Wave
t$D0E6 DEFB $1A,$00     ; Select font: #N(#PEEK(#PC+$01)).
 $D0E8 DEFB $16,$77,$BB ; PRINT AT #N(#PEEK(#PC+$01)), #N(#PEEK(#PC+$02)).
 $D0EB DEFM "WAVE"
 $D0EF DEFB $1F         ; Terminator.

; Spawn Primary Wave Enemies
;
; Used by the routine at #R$D24C.
; .
; Reads the enemy count and type for the current wave from the definition
; pointed to by #REGhl, then spawns that many primary wave entities at random
; valid screen positions by writing records into the entity list at #R$C509.
; Each entity is placed at a random column (1–30) and row (2–22), scaled to
; pixel coordinates, and drawn to the screen via #N$CC81. If the count is zero
; the entity list is left empty and the routine returns immediately.
;
; HL Pointer to the wave enemy definition (count byte followed by type byte)
@label=Spawn_Primary_Wave_Enemies
c$D0F0 LD B,(HL)     ; {Read the enemy count from the wave definition and store
 $D0F1 LD A,B        ; at #R$C423.
 $D0F2 LD ($C423),A  ; }
 $D0F5 INC HL        ; Advance #REGhl to the enemy type byte.
 $D0F6 LD A,(HL)     ; Read the enemy type parameter from the wave definition.
 $D0F7 LD ($C424),A  ; Store the enemy type parameter at #R$C424.
 $D0FA INC HL        ; Advance the wave definition pointer.
 $D0FB PUSH HL       ; Stash the wave definition pointer on the stack.
 $D0FC LD HL,($C509) ; Load the entity list write pointer from *#R$C509.
 $D0FF LD A,B        ; {Skip spawning if the wave has no enemies.
 $D100 AND A         ;
 $D101 JP Z,$D196    ; }
; For each enemy: write the entity handler, pick a random valid screen
; position, build the entity record, and draw the sprite.
@label=Spawn_Primary_Wave_Enemies_Loop
*$D104 PUSH BC       ; Stash the enemy count on the stack.
 $D105 LD DE,$CCCE   ; Load the primary entity handler address #R$CCCE into
                     ; #REGde.
 $D108 LD (HL),E     ; {Write the primary entity handler address into the
 $D109 INC HL        ; entity list.
 $D10A LD (HL),D     ; }
 $D10B INC HL        ; Advance #REGhl past the handler bytes.
@label=Spawn_Primary_Wave_Enemies_Get_X
*$D10C CALL $D1BF    ; Generate a random column via #R$D1BF.
 $D10F AND %00011111 ; Mask to columns 0–31.
 $D111 JR Z,$D10C    ; {Retry if the column is at the left or right wall.
 $D113 CP $1F        ;
 $D115 JR Z,$D10C    ; }
 $D117 LD B,A        ; Copy the valid column to #REGb.
@label=Spawn_Primary_Wave_Enemies_Get_Y
*$D118 CALL $D1BF    ; Generate a random row via #R$D1BF.
 $D11B AND %00011111 ; Mask to rows 0–31.
 $D11D CP $02        ; {Retry if the row is too close to the top or bottom
 $D11F JR C,$D118    ; edge.
 $D121 CP $17        ;
 $D123 JR NC,$D118   ; }
 $D125 SLA A         ; {Scale the row and column to pixel coordinates (multiply
 $D127 SLA A         ; by 8).
 $D129 SLA A         ;
 $D12B SLA B         ;
 $D12D SLA B         ;
 $D12F SLA B         ; }
 $D131 LD (HL),A     ; Write the Y pixel to the entity record.
 $D132 LD ($C4F3),A  ; Cache the Y pixel at #R$C4F3.
 $D135 INC HL        ; Advance #REGhl to the X slot in the entity record.
 $D136 LD (HL),B     ; Write the X pixel to the entity record.
 $D137 LD A,B        ; {Copy the X pixel from #REGb into #REGa and cache it at
 $D138 LD ($C4F4),A  ; #R$C4F3(#N$C4F4).}
 $D13B INC HL        ; Advance #REGhl to the colour slot.
 $D13C LD (HL),$07   ; {Write #INK$07 to the colour and type bytes.
 $D13E INC HL        ;
 $D13F LD (HL),$07   ; }
 $D141 DEC HL        ; {Step back three bytes to point at the start of the
 $D142 DEC HL        ; entity record.
 $D143 DEC HL        ; }
 $D144 EXX           ; {Load the entity spawn handler address #R$D1C7 into
 $D145 LD HL,$D1C7   ; alternate #REGhl.
 $D148 EXX           ; }
 $D149 CALL $C6DA    ; Test whether this position overlaps an existing entity
                     ; via #R$C6DA.
 $D14C DEC HL        ; {Retry with new coordinates if the position is occupied.
 $D14D DEC HL        ;
 $D14E DEC HL        ;
 $D14F JR NC,$D10C   ; }
 $D151 INC HL        ; {Advance past the entity record header fields.
 $D152 INC HL        ;
 $D153 INC HL        ;
 $D154 INC HL        ; }
 $D155 LD A,($C424)  ; {Copy the wave enemy type from #R$C424 into the entity
 $D158 LD (HL),A     ; record.
 $D159 INC HL        ; }
; Build the on-screen pixel address and attribute address from the cached
; pixel coordinates at #R$C4F3.
 $D15A EX DE,HL      ; Copy #REGhl to #REGde (entity record pointer now in
                     ; #REGde).
 $D15B LD HL,$C4F3   ; Point #REGhl at the cached pixel coordinates at #R$C4F3.
 $D15E LD A,(HL)     ; Read the Y pixel (row) from the cache.
 $D15F INC HL        ; Advance #REGhl to the X pixel byte.
 $D160 LD C,(HL)     ; Read the X pixel (column) from the cache.
 $D161 LD L,A        ; Move the Y pixel into #REGl for the row term.
 $D162 LD B,$45      ; Load the screen address high-byte base #N$45 into #REGb.
 $D164 SLA C         ; Shift the X pixel left in #REGc.
 $D166 RL B          ; Roll the carry into the screen high byte in #REGb.
 $D168 LD H,$46      ; Load the second high-byte term #N$46 into #REGh.
 $D16A SLA L         ; Shift the Y pixel left in #REGl.
 $D16C RL H          ; Finish forming the screen address high byte in #REGh.
 $D16E LD A,(HL)     ; Read the low byte of the pixel data pointer from the
                     ; table.
 $D16F INC HL        ; Advance #REGhl to the high byte.
 $D170 LD H,(HL)     ; Read the high byte of the pixel data pointer.
 $D171 LD L,A        ; Form the full pixel data pointer in #REGhl (low in
                     ; #REGl).
 $D172 LD A,(BC)     ; Read a byte from the built screen address in #REGbc.
 $D173 OR L          ; Combine the screen low byte with the pixel table low
                     ; byte.
 $D174 LD L,A        ; Store the combined screen low byte in #REGl.
 $D175 EX DE,HL      ; Exchange #REGhl with #REGde (entity record pointer back
                     ; in #REGhl).
 $D176 LD (HL),E     ; {Write the screen address into the entity record.
 $D177 INC HL        ;
 $D178 LD (HL),D     ; }
 $D179 INC HL        ; Advance #REGhl to the attribute slot.
 $D17A LD A,D        ; Load the attribute address high byte from #REGd.
 $D17B RRCA          ; {Rotate the attribute page bits toward the low end three
 $D17C RRCA          ; times.
 $D17D RRCA          ; }
 $D17E AND %00000011 ; Mask to the attribute page bits.
 $D180 OR %01011000  ; Set the attribute area high byte.
 $D182 LD D,A        ; Store the attribute address high byte in #REGd.
 $D183 LD (HL),E     ; {Write the attribute address into the entity record.
 $D184 INC HL        ;
 $D185 LD (HL),D     ; }
 $D186 DEC HL        ; {Step #REGhl back four bytes to the entity origin for
 $D187 DEC HL        ; drawing.
 $D188 DEC HL        ;
 $D189 DEC HL        ; }
 $D18A CALL $CC81    ; Call #R$CC81.
 $D18D DEC HL        ; Step #REGhl to the end-of-record marker position.
 $D18E LD (HL),$FF   ; Write the record terminator #N$FF after this entity.
 $D190 INC HL        ; Advance #REGhl for the next list write.
 $D191 POP BC        ; Restore the enemy count from the stack.
 $D192 DEC B         ; Decrement the remaining enemies to spawn for this wave.
 $D193 JP NZ,$D104   ; Loop back to #R$D104 if more enemies remain.
; All enemies spawned: write the entity list terminator and return.
@label=Spawn_Primary_Wave_Enemies_Done
*$D196 LD DE,$D1A4   ; Load #R$D1A4 into #REGde.
 $D199 LD ($C509),HL ; Store the updated write pointer at #R$C509.
 $D19C LD (HL),E     ; {Store the entity list terminator routine address #R$D1A4 at *#REGhl
 $D19D INC HL        ; (low byte then high byte).
 $D19E LD (HL),D     ; }
 $D19F INC HL        ; Advance #REGhl past the stored pointer bytes.
 $D1A0 LD (HL),$FF   ; Write the terminator byte (#N$FF) to the entity list.
 $D1A2 POP HL        ; Restore the wave definition pointer from the stack.
 $D1A3 RET           ; Return.
; Inline stub: resets the entity list pointer and returns. Used as the
; terminal routine address written into the entity list by the spawning routines.
@label=Entity_List_Reset
 $D1A4 LD HL,$6000   ; Reset the entity list pointer to #R$6000.
 $D1A7 RET           ; Return.

; Advance RNG Seed
;
; Used by the routines at #R$D1BF, #R$E360 and #R$E7CF.
; .
; Advances the linear congruential generator one step. The seed at #R$C4DC
; is updated using the recurrence seed = seed × #N$21 + #N$29 (multiply by 33,
; add 41), producing the next pseudo-random value. Called by #R$D1BF to
; generate each random byte during enemy spawning.
@label=Advance_RNG_Seed
c$D1A8 LD HL,($C4DC) ; Load the current RNG seed from #R$C4DC.
 $D1AB PUSH BC       ; Stash #REGbc on the stack.
 $D1AC ADD HL,HL     ; {Multiply the seed by #N$20 by shifting left five times.
 $D1AD ADD HL,HL     ;
 $D1AE ADD HL,HL     ;
 $D1AF ADD HL,HL     ;
 $D1B0 ADD HL,HL     ; }
 $D1B1 LD BC,($C4DC) ; {Reload the original seed into #REGbc and add it (total
 $D1B5 ADD HL,BC     ; factor: #N$21).}
 $D1B6 LD BC,$0029   ; {Add #N($0029,$04,$04) and store the new seed back to
 $D1B9 ADD HL,BC     ; #R$C4DC.
 $D1BA LD ($C4DC),HL ; }
 $D1BD POP BC        ; {Restore #REGbc and return.
 $D1BE RET           ; }

; Generate Random Byte
;
; Used by the routines at #R$CD34, #R$D0F0, #R$E003, #R$E122, #R$E1B6, #R$E290,
; #R$E2C8, #R$E520, #R$E6F7, #R$E7CF, #R$EA6E and #R$EB07.
; .
; Produces a single pseudo-random byte by advancing the RNG seed via
; #R$D1A8 and XOR-mixing its two bytes. #REGhl is preserved. Called throughout
; the enemy spawning routines to pick random positions and directions.
@label=Generate_Random_Byte
c$D1BF PUSH HL       ; {Stash #REGhl and advance the RNG seed via #R$D1A8.
 $D1C0 CALL $D1A8    ; }
 $D1C3 LD A,L        ; {XOR-mix the seed high and low bytes to produce the
 $D1C4 XOR H         ; random byte.}
 $D1C5 POP HL        ; {Restore #REGhl and return.
 $D1C6 RET           ; }
; Entity spawn handler stub, invoked by #R$C6DA during hit-testing. Stores
; the entity colour from #REGc and advances the entity pointer.
@label=Entity_Spawn_Handler
 $D1C7 LD D,B        ; {Initialise the entity colour byte and advance the
 $D1C8 LD (HL),C     ; entity data pointer.
 $D1C9 INC HL        ;
 $D1CA RRA           ; }
; This entry point is used by the routine at #R$D24C.
; .
; Secondary wave enemy spawn: reads the entity configuration from the wave
; definition pointed to by #REGhl, then spawns secondary entities (handler
; #N$CEDF) at random valid pixel positions on the playfield.
@label=Spawn_Wave_Enemies_Class2
*$D1CB LD A,(HL)     ; {Read the sprite type byte from the wave definition and store at
 $D1CC LD ($C425),A  ; #N$C425.}
 $D1CF LD B,A        ; {Copy the sprite type to #REGb, accumulate it into #R$C41C, and
 $D1D0 LD A,($C41C)  ; advance the definition pointer.
 $D1D3 ADD A,B       ;
 $D1D4 LD ($C41C),A  ;
 $D1D7 INC HL        ; }
 $D1D8 LD A,(HL)     ; {Read the direction byte from the definition and store
 $D1D9 LD ($C426),A  ; at #N$C426.
 $D1DC INC HL        ; }
 $D1DD LD D,(HL)     ; {Read the speed byte, store at #N$C427; set the initial animation
 $D1DE LD A,D        ; frame pair at #R$C51B.
 $D1DF LD ($C427),A  ;
 $D1E2 LD E,$FE      ;
 $D1E4 LD ($C51B),DE ; }
 $D1E8 INC HL        ; {Advance past the definition data and stash the definition pointer;
 $D1E9 PUSH HL       ; load the entity list write pointer from #R$C509.
 $D1EA LD HL,($C509) ; }
 $D1ED LD A,B        ; {Skip spawning if the enemy count is zero.
 $D1EE AND A         ;
 $D1EF JP Z,$D23E    ; }
@label=Spawn_Wave_Enemies_Class2_Loop
*$D1F2 PUSH BC       ; {Stash the enemy count and write the secondary entity handler address
 $D1F3 LD DE,$CEDF   ; #N$CEDF to the entity list.
 $D1F6 LD (HL),E     ;
 $D1F7 INC HL        ;
 $D1F8 LD (HL),D     ;
 $D1F9 INC HL        ; }
*$D1FA CALL $D1BF    ; Generate a random direction via #R$D1BF.
 $D1FD AND %00000011 ; Mask to values 1–3.
 $D1FF JR Z,$D1FA    ; Retry if the direction rolled zero.
 $D201 LD (HL),A     ; {Store the direction and set the initial entity state to
 $D202 INC HL        ; #N$04.
 $D203 LD (HL),$04   ;
 $D205 INC HL        ; }
*$D206 CALL $D1BF    ; Generate a random Y pixel position via #R$D1BF.
 $D209 CP $18        ; {Retry if outside the playfield vertical range
 $D20B JR C,$D206    ; (#N$18–#N$A3).
 $D20D CP $A4        ;
 $D20F JR NC,$D206   ; }
 $D211 LD (HL),A     ; {Write the Y position and advance the entity pointer.
 $D212 INC HL        ; }
*$D213 CALL $D1BF    ; Generate a random X pixel position via #R$D1BF.
 $D216 CP $08        ; {Retry if outside the playfield horizontal range
 $D218 JR C,$D213    ; (#N$08–#N$EE).
 $D21A CP $EF        ;
 $D21C JR NC,$D213   ; }
 $D21E LD (HL),A     ; {Write the X position and the entity dimensions (#N$0C ×
 $D21F INC HL        ; #N$09).
 $D220 LD (HL),$0C   ;
 $D222 INC HL        ;
 $D223 LD (HL),$09   ; }
 $D225 DEC HL        ; {Step back to the entity record origin and load the spawn handler
 $D226 DEC HL        ; #R$D1C7 into alternate #REGhl.
 $D227 DEC HL        ;
 $D228 EXX           ;
 $D229 LD HL,$D1C7   ;
 $D22C EXX           ; }
 $D22D CALL $C6DA    ; Test whether this position overlaps an existing entity
                     ; via #R$C6DA.
 $D230 JR C,$D237    ; Jump to #R$D237 if the position is clear.
 $D232 DEC HL        ; {Step back and retry with a new X position.
 $D233 DEC HL        ;
 $D234 DEC HL        ;
 $D235 JR $D206      ; }
@label=Spawn_Wave_Enemies_Class2_Accept
*$D237 INC HL        ; {Advance past the entity record and write the #N$FF end-of-record
 $D238 LD (HL),$FF   ; marker.
 $D23A INC HL        ; }
 $D23B POP BC        ; {Restore the enemy count and loop for the next secondary
 $D23C DJNZ $D1F2    ; enemy.}
@label=Spawn_Wave_Enemies_Class2_Done
*$D23E LD DE,$D1A4   ; {Write the entity list return-routine address and the #N$FF sentinel;
 $D241 LD ($C509),HL ; store the updated entity list write pointer at #R$C509.
 $D244 LD (HL),E     ;
 $D245 INC HL        ;
 $D246 LD (HL),D     ;
 $D247 INC HL        ;
 $D248 LD (HL),$FF   ; }
 $D24A POP HL        ; {Restore the wave definition pointer and return.
 $D24B RET           ; }

; Stage Next Wave
;
; Used by the routines at #R$C5C1 and #R$D367.
; .
; Entry point for wave staging. Resets the entity list write pointer to
; #R$6100 and writes a terminator. If #R$C41C is non-zero the current wave set
; is re-populated (#R$D299); otherwise a fresh wave is loaded: enemy parameters
; are cleared, the next entry in the wave definition table (#R$C409) is read,
; the display is reinitialised via #R$D30C, and the main game loop is entered
; via #R$CB4F with the playfield entity handler #N$CE62 in place.
@label=Stage_Next_Wave
c$D24C LD HL,$6100   ; Reset the entity list write pointer to #R$6100.
 $D24F LD ($C509),HL ; {Write the entity list terminator routine address #N$D1A4 and the
 $D252 LD DE,$D1A4   ; #N$FF sentinel; store the updated write pointer at #R$C509.
 $D255 LD (HL),E     ;
 $D256 INC HL        ;
 $D257 LD (HL),D     ;
 $D258 INC HL        ;
 $D259 LD (HL),$FF   ; }
 $D25B LD A,($C41C)  ; {Check whether the wave counter at #R$C41C is non-zero; if so, jump
 $D25E AND A         ; to #R$D299 to re-populate the current wave set.
 $D25F JR NZ,$D299   ; }
; New wave: clear enemy parameters, read the next wave definition entry,
; and reinitialise the display.
 $D261 LD HL,$C423   ; {Clear the enemy parameter block at #R$C423 (#N$0C bytes) ready for
 $D264 LD DE,$C424   ; the incoming wave.
 $D267 LD (HL),$00   ;
 $D269 LD BC,$000C   ;
 $D26C LDIR          ; }
 $D26E LD HL,($C409) ; {Read the new wave number from #R$C409 into #R$C408, then reinitialise
 $D271 LD A,(HL)     ; the display via #R$D30C.
 $D272 LD ($C408),A  ;
 $D275 CALL $D30C    ; }
 $D278 LD HL,($C409) ; {Advance the wave definition pointer in #R$C409 past the current entry
 $D27B INC HL        ; via #R$C702.
 $D27C CALL $C702    ; }
 $D27F LD ($C409),HL ; Store the updated wave definition pointer back to
                     ; #R$C409.
@label=Stage_Next_Wave_Activate
*$D282 LD HL,$6000   ; {Point the playfield write pointer (#R$C4D1) to #R$6000 and write the
 $D285 LD DE,$CE62   ; playfield entity handler address #N$CE62 to the entity list.
 $D288 LD ($C4D1),HL ; }
 $D28B LD (HL),E     ; {Write the #N$FF end-of-list sentinel after the handler
 $D28C INC HL        ; address.
 $D28D LD (HL),D     ;
 $D28E INC HL        ;
 $D28F LD (HL),$FF   ; }
 $D291 LD HL,$C4DE   ; {Set the wave active flag at #R$C4DE to #N$01 and jump to the main
 $D294 LD (HL),$01   ; game loop at #R$CB4F.
 $D296 JP $CB4F      ; }
; Re-populate: clear the wave counter, redraw the HUD, and spawn all enemy
; types for the current wave before restarting the game loop.
@label=Stage_Next_Wave_Populate
*$D299 XOR A         ; {Clear the wave counter at #R$C41C and redraw the HUD
 $D29A LD ($C41C),A  ; via #R$D317.
 $D29D CALL $D317    ; }
 $D2A0 LD HL,$C423   ; {Call #R$D0F0 using #R$C423.
 $D2A3 CALL $D0F0    ; }
 $D2A6 CALL $D1CB    ; Spawn the secondary wave enemies via #R$D1CB.
 $D2A9 CALL $E122    ; Run the entity update pass via #R$E122.
 $D2AC CALL $E290    ; Call #R$E290.
 $D2AF CALL $E863    ; Call #R$E863.
 $D2B2 CALL $CE64    ; Call #R$CE64.
 $D2B5 CALL $E92C    ; Call #R$E92C.
 $D2B8 XOR A         ; {Clear #REGa and restart the playfield via #R$D282.
 $D2B9 JP $D282      ; }

; Strip Attributes and Fade
;
; Used by the routines at #R$CCCE, #R$CD34, #R$E1B6, #R$E360, #R$E520, #R$E6F7,
; #R$E881 and #R$EB07.
; .
; Player-death transition. Strips the paper and bright bits from every
; attribute cell in the attribute area (#N$5800–#N$5AFF), keeping only the ink
; colour, then calls #R$D2D1 to fade the screen pixel data to black with a
; flashing border effect. On return, two levels of call stack are discarded
; via back-to-back POP #REGde, aborting the current game-loop callers and
; returning to the outer death-handling code.
@label=Strip_Attributes_And_Fade
c$D2BC LD HL,$5800   ; Point #REGhl to the start of the attribute area at
                     ; #N$5800.
 $D2BF LD B,$07      ; Load the ink-colour mask #N$07 into #REGb.
@label=Strip_Attributes_Loop
*$D2C1 LD A,(HL)     ; {Mask out the paper and bright bits from the current
 $D2C2 AND B         ; attribute cell.
 $D2C3 LD (HL),A     ; }
 $D2C4 INC HL        ; {Advance to the next cell and loop until the end of the attribute
 $D2C5 LD A,H        ; area at #N$5B00.
 $D2C6 CP $5B        ;
 $D2C8 JP NZ,$D2C1   ; }
 $D2CB CALL $D2D1    ; Call the screen fade routine at #R$D2D1.
 $D2CE POP DE        ; {Discard two return addresses from the stack and return to the
 $D2CF POP DE        ; outer death handler.
 $D2D0 RET           ; }
; Screen fade: AND-masks the entire pixel area in 20 passes, cycling the
; border between black and white on each pass to create a flash effect.
@label=Fade_Screen
*$D2D1 LD B,$14      ; Set the fade pass counter to #N$14.
 $D2D3 LD HL,$0000   ; Initialise the pixel mask pointer to #N$0000.
@label=Fade_Screen_Outer_Loop
*$D2D6 PUSH HL       ; {Stash the mask pointer and point #REGde to the start of the pixel
 $D2D7 LD DE,$4000   ; area at #N$4000.}
@label=Fade_Screen_Inner_Loop
*$D2DA LD A,(DE)     ; {AND each pixel byte with the corresponding mask byte; loop across
 $D2DB AND (HL)      ; the current 256-byte row until #REGe wraps.
 $D2DC LD (DE),A     ;
 $D2DD INC DE        ;
 $D2DE INC HL        ;
 $D2DF LD A,E        ;
 $D2E0 AND A         ;
 $D2E1 JR NZ,$D2DA   ; }
 $D2E3 LD A,$00      ; {Set the border to black (#INK$00) via port #N$FE.
 $D2E5 OUT ($FE),A   ; }
 $D2E7 LD A,B        ; {Scale the pass counter for the delay loop duration.
 $D2E8 SLA A         ;
 $D2EA SLA A         ; }
@label=Fade_Screen_Black_Delay
*$D2EC DEC A         ; {Busy-wait for the black border period.
 $D2ED JR NZ,$D2EC   ; }
 $D2EF LD A,$18      ; Load the white border value #N$18.
 $D2F1 AND %00011000 ; Mask to border bits only.
 $D2F3 OUT ($FE),A   ; Set the border to white via port #N$FE.
 $D2F5 LD A,B        ; {Scale the pass counter for the second delay loop
 $D2F6 SLA A         ; duration.
 $D2F8 SLA A         ; }
@label=Fade_Screen_White_Delay
*$D2FA DEC A         ; {Busy-wait for the white border period.
 $D2FB JR NZ,$D2FA   ; }
 $D2FD LD A,D        ; {Continue masking screen rows until the full pixel area (#N$4000–
 $D2FE CP $58        ; #N$57FF) has been processed.
 $D300 JR NZ,$D2DA   ; }
 $D302 POP HL        ; {Restore the mask pointer, advance the mask page, and repeat for the
 $D303 INC H         ; next fade pass.
 $D304 DJNZ $D2D6    ; }
 $D306 RET           ; Return.
; Restore the border colour to white after the fade.
@label=Restore_Border_White
 $D307 LD A,$07      ; {Set the border to white (#INK$07) via port #N$FE and
 $D309 OUT ($FE),A   ; return.
 $D30B RET           ; }

; Clear Screen and Render HUD
;
; Used by the routine at #R$D24C.
; .
; Clears the screen buffer via #R$D070, sets a white background via
; #R$D07E, then jumps directly to #R$D325 to render scores and lives for
; both players. Called by #R$D24C at the start of each new wave. Unlike
; #R$D317 this skips redrawing the playfield border and attribute bar.
@label=Clear_Screen_And_Render_HUD
c$D30C CALL $D070    ; Clear the screen buffer via #R$D070.
 $D30F LD A,$07      ; {Call #R$D07E using #INK$07.
 $D311 CALL $D07E    ; }
 $D314 JP $D325      ; Jump to #R$D325 to render the scores and lives.

; Render HUD
;
; Used by the routines at #R$D24C and #R$D367.
; .
; Clears the screen buffer, sets a white background, draws the playfield
; border (#R$D570), and redraws the attribute bar (#R$C713)
; before falling through to #R$D325. Scores (#R$C544) and lives (#R$C794)
; are then rendered for each player in turn by swapping state with #R$D08B;
; the "WAVE" label and wave number (#R$D0A7) are printed last for player 1.
@label=RenderHUD
c$D317 CALL $D070    ; Call #R$D070.
 $D31A LD A,$07      ; {Call #R$D07E using #INK$07.
 $D31C CALL $D07E    ; }
 $D31F CALL $D570    ; Call #R$D570.
 $D322 CALL $C713    ; Call #R$C713.
; This entry point is used by the routine at #R$D30C.
; .
; Shared entry point, also reached from #R$D30C via JP (which clears the
; screen and sets the background but skips the wave animation and attribute
; bar setup). Renders scores and lives for player 1, then swaps to player 2.
@label=RenderHUD_Draw
*$D325 CALL $C544    ; Call #R$C544.
 $D328 CALL $C794    ; Call #R$C794.
; Swap to player 2 to render their score, lives and wave number.
 $D32B CALL $D08B    ; Call #R$D08B.
 $D32E CALL $C544    ; Call #R$C544.
 $D331 CALL $C794    ; Call #R$C794.
 $D334 CALL $D0A7    ; Call #R$D0A7.
; Swap back to player 1; print the "WAVE" label and player 1's wave number,
; then redraw the attribute bar to complete the HUD.
 $D337 CALL $D08B    ; Call #R$D08B.
 $D33A LD HL,$D0E6   ; {Call #R$9006 using #R$D0E6.
 $D33D CALL $9006    ; }
 $D340 CALL $D0A7    ; Call #R$D0A7.
 $D343 CALL $C713    ; Call #R$C713.
 $D346 RET           ; Return.

; Messaging: Player
@label=Messaging_Player
t$D347 DEFB $10,$07     ; Set INK: #INK(#PEEK(#PC+$01)).
 $D349 DEFB $11,$00     ; Set PAPER: #INK(#PEEK(#PC+$01)).
 $D34B DEFB $16,$68,$56 ; PRINT AT #N(#PEEK(#PC+$01)), #N(#PEEK(#PC+$02)).
 $D34E DEFM "PLAYER "
 $D355 DEFB $1F         ; Terminator.

; Messaging: Game Over
@label=Messaging_GameOver
t$D356 DEFB $10,$07     ; Set INK: #INK(#PEEK(#PC+$01)).
 $D358 DEFB $11,$00     ; Set PAPER: #INK(#PEEK(#PC+$01)).
 $D35A DEFB $16,$65,$5E ; PRINT AT #N(#PEEK(#PC+$01)), #N(#PEEK(#PC+$02)).
 $D35D DEFM "GAME OVER"
 $D366 DEFB $1F         ; Terminator.

; Player Death
;
; Used by the routine at #R$D3F8.
; .
; Handles a lost life and game-over flow: optional HUD and "PLAYER" messaging,
; decrementing #R$C415, calling #R$D24C to re-stage the wave, swapping players with
; #R$D08B, printing "GAME OVER" when no lives remain, and either returning to the
; attract mode at #R$EBBC or looping. A lookup table at #R$D3E4 (read from #R$D400)
; supplies a start pointer stored at #R$C519; #R$ECFB jumps to #R$D3F8 after a
; successful tape load. Clears player state at #R$C403, wave and score fields, and
; applies #R$D481 (reset margins) when starting a fresh game.
@label=PlayerDeath
c$D367 LD A,($C532)    ; #REGa=*#R$C532 (death-sequence mode; #N$01 = skip the
                       ; intro HUD/delay).
 $D36A CP $01          ; Compare with #N$01.
 $D36C JR Z,$D38B      ; If set, jump to #R$D38B to decrement #R$C415
                       ; immediately.
; Full death sequence: redraw the HUD (#R$D317), print #R$D347 ("PLAYER") via
; #R$9006, then print the current player digit from *#R$C41F as ASCII (#N$30–#N$39).
 $D36E CALL $D317      ; Call #R$D317.
 $D371 LD HL,$D347     ; {Call #R$9006 using #R$D347.
 $D374 CALL $9006      ; }
 $D377 LD A,($C41F)    ; #REGa=*#R$C41F (player index for the digit).
 $D37A ADD A,%00110000 ; Convert to ASCII ("#CHR$30"–"#CHR$39").
 $D37C CALL $8DCC      ; Call #R$8DCC (print dispatch).
 $D37F LD B,$20        ; Inner delay loop count #N$20 (#REGb=#N$20).
@label=PlayerDeath_IntroDelay
*$D381 PUSH BC         ; Stash #REGbc on the stack.
 $D382 CALL $DAA3      ; Call #R$DAA3.
 $D385 CALL $C713      ; Call #R$C713.
 $D388 POP BC          ; Restore #REGbc from the stack.
 $D389 DJNZ $D381      ; Decrease counter and loop back to #R$D381 until the
                       ; intro delay finishes.
; See #POKE(infinite-lives)(Infinite Lives (Final Version)).
@label=PlayerDeath_LoseLife
*$D38B LD HL,$C415     ; #REGhl=#R$C415 (lives counter).
 $D38E DEC (HL)        ; Decrease *#REGhl (lose one life).
 $D38F CALL $D24C      ; Call #R$D24C (re-stage the wave / death handling).
 $D392 LD A,($C415)    ; {Jump to #R$D3A7 if *#R$C415 shows no lives are left.
 $D395 AND A           ;
 $D396 JR Z,$D3A7      ; }
; Lives remain: swap to the other player and continue if two-player mode.
 $D398 CALL $D08B      ; Call #R$D08B.
; If not two-player, jump back to #R$D367 for the same player.
 $D39B LD A,($C41E)    ; {Jump back to #R$D367 if *#R$C41E is not set.
 $D39E CP $01          ;
 $D3A0 JR NZ,$D367     ; }
 $D3A2 CALL $D08B      ; Call #R$D08B (swap back).
 $D3A5 JR $D367        ; Jump back to #R$D367.
; No lives left: redraw the HUD, then either the "PLAYER" line or straight to
; "GAME OVER" depending on *#R$C532, with a longer delay loop.
@label=PlayerDeath_GameOver
*$D3A7 CALL $D317      ; Call #R$D317.
 $D3AA LD A,($C532)    ; {Jump to #R$D3BF if *#R$C532 is #N$01.
 $D3AD CP $01          ;
 $D3AF JR Z,$D3BF      ; }
 $D3B1 LD HL,$D347     ; {Call #R$9006 using #R$D347.
 $D3B4 CALL $9006      ; }
 $D3B7 LD A,($C41F)    ; #REGa=*#R$C41F.
 $D3BA ADD A,%00110000 ; Convert to ASCII.
 $D3BC CALL $8DCC      ; Call #R$8DCC.
@label=PlayerDeath_GameOverDelay
*$D3BF LD HL,$D356     ; {Call #R$9006 using #R$D356.
 $D3C2 CALL $9006      ; }
 $D3C5 LD B,$29        ; Longer delay loop count #N$29 (#REGb=#N$29).
@label=PlayerDeath_GameOverDelayLoop
*$D3C7 PUSH BC         ; Stash #REGbc on the stack.
 $D3C8 CALL $DAA3      ; Call #R$DAA3.
 $D3CB CALL $C713      ; Call #R$C713.
 $D3CE POP BC          ; Restore #REGbc from the stack.
 $D3CF DJNZ $D3C7      ; Decrease counter and loop back to #R$D3C7.
; Set *#R$C41E to #N$01, swap players with #R$D08B, then branch on the flag
; read back from *#R$C41E.
 $D3D1 LD A,$01        ; {Write #N$01 to *#R$C41E.
 $D3D3 LD ($C41E),A    ; }
 $D3D6 CALL $D08B      ; Call #R$D08B.
 $D3D9 LD A,($C41E)    ; {Jump to #R$EBBC if *#R$C41E is #N$01 (attract mode).
 $D3DC CP $01          ;
 $D3DE JP Z,$EBBC      ; }
 $D3E1 JP $D367        ; Jump back to #R$D367.

; Game status buffer entry at D3E4
g$D3E4 DEFB $F9,$DD,$0D,$DE,$27,$DE,$41,$DE
 $D3EC DEFB $5B,$DE,$75,$DE,$8F,$DE,$A6,$DE
 $D3F4 DEFB $C0,$DE,$DA,$DE

; Player Death: Tape Load Continue
;
; Used by the routine at #R$ECFB.
;
; B Scratch (from the tape block header at *#R$C4FD).
; E Scratch (from the tape block header at *#R$C4FE).
;
; This routine is called after a successful tape load.
@label=PlayerDeath_TapeLoadContinue
c$D3F8 LD A,($C4FE)  ; Load #REGa with *#R$C4FE.
 $D3FB DEC A         ; Decrease #REGa by one.
 $D3FC ADD A,A       ; {#REGe=#REGa multiplied by #N$02.
 $D3FD LD E,A        ; }
 $D3FE LD D,$00      ; #REGd=#N$00 (high byte of index).
 $D400 LD HL,$D3E4   ; #REGhl=#R$D3E4 (base of the lookup table).
 $D403 ADD HL,DE     ; Add #REGde into #REGhl (index into the table).
 $D404 LD A,(HL)     ; #REGa=*(#REGhl) (low byte of the table word).
 $D405 INC HL        ; Advance #REGhl.
 $D406 LD H,(HL)     ; #REGh=*(#REGhl) (high byte of the table word).
 $D407 LD L,A        ; #REGl=#REGa (little-endian word in #REGhl).
 $D408 LD ($C519),HL ; Write the pointer to *#R$C519.
 $D40B LD A,B        ; {Write #REGb (variant/ slot) to *#R$C532.
 $D40C LD ($C532),A  ; }
 $D40F LD A,($C416)  ; {Jump to #R$D41B if *#R$C416 is at the maximum wave.
 $D412 CP $3C        ;
 $D414 JR Z,$D41B    ; }
 $D416 PUSH BC       ; Stash #REGbc on the stack.
 $D417 CALL $D08B    ; Call #R$D08B.
 $D41A POP BC        ; Restore #REGbc from the stack.
; Set the starting lives.
@label=PlayerDeath_InitMaxWave
*$D41B LD A,$03      ; {Write #N$03 to *#R$C415.
 $D41D LD ($C415),A  ; }
 $D420 XOR A         ; {Write #N$00 to *#R$C41E.
 $D421 LD ($C41E),A  ; }
 $D424 LD A,$44      ; {Write #COLOUR$44 (#N$44) to; #LIST
 $D426 LD ($C42E),A  ; { *#R$C42E }
 $D429 LD ($C46E),A  ; { *#R$C46E }
                     ; LIST#}
 $D42C LD A,B        ; {Jump to #R$D442 (margins + clear) if this is player
 $D42D CP $01        ; #N$01.
 $D42F JR Z,$D442    ; }
 $D431 CALL $D08B    ; Call #R$D08B.
 $D434 LD A,$03      ; {Write #N$03 to *#R$C415.
 $D436 LD ($C415),A  ; }
 $D439 XOR A         ; {Write #N$00 to *#R$C41E.
 $D43A LD ($C41E),A  ; }
 $D43D LD A,$44      ; {Write #COLOUR$44 (#N$44) to *#R$C42E.
 $D43F LD ($C42E),A  ; }
@label=PlayerDeath_NewGameSetup
*$D442 LD HL,$D481   ; {Call #R$9006 using #R$D481.
 $D445 CALL $9006    ; }
 $D448 XOR A         ; #REGa=#N$00.
 $D449 LD B,$02      ; Outer loop: two player slots (#REGb=#N$02).
@label=PlayerDeath_ClearPlayerSlot
*$D44B LD HL,$C403   ; #REGhl=#R$C403 (player 1 state block).
 $D44E LD C,$04      ; Clear #N$04 bytes per slot (#REGc=#N$04).
@label=PlayerDeath_ClearPlayerBytes
*$D450 LD (HL),A     ; Write #REGa to *#REGhl.
 $D451 INC HL        ; Advance #REGhl.
 $D452 DEC C         ; Decrease #REGc.
 $D453 JR NZ,$D450   ; Loop back to #R$D450 until the slot prefix is cleared.
 $D455 LD ($C408),A  ; Write #REGa to *#R$C408.
 $D458 LD ($C41C),A  ; Write #REGa to *#R$C41C.
 $D45B LD HL,$C418   ; #REGhl=#R$C418.
 $D45E LD (HL),A     ; Write #REGa to *#REGhl.
 $D45F INC HL        ; Advance #REGhl.
 $D460 LD (HL),$02   ; Write #N$02 to *#REGhl.
 $D462 INC HL        ; Advance #REGhl.
 $D463 LD (HL),A     ; Write #REGa to *#REGhl.
 $D464 INC HL        ; Advance #REGhl.
 $D465 LD (HL),A     ; Write #REGa to *#REGhl.
 $D466 LD HL,($C519) ; {Write *#R$C519 to *#R$C409.
 $D469 LD ($C409),HL ; }
 $D46C PUSH BC       ; Stash #REGbc on the stack.
 $D46D CALL $D08B    ; Call #R$D08B.
 $D470 POP BC        ; Restore #REGbc from the stack.
 $D471 DJNZ $D44B    ; Decrease outer counter and loop back to #R$D44B for the
                     ; second player.
 $D473 LD A,($C416)  ; {Jump back to #R$D367 if *#R$C416 is still at the
 $D476 CP $3C        ; maximum wave.
 $D478 JP Z,$D367    ; }
 $D47B CALL $D08B    ; Call #R$D08B.
 $D47E JP $D367      ; Jump back to #R$D367.

; Messaging: Reset Margins
@label=Messaging_ResetMargins
t$D481 DEFB $18,$00  ; Set left margin: #N(#PEEK(#PC+$01)).
 $D483 DEFB $19,$FF  ; Set right margin: #N(#PEEK(#PC+$01)).
 $D485 DEFB $1F      ; Terminator.

; Draw Life Icon Cells
;
; Used by the routine at #R$C794.
; .
; Draws the life icon cell pixels into the display file. Given an icon
; index in #REGa, looks up the icon cell data address from the descriptor
; table, then for each cell computes the screen pixel address and OR-blits
; the icon pixels into the display file. Used by #R$C794 to repaint the
; lives display.
;
; A Icon index; selects the cell data from the icon descriptor table
@label=Draw_Life_Icon_Cells
c$D486 ADD A,A       ; {Double the icon index to form a 16-bit table offset.
 $D487 LD E,A        ;
 $D488 LD D,$00      ; }
 $D48A LD HL,$C60C   ; {Index into the icon descriptor table.
 $D48D ADD HL,DE     ; }
 $D48E LD E,(HL)     ; {Load the icon cell data address.
 $D48F INC HL        ;
 $D490 LD D,(HL)     ;
 $D491 EX DE,HL      ; }
 $D492 LD E,C        ; {Set #REGde to the source data and load the cell count
 $D493 LD D,B        ; into #REGb.
 $D494 LD B,(HL)     ; }
@label=Draw_Life_Icon_Cells_Loop
*$D495 PUSH BC       ; Stash the loop state on the stack.
 $D496 INC HL        ; {Compute the pixel row for this icon cell.
 $D497 LD A,D        ;
 $D498 ADD A,(HL)    ;
 $D499 INC HL        ;
 $D49A LD C,A        ; }
 $D49B LD A,E        ; {Compute the pixel column and stash the data pointer on
 $D49C ADD A,(HL)    ; the stack.
 $D49D PUSH HL       ; }
 $D49E LD L,A        ; {Compute the row lookup address in #REGbc.
 $D49F LD B,$C5      ;
 $D4A1 SLA C         ;
 $D4A3 RL B          ; }
 $D4A5 LD H,$C6      ; {Compute the column lookup address in #REGhl.
 $D4A7 SLA L         ;
 $D4A9 RL H          ; }
 $D4AB LD A,(HL)     ; {Resolve the screen pixel address for this cell.
 $D4AC INC HL        ;
 $D4AD LD H,(HL)     ;
 $D4AE LD L,A        ; }
 $D4AF LD A,(BC)     ; {Combine the pixel row mask with the screen address.
 $D4B0 OR L          ;
 $D4B1 LD L,A        ;
 $D4B2 INC BC        ; }
 $D4B3 LD A,(BC)     ; {OR the icon pixel data into the display file.
 $D4B4 OR (HL)       ;
 $D4B5 LD (HL),A     ; }
 $D4B6 POP HL        ; {Restore the data pointer and loop state, and repeat for
 $D4B7 POP BC        ; the next cell.
 $D4B8 DJNZ $D495    ; }
 $D4BA RET           ; Return.

; Erase Life Icon Cells
;
; Used by the routine at #R$C794.
; .
; Clears the display file cells that make up one life icon. Mirrors
; the structure of #R$D486 but uses CPL and AND to erase each pixel cell
; rather than OR-blitting it. Given an icon index in #REGa, the routine
; looks up the cell data address, then for each cell computes the screen
; pixel address and removes the icon pixels.
;
; A Icon index; selects the cell data from the icon descriptor table
@label=Erase_Life_Icon_Cells
c$D4BB ADD A,A       ; {Double the icon index to form a 16-bit table offset.
 $D4BC LD E,A        ;
 $D4BD LD D,$00      ; }
 $D4BF LD HL,$C60C   ; {Index into the icon descriptor table.
 $D4C2 ADD HL,DE     ; }
 $D4C3 LD E,(HL)     ; {Load the icon cell data address.
 $D4C4 INC HL        ;
 $D4C5 LD D,(HL)     ;
 $D4C6 EX DE,HL      ; }
 $D4C7 LD E,C        ; {Set #REGde to the source data and load the cell count
 $D4C8 LD D,B        ; into #REGb.
 $D4C9 LD B,(HL)     ; }
@label=Erase_Life_Icon_Cells_Loop
*$D4CA PUSH BC       ; Stash the loop state on the stack.
 $D4CB INC HL        ; {Compute the pixel row for this icon cell.
 $D4CC LD A,D        ;
 $D4CD ADD A,(HL)    ;
 $D4CE INC HL        ;
 $D4CF LD C,A        ; }
 $D4D0 LD A,E        ; {Compute the pixel column and stash the data pointer on
 $D4D1 ADD A,(HL)    ; the stack.
 $D4D2 PUSH HL       ; }
 $D4D3 LD L,A        ; {Compute the row lookup address in #REGbc.
 $D4D4 LD B,$C5      ;
 $D4D6 SLA C         ;
 $D4D8 RL B          ; }
 $D4DA LD H,$C6      ; {Compute the column lookup address in #REGhl.
 $D4DC SLA L         ;
 $D4DE RL H          ; }
 $D4E0 LD A,(HL)     ; {Resolve the screen pixel address for this cell.
 $D4E1 INC HL        ;
 $D4E2 LD H,(HL)     ;
 $D4E3 LD L,A        ; }
 $D4E4 LD A,(BC)     ; {Combine the pixel row mask with the screen address.
 $D4E5 OR L          ;
 $D4E6 LD L,A        ;
 $D4E7 INC BC        ; }
 $D4E8 LD A,(BC)     ; {Erase the icon pixel data from the display file.
 $D4E9 CPL           ;
 $D4EA AND (HL)      ;
 $D4EB LD (HL),A     ; }
 $D4EC POP HL        ; {Restore the data pointer and loop state, and repeat for
 $D4ED POP BC        ; the next cell.
 $D4EE DJNZ $D4CA    ; }
 $D4F0 RET           ; Return.

; Entity Type By Direction Table
;
; Sixteen entity type bytes, one per movement direction index. Indexed by
; the Y direction value from #R$C517 by #R$CB4F to select the entity type
; written into each newly spawned entity record.
@label=Entity_Type_By_Direction_Table
b$D4F1 DEFB $07,$07,$07,$07,$07,$08,$06,$05
 $D4F9 DEFB $07,$06,$08,$05,$07,$07,$07,$07

; Intro Sprite Template
;
; Three four-byte entries used as the initial sprite state for
; #R$D50D. Copied to the working state at the start of each animation
; cycle by #R$D519. Each entry contains the sprite identifier at
; +#N$00, the initial Y-position at +#N$01, the initial X-position at
; +#N$02, and the X-velocity at +#N$03.
@label=Intro_Sprite_Template
b$D501 DEFB $00,$0E,$2F,$06
 $D505 DEFB $00,$0E,$7D,$00
 $D509 DEFB $00,$0E,$CB,$FA

; Intro Sprite State
;
; Working copy of #R$D501 updated each frame by #R$D52A.
; Y-positions advance by #N$06 per frame; X-positions accumulate
; their velocity values.
@label=Intro_Sprite_State
b$D50D DEFB $41,$4C,$4C,$09
 $D511 DEFB $49,$4E,$41,$4C
 $D515 DEFB $4C,$0D,$C4,$3B

; Animate Intro Screen Sprites
;
; Used by the routine at #R$CB4F.
; .
; Controls a three-sprite scrolling animation on the intro screen.
; Entering at #R$D519 copies the sprite template to the working state
; and sets the frame counter to #N$0E. Entering at #R$D52A runs one
; frame: each sprite is rendered via #R$D794, its Y-position scrolled
; down by #N$06 and X-position advanced by its velocity. After #N$0E
; frames, a bright white closing sprite is drawn and the animation
; restarts.
@label=Animate_Intro_Screen_Sprites
c$D519 LD HL,$D501   ; {Set up to copy the sprite template to the working
 $D51C LD DE,$D50D   ; state.
 $D51F LD BC,$000C   ; }
 $D522 LDIR          ; Copy the sprite template to the working sprite state.
 $D524 LD A,$0E      ; {Reset the animation frame counter to #N$0E.
 $D526 LD ($C531),A  ; }
 $D529 RET           ; Return.
; This entry point is used by the routine at #R$CD34.
@label=Animate_Intro_Screen_Sprites_Step
*$D52A LD HL,$D50D   ; Point to the first sprite state entry.
 $D52D LD B,$03      ; Set the sprite entry loop counter.
 $D52F LD A,($C531)  ; Load the animation frame counter.
 $D532 EXX           ; {Stash the frame counter in the shadow register.
 $D533 LD B,A        ;
 $D534 EXX           ; }
@label=Animate_Intro_Screen_Sprites_Loop
*$D535 PUSH HL       ; {Stash the sprite state pointer and loop counter on the
 $D536 PUSH BC       ; stack.}
 $D537 CALL $D794    ; Render this sprite via #R$D794.
 $D53A POP BC        ; {Restore the loop counter and state pointer from the
 $D53B POP HL        ; stack.}
 $D53C INC HL        ; Advance past the sprite identifier byte.
 $D53D LD A,(HL)     ; {Scroll the Y-position down by #N$06 pixels.
 $D53E ADD A,$06     ;
 $D540 LD (HL),A     ; }
 $D541 INC HL        ; {Apply the X velocity to the X-position.
 $D542 LD A,(HL)     ;
 $D543 INC HL        ;
 $D544 ADD A,(HL)    ;
 $D545 DEC HL        ;
 $D546 LD (HL),A     ; }
 $D547 INC HL        ; {Advance to the next sprite state entry.
 $D548 INC HL        ; }
 $D549 DJNZ $D535    ; Repeat for the next sprite entry.
 $D54B LD A,($C531)  ; {Decrement the animation frame counter.
 $D54E DEC A         ;
 $D54F LD ($C531),A  ; }
 $D552 CP $01        ; {Return if the animation is still running.
 $D554 RET NZ        ; }
; Final frame: draw the closing sprite with bright white and restart.
 $D555 EXX           ; {Set the closing sprite attribute to bright white.
 $D556 LD B,$47      ;
 $D558 EXX           ; }
 $D559 LD HL,$C4D3   ; {Call #R$D637 using #R$C4D3.
 $D55C CALL $D637    ; }
 $D55F JP $D519      ; Reinitialise the animation and restart.

; Draw Playfield Border Row
;
; Used by the routine at #R$D570.
; .
; Caller supplies the row in #REGl. Sweeps #REGh from #N$06 to #N$F9
; inclusive, calling #R$8D80 each time to OR the border glyph across that row
; of the screen buffer. Used only from #R$D570.
@label=DrawPlayfieldBorderRow
c$D562 LD H,$06      ; #REGh=#N$06 (start of the horizontal sweep).
@label=DrawPlayfieldBorderRow_Loop
*$D564 PUSH HL       ; Stash #REGhl on the stack (coordinates for #R$8D80).
 $D565 CALL $8D80    ; Call #R$8D80 (OR-blit at this cell).
 $D568 POP HL        ; Restore #REGhl from the stack.
 $D569 INC H         ; Increment #REGh (next column in the sweep).
 $D56A LD A,H        ; {Loop back to #R$D564 until the full row has been drawn.
 $D56B CP $FA        ;
 $D56D JR NZ,$D564   ; }
 $D56F RET           ; Return.

; Draw Playfield Border
;
; Used by the routines at #R$CD34 and #R$D317.
; .
; Draws the rectangular border surrounding the play area. If the units
; digit of *#R$C408 is #N$09 the routine returns without drawing. Otherwise it
; draws full-width horizontal strips at rows #N$0E and #N$0F (top edge) via
; #R$D562, then for each row from #N$10 to #N$B7 it OR-blits columns #N$06,
; #N$07, #N$F8 and #N$F9 (left and right edges), and finally draws full-width
; strips at rows #N$B8 and #N$B9 (bottom edge) via #R$D562. Called from
; #R$C84F and #R$D317.
;
; .
;
; #PUSHS #SIM(start=$D317,stop=$D5B0) #UDGTABLE {
;   #SCR$02(playfield-border)
; } TABLE# #POPS
@label=DrawPlayfieldBorder
c$D570 LD A,($C408)  ; #REGa=*#R$C408 (BCD wave number).
 $D573 AND %00001111 ; Keep the low decimal digit (AND #N$0F).
 $D575 CP $09        ; {Return if the units digit is #N$09 (no border drawn).
 $D577 RET Z         ; }
 $D578 LD L,$0E      ; {Call #R$D562 to draw the top-edge strip at row #N$0E.
 $D57A CALL $D562    ; }
 $D57D LD L,$0F      ; {Call #R$D562 to draw the top-edge strip at row #N$0F.
 $D57F CALL $D562    ; }
 $D582 LD L,$10      ; #REGl=#N$10 (top row of the framed block).
; Left and right edges: for each row #N$10 to #N$B7, OR-blit columns
; #N$06, #N$07, #N$F8 and #N$F9 via #R$8D80.
@label=DrawPlayfieldBorder_SideColumns
*$D584 LD H,$06      ; #REGh=#N$06 (left inner column).
 $D586 PUSH HL       ; Stash #REGhl on the stack.
 $D587 CALL $8D80    ; Call #R$8D80.
 $D58A POP HL        ; Restore #REGhl from the stack.
 $D58B LD H,$07      ; #REGh=#N$07 (left inner column + #N$01).
 $D58D PUSH HL       ; Stash #REGhl on the stack.
 $D58E CALL $8D80    ; Call #R$8D80.
 $D591 POP HL        ; Restore #REGhl from the stack.
 $D592 LD H,$F8      ; #REGh=#N$F8 (right inner column).
 $D594 PUSH HL       ; Stash #REGhl on the stack.
 $D595 CALL $8D80    ; Call #R$8D80.
 $D598 POP HL        ; Restore #REGhl from the stack.
 $D599 LD H,$F9      ; #REGh=#N$F9 (right inner column + #N$01).
 $D59B PUSH HL       ; Stash #REGhl on the stack.
 $D59C CALL $8D80    ; Call #R$8D80.
 $D59F POP HL        ; Restore #REGhl from the stack.
 $D5A0 INC L         ; Increment #REGl (next row).
 $D5A1 LD A,L        ; {Loop back to #R$D584 until all rows are drawn.
 $D5A2 CP $B8        ;
 $D5A4 JR NZ,$D584   ; }
 $D5A6 LD L,$B8      ; {Call #R$D562 to draw the bottom-edge strip at row
 $D5A8 CALL $D562    ; #N$B8.}
 $D5AB LD L,$B9      ; {Call #R$D562 to draw the bottom-edge strip at row
 $D5AD CALL $D562    ; #N$B9.}
 $D5B0 RET           ; Return.

; Remove Entity from List
;
; Used by the routines at #R$CCE9, #R$CD34, #R$E974 and #R$EB07.
; .
; Removes the entity whose record is pointed to by #R$C4DA from the
; entity list. Steps back to the start of the entity's 12-byte record, then
; block-copies all subsequent records down by 12 bytes via LDIR, closing the
; gap. The entity list end pointer at #R$C4D1 is decremented by 12 to reflect
; the shorter list. Returns with #REGhl pointing to the record that now
; occupies the removed entity's slot.
@label=Remove_Entity_From_List
c$D5B1 LD HL,($C4DA) ; Load the entity record pointer from #R$C4DA.
; This entry point is used by the routines at #R$E4B9 and #R$E520.
@label=Remove_Entity_From_List_Step
*$D5B4 DEC HL        ; {Step back to the start of the entity record and save the updated
 $D5B5 DEC HL        ; pointer to #R$C4DA.
 $D5B6 LD ($C4DA),HL ; }
 $D5B9 LD DE,$000C   ; {Compute the start of the next entity record (12 bytes ahead) in
 $D5BC ADD HL,DE     ; #REGde.
 $D5BD EX DE,HL      ; }
 $D5BE LD HL,($C4D1) ; {Load the entity list end pointer from #R$C4D1, subtract the
 $D5C1 SBC HL,DE     ; destination address to get the copy byte count, and load that count into
 $D5C3 INC HL        ; #REGbc.
 $D5C4 INC HL        ;
 $D5C5 INC HL        ;
 $D5C6 LD B,H        ;
 $D5C7 LD C,L        ; }
 $D5C8 LD HL,($C4DA) ; {Set source to the start of the next entity record and shift all
 $D5CB EX DE,HL      ; remaining records down by 12 bytes via LDIR.
 $D5CC LDIR          ; }
 $D5CE LD HL,($C4D1) ; {Decrement the entity list end pointer at #R$C4D1 by 12 bytes and
 $D5D1 LD DE,$000C   ; return with #REGhl pointing to the new occupant of the vacated slot.
 $D5D4 SBC HL,DE     ;
 $D5D6 LD ($C4D1),HL ;
 $D5D9 LD HL,($C4DA) ; }
 $D5DC RET           ; Return.
; Entity movement handler, stored as the entity handler address in entity
; records that use the narrow sprite renderer. Applies the entity's velocity
; to its current screen position, validates that the new position lies within
; the playfield bounds, updates the entity record, and redraws the sprite. If
; the new position is out of bounds the entity is removed via #R$D5B1.
@label=Move_And_Redraw_Entity
 $D5DD LD ($C4DA),HL ; Save the entity record pointer to #R$C4DA.
 $D5E0 CALL $C84F    ; Erase the entity's current sprite via #R$C84F.
 $D5E3 LD HL,($C4DA) ; {Reload the entity record from #R$C4DA and point #REGhl at the Y
 $D5E6 INC HL        ; position field; copy the pointer to #REGde.
 $D5E7 INC HL        ;
 $D5E8 INC HL        ;
 $D5E9 LD D,H        ;
 $D5EA LD E,L        ; }
 $D5EB INC DE        ; {Advance #REGde to the Y velocity field and add the velocity to the
 $D5EC INC DE        ; current Y position.
 $D5ED INC DE        ;
 $D5EE INC DE        ;
 $D5EF LD A,(DE)     ;
 $D5F0 ADD A,(HL)    ;
 $D5F1 CP $10        ; }
 $D5F3 JR C,$D5B1    ; {Reject the move if the new Y position is above the playfield top
 $D5F5 CP $B8        ; edge (#N$10).}
 $D5F7 JR NC,$D5B1   ; Reject the move if the new Y position is below the playfield bottom
                     ; edge (#N$B8).
 $D5F9 LD (HL),A     ; {Store the new Y position; advance to the X fields and add the X
 $D5FA LD B,A        ; velocity to the current X position.
 $D5FB INC DE        ;
 $D5FC INC HL        ;
 $D5FD LD A,(DE)     ;
 $D5FE ADD A,(HL)    ; }
 $D5FF CP $08        ; Reject the move if the new X position is past the left edge
                     ; (#N$08).
 $D601 JR C,$D5B1    ; Remove the entity if the new X position is too close to the left
                     ; wall.
 $D603 CP $F8        ; Reject the move if the new X position is past the right edge
                     ; (#N$F8).
 $D605 JR NC,$D5B1   ; Remove the entity if the new X position is too close to the right
                     ; wall.
 $D607 LD (HL),A     ; {Store the new X position; step back and update the two additional
 $D608 DEC HL        ; entity record fields from their corresponding velocity bytes.
 $D609 DEC HL        ;
 $D60A LD A,(DE)     ;
 $D60B ADD A,(HL)    ;
 $D60C LD (HL),A     ;
 $D60D DEC HL        ;
 $D60E DEC DE        ;
 $D60F LD A,(DE)     ; }
 $D610 ADD A,(HL)    ; {Update the final position field and step back to the entity record
 $D611 LD (HL),A     ; origin.
 $D612 DEC HL        ; }
 $D613 EXX           ; {Set the entity colour to #COLOUR$47 in #REGb' and redraw the
 $D614 LD B,$47      ; sprite via #R$C856.
 $D616 EXX           ;
 $D617 CALL $C856    ; }
 $D61A LD HL,($C4DA) ; Reload the entity record pointer from #R$C4DA.
 $D61D JP $CD13      ; Jump to the entity update completion handler at #R$CD13.

; Sprite Frame Table
;
; Sixteen sprite frame indices (one per movement direction) used by
; #R$CB4F to select the correct player sprite for the current direction.
@label=Sprite_Frame_Table
b$D620 DEFB $00,$00,$00,$00,$00,$01,$01,$01
 $D628 DEFB $00,$02,$02,$02,$00,$03,$00,$00

; Erase Entity Sprite
;
; Used by the routines at #R$CB4F, #R$CD34, #R$E003, #R$E4A7 and #R$E520.
; .
; Entry point for erasing an entity sprite. Sets erase mode then falls
; through to #R$D63B. In erase mode the attribute write is skipped.
@label=Erase_Entity_Sprite
c$D630 EXX           ; {Set erase mode (attribute write disabled).
 $D631 LD D,$00      ;
 $D633 EXX           ; }
 $D634 JP $D63B      ; Jump to #R$D63B.

; Draw Entity Sprite
;
; Used by the routines at #R$CB4F, #R$CD34, #R$D519, #R$E003, #R$E22A, #R$E360,
; #R$E4B9, #R$E520, #R$E6F7 and #R$EA6E.
; .
; Draws or erases an entity's sprite on the display. #R$D637 sets draw
; mode so the entity colour is written to the attribute area. #R$D630 sets
; erase mode and skips the attribute write. Both paths enter #R$D63B, which
; reads the entity type to look up sprite data from #R$C60C, computes the
; screen position from the Y and X bytes, then XOR-blends twelve pixel rows
; of sprite data onto the display.
;
; HL Entity record pointer
@label=Draw_Entity_Sprite
c$D637 EXX           ; {Set draw mode (attribute write enabled).
 $D638 LD D,$01      ;
 $D63A EXX           ; }
; This entry point is used by the routine at #R$D630.
@label=Draw_Entity_Sprite_Render
*$D63B LD B,H        ; {Copy the entity record pointer to #REGbc.
 $D63C LD C,L        ; }
 $D63D LD E,(HL)     ; {Look up the sprite data address for this entity type.
 $D63E SLA E         ;
 $D640 LD D,$00      ;
 $D642 LD HL,$C60C   ;
 $D645 ADD HL,DE     ;
 $D646 LD E,(HL)     ;
 $D647 INC HL        ;
 $D648 LD D,(HL)     ; }
 $D649 LD H,B        ; {Copy the entity record pointer from #REGbc.
 $D64A LD L,C        ; }
 $D64B INC HL        ; {Read the entity's Y position.
 $D64C LD B,$46      ;
 $D64E LD C,(HL)     ;
 $D64F INC HL        ; }
 $D650 SLA C         ; {Double the Y position to form the pixel row address.
 $D652 RL B          ; }
 $D654 PUSH BC       ; Stash the pixel row address on the stack.
 $D655 LD A,(HL)     ; {Read the X position and extract the byte column and bit
 $D656 AND A         ; offset.
 $D657 LD HL,$0000   ;
 $D65A RRA           ;
 $D65B RR L          ;
 $D65D RRA           ;
 $D65E RR L          ;
 $D660 RRA           ;
 $D661 RR L          ; }
 $D663 EXX           ; {Save the pixel bit offset in the shadow register.
 $D664 LD C,A        ;
 $D665 EXX           ; }
 $D666 LD A,L        ; {Compute the sprite pixel data address and add the
 $D667 RRCA          ; column offset.
 $D668 LD L,A        ;
 $D669 RRCA          ;
 $D66A ADD A,L       ;
 $D66B LD L,A        ;
 $D66C ADD HL,DE     ; }
 $D66D LD B,H        ; {Copy the sprite data pointer to #REGbc.
 $D66E LD C,L        ; }
 $D66F POP HL        ; Restore the pixel row address from the stack.
 $D670 EXX           ; {Read the pixel bit offset from the shadow register.
 $D671 LD A,C        ;
 $D672 EXX           ; }
; Render the sprite row by row. Each row XOR-blends two bytes of pixel
; data onto the display. After every seventh row the entity's colour is
; written to the screen attribute cells.
@label=Draw_Entity_Sprite_Row1
 $D673 ADD A,(HL)    ; {Blit the first sprite row onto the display.
 $D674 LD E,A        ;
 $D675 INC HL        ;
 $D676 LD D,(HL)     ;
 $D677 INC HL        ;
 $D678 LD A,(BC)     ;
 $D679 EX DE,HL      ;
 $D67A XOR (HL)      ;
 $D67B LD (HL),A     ;
 $D67C INC BC        ;
 $D67D INC HL        ;
 $D67E LD A,(BC)     ;
 $D67F INC BC        ;
 $D680 XOR (HL)      ;
 $D681 LD (HL),A     ; }
 $D682 EXX           ; {Jump to #R$D698 if in erase mode (skip the attribute
 $D683 LD A,D        ; write).
 $D684 AND A         ;
 $D685 EXX           ;
 $D686 JP Z,$D698    ; }
 $D689 LD A,H        ; {Compute the attribute area address from the current
 $D68A RRCA          ; screen row.
 $D68B RRCA          ;
 $D68C RRCA          ; }
 $D68D AND %00000011 ; Keep only the row address bits.
 $D68F OR %01011000  ; Set the attribute memory flag.
 $D691 LD H,A        ; {Write the entity's colour to two attribute cells.
 $D692 EXX           ;
 $D693 LD A,B        ;
 $D694 EXX           ;
 $D695 LD (HL),A     ;
 $D696 DEC HL        ;
 $D697 LD (HL),A     ; }
@label=Draw_Entity_Sprite_Row2
*$D698 EX DE,HL      ; {Blit row two.
 $D699 EXX           ;
 $D69A LD A,C        ;
 $D69B EXX           ;
 $D69C ADD A,(HL)    ;
 $D69D LD E,A        ;
 $D69E INC HL        ;
 $D69F LD D,(HL)     ;
 $D6A0 INC HL        ;
 $D6A1 LD A,(BC)     ;
 $D6A2 EX DE,HL      ;
 $D6A3 XOR (HL)      ;
 $D6A4 LD (HL),A     ;
 $D6A5 INC BC        ;
 $D6A6 INC HL        ;
 $D6A7 LD A,(BC)     ;
 $D6A8 INC BC        ;
 $D6A9 XOR (HL)      ;
 $D6AA LD (HL),A     ; }
 $D6AB EX DE,HL      ; {Blit row three.
 $D6AC EXX           ;
 $D6AD LD A,C        ;
 $D6AE EXX           ;
 $D6AF ADD A,(HL)    ;
 $D6B0 LD E,A        ;
 $D6B1 INC HL        ;
 $D6B2 LD D,(HL)     ;
 $D6B3 INC HL        ;
 $D6B4 LD A,(BC)     ;
 $D6B5 EX DE,HL      ;
 $D6B6 XOR (HL)      ;
 $D6B7 LD (HL),A     ;
 $D6B8 INC BC        ;
 $D6B9 INC HL        ;
 $D6BA LD A,(BC)     ;
 $D6BB INC BC        ;
 $D6BC XOR (HL)      ;
 $D6BD LD (HL),A     ; }
 $D6BE EX DE,HL      ; {Blit row four.
 $D6BF EXX           ;
 $D6C0 LD A,C        ;
 $D6C1 EXX           ;
 $D6C2 ADD A,(HL)    ;
 $D6C3 LD E,A        ;
 $D6C4 INC HL        ;
 $D6C5 LD D,(HL)     ;
 $D6C6 INC HL        ;
 $D6C7 LD A,(BC)     ;
 $D6C8 EX DE,HL      ;
 $D6C9 XOR (HL)      ;
 $D6CA LD (HL),A     ;
 $D6CB INC BC        ;
 $D6CC INC HL        ;
 $D6CD LD A,(BC)     ;
 $D6CE INC BC        ;
 $D6CF XOR (HL)      ;
 $D6D0 LD (HL),A     ; }
 $D6D1 EX DE,HL      ; {Blit row five.
 $D6D2 EXX           ;
 $D6D3 LD A,C        ;
 $D6D4 EXX           ;
 $D6D5 ADD A,(HL)    ;
 $D6D6 LD E,A        ;
 $D6D7 INC HL        ;
 $D6D8 LD D,(HL)     ;
 $D6D9 INC HL        ;
 $D6DA LD A,(BC)     ;
 $D6DB EX DE,HL      ;
 $D6DC XOR (HL)      ;
 $D6DD LD (HL),A     ;
 $D6DE INC BC        ;
 $D6DF INC HL        ;
 $D6E0 LD A,(BC)     ;
 $D6E1 INC BC        ;
 $D6E2 XOR (HL)      ;
 $D6E3 LD (HL),A     ; }
 $D6E4 EX DE,HL      ; {Blit row six.
 $D6E5 EXX           ;
 $D6E6 LD A,C        ;
 $D6E7 EXX           ;
 $D6E8 ADD A,(HL)    ;
 $D6E9 LD E,A        ;
 $D6EA INC HL        ;
 $D6EB LD D,(HL)     ;
 $D6EC INC HL        ;
 $D6ED LD A,(BC)     ;
 $D6EE EX DE,HL      ;
 $D6EF XOR (HL)      ;
 $D6F0 LD (HL),A     ;
 $D6F1 INC BC        ;
 $D6F2 INC HL        ;
 $D6F3 LD A,(BC)     ;
 $D6F4 INC BC        ;
 $D6F5 XOR (HL)      ;
 $D6F6 LD (HL),A     ; }
 $D6F7 EX DE,HL      ; {Blit row seven.
 $D6F8 EXX           ;
 $D6F9 LD A,C        ;
 $D6FA EXX           ;
 $D6FB ADD A,(HL)    ;
 $D6FC LD E,A        ;
 $D6FD INC HL        ;
 $D6FE LD D,(HL)     ;
 $D6FF INC HL        ;
 $D700 LD A,(BC)     ;
 $D701 EX DE,HL      ;
 $D702 XOR (HL)      ;
 $D703 LD (HL),A     ;
 $D704 INC BC        ;
 $D705 INC HL        ;
 $D706 LD A,(BC)     ;
 $D707 INC BC        ;
 $D708 XOR (HL)      ;
 $D709 LD (HL),A     ; }
 $D70A EXX           ; {Jump to #R$D720 if in erase mode (skip the attribute
 $D70B LD A,D        ; write).
 $D70C AND A         ;
 $D70D EXX           ;
 $D70E JP Z,$D720    ; }
 $D711 LD A,H        ; {Compute the attribute area address from the current
 $D712 RRCA          ; screen row.
 $D713 RRCA          ;
 $D714 RRCA          ; }
 $D715 AND %00000011 ; Keep only the row address bits.
 $D717 OR %01011000  ; Set the attribute memory flag.
 $D719 LD H,A        ; {Write the entity's colour to two attribute cells.
 $D71A EXX           ;
 $D71B LD A,B        ;
 $D71C EXX           ;
 $D71D LD (HL),A     ;
 $D71E DEC HL        ;
 $D71F LD (HL),A     ; }
@label=Draw_Entity_Sprite_Row8
*$D720 EX DE,HL      ; {Blit row eight.
 $D721 EXX           ;
 $D722 LD A,C        ;
 $D723 EXX           ;
 $D724 ADD A,(HL)    ;
 $D725 LD E,A        ;
 $D726 INC HL        ;
 $D727 LD D,(HL)     ;
 $D728 INC HL        ;
 $D729 LD A,(BC)     ;
 $D72A EX DE,HL      ;
 $D72B XOR (HL)      ;
 $D72C LD (HL),A     ;
 $D72D INC BC        ;
 $D72E INC HL        ;
 $D72F LD A,(BC)     ;
 $D730 INC BC        ;
 $D731 XOR (HL)      ;
 $D732 LD (HL),A     ; }
 $D733 EX DE,HL      ; {Blit row nine.
 $D734 EXX           ;
 $D735 LD A,C        ;
 $D736 EXX           ;
 $D737 ADD A,(HL)    ;
 $D738 LD E,A        ;
 $D739 INC HL        ;
 $D73A LD D,(HL)     ;
 $D73B INC HL        ;
 $D73C LD A,(BC)     ;
 $D73D EX DE,HL      ;
 $D73E XOR (HL)      ;
 $D73F LD (HL),A     ;
 $D740 INC BC        ;
 $D741 INC HL        ;
 $D742 LD A,(BC)     ;
 $D743 INC BC        ;
 $D744 XOR (HL)      ;
 $D745 LD (HL),A     ; }
 $D746 EX DE,HL      ; {Blit row ten.
 $D747 EXX           ;
 $D748 LD A,C        ;
 $D749 EXX           ;
 $D74A ADD A,(HL)    ;
 $D74B LD E,A        ;
 $D74C INC HL        ;
 $D74D LD D,(HL)     ;
 $D74E INC HL        ;
 $D74F LD A,(BC)     ;
 $D750 EX DE,HL      ;
 $D751 XOR (HL)      ;
 $D752 LD (HL),A     ;
 $D753 INC BC        ;
 $D754 INC HL        ;
 $D755 LD A,(BC)     ;
 $D756 INC BC        ;
 $D757 XOR (HL)      ;
 $D758 LD (HL),A     ; }
 $D759 EX DE,HL      ; {Blit row eleven.
 $D75A EXX           ;
 $D75B LD A,C        ;
 $D75C EXX           ;
 $D75D ADD A,(HL)    ;
 $D75E LD E,A        ;
 $D75F INC HL        ;
 $D760 LD D,(HL)     ;
 $D761 INC HL        ;
 $D762 LD A,(BC)     ;
 $D763 EX DE,HL      ;
 $D764 XOR (HL)      ;
 $D765 LD (HL),A     ;
 $D766 INC BC        ;
 $D767 INC HL        ;
 $D768 LD A,(BC)     ;
 $D769 INC BC        ;
 $D76A XOR (HL)      ;
 $D76B LD (HL),A     ; }
 $D76C EX DE,HL      ; {Blit row twelve.
 $D76D EXX           ;
 $D76E LD A,C        ;
 $D76F EXX           ;
 $D770 ADD A,(HL)    ;
 $D771 LD E,A        ;
 $D772 INC HL        ;
 $D773 LD D,(HL)     ;
 $D774 INC HL        ;
 $D775 LD A,(BC)     ;
 $D776 EX DE,HL      ;
 $D777 XOR (HL)      ;
 $D778 LD (HL),A     ;
 $D779 INC BC        ;
 $D77A INC HL        ;
 $D77B LD A,(BC)     ;
 $D77C INC BC        ;
 $D77D XOR (HL)      ;
 $D77E LD (HL),A     ; }
 $D77F EXX           ; {Return if in erase mode (skip the final attribute
 $D780 LD A,D        ; write).
 $D781 AND A         ;
 $D782 EXX           ;
 $D783 RET Z         ; }
 $D784 LD A,H        ; {Compute the attribute area address from the current
 $D785 RRCA          ; screen row.
 $D786 RRCA          ;
 $D787 RRCA          ; }
 $D788 AND %00000011 ; Keep only the row address bits.
 $D78A OR %01011000  ; Set the attribute memory flag.
 $D78C LD H,A        ; {Write the entity's colour to two attribute cells.
 $D78D EXX           ;
 $D78E LD A,B        ;
 $D78F EXX           ;
 $D790 LD (HL),A     ;
 $D791 DEC HL        ;
 $D792 LD (HL),A     ; }
 $D793 RET           ; Return.

; Draw Clipped Wide Sprite
;
; Used by the routines at #R$CD34 and #R$D519.
; .
; Draws a 2-byte-wide, 12-row entity sprite to the screen by
; toggling each row's pixel data against the existing screen content.
; Reads the sprite type and screen position from the entity record,
; looks up the pixel data address in #R$C60C, then renders twelve
; rows of two bytes each. Each row is bounds-checked against the play
; area (#N$10 top / #N$B9 bottom); rows outside the play area are
; skipped. Alternate registers carry the Y position and column offset
; across all twelve rows.
;
; HL Entity record pointer
@label=Draw_Clipped_Wide_Sprite
c$D794 LD B,H        ; {Stash the entity record pointer in #REGbc and read the
 $D795 LD C,L        ; sprite type.
 $D796 LD E,(HL)     ; }
 $D797 SLA E         ; {Double the sprite type and look up the pixel data
 $D799 LD D,$00      ; address in #R$C60C.
 $D79B LD HL,$C60C   ;
 $D79E ADD HL,DE     ;
 $D79F LD E,(HL)     ;
 $D7A0 INC HL        ;
 $D7A1 LD D,(HL)     ; }
 $D7A2 LD H,B        ; {Restore the entity record pointer and advance to the screen column
 $D7A3 LD L,C        ; byte.
 $D7A4 INC HL        ; }
 $D7A5 LD B,$46      ; {Load the screen column, stash it in #REGd', and advance to
 $D7A7 LD C,(HL)     ; the screen row byte.
 $D7A8 LD A,C        ;
 $D7A9 EXX           ;
 $D7AA LD D,A        ;
 $D7AB EXX           ;
 $D7AC INC HL        ; }
 $D7AD SLA C         ; {Shift the column into the screen address high byte.
 $D7AF RL B          ; }
 $D7B1 PUSH BC       ; Stash the screen address high byte on the stack.
 $D7B2 LD A,(HL)     ; {Load the screen row byte, extract the block-row bits via three right
 $D7B3 AND A         ; rotations, and combine with the column to build the screen address in #REGbc.
 $D7B4 LD HL,$0000   ;
 $D7B7 RRA           ;
 $D7B8 RR L          ;
 $D7BA RRA           ;
 $D7BB RR L          ;
 $D7BD RRA           ;
 $D7BE RR L          ;
 $D7C0 EXX           ;
 $D7C1 LD C,A        ;
 $D7C2 EXX           ;
 $D7C3 LD A,L        ;
 $D7C4 RRCA          ;
 $D7C5 LD L,A        ;
 $D7C6 RRCA          ;
 $D7C7 ADD A,L       ;
 $D7C8 LD L,A        ;
 $D7C9 ADD HL,DE     ;
 $D7CA LD B,H        ;
 $D7CB LD C,L        ;
 $D7CC POP HL        ;
 $D7CD EXX           ;
 $D7CE LD A,D        ;
 $D7CF EXX           ; }
; Row 1: return if below the play area, skip if above, else draw.
 $D7D0 CP $B9        ; {Return if the entity's Y position is below the play area bottom
 $D7D2 RET NC        ; (#N$B9).}
 $D7D3 CP $10        ; {Skip row 1 if above the play area top (#N$10).
 $D7D5 JR C,$D7EA    ; }
 $D7D7 EXX           ; {Compute the screen address and toggle the sprite row's two
 $D7D8 LD A,C        ; pixel bytes onto the screen.
 $D7D9 EXX           ;
 $D7DA ADD A,(HL)    ;
 $D7DB LD E,A        ;
 $D7DC INC HL        ;
 $D7DD LD D,(HL)     ;
 $D7DE INC HL        ;
 $D7DF EX DE,HL      ;
 $D7E0 LD A,(BC)     ;
 $D7E1 XOR (HL)      ;
 $D7E2 LD (HL),A     ;
 $D7E3 INC BC        ;
 $D7E4 INC HL        ;
 $D7E5 LD A,(BC)     ;
 $D7E6 XOR (HL)      ;
 $D7E7 LD (HL),A     ;
 $D7E8 EX DE,HL      ;
 $D7E9 DEC BC        ; }
; Row 2: advance sprite data if skipped, step Y, step row table, draw.
@label=Draw_Clipped_Wide_Sprite_Row2
*$D7EA INC BC        ; {Advance the sprite data pointer past the skipped row.
 $D7EB INC BC        ; }
 $D7EC EXX           ; {Advance Y by the row stride and decrement the step
 $D7ED LD A,B        ; count.
 $D7EE ADD A,D       ;
 $D7EF LD D,A        ;
 $D7F0 LD A,B        ;
 $D7F1 EXX           ;
 $D7F2 DEC A         ; }
@label=Draw_Clipped_Wide_Sprite_Row2_Stride
*$D7F3 INC HL        ; {Step #REGhl forward to the next pixel row.
 $D7F4 INC HL        ;
 $D7F5 DEC A         ;
 $D7F6 JR NZ,$D7F3   ; }
 $D7F8 EXX           ; {Reload the Y position and return if below the play area
 $D7F9 LD A,D        ; bottom.
 $D7FA EXX           ;
 $D7FB CP $B9        ;
 $D7FD RET NC        ; }
 $D7FE CP $10        ; {Skip row 2 if above the play area top.
 $D800 JR C,$D815    ; }
 $D802 EXX           ; {Compute the screen address and toggle the sprite row's two
 $D803 LD A,C        ; pixel bytes onto the screen.
 $D804 EXX           ;
 $D805 ADD A,(HL)    ;
 $D806 LD E,A        ;
 $D807 INC HL        ;
 $D808 LD D,(HL)     ;
 $D809 INC HL        ;
 $D80A EX DE,HL      ;
 $D80B LD A,(BC)     ;
 $D80C XOR (HL)      ;
 $D80D LD (HL),A     ;
 $D80E INC BC        ;
 $D80F INC HL        ;
 $D810 LD A,(BC)     ;
 $D811 XOR (HL)      ;
 $D812 LD (HL),A     ;
 $D813 EX DE,HL      ;
 $D814 DEC BC        ; }
; Row 3: advance sprite data if skipped, step Y, step row table, draw.
@label=Draw_Clipped_Wide_Sprite_Row3
*$D815 INC BC        ; {Advance the sprite data pointer past the skipped row.
 $D816 INC BC        ; }
 $D817 EXX           ; {Advance Y by the row stride and decrement the step
 $D818 LD A,B        ; count.
 $D819 ADD A,D       ;
 $D81A LD D,A        ;
 $D81B LD A,B        ;
 $D81C EXX           ;
 $D81D DEC A         ; }
@label=Draw_Clipped_Wide_Sprite_Row3_Stride
*$D81E INC HL        ; {Step #REGhl forward to the next pixel row.
 $D81F INC HL        ;
 $D820 DEC A         ;
 $D821 JR NZ,$D81E   ; }
 $D823 EXX           ; {Reload the Y position and return if below the play area
 $D824 LD A,D        ; bottom.
 $D825 EXX           ;
 $D826 CP $B9        ;
 $D828 RET NC        ; }
 $D829 CP $10        ; {Skip row 3 if above the play area top.
 $D82B JR C,$D840    ; }
 $D82D EXX           ; {Compute the screen address and toggle the sprite row's two
 $D82E LD A,C        ; pixel bytes onto the screen.
 $D82F EXX           ;
 $D830 ADD A,(HL)    ;
 $D831 LD E,A        ;
 $D832 INC HL        ;
 $D833 LD D,(HL)     ;
 $D834 INC HL        ;
