 $F1C3 DEFM $10,"BILTIM",$00,$12,"PPSIL",$00,$12,"CuKID",$00,$12,"CpTEZ",$00,$12,"@PPAH",$00,$12," ",$10,"ELO",$00,$12,$19,"uJLA",$00,$12,"2%WHO",$00,$11,"vpAMF",$00,$11
 $F204 DEFM "RPSLF",$00,$10,"r%THE",$00,$10,"Q",$15,"WIZ",$00,$09,$82," KID",$00,$09,"R",$00,"ESC",$00,$09,"9",$00,"MJS",$00,$09,"8",$85,"JAS",$00,$09,"8",$14,"LIZ",$00,$09,$00,$10,"NIK",$00,$08,"p "
 $F245 DEFM "TAM",$00,$08,")%WAL",$00,$08,$06,$00,"MRK",$00,$07,$82,"EMIK",$00,$07,"b",$00,"MOM",$00,$07,"P",$00,"DAD",$00,$07,"BEVID",$00,$07,"1",$00,"KID",$00,$07,"\"%APE",$00,$06,"u",$00,"SX"
