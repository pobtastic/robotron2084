; Lookup Vector Table Entry
;
; Returns the word at index #REGa in #R$C60C: #REGhl = #R$C60C + (#REGa *
; #N$02), little-endian word into #REGde. Valid range is #R$C60C through #N$C6CD
; (last word starts at #R$C6CC). No direct CALL to #R$C6CE in this ROM.
@label=LookupVectorTableEntry
c$C6CE ADD A,A       ; Double #REGa (word stride).
 $C6CF LD HL,$C60C   ; #REGhl=#R$C60C (table base).
 $C6D2 LD D,$00      ; #REGd=#N$00.
 $C6D4 LD E,A        ; #REGe=#REGa (word offset in #REGde).
 $C6D5 ADD HL,DE     ; Add #REGde to #REGhl (pointer to the entry).
 $C6D6 LD E,(HL)     ; #REGe=*#REGhl (low byte of the word).
 $C6D7 INC HL        ; Advance #REGhl.
 $C6D8 LD D,(HL)     ; #REGd=*#REGhl (high byte of the word).
 $C6D9 RET           ; Return with the word in #REGde.

; Hit Test: 8-Byte Bounds Pair
;
; Used by the routines at #R$CCCE, #R$CD18, #R$CD34, #R$D0F0, #R$D1BF, #R$E003,
; #R$E1B6, #R$E262, #R$E2C8, #R$E360, #R$E520, #R$E6F7, #R$E881 and #R$EB07.
; .
; Reads four little-endian words at #REGhl (#N$08 bytes). The first two load into
; main #REGbc and #REGde; EXX swaps to the shadow set so the next two words load into
; shadow #REGbc and #REGde while #REGhl walks the same block. After swapping back, four
; ADD/SUB pairs (with further EXX) each end in RET C if the subtraction borrows (no
; hit). If none borrow, falls through to RET with carry clear (hit). #REGhl ends just
; past the eighth byte. Used throughout the gameplay object loop for collisions (among
; others #R$CCDA, #R$CD25, #R$D149, #R$D22D, #R$E03D, #R$EB1C).
@label=HitTestBounds8AtHL
c$C6DA LD B,(HL)     ; #REGb=*#REGhl (first word, low byte).
 $C6DB INC HL        ; Advance #REGhl.
 $C6DC LD C,(HL)     ; #REGc=*#REGhl (first word, high byte).
 $C6DD INC HL        ; Advance #REGhl.
 $C6DE LD D,(HL)     ; #REGd=*#REGhl (second word, low byte).
 $C6DF INC HL        ; Advance #REGhl.
 $C6E0 LD E,(HL)     ; #REGe=*#REGhl (second word, high byte).
 $C6E1 EXX           ; EXX (shadow #REGhl continues the load; shadow
                     ; #REGbc/#REGde hold first pair).
 $C6E2 LD B,(HL)     ; #REGb=*#REGhl (third word, low byte).
 $C6E3 INC HL        ; Advance #REGhl.
 $C6E4 LD C,(HL)     ; #REGc=*#REGhl (third word, high byte).
 $C6E5 INC HL        ; Advance #REGhl.
 $C6E6 LD D,(HL)     ; #REGd=*#REGhl (fourth word, low byte).
 $C6E7 INC HL        ; Advance #REGhl.
 $C6E8 LD E,(HL)     ; #REGe=*#REGhl (fourth word, high byte).
 $C6E9 EXX           ; EXX (main holds first pair; shadow second pair; #REGhl
                     ; past all #N$08 bytes).
; Each test adds two bytes from one pair, switches to the shadow pair, subtracts a
; byte from the other rectangle, and RET C on borrow (no overlap on that check).
 $C6EA LD A,B        ; #REGa=#REGb.
 $C6EB ADD A,D       ; #REGa+=#REGd (high bytes from main #REGbc/#REGde).
 $C6EC EXX           ; EXX.
 $C6ED SUB B         ; Subtract shadow #REGb from #REGa.
 $C6EE EXX           ; EXX.
 $C6EF RET C         ; RET C if no hit (carry from SUB).
 $C6F0 EXX           ; EXX.
 $C6F1 LD A,B        ; #REGa=#REGb.
 $C6F2 ADD A,D       ; #REGa+=#REGd (second high-byte sum).
 $C6F3 EXX           ; EXX.
 $C6F4 SUB B         ; Subtract shadow #REGb from #REGa.
 $C6F5 RET C         ; RET C if no hit.
 $C6F6 LD A,C        ; #REGa=#REGc.
 $C6F7 ADD A,E       ; #REGa+=#REGe (low-byte sum).
 $C6F8 EXX           ; EXX.
 $C6F9 SUB C         ; Subtract shadow #REGc from #REGa.
 $C6FA EXX           ; EXX.
 $C6FB RET C         ; RET C if no hit.
 $C6FC EXX           ; EXX.
 $C6FD LD A,C        ; #REGa=#REGc.
 $C6FE ADD A,E       ; #REGa+=#REGe (final low-byte sum).
 $C6FF EXX           ; EXX.
 $C700 SUB C         ; Subtract shadow #REGc from #REGa (last test).
 $C701 RET           ; RET (carry clear if overlapping).

; Dispatch Handler Pointer From HL
;
; Used by the routines at #R$CB4F, #R$CD34 and #R$D24C.
; .
; Chained trampoline: pushes resume address #R$C702, loads a #N$16-bit routine
; pointer from #REGhl, advances #REGhl by #N$02, then jumps to that pointer via the
; stack. When the handler RETs, execution continues at #R$C702 for the next table
; entry, so handlers should leave #REGhl valid for the following word unless the chain
; ends. Used from #R$CC5F, #R$CEBF, #R$CF45, #R$D27C with tables such as #R$6100.
@label=DispatchWordFromHL
c$C702 LD DE,$C702   ; #REGde=#R$C702 (resume address after each nested RET).
 $C705 PUSH DE       ; Save the resume address on the stack.
 $C706 LD E,(HL)     ; #REGe=*#REGhl (handler pointer, low byte).
 $C707 INC HL        ; Advance #REGhl.
 $C708 LD D,(HL)     ; #REGd=*#REGhl (handler pointer, high byte).
 $C709 INC HL        ; Advance #REGhl past the pointer.
 $C70A PUSH DE       ; Stack the handler address.
 $C70B RET           ; RET to the handler (next RET pops back to #R$C702).

; Help Bar Attribute Sequence
;
; Seven attribute bytes (#N$41 / #N$42 / #N$44 ink cycling) and a #N$00
; terminator, consumed from #R$C713 when #R$C777 arms #REGhl here after the "H" key
; path through #R$C77D.
@label=HelpBarAttributeSequence
g$C70C DEFB $41      ; #COLOUR(#PEEK(#PC)).
 $C70D DEFB $41      ; #COLOUR(#PEEK(#PC)).
 $C70E DEFB $42      ; #COLOUR(#PEEK(#PC)).
 $C70F DEFB $42      ; #COLOUR(#PEEK(#PC)).
 $C710 DEFB $44      ; #COLOUR(#PEEK(#PC)).
 $C711 DEFB $44      ; #COLOUR(#PEEK(#PC)).
 $C712 DEFB $00      ; Terminator.

; Update Attribute Bar
;
; Used by the routines at #R$CB4F, #R$CD34, #R$D317 and #R$D367.
; .
; Paints the HUD attribute border with *#R$C42E and writes the cycling colour
; from #R$C70C to #N$07 attribute cells at *#R$C420. Checks the H key (help) and
; F key (restart). #R$C71F is also called directly by #R$C5BD.
@label=UpdateAttributeBar
c$C713 LD HL,($C4E5) ; #REGhl=*#R$C4E5 (colour cycle table pointer).
@label=UpdateAttributeBar_FetchColour
*$C716 LD A,(HL)     ; {Read the next colour byte; jump to #R$C777 if zero
 $C717 AND A         ; (table end).
 $C718 JP Z,$C777    ; }
 $C71B INC HL        ; {Advance the table pointer and save it back to *#R$C4E5.
 $C71C LD ($C4E5),HL ; }
; This entry point is used by the routine at #R$C544.
; .
; Fill the attribute area border with *#R$C42E (current border colour).
@label=UpdateAttributeBar_FillBorder
*$C71F LD HL,$5800   ; #REGhl=#N$5800 (attribute area start).
 $C722 LD A,($C42E)  ; #REGa=*#R$C42E (border colour).
 $C725 LD B,$40      ; Top rows loop count #N$40 (#REGb=#N$40).
@label=UpdateAttributeBar_TopFillLoop
*$C727 LD (HL),A     ; {Write the border colour to #N$40 attribute cells (top
 $C728 INC HL        ; two rows).
 $C729 DJNZ $C727    ; }
 $C72B LD B,$15      ; Side-column loop count #N$15 (#REGb=#N$15).
 $C72D LD DE,$001F   ; #REGde=#N$001F (stride between left and right edge
                     ; columns).
@label=UpdateAttributeBar_SideFillLoop
*$C730 LD (HL),A     ; {Write the border colour to the left (col #N$00) and right (col #N$1F)
 $C731 ADD HL,DE     ; edge cells of #N$15 consecutive rows.
 $C732 LD (HL),A     ;
 $C733 INC HL        ;
 $C734 DJNZ $C730    ; }
 $C736 LD B,$20      ; Bottom row loop count #N$20 (#REGb=#N$20).
@label=UpdateAttributeBar_BottomFillLoop
*$C738 LD (HL),A     ; {Write the border colour to #N$20 attribute cells
 $C739 INC HL        ; (bottom row).
 $C73A DJNZ $C738    ; }
; Load the current colour byte from the table into #REGc.
 $C73C LD HL,($C4E5) ; {Back up one step in the table and load the colour byte
 $C73F DEC HL        ; into #REGc.
 $C740 LD C,(HL)     ; }
 $C741 LD H,$58      ; #REGh=#N$58 (high byte of the colour bar attribute row
                     ; pointer).
 $C743 LD A,($C420)  ; {#REGl=*#R$C420 (colour bar column offset).
 $C746 LD L,A        ; }
 $C747 LD B,$07      ; Colour bar loop count #N$07 (#REGb=#N$07).
@label=UpdateAttributeBar_ColourBarLoop
*$C749 LD (HL),C     ; {Write the cycling colour (#REGc) to #N$07 consecutive
 $C74A INC HL        ; attribute cells.
 $C74B DJNZ $C749    ; }
; Check H (help) and F (restart) keys.
 $C74D LD A,$BF      ; {Read from the keyboard;
 $C74F IN A,($FE)    ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$BF | ENTER | L | K | J | H }
                     ; TABLE#}
 $C751 AND %00010000 ; Test the H key (bit 4).
 $C753 JP Z,$C760    ; Jump to #R$C760 if H is pressed.
 $C756 LD A,$FD      ; {Read from the keyboard;
 $C758 IN A,($FE)    ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$FD | A | S | D | F | G }
                     ; TABLE#}
 $C75A AND %00001000 ; Test the F key (bit 3).
 $C75C JP Z,$EBBC    ; Jump to #R$EBBC if F is pressed (restart the game).
 $C75F RET           ; Return.
; H key pressed: poll via #R$C77D, counting down #REGd then #REGe then
; #REGd again.
@label=UpdateAttributeBar_HKeyWait_D
*$C760 CALL $C77D    ; Call #R$C77D.
 $C763 DEC D         ; {Decrease #REGd and loop back to #R$C760 while non-zero.
 $C764 JP NZ,$C760   ; }
@label=UpdateAttributeBar_HKeyWait_E
*$C767 CALL $C77D    ; Call #R$C77D.
 $C76A DEC E         ; {Decrease #REGe and loop back to #R$C767 while non-zero.
 $C76B JP NZ,$C767   ; }
@label=UpdateAttributeBar_HKeyWait_D2
*$C76E CALL $C77D    ; Call #R$C77D.
 $C771 DEC D         ; {Decrease #REGd and loop back to #R$C76E while non-zero.
 $C772 JP NZ,$C76E   ; }
 $C775 RET           ; Return.
 $C776 RET           ; Return.
; Table exhausted: reset the pointer to the start of #R$C70C and continue.
@label=UpdateAttributeBar_ResetTable
*$C777 LD HL,$C70C   ; #REGhl=#R$C70C (start of the colour cycle table).
 $C77A JP $C716      ; Jump to #R$C716 (fetch the first colour byte).

; Poll H Key
;
; Used by the routine at #R$C713.
; .
; Reads keyboard port #N$BF bit 4 (the "H" key) on each pass of the inner
; loop. Key bits are active-low (#N$00 = pressed); if "H" is not pressed, #REGd is
; decremented, otherwise #REGe is decremented. Called from #R$C713 while handling the
; attribute bar after the key has been detected.
@label=PollHKey
c$C77D LD D,$15      ; Initialise #REGd to #N$15 (down-counter for "H" not
                     ; pressed).
 $C77F LD E,$15      ; Initialise #REGe to #N$15 (down-counter for "H"
                     ; pressed).
 $C781 LD B,$14      ; Set an inner loop counter to #N$14 loops.
@label=PollHKey_Loop
*$C783 LD A,$BF      ; {Read from the keyboard;
 $C785 IN A,($FE)    ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$BF | ENTER | L | K | J | H }
                     ; TABLE#}
 $C787 AND %00010000 ; Keep only bit 4 ("H" key).
 $C789 JP NZ,$C790   ; If "H" is not pressed (bit 4 is 1), jump to #R$C790 to
                     ; decrement #REGd.
; "H" key was pressed.
 $C78C DEC E         ; Decrease #REGe by one.
 $C78D JP $C791      ; Jump to #R$C791 (skip the #REGd decrement).
@label=PollHKey_NotPressed
*$C790 DEC D         ; Decrease #REGd by one.
@label=PollHKey_Continue
*$C791 DJNZ $C783    ; Decrease the inner loop counter and loop back to #R$C783
                     ; until it reaches zero.
 $C793 RET           ; Return.

; Draw Lives Display
;
; Used by the routines at #R$C5C1 and #R$D317.
; .
; Refreshes the on-screen life icons. Runs #N$07 passes of #R$D4BB (masked
; clear) with glyph code #N$1B, vertical seed *#R$C416 and step *#R$C417. If
; *#R$C415 is zero, returns; else #REGd is the lives count capped at #N$07, the
; vertical seed is reloaded from *#R$C416, and that many OR-blits run via
; #R$D486 with the same glyph and stride. Called from #R$D317 and #R$C5C1.
@label=DrawLivesDisplay
c$C794 LD D,$07      ; #REGd=#N$07 (fixed passes for the clear / background
                     ; phase).
 $C796 LD A,($C416)  ; {#REGe=*#R$C416 (initial vertical parameter for the
 $C799 LD E,A        ; first phase).}
; Seven stacked clears using #R$D4BB (CPL and AND into the display file).
@label=DrawLivesDisplay_ClearLoop
*$C79A PUSH DE       ; Stash #REGde on the stack.
 $C79B LD A,$1B      ; #REGa=#N$1B (life-icon character / glyph selector).
 $C79D LD B,E        ; #REGb=#REGe (vertical argument for the blit helper).
 $C79E LD C,$00      ; #REGc=#N$00.
 $C7A0 CALL $D4BB    ; Call #R$D4BB (masked clear at this cell).
 $C7A3 POP DE        ; Restore #REGde from the stack.
 $C7A4 LD A,($C417)  ; #REGa=*#R$C417 (vertical spacing between stacked slots).
 $C7A7 ADD A,E       ; Add #REGe to #REGa.
 $C7A8 LD E,A        ; #REGe=#REGa (advance the vertical parameter).
 $C7A9 DEC D         ; Decrement #REGd.
 $C7AA JP NZ,$C79A   ; Loop back to #R$C79A until all #N$07 clear passes
                     ; finish.
 $C7AD LD HL,$C415   ; #REGhl=#R$C415 (lives counter).
 $C7B0 LD A,(HL)     ; #REGa=*#REGhl.
 $C7B1 AND A         ; {Return if there are no lives to draw.
 $C7B2 RET Z         ; }
 $C7B3 CP $08        ; Compare with #N$08.
 $C7B5 JR C,$C7B9    ; Jump to #R$C7B9 if the count is below #N$08 (use it
                     ; as-is).
 $C7B7 LD A,$07      ; #REGa=#N$07 (cap at seven visible life icons).
@label=DrawLivesDisplay_CountReady
*$C7B9 LD D,A        ; #REGd=#REGa (number of OR-blits to perform).
 $C7BA INC HL        ; Advance #REGhl to #R$C416 (vertical seed for the draw
                     ; phase).
 $C7BB LD E,(HL)     ; #REGe=*#REGhl.
; Each iteration OR-merges a life glyph via #R$D486 (see #R$D486).
@label=DrawLivesDisplay_DrawLoop
*$C7BC PUSH DE       ; Stash #REGde on the stack.
 $C7BD LD A,$1B      ; #REGa=#N$1B.
 $C7BF LD B,E        ; #REGb=#REGe.
 $C7C0 LD C,$00      ; #REGc=#N$00.
 $C7C2 CALL $D486    ; Call #R$D486 (OR-blit at this cell).
 $C7C5 POP DE        ; Restore #REGde from the stack.
 $C7C6 LD A,($C417)  ; #REGa=*#R$C417.
 $C7C9 ADD A,E       ; Add #REGe to #REGa.
 $C7CA LD E,A        ; #REGe=#REGa (advance the vertical parameter).
 $C7CB DEC D         ; Decrement #REGd.
 $C7CC JR NZ,$C7BC   ; Loop back to #R$C7BC while more icons remain.
 $C7CE RET           ; Return.

; Narrow Entity Sprite Data
;
; Pixel data for narrow entity sprites (#N$10 bytes per entry),
; addressed via the lookup table at #R$C60C and rendered by #R$C84F.
; Each entry provides 8 rows of 2 pixel bytes each.
@label=Narrow_Entity_Sprite_Data
w$C7CF DEFW $0308
 $C7D1 DEFW $030F
 $C7D3 DEFW $0101
 $C7D5 DEFW $0008
 $C7D7 DEFW $0308
 $C7D9 DEFW $030F
 $C7DB DEFW $0101
 $C7DD DEFW $0008
 $C7DF DEFW $0308
 $C7E1 DEFW $030F
 $C7E3 DEFW $0101
 $C7E5 DEFW $0008
 $C7E7 DEFW $0308
 $C7E9 DEFW $030F
 $C7EB DEFW $0101
 $C7ED DEFW $0008
 $C7EF DEFW $0308
 $C7F1 DEFW $030F
 $C7F3 DEFW $0101
 $C7F5 DEFW $0008
 $C7F7 DEFW $05F5
 $C7F9 DEFW $0CFB
 $C7FB DEFW $0303
 $C7FD DEFW $08F8
 $C7FF DEFW $0505
 $C801 DEFW $0C0C
 $C803 DEFW $0303
 $C805 DEFW $0808
 $C807 DEFW $0505
 $C809 DEFW $0C05
 $C80B DEFW $0101
 $C80D DEFW $0800
 $C80F DEFW $0308
 $C811 DEFW $030F
 $C813 DEFW $0101
 $C815 DEFW $0008
 $C817 DEFW $F8FE
 $C819 DEFW $F8FE
 $C81B DEFW $0303
 $C81D DEFW $F8F8
 $C81F DEFW $F805
 $C821 DEFW $F60C
 $C823 DEFW $0303
 $C825 DEFW $F808
 $C827 DEFW $F805
 $C829 DEFW $F805
 $C82B DEFW $0801
 $C82D DEFW $F800
 $C82F DEFW $0308
 $C831 DEFW $030F
 $C833 DEFW $0101
 $C835 DEFW $0008
 $C837 DEFW $03F7
 $C839 DEFW $03F7
 $C83B DEFW $0108
 $C83D DEFW $00F8
 $C83F DEFW $0308
 $C841 DEFW $030F
 $C843 DEFW $0101
 $C845 DEFW $0008
 $C847 DEFW $0308
 $C849 DEFW $030F
 $C84B DEFW $0101
 $C84D DEFW $0008

; Erase Narrow Entity Sprite
;
; Used by the routines at #R$CCE9, #R$CD34, #R$D5B1, #R$E4B9, #R$E520, #R$E974
; and #R$EB07.
; .
; Entry point for erasing a narrow entity sprite. Sets erase mode
; (attribute writes disabled) and jumps to #R$C85A.
;
; HL Entity record pointer
@label=Erase_Narrow_Entity_Sprite
c$C84F EXX           ; {Set erase mode: clear the attribute-write flag in #REGd' and
 $C850 LD D,$00      ; jump to #R$C85A.
 $C852 EXX           ;
 $C853 JP $C85A      ; }

; Draw Narrow Entity Sprite
;
; Used by the routines at #R$CB4F, #R$D5B1, #R$E520 and #R$E6C4.
; .
; Entry point for drawing a narrow entity sprite. Sets draw mode
; (attribute writes enabled) and falls through to #R$C85A. XOR-renders
; 8 rows of 2 bytes each; the sprite type is looked up in #R$C60C for
; the pixel data address, and the entity colour is written to the 2
; attribute cells flanking each pixel row.
;
; HL Entity record pointer
@label=Draw_Narrow_Entity_Sprite
c$C856 EXX           ; {Set draw mode: set the attribute-write flag in #REGd'.
 $C857 LD D,$01      ;
 $C859 EXX           ; }
; This entry point is used by the routine at #R$C84F.
; .
; Compute the sprite pixel data pointer and screen coordinate.
@label=Render_Narrow_Entity_Sprite
*$C85A LD B,H        ; {Copy the entity record pointer to #REGbc.
 $C85B LD C,L        ; }
 $C85C LD E,(HL)     ; {Read the sprite type byte and form a word offset in
 $C85D SLA E         ; #REGde.
 $C85F LD D,$00      ; }
 $C861 LD HL,$C60C   ; {Look up the sprite pixel data address in the table at
 $C864 ADD HL,DE     ; #R$C60C.
 $C865 LD E,(HL)     ;
 $C866 INC HL        ;
 $C867 LD D,(HL)     ; }
 $C868 LD H,B        ; {Restore the entity record pointer to #REGhl.
 $C869 LD L,C        ; }
 $C86A INC HL        ; {Advance past the sprite type byte and load the screen row
 $C86B LD B,$46      ; address high byte from the entity record.
 $C86D LD C,(HL)     ;
 $C86E INC HL        ; }
 $C86F SLA C         ; {Shift the coordinate into #REGb to build the screen address
 $C871 RL B          ; high byte.}
 $C873 PUSH BC       ; Stash the screen coordinate on the stack.
 $C874 LD A,(HL)     ; {Load the column byte, clear #REGhl, and distribute its bits
 $C875 AND A         ; into #REGl via successive right-rotations to form the pixel offset.
 $C876 LD HL,$0000   ;
 $C879 RRA           ;
 $C87A RR L          ;
 $C87C RRA           ;
 $C87D RR L          ;
 $C87F RRA           ;
 $C880 RR L          ;
 $C882 RRC L         ; }
 $C884 ADD HL,DE     ; {Add the sprite data base to the offset, set #REGbc as the
 $C885 LD B,H        ; sprite pixel data pointer, and restore the screen coordinate.
 $C886 LD C,L        ;
 $C887 POP HL        ;
 $C888 EXX           ; }
 $C889 LD C,A        ; {Stash the column offset in alternate #REGc and return to the
 $C88A EXX           ; main register set.}
; Row 1: XOR-render the first sprite row and optionally write the
; entity colour to the flanking attribute cells.
 $C88B ADD A,(HL)    ; {Compute the first screen row address from the entity record
 $C88C LD E,A        ; into #REGde.
 $C88D INC HL        ;
 $C88E LD D,(HL)     ;
 $C88F INC HL        ; }
 $C890 LD A,(BC)     ; {XOR-render 2 sprite pixel bytes at the first screen
 $C891 EX DE,HL      ; row.
 $C892 XOR (HL)      ;
 $C893 LD (HL),A     ;
 $C894 INC BC        ;
 $C895 INC HL        ;
 $C896 LD A,(BC)     ;
 $C897 INC BC        ;
 $C898 XOR (HL)      ;
 $C899 LD (HL),A     ; }
 $C89A EXX           ; {Check whether attribute writes are enabled; jump to #R$C8AF
 $C89B LD A,D        ; to skip the colour write in erase mode.
 $C89C AND A         ;
 $C89D EXX           ;
 $C89E JR Z,$C8AF    ; }
 $C8A0 LD A,H        ; {Convert the screen address high byte to an attribute
 $C8A1 RRCA          ; address.
 $C8A2 RRCA          ;
 $C8A3 RRCA          ; }
 $C8A4 AND %00000011 ; Mask to the attribute page bits.
 $C8A6 OR %01011000  ; Set the attribute area high byte.
 $C8A8 LD H,A        ; Update #REGh to point into attribute RAM.
 $C8A9 EXX           ; {Fetch the entity colour via #REGb' and write it to
 $C8AA LD A,B        ; the first attribute cell.
 $C8AB EXX           ;
 $C8AC LD (HL),A     ;
 $C8AD DEC HL        ; }
 $C8AE LD (HL),A     ; Write the entity colour to the second attribute cell.
; Rows 2–7: XOR-render the remaining sprite rows without attribute
; writes (attribute colour was set once on row 1).
@label=Render_Narrow_Entity_Sprite_Row2
*$C8AF EX DE,HL      ; {Restore the entity record pointer and fetch the column offset
 $C8B0 EXX           ; from alternate #REGc.
 $C8B1 LD A,C        ;
 $C8B2 EXX           ; }
 $C8B3 ADD A,(HL)    ; {Compute the second screen row address from the entity
 $C8B4 LD E,A        ; record.
 $C8B5 INC HL        ;
 $C8B6 LD D,(HL)     ;
 $C8B7 INC HL        ; }
 $C8B8 LD A,(BC)     ; {XOR-render 2 sprite bytes at the second screen row and
 $C8B9 EX DE,HL      ; restore the entity record pointer.
 $C8BA XOR (HL)      ;
 $C8BB LD (HL),A     ;
 $C8BC INC BC        ;
 $C8BD INC HL        ;
 $C8BE LD A,(BC)     ;
 $C8BF INC BC        ;
 $C8C0 XOR (HL)      ;
 $C8C1 LD (HL),A     ;
 $C8C2 EX DE,HL      ; }
 $C8C3 EXX           ; {Fetch the column offset from alternate #REGc.
 $C8C4 LD A,C        ;
 $C8C5 EXX           ; }
 $C8C6 ADD A,(HL)    ; {Compute the third screen row address from the entity
 $C8C7 LD E,A        ; record.
 $C8C8 INC HL        ;
 $C8C9 LD D,(HL)     ;
 $C8CA INC HL        ; }
 $C8CB LD A,(BC)     ; {XOR-render 2 sprite bytes at the third screen row and
 $C8CC EX DE,HL      ; restore.
 $C8CD XOR (HL)      ;
 $C8CE LD (HL),A     ;
 $C8CF INC BC        ;
 $C8D0 INC HL        ;
 $C8D1 LD A,(BC)     ;
 $C8D2 INC BC        ;
 $C8D3 XOR (HL)      ;
 $C8D4 LD (HL),A     ;
 $C8D5 EX DE,HL      ; }
 $C8D6 EXX           ; {Fetch the column offset from alternate #REGc.
 $C8D7 LD A,C        ;
 $C8D8 EXX           ; }
