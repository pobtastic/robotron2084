; Poll H Key
;
; Used by the routine at #R$C713.
; .
; Reads keyboard port #N$BF bit 4 (the "H" key) on each pass of the inner
; loop. Key bits are active-low (#N$00 = pressed); if "H" is not pressed, #REGd is
; decremented, otherwise #REGe is decremented. Called from #R$C713 while handling the
; attribute bar after the key has been detected.
@label=PollHKey
c$C77D LD D,$15      ; Initialise #REGd to #N$15 (down-counter for "H" not
                     ; pressed).
 $C77F LD E,$15      ; Initialise #REGe to #N$15 (down-counter for "H"
                     ; pressed).
 $C781 LD B,$14      ; Set an inner loop counter to #N$14 loops.
@label=PollHKey_Loop
*$C783 LD A,$BF      ; {Read from the keyboard;
 $C785 IN A,($FE)    ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$BF | ENTER | L | K | J | H }
                     ; TABLE#}
 $C787 AND %00010000 ; Keep only bit 4 ("H" key).
 $C789 JP NZ,$C790   ; If "H" is not pressed (bit 4 is 1), jump to #R$C790 to
                     ; decrement #REGd.
; "H" key was pressed.
 $C78C DEC E         ; Decrease #REGe by one.
 $C78D JP $C791      ; Jump to #R$C791 (skip the #REGd decrement).
@label=PollHKey_NotPressed
*$C790 DEC D         ; Decrease #REGd by one.
@label=PollHKey_Continue
*$C791 DJNZ $C783    ; Decrease the inner loop counter and loop back to #R$C783
                     ; until it reaches zero.
 $C793 RET           ; Return.

