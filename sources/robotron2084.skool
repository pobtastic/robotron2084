; Process Entity Record
;
; Processes one entity slot in the wave entity list. If the slot is
; active, the enemy's animation colours are updated on screen via #R$CFA4
; and its animation counter decremented. If the counter expires the enemy
; is erased and the slot retired. If the slot holds spawn data (#R$E031),
; a new enemy position is found and the enemy is placed in the play area.
;
; HL Pointer to the entity type/state byte
@label=Process_Entity_Record_Fast
c$E003 LD A,(HL)     ; Read the entity's animation counter.
 $E004 JP $E00C      ; Jump to #R$E00C.
@label=Process_Entity_Record
 $E007 LD A,(HL)     ; Read the entity's animation counter.
 $E008 AND A         ; {Jump to #R$E031 if the entity slot is inactive.
 $E009 JP Z,$E031    ; }
; Update the enemy's on-screen colour then advance its animation counter.
; If the counter expires the enemy is erased.
@label=Process_Entity_Record_Tick
*$E00C AND %00000111 ; Extract the three-bit animation frame number.
 $E00E INC HL        ; Move past the animation counter byte.
 $E00F PUSH HL       ; Stash the entity data pointer on the stack.
 $E010 EXX           ; {Pass the animation frame number to the colouring
 $E011 LD B,A        ; routine.
 $E012 EXX           ; }
 $E013 CALL $CFA4    ; Call #R$CFA4 to colour the entity on screen.
 $E016 POP HL        ; Restore the entity data pointer from the stack.
 $E017 DEC HL        ; Step back to the animation counter byte.
 $E018 DEC (HL)      ; {Advance the animation frame and jump to #R$E02C if not
 $E019 JP NZ,$E02C   ; yet expired.}
; The animation counter has run down to zero: remove the enemy from
; the screen.
 $E01C INC HL        ; Move past the animation counter byte.
 $E01D PUSH HL       ; Stash the entity data pointer on the stack.
 $E01E CALL $D630    ; Call #R$D630 to erase the enemy sprite from the screen.
 $E021 POP HL        ; Restore the entity data pointer from the stack.
 $E022 DEC HL        ; {Step back to the entity handler address field.
 $E023 DEC HL        ;
 $E024 DEC HL        ; }
 $E025 LD DE,$E02C   ; Load #R$E02C as the replacement entity handler.
 $E028 LD (HL),E     ; {Write #R$E02C into the entity handler address field.
 $E029 INC HL        ;
 $E02A LD (HL),D     ;
 $E02B INC HL        ; }
; This entry point is used by the routines at #R$CD34 and #R$E9CC.
@label=Process_Entity_Record_Next7
*$E02C LD DE,$0007   ; {Skip to the next entity record and return.
 $E02F ADD HL,DE     ;
 $E030 RET           ; }
; This slot holds spawn data for a new enemy. Erase any ghost at the
; target position, check it falls within the play area, then try to
; place the enemy.
@label=Process_Entity_Record_Inactive
*$E031 INC HL        ; Move past the animation counter byte.
 $E032 PUSH HL       ; Stash the entity data pointer on the stack.
 $E033 CALL $C949    ; Call #R$C949 to erase any residual sprite at the spawn
                     ; position.
 $E036 POP HL        ; Restore the entity data pointer from the stack.
 $E037 INC HL        ; Move to the entity's Y position.
 $E038 EXX           ; {Set the play area boundary data address for the bounds
 $E039 LD HL,$C4D4   ; check.
 $E03C EXX           ; }
 $E03D CALL $C6DA    ; Call #R$C6DA to test if the spawn position is within the
                     ; play area.
 $E040 JP NC,$E0B7   ; Jump to #R$E0B7 if the position is outside the play
                     ; area.
 $E043 DEC HL        ; {Step back to the entity type state byte.
 $E044 DEC HL        ;
 $E045 DEC HL        ; }
 $E046 CALL $D1BF    ; Call #R$D1BF to determine whether the enemy should
                     ; change type.
 $E049 CP $F0        ; {Stay with the current enemy type if the random roll is
 $E04B JP C,$E058    ; below #N$F0.}
@label=Process_Entity_Record_Cycle_Type
*$E04E DEC HL        ; Step back to the entity type state byte.
 $E04F LD A,(HL)     ; Read the entity type state.
 $E050 INC A         ; Advance to the next animation variant.
 $E051 AND %00110011 ; Wrap within the valid entity type range (#N$33).
 $E053 LD (HL),A     ; Save the new entity type state.
 $E054 INC HL        ; Move to the entity's animation frame data.
 $E055 JP $E05B      ; Jump to #R$E05B.
; The random roll was below #N$F0 so the enemy keeps its current type.
; Load the unchanged type state and fall through to apply a movement step.
@label=Process_Entity_Record_Keep_Type
*$E058 DEC HL        ; Step back to the entity type state byte.
 $E059 LD A,(HL)     ; Read the entity type state.
 $E05A INC HL        ; Move to the entity's animation frame data.
; Apply a one-step movement from the direction table at #R$E11A. The
; direction is derived from the low two bits of the entity type state.
@label=Process_Entity_Record_Apply_Delta
*$E05B EX DE,HL      ; Preserve the entity data pointer in #REGde.
 $E05C AND %00000011 ; Isolate the movement direction (two bits).
 $E05E SLA A         ; {Index into the direction delta table at #R$E11A.
 $E060 LD C,A        ;
 $E061 LD B,$00      ;
 $E063 LD HL,$E11A   ;
 $E066 ADD HL,BC     ; }
 $E067 EX DE,HL      ; Restore #REGhl to the entity data and #REGde to the
                     ; delta entry.
 $E068 LD A,(DE)     ; {Apply the Y movement delta to the enemy's current Y
 $E069 ADD A,(HL)    ; position.}
 $E06A CP $AB        ; {Retry with a new type if the enemy moves below the play
 $E06C JP NC,$E04E   ; area.}
 $E06F CP $10        ; {Retry with a new type if the enemy moves above the play
 $E071 JP C,$E04E    ; area.}
 $E074 LD C,A        ; Save the validated Y position.
 $E075 INC HL        ; {Advance to the enemy's X position and the X delta.
 $E076 INC DE        ; }
 $E077 LD A,(DE)     ; {Apply the X movement delta to the enemy's current X
 $E078 ADD A,(HL)    ; position.}
 $E079 CP $F1        ; {Jump to #R$E083 if the new X overshoots the right edge.
 $E07B JP NC,$E083   ; }
 $E07E CP $08        ; {Accept the position if it is within the play area's
 $E080 JP NC,$E087   ; left boundary.}
@label=Process_Entity_Record_Retry
*$E083 DEC HL        ; Step back to the Y delta entry.
 $E084 JP $E04E      ; Retry with a new enemy type.
; The enemy's new position is inside the play area. Write it to the
; record and draw the enemy on screen.
@label=Process_Entity_Record_Register
*$E087 LD (HL),A     ; {Write the new screen position into the entity record.
 $E088 DEC HL        ;
 $E089 LD (HL),C     ;
 $E08A DEC HL        ; }
 $E08B PUSH HL       ; Stash the entity record pointer on the stack.
 $E08C EXX           ; {Set the spawn display attribute (#COLOUR$47) in the
 $E08D LD B,$47      ; shadow register.
 $E08F EXX           ; }
 $E090 CALL $C950    ; Call #R$C950 to spawn the enemy and draw it on screen.
 $E093 POP HL        ; Restore the entity record pointer from the stack.
; This entry point is used by the routines at #R$CD34, #R$E1B6, #R$E9CC,
; #R$EA6E and #R$EB07.
@label=Process_Entity_Record_Next6
*$E094 LD DE,$0006   ; {Skip to the next entity record and return.
 $E097 ADD HL,DE     ;
 $E098 RET           ; }
; This entry point is used by the routine at #R$E1B6.
; .
; The enemy was placed successfully. Increment the scroll position
; counter before advancing to the next record.
@label=Process_Entity_Record_Counter_Up_Next6
*$E099 EX DE,HL      ; Preserve the entity list pointer in #REGde.
 $E09A LD HL,($C535) ; {Add #N$0040 to *#N$C535.
 $E09D LD BC,$0040   ;
 $E0A0 ADD HL,BC     ;
 $E0A1 LD ($C535),HL ; }
 $E0A4 EX DE,HL      ; Restore the entity list pointer.
 $E0A5 JP $E094      ; Jump to #R$E094.
; This entry point is used by the routine at #R$CD34.
; .
; Same as #R$E099 but steps over a seven-byte record.
@label=Process_Entity_Record_Counter_Up_Next7
*$E0A8 EX DE,HL      ; Preserve the entity list pointer in #REGde.
 $E0A9 LD HL,($C535) ; {Add #N$0040 to *#N$C535.
 $E0AC LD BC,$0040   ;
 $E0AF ADD HL,BC     ;
 $E0B0 LD ($C535),HL ; }
 $E0B3 EX DE,HL      ; Restore the entity list pointer.
 $E0B4 JP $E02C      ; Jump to #R$E02C.
; The enemy has left the play area. Flash it with its death sprite then
; add a kill bonus to the player's score.
@label=Process_Entity_Record_Kill
*$E0B7 DEC HL        ; {Rewind to the entity handler address field.
 $E0B8 DEC HL        ;
 $E0B9 DEC HL        ;
 $E0BA DEC HL        ;
 $E0BB DEC HL        ; }
 $E0BC LD (HL),$32   ; Switch the entity to the kill sequence handler.
 $E0BE INC HL        ; Move to the entity colour attribute byte.
 $E0BF LD A,(HL)     ; Read the entity colour attribute.
 $E0C0 PUSH AF       ; Stash the entity colour attribute on the stack.
 $E0C1 LD A,($C4DE)  ; {Set the entity's death colour from the current kill
 $E0C4 ADD A,$13     ; tally.
 $E0C6 LD (HL),A     ; }
 $E0C7 PUSH HL       ; Stash the attribute pointer on the stack.
 $E0C8 EXX           ; {Set the death flash attribute (#INK$07) in the shadow
 $E0C9 LD B,$07      ; register.
 $E0CB EXX           ; }
 $E0CC CALL $D637    ; Call #R$D637 to draw the entity's death animation
                     ; sprite.
 $E0CF POP HL        ; Restore the attribute pointer from the stack.
 $E0D0 LD A,($C4DE)  ; Read the enemy kill value from the wave counter.
 $E0D3 SLA A         ; {Multiply by #N$10 for the score contribution.
 $E0D5 SLA A         ;
 $E0D7 SLA A         ;
 $E0D9 SLA A         ; }
 $E0DB EX DE,HL      ; Save the entity pointer while accessing the score.
 $E0DC LD HL,$C405   ; Point #REGhl at the player's score.
 $E0DF ADD A,(HL)    ; {Add the kill score to the ones digit of the player's
 $E0E0 DAA           ; score (BCD).
 $E0E1 LD (HL),A     ; }
 $E0E2 JP NC,$E0F4   ; Jump to #R$E0F4 if the ones digit did not overflow.
 $E0E5 DEC HL        ; Move to the tens digit.
 $E0E6 LD A,$01      ; {Carry one into the tens digit of the player's score
 $E0E8 ADD A,(HL)    ; (BCD).
 $E0E9 DAA           ;
 $E0EA LD (HL),A     ; }
 $E0EB JP NC,$E0F4   ; Jump to #R$E0F4 if the tens digit did not overflow.
 $E0EE DEC HL        ; Move to the hundreds digit.
 $E0EF LD A,$01      ; {Carry one into the hundreds digit of the player's score
 $E0F1 ADD A,(HL)    ; (BCD).
 $E0F2 DAA           ;
 $E0F3 LD (HL),A     ; }
@label=Process_Entity_Record_Wave_Count
*$E0F4 LD A,($C4DE)  ; {Jump to #R$E100 if the maximum kill count for this wave
 $E0F7 CP $05        ; is reached.
 $E0F9 JP Z,$E100    ; }
 $E0FC INC A         ; {Increment the wave kill counter.
 $E0FD LD ($C4DE),A  ; }
@label=Process_Entity_Record_Decrement_Count
*$E100 POP AF        ; Restore the entity colour attribute from the stack.
 $E101 SRL A         ; {Extract the entity type to use as a count table index.
 $E103 SRL A         ;
 $E105 SRL A         ;
 $E107 SRL A         ;
 $E109 LD C,A        ; }
 $E10A LD B,$00      ; {Form a pointer to the entity count entry for this type.
 $E10C LD HL,$C427   ;
 $E10F ADD HL,BC     ; }
 $E110 DEC (HL)      ; Decrement the on-screen enemy count for this type.
 $E111 EX DE,HL      ; Restore the entity list pointer.
 $E112 PUSH HL       ; Stash the entity list pointer on the stack.
 $E113 CALL $CD34    ; Call #R$CD34 to update the score and wave display.
 $E116 POP HL        ; Restore the entity list pointer from the stack.
 $E117 JP $E094      ; Jump to #R$E094.
; Movement delta table: one two-byte entry (Y delta, X delta) per
; cardinal direction, indexed by the low two bits of the entity type
; state. Order: up, right, down, left.
@label=Direction_Delta_Table
 $E11A DEFB $FF,$00  ;
 $E11C DEFB $00,$01  ;
 $E11E DEFB $01,$00  ;
 $E120 DEFB $00,$FF  ;

; Spawn Wave Enemies
;
; Used by the routine at #R$D24C.
; .
; Reads three spawn-count bytes from #REGhl (slots #N$10, #N$20, #N$30)
; and populates the entity list at *#R$C50D with entities via #R$E149. Each
; record has a random screen position and a slot-typed variant; #R$C950 spawns
; each entity. Terminates the list with #N$D1A4 and updates *#R$C509.
@label=Spawn_Wave_Enemies
c$E122 LD DE,($C509) ; #REGde=*#R$C509 (current entity list write pointer).
 $E126 LD ($C50D),DE ; {Copy #REGde to *#R$C50D and *#R$C50B.
 $E12A LD ($C50B),DE ; }
 $E12E LD C,$10      ; {Call #R$E149 with enemy slot #N$10.
 $E130 CALL $E149    ; }
 $E133 LD C,$20      ; {Call #R$E149 with enemy slot #N$20.
 $E135 CALL $E149    ; }
 $E138 LD C,$30      ; {Call #R$E149 with enemy slot #N$30.
 $E13A CALL $E149    ; }
 $E13D EX DE,HL      ; {Save the final entity list write pointer to *#R$C509.
 $E13E LD ($C509),HL ; }
 $E141 LD BC,$D1A4   ; {Write the entity list terminator #N$D1A4 to *#REGhl.
 $E144 LD (HL),C     ;
 $E145 INC HL        ;
 $E146 LD (HL),B     ; }
 $E147 EX DE,HL      ; Restore #REGhl and #REGde.
 $E148 RET           ; Return.
; Reads the count byte from *#REGhl. Caches it in the entity count table
; at #R$C41E(#N$C427)+index. If zero, jumps to #R$E1AF; otherwise loops
; #REGb times, writing a nine-byte entity record and calling #R$C950.
@label=Spawn_Wave_Enemies_Populate_Slot
*$E149 PUSH HL       ; Stash the source pointer on the stack.
 $E14A LD D,(HL)     ; #REGd=*#REGhl (entity count for this slot).
 $E14B LD A,C        ; Save the slot ID in #REGa.
 $E14C SRL C         ; {Shift #REGc right four times to derive the slot count
 $E14E SRL C         ; table index.
 $E150 SRL C         ;
 $E152 SRL C         ; }
 $E154 LD B,$00      ; {Write entity count (#REGd) to *#R$C41E(#N$C427)+index.
 $E156 LD HL,$C427   ;
 $E159 ADD HL,BC     ;
 $E15A LD (HL),D     ; }
 $E15B POP HL        ; Restore the source pointer.
 $E15C LD C,A        ; #REGc=#REGa (restore the slot ID).
 $E15D LD A,D        ; {#REGa=#REGb=entity count (#REGb drives the entity spawn
 $E15E LD B,A        ; loop).}
 $E15F AND A         ; Test if the entity count is zero.
 $E160 PUSH HL       ; Stash the source pointer on the stack.
 $E161 LD HL,($C50D) ; #REGhl=*#R$C50D (entity list write pointer).
 $E164 JP Z,$E1AF    ; Jump to #R$E1AF if the entity count is zero.
; Build one entity record at *#REGhl: entity handler #N$E007, zero byte,
; type nibble, random Y (#N$10-#N$AA), random X (#N$08-#N$F0), then
; #N$0D, #N$07, #N$FF; call #R$C950 to spawn. Loop #REGb times.
@label=Spawn_Wave_Enemies_Write_Record
*$E167 LD DE,$E007   ; #REGde=#N$E007 (entity update handler address).
 $E16A LD (HL),E     ; {Write #REGde to *#REGhl as a little-endian word.
 $E16B INC HL        ;
 $E16C LD (HL),D     ;
 $E16D INC HL        ; }
 $E16E LD (HL),$00   ; {Write #N$00 to *#REGhl; advance #REGhl.
 $E170 INC HL        ; }
 $E171 CALL $D1BF    ; Call #R$D1BF to generate a random byte.
 $E174 AND %00000011 ; Mask to the low two bits.
 $E176 OR C          ; {Write entity type (slot ORed with random bits) to
 $E177 LD (HL),A     ; *#REGhl.
 $E178 INC HL        ; }
@label=Spawn_Wave_Enemies_Get_Y
*$E179 CALL $D1BF    ; Call #R$D1BF to generate a random byte.
 $E17C CP $10        ; {Retry if below #N$10 (outside valid Y range).
 $E17E JP C,$E179    ; }
 $E181 CP $AB        ; {Retry if #N$AB or greater (outside valid Y range).
 $E183 JP NC,$E179   ; }
 $E186 LD (HL),A     ; {Write random Y coordinate to *#REGhl; advance #REGhl.
 $E187 INC HL        ; }
@label=Spawn_Wave_Enemies_Get_X
*$E188 CALL $D1BF    ; Call #R$D1BF to generate a random byte.
 $E18B CP $08        ; {Retry if below #N$08 (outside valid X range).
 $E18D JP C,$E188    ; }
 $E190 CP $F1        ; {Retry if #N$F1 or greater (outside valid X range).
 $E192 JP NC,$E188   ; }
 $E195 LD (HL),A     ; Write random X coordinate to *#REGhl.
 $E196 PUSH HL       ; {Stash #REGhl on the stack; step #REGhl back to the type
 $E197 DEC HL        ; byte.
 $E198 DEC HL        ; }
 $E199 EXX           ; {Set #REGb'=#COLOUR$47 via shadow registers.
 $E19A LD B,$47      ;
 $E19C EXX           ; }
 $E19D PUSH BC       ; {Spawn the entity via #R$C950, preserving #REGbc.
 $E19E CALL $C950    ;
 $E1A1 POP BC        ; }
 $E1A2 POP HL        ; Restore #REGhl (X coordinate position).
 $E1A3 INC HL        ; {Write trailing record bytes #N$0D, #N$07 and #N$FF.
 $E1A4 LD (HL),$0D   ;
 $E1A6 INC HL        ;
 $E1A7 LD (HL),$07   ;
 $E1A9 INC HL        ;
 $E1AA LD (HL),$FF   ; }
 $E1AC INC HL        ; {Advance #REGhl; loop back to #R$E167 for the next
 $E1AD DJNZ $E167    ; entity.}
@label=Spawn_Wave_Enemies_Update_Pointer
*$E1AF LD ($C50D),HL ; Save the entity list write pointer to *#R$C50D.
 $E1B2 EX DE,HL      ; Restore #REGde.
 $E1B3 POP HL        ; {Restore the source pointer; advance past the count
 $E1B4 INC HL        ; byte.}
 $E1B5 RET           ; Return.

; Handle Horizontal Enemy Entity
;
; Per-frame entity handler for the horizontal-moving wave enemy, written
; into entity records by #R$E290. Checks the wave start delay at #N$C533;
; if still counting, skips forward via #R$E099. Otherwise erases the
; sprite, tests player contact via #R$C6DA (triggering death via #R$D2BC
; if touching), searches the wave enemy list for a collision partner via
; #R$E262, and repositions the entity by applying a directional delta
; from the table at #R$E11A. Spawns the entity at its new position via
; #R$C950 and advances the entity record pointer via #R$E094.
@label=Handle_Horizontal_Enemy_Entity
c$E1B6 LD A,($C533)  ; {Skip to #R$E099 if the wave start delay at #N$C533 is still
 $E1B9 AND A         ; active.
 $E1BA JP NZ,$E099   ; }
 $E1BD PUSH HL       ; {Stash the entity record pointer and erase the sprite
 $E1BE CALL $C949    ; via #R$C949.
 $E1C1 POP HL        ; }
 $E1C2 INC HL        ; Advance past the entity handler field.
 $E1C3 EXX           ; {Set the player Y position address into alternate
 $E1C4 LD HL,$C4D4   ; #REGhl.
 $E1C7 EXX           ; }
 $E1C8 CALL $C6DA    ; Test whether this entity overlaps the player via
                     ; #R$C6DA.
 $E1CB JP NC,$D2BC   ; Trigger the death sequence via #R$D2BC if the entity touches the
                     ; player.
 $E1CE DEC HL        ; {Step back three bytes to the entity Y position field.
 $E1CF DEC HL        ;
 $E1D0 DEC HL        ; }
 $E1D1 CALL $E262    ; Search the wave entity list for another entity at this position
                     ; via #R$E262.
 $E1D4 CALL NC,$E22A ; Begin the death animation via #R$E22A if a collision was
                     ; found.
; Decide whether to pick a new entity type or keep the existing one:
; if a random value is #N$F0 or higher, randomise a new type in the
; range #N$34-#N$37; otherwise reuse the current entity type.
 $E1D7 EXX           ; {Switch to alternate registers and generate a random value; compare
 $E1D8 CALL $D1BF    ; against #N$F0.
 $E1DB CP $F0        ; }
 $E1DD JP C,$E1ED    ; Keep the existing entity type if the random value is
                     ; below #N$F0.
@label=Handle_Horizontal_Enemy_Entity_Retry
*$E1E0 DEC HL        ; {Step back to the entity type byte and generate a new random byte
 $E1E1 CALL $D1BF    ; via #R$D1BF.}
 $E1E4 AND %00000011 ; Mask to the low 2 bits for the entity type offset.
 $E1E6 ADD A,$34     ; {Add #N$34 to form the entity type, write it, and
 $E1E8 LD (HL),A     ; advance.
 $E1E9 INC HL        ; }
 $E1EA JP $E1F0      ; Jump to #R$E1F0.
*$E1ED DEC HL        ; {Load the existing entity type and advance past it.
 $E1EE LD A,(HL)     ;
 $E1EF INC HL        ; }
; Apply the directional delta from the table to the entity Y and X
; position. Retry if the new position falls outside the play area.
@label=Handle_Horizontal_Enemy_Entity_Apply_Delta
*$E1F0 EX DE,HL      ; Exchange #REGde and #REGhl to preserve the entity record
                     ; pointer.
 $E1F1 AND %00000011 ; Mask the entity type to the low 2 bits for the direction
                     ; index.
 $E1F3 LD C,A        ; {Double the direction index and load the delta table base at
 $E1F4 SLA C         ; #R$E11A.
 $E1F6 LD B,$00      ;
 $E1F8 LD HL,$E11A   ;
 $E1FB ADD HL,BC     ; }
 $E1FC EX DE,HL      ; Exchange #REGde and #REGhl to restore the entity record
                     ; pointer.
 $E1FD LD A,(DE)     ; {Apply the Y delta to the current Y coordinate; retry via
 $E1FE ADD A,(HL)    ; #R$E1E0 if the result is outside #N$10-#N$AA.
 $E1FF CP $AA        ;
 $E201 JP NC,$E1E0   ; }
 $E204 CP $10        ; {Apply the X delta to the current X coordinate; retry via
 $E206 JP C,$E1E0    ; #R$E1E0 if the result is outside #N$08-#N$EB.
 $E209 LD C,A        ;
 $E20A INC HL        ; }
 $E20B INC DE        ; {Step the delta pointer forward; apply the second delta to X;
 $E20C LD A,(DE)     ; validate X bounds.
 $E20D ADD A,(HL)    ;
 $E20E CP $EB        ;
 $E210 DEC HL        ; }
 $E211 JP NC,$E1E0   ; {Write the validated Y and X coordinates back to the
 $E214 CP $08        ; entity record.
 $E216 JP C,$E1E0    ;
 $E219 INC HL        ;
 $E21A LD (HL),A     ;
 $E21B DEC HL        ;
 $E21C LD (HL),C     ; }
 $E21D DEC HL        ; {Stash the record pointer, set colour #N$44, spawn the entity via
 $E21E PUSH HL       ; #R$C950, and restore the pointer.
 $E21F EXX           ;
 $E220 LD B,$44      ;
 $E222 EXX           ;
 $E223 CALL $C950    ; }
 $E226 POP HL        ; Restore the entity record pointer.
 $E227 JP $E094      ; Advance to the next entity record via #R$E094.

; Begin Enemy Death Animation
;
; Used by the routine at #R$E1B6.
; .
; Called when a colliding wave enemy is struck: freezes movement, removes
; the sprite, flashes it white, marks it as dying, and starts the #N$32-frame
; death timer. Decrements the live count for this enemy's class. Called from
; #R$E1B6 and #R$E881.
;
; HL Entity record pointer (positioned at the entity type byte)
;
; Freeze the enemy and remove it from the screen.
@label=Begin_Enemy_Death_Animation
c$E22A DEC HL        ; {Step back four bytes to the entity handler field.
 $E22B DEC HL        ;
 $E22C DEC HL        ;
 $E22D DEC HL        ; }
 $E22E PUSH HL       ; {Freeze the enemy: save the entity pointer and call #R$D9C4 with
 $E22F LD E,$03      ; movement state #N$03.
 $E231 CALL $D9C4    ; }
 $E234 POP HL        ; {Restore the entity pointer into #REGhl and keep a copy
 $E235 PUSH HL       ; on the stack.}
 $E236 CALL $C949    ; Erase the enemy sprite from the screen via #R$C949.
 $E239 POP HL        ; Restore the entity pointer from the stack.
; Mark the enemy as dying and flash it white to signal the kill.
@label=Begin_Enemy_Death_Animation_Flash
 $E23A LD C,(HL)     ; {Save the entity type in #REGc, stash both on the stack, and mark
 $E23B PUSH BC       ; the enemy as dying (#N$0F).
 $E23C LD (HL),$0F   ;
 $E23E PUSH HL       ; }
 $E23F EXX           ; {Set the draw colour to #COLOUR$47 in #REGb'.
 $E240 LD B,$47      ;
 $E242 EXX           ; }
 $E243 CALL $D637    ; Flash the enemy white on screen via #R$D637.
; Restore context, reduce the live count, and start the death timer.
 $E246 POP HL        ; {Restore the entity pointer and entity type from the
 $E247 POP BC        ; stack.}
 $E248 SRL C         ; {Shift the entity type right four bits to get the enemy
 $E24A SRL C         ; class index.
 $E24C SRL C         ;
 $E24E SRL C         ; }
 $E250 EX DE,HL      ; {Reduce the live enemy count for this class in the table
 $E251 LD B,$00      ; at #R$C427.
 $E253 LD HL,$C427   ;
 $E256 ADD HL,BC     ;
 $E257 DEC (HL)      ;
 $E258 EX DE,HL      ; }
 $E259 DEC HL        ; {Step back to the animation timer byte and set it to
 $E25A LD (HL),$32   ; #N$32 frames.}
 $E25C EXX           ; {Step the alternate entity list pointer back three
 $E25D DEC HL        ; bytes.
 $E25E DEC HL        ;
 $E25F DEC HL        ;
 $E260 EXX           ; }
 $E261 RET           ; Return.

; Find Colliding Wave Enemy
;
; Used by the routines at #R$E1B6 and #R$E881.
; .
; Walks the wave entity list between the snapshot pointer at #N$C50B and
; the write pointer at #N$C50D. For each entity with a type nibble below
; #N$04, tests bounds overlap via #R$C6DA; returns without carry set if
; an overlapping entity is found with its position left in alternate
; #REGhl. Returns with carry set if the list is exhausted without a
; match. Entities with a type nibble of #N$04 or higher are skipped as
; non-collidable. Called from #R$E1B6 and #R$E881.
@label=Find_Colliding_Wave_Enemy
c$E262 EXX           ; {Switch to alternate registers and load the entity list snapshot
 $E263 LD HL,($C50B) ; pointer from #N$C50B.}
@label=Find_Colliding_Wave_Enemy_Next
*$E266 EX DE,HL      ; {Compare the snapshot against the write pointer; return with carry
 $E267 LD HL,($C50D) ; set (no match) if the list is exhausted.
 $E26A AND A         ;
 $E26B SBC HL,DE     ;
 $E26D SCF           ;
 $E26E EX DE,HL      ; }
 $E26F RET Z         ; {Advance three bytes past the handler word, read the entity type
 $E270 INC HL        ; nibble, and mask to the low 4 bits.
 $E271 INC HL        ;
 $E272 INC HL        ;
 $E273 LD A,(HL)     ; }
 $E274 AND %00001111 ; Mask the type to the low nibble.
 $E276 CP $04        ; {Jump to #R$E28A to skip this entity if the type is #N$04 or
 $E278 INC HL        ; higher (non-collidable).}
 $E279 JP NC,$E28A   ; {Test whether this entity's bounds overlap the current position
 $E27C CALL $C6DA    ; via #R$C6DA; advance and loop if they do not.}
 $E27F RET NC        ; {No overlap: step the alternate #REGhl back three bytes
 $E280 EXX           ; and loop.
 $E281 DEC HL        ;
 $E282 DEC HL        ;
 $E283 DEC HL        ;
 $E284 EXX           ; }
*$E285 INC HL        ; {Advance two bytes to the next entity record and loop.
 $E286 INC HL        ;
 $E287 JP $E266      ; }
*$E28A INC HL        ; {Wide entity: advance three more bytes and loop.
 $E28B INC HL        ;
 $E28C INC HL        ;
 $E28D JP $E285      ; }

; Spawn Horizontal Wave Enemies
;
; Used by the routine at #R$D24C.
; .
; Entry point called from #R$D24C. Reads the horizontal enemy spawn
; count from *#REGhl and stores it at #N$C42B; if zero, returns
; immediately. Otherwise loops #REGb times, writing a full entity record
; into the entity list: the #R$CF52 handler address, a random entity
; type in the range #N$34-#N$37, a valid random screen position via
; #R$E2C8, and trailing bytes #N$0E, #N$0D, #N$FF. Saves the updated
; entity list pointer to *#R$C509 and writes the #N$D1A4 list terminator.
@label=Spawn_Horizontal_Wave_Enemies
c$E290 LD A,(HL)     ; {Load the horizontal enemy count from *#REGhl and store it at
 $E291 LD ($C42B),A  ; #N$C42B.}
 $E294 INC HL        ; {Return if the spawn count is zero.
 $E295 AND A         ;
 $E296 RET Z         ; }
 $E297 LD B,A        ; {Set the spawn loop counter in #REGb and stash the
 $E298 PUSH HL       ; source pointer.}
 $E299 LD HL,($C509) ; Load the entity list write pointer from *#R$C509.
@label=Spawn_Horizontal_Wave_Enemies_Record
*$E29C LD DE,$CF52   ; {Write the #R$CF52 entity handler as a little-endian
 $E29F LD (HL),E     ; word.
 $E2A0 INC HL        ;
 $E2A1 LD (HL),D     ; }
 $E2A2 INC HL        ; Advance past the handler word.
 $E2A3 CALL $D1BF    ; Generate a random byte via #R$D1BF.
 $E2A6 AND %00000011 ; Mask to the low 2 bits for the entity type offset.
 $E2A8 ADD A,$34     ; {Add #N$34, write the entity type, and advance.
 $E2AA LD (HL),A     ;
 $E2AB INC HL        ; }
 $E2AC PUSH BC       ; {Stash #REGbc and call #R$E2C8 to place the entity at a valid
 $E2AD CALL $E2C8    ; random screen position.
 $E2B0 POP BC        ; }
 $E2B1 DEC HL        ; {Restore #REGbc and step back one byte.
 $E2B2 LD (HL),$0E   ; }
 $E2B4 INC HL        ; {Write trailing record bytes #N$0E, #N$0D, and #N$FF.
 $E2B5 LD (HL),$0D   ;
 $E2B7 INC HL        ;
 $E2B8 LD (HL),$FF   ; }
 $E2BA INC HL        ; {Advance #REGhl and loop back to #R$E29C for the next
 $E2BB DJNZ $E29C    ; entity.}
 $E2BD LD ($C509),HL ; {Save the updated entity list pointer to *#R$C509.
 $E2C0 LD DE,$D1A4   ;
 $E2C3 LD (HL),E     ;
 $E2C4 INC HL        ; }
 $E2C5 LD (HL),D     ; {Write the list terminator #N$D1A4 to *#REGhl.
 $E2C6 POP HL        ; }
 $E2C7 RET           ; Return.

; Pick Random Spawn Position
;
; Used by the routines at #R$E290, #R$E7CF and #R$E92C.
; .
; Generates a random Y coordinate in the range #N$10-#N$A7 and a random
; X coordinate in the range #N$08-#N$E7, writing both to *#REGhl with
; initial velocities #N$10/#N$10, then tests whether the chosen position
; overlaps the player spawn zone via #R$C6DA; retries the whole selection
; if it does. Called from #R$E290 and #R$E92C.
@label=Pick_Random_Spawn_Position
@label=Pick_Random_Spawn_Position_Y
c$E2C8 CALL $D1BF    ; {Generate random bytes until a valid Y coordinate (#N$10-#N$A7) is
 $E2CB CP $10        ; found and write it to *#REGhl.
 $E2CD JP C,$E2C8    ; }
 $E2D0 CP $A8        ;
 $E2D2 JP NC,$E2C8   ;
 $E2D5 LD (HL),A     ;
 $E2D6 INC HL        ;
@label=Pick_Random_Spawn_Position_X
*$E2D7 CALL $D1BF    ; {Generate random bytes until a valid X coordinate (#N$08-#N$E7) is
 $E2DA CP $08        ; found and write it to *#REGhl.
 $E2DC JP C,$E2D7    ; }
 $E2DF CP $E8        ;
 $E2E1 JP NC,$E2D7   ;
 $E2E4 LD (HL),A     ;
 $E2E5 INC HL        ; {Write initial Y and X velocities (#N$10 each) to the
 $E2E6 LD (HL),$10   ; entity record.
 $E2E8 INC HL        ;
 $E2E9 LD (HL),$10   ; }
 $E2EB DEC HL        ; {Step back three bytes and set the player spawn area address in
 $E2EC DEC HL        ; alternate #REGhl via #R$D1C7.
 $E2ED DEC HL        ;
 $E2EE EXX           ;
 $E2EF LD HL,$D1C7   ;
 $E2F2 EXX           ; }
 $E2F3 CALL $C6DA    ; {Test whether the position overlaps the player spawn zone via
 $E2F6 RET C         ; #R$C6DA; return if clear.}
 $E2F7 DEC HL        ; {Retry the whole position selection from #R$E2C8 if it
 $E2F8 DEC HL        ; overlaps.
 $E2F9 DEC HL        ; }
 $E2FA JP $E2C8      ;

; Clamp Entity Velocity
;
; Used by the routines at #R$E360 and #R$E7CF.
; .
; Adds a 16-bit signed delta (#REGde) to a velocity byte in #REGh,
; sign-extending #REGh to a full 16-bit value first, then clamps the
; result to the range #N$FC00-#N$03FF. Returns the clamped result in
; #REGhl. Called from #R$E360 and #R$E6F7 when updating tracked enemy
; velocities.
@label=Clamp_Entity_Velocity
c$E2FD LD A,H        ; {Sign-extend #REGh into a 16-bit value and add the delta in
 $E2FE AND $80       ; #REGde.
 $E300 LD H,$00      ;
 $E302 JP Z,$E307    ; }
 $E305 LD H,$FF      ; {Positive result: check bit 7 and jump if the result is
*$E307 ADD HL,DE     ; negative.
 $E308 LD A,H        ; }
 $E309 BIT 7,H       ; {Positive ceiling: return if within range; clamp to #N$03FF
 $E30B JP NZ,$E315   ; otherwise.
 $E30E CP $04        ; }
 $E310 RET C         ;
 $E311 LD HL,$03FF   ;
 $E314 RET           ;
@label=Clamp_Entity_Velocity_Negative
*$E315 CP $FC        ; {Negative result: return if within range; clamp to #N$FC00
 $E317 RET NC        ; otherwise.
 $E318 LD HL,$FC00   ;
 $E31B RET           ; }

; Build Entity Spawn Record
;
; Used by the routine at #R$E360.
; .
; Reads the direction byte from (#REGix+#N$02), indexes the direction
; animation offset table at #R$E7AF by direction × 4, and writes five
; bytes to the entity spawn buffer at #N$C511: the animation type byte
; (#N$28 + direction), the direction-adjusted Y coordinate, the
; direction-adjusted X coordinate, and two further table bytes via
; two LDI instructions. Called from #R$E360.
@label=Build_Entity_Spawn_Record
c$E31C LD HL,$E7AF   ; {Index the direction animation table at #R$E7AF and write the
 $E31F LD D,$00      ; animation type byte (#N$28 + direction) to the spawn buffer at #N$C511.
 $E321 LD A,(IX+$02) ;
 $E324 AND $07       ;
 $E326 LD E,A        ;
 $E327 SLA E         ;
 $E329 SLA E         ; }
 $E32B ADD HL,DE     ; {Write the direction-adjusted Y and X coordinates to the spawn
 $E32C LD DE,$C511   ; buffer.
 $E32F ADD A,$28     ;
 $E331 LD (DE),A     ;
 $E332 INC DE        ;
 $E333 LD A,(IX+$03) ;
 $E336 ADD A,(HL)    ;
 $E337 LD (DE),A     ;
 $E338 INC HL        ; }
 $E339 INC DE        ; {Copy two further direction table bytes to the spawn buffer via
 $E33A LD A,(IX+$05) ; LDI×2.
 $E33D ADD A,(HL)    ;
 $E33E LD (DE),A     ;
 $E33F INC HL        ; }
 $E340 INC DE        ;
 $E341 LDI           ;
 $E343 LDI           ;
 $E345 RET           ; Return.

; Apply Direction Delta
;
; Used by the routine at #R$E7CF.
; .
; Reads the direction byte from (#REGde), and uses it as an index into
; the direction animation table at #R$E7AF (direction × 4). Adds the Y
; delta at table[index] to the byte at (#REGde+1) and the X delta at
; table[index+1] to the byte at (#REGde+2), writing the updated
; coordinates back in place. Called from #R$E7EB when building entity
; records.
@label=Apply_Direction_Delta
c$E346 EX DE,HL      ; {Exchange #REGde and #REGhl and load the direction table base at
 $E347 LD HL,$E7AF   ; #R$E7AF.
 $E34A LD A,(DE)     ; }
 $E34B AND %00000111 ; Mask the direction byte to 3 bits.
 $E34D RLA           ; {Double the index (two left shifts) and form the zero-extended
 $E34E RLA           ; byte offset in #REGbc.
 $E34F LD C,A        ;
 $E350 LD B,$00      ;
 $E352 ADD HL,BC     ; }
 $E353 INC DE        ; {Apply the Y delta to (#REGde+1) and the X delta to (#REGde+2)
 $E354 LD A,(DE)     ; and write both coordinates back in place.
 $E355 ADD A,(HL)    ;
 $E356 LD (DE),A     ;
 $E357 INC HL        ;
 $E358 INC DE        ;
 $E359 LD A,(DE)     ;
 $E35A ADD A,(HL)    ;
 $E35B LD (DE),A     ;
 $E35C DEC DE        ;
 $E35D DEC DE        ; }
 $E35E EX DE,HL      ; {Exchange #REGde and #REGhl to restore the entity pointer and
 $E35F RET           ; return.}

; Process Tracked Enemy Entity
;
; Per-frame entity handler for IX-indexed tracked wave enemies. If the
; wave start delay is still counting, advances the entity pointer via
; #R$E41C. Otherwise stores the entity record pointer at #R$C50F,
; rebuilds the spawn buffer via #R$E31C, and searches for a collision-
; free slot via #R$CD18. Tests player contact via #R$C6DA and triggers
; death via #R$D2BC if touching. Decrements the animation phase, erases
; the sprite via #R$C949, advances the animation frame within the phase
; mask, then re-enters movement at #R$E3AB. Updates the entity velocity
; with angular rate via #R$D1A8 and #R$E2FD, clamps position to the
; play area, rebuilds the spawn buffer, and draws via #R$C950. When the
; animation phase reaches zero, either removes the entity or promotes
; it to the next phase and spawns a cluster entity with handler #R$E520.
@label=Process_Tracked_Enemy_Entity
c$E360 LD A,($C533)    ; {Skip to #R$E41C if the wave start delay at #N$C533 is still
 $E363 AND A           ; active.
 $E364 JP NZ,$E41C     ; }
 $E367 LD ($C50F),HL   ; {Store the entity record pointer at #R$C50F and reload into
 $E36A LD IX,($C50F)   ; #REGix.}
 $E36E CALL $E31C      ; {Point #REGhl at the spawn buffer (#N$C512), switch to alternate
 $E371 LD HL,$C512     ; registers, and search for a free entity slot via #R$CD18; jump to
 $E374 EXX             ; #R$E4B9 if no free slot is available.
 $E375 CALL $CD18      ; }
 $E378 JP NC,$E4B9     ; {Test player contact via #R$C6DA; trigger death via #R$D2BC if
 $E37B LD HL,$C4D4     ; touching. Reload the entity pointer, decrement the animation phase, and
 $E37E CALL $C6DA      ; erase the entity sprite via #R$C949.
 $E381 JP NC,$D2BC     ;
 $E384 LD HL,$C511     ; }
 $E387 CALL $C949      ;
 $E38A LD HL,($C50F)   ;
 $E38D DEC (HL)        ;
; Read the animation phase and select the animation frame mask: #N$07
; if the phase is #N$37 or higher, #N$03 otherwise.
 $E38E LD A,(HL)       ; {Read the phase, select the frame mask, and advance
 $E38F LD C,A          ; #REGhl.
 $E390 BIT 0,A         ;
 $E392 JP NZ,$E3AB     ;
 $E395 CP $37          ;
 $E397 LD B,$03        ; }
 $E399 JP NC,$E39E     ;
 $E39C LD B,$07        ;
@label=Process_Tracked_Enemy_Entity_Frame
*$E39E INC HL          ; {Increment the animation frame within the mask, add the base
 $E39F INC HL          ; offset #N$28, and write back.
 $E3A0 LD A,(HL)       ;
 $E3A1 INC A           ;
 $E3A2 AND B           ;
 $E3A3 ADD A,$28       ; }
 $E3A5 LD (HL),A       ; {Jump to #R$E421 if the animation phase has reached
 $E3A6 LD A,C          ; zero.
 $E3A7 AND A           ; }
 $E3A8 JP Z,$E421      ;
; Update the entity velocity: apply the angular rate via #R$D1A8 to
; both Y and X velocity components, clamp each via #R$E2FD, then add
; the velocities to the Y and X position and clamp to the play area.
@label=Process_Tracked_Enemy_Entity_Move
*$E3AB LD D,(IX+$07)   ; {Load the Y velocity from the entity record and apply the angular
 $E3AE LD E,(IX+$08)   ; rate via #R$D1A8.}
 $E3B1 CALL $D1A8      ; {Clamp the Y velocity via #R$E2FD and store it back.
 $E3B4 CALL $E2FD      ; }
 $E3B7 LD (IX+$07),H   ; {Add the clamped Y velocity to the entity Y position; load and
 $E3BA LD (IX+$08),L   ; apply the angular rate to the X velocity.
 $E3BD LD D,(IX+$03)   ;
 $E3C0 LD E,(IX+$04)   ; }
 $E3C3 ADD HL,DE       ;
 $E3C4 LD A,H          ;
 $E3C5 CP $10          ;
 $E3C7 JP NC,$E3CF     ;
 $E3CA LD H,$10        ;
 $E3CC JP $E3D6        ;
@label=Process_Tracked_Enemy_Entity_Clamp_Y
*$E3CF CP $A9          ; {Clamp the Y position to the floor #N$10 or ceiling
 $E3D1 JP C,$E3D6      ; #N$A9.
 $E3D4 LD H,$A9        ; }
@label=Process_Tracked_Enemy_Entity_X
*$E3D6 LD (IX+$03),H   ; {Store the clamped Y position and load the X velocity
 $E3D9 LD (IX+$04),L   ; components.
 $E3DC LD D,(IX+$09)   ; }
 $E3DF LD E,(IX+$0A)   ; {Apply the angular rate to the X velocity and clamp
 $E3E2 CALL $D1A8      ; via #R$E2FD.
 $E3E5 CALL $E2FD      ; }
 $E3E8 LD (IX+$09),H   ; {Add the clamped X velocity to the entity X position.
 $E3EB LD (IX+$0A),L   ;
 $E3EE LD D,(IX+$05)   ;
 $E3F1 LD E,(IX+$06)   ; }
 $E3F4 ADD HL,DE       ;
 $E3F5 LD A,H          ;
 $E3F6 CP $08          ;
 $E3F8 JP NC,$E400     ;
 $E3FB LD H,$08        ;
 $E3FD JP $E407        ;
@label=Process_Tracked_Enemy_Entity_Clamp_X
*$E400 CP $E9          ; {Clamp the X position to the floor #N$08 or ceiling
 $E402 JP C,$E407      ; #N$E9.
 $E405 LD H,$E9        ; }
@label=Process_Tracked_Enemy_Entity_Draw
*$E407 LD (IX+$05),H   ; {Store the clamped X position and rebuild the spawn buffer via
 $E40A LD (IX+$06),L   ; #R$E31C.
 $E40D CALL $E31C      ; }
 $E410 LD B,$42        ; {Set colour #N$42 in #REGb', draw the entity via #R$C950,
 $E412 EXX             ; and restore #REGhl.
 $E413 LD HL,$C511     ;
 $E416 CALL $C950      ; }
; This entry point is used by the routine at #R$E4B9.
; .
; Reload the entity list pointer from #R$C50F and advance it by
; #N$0C bytes.
@label=Process_Tracked_Enemy_Entity_Reload
*$E419 LD HL,($C50F)   ; Reload #REGhl from #R$C50F.
@label=Process_Tracked_Enemy_Entity_Advance
*$E41C LD DE,$000C     ; {Advance the entity pointer by #N$0C bytes and return.
 $E41F ADD HL,DE       ;
 $E420 RET             ; }
; The animation phase has reached zero. If the entity still has
; remaining passes, promote it to the next phase and spawn a cluster
; entity; otherwise remove it from the active set.
@label=Process_Tracked_Enemy_Entity_Phase_End
*$E421 LD A,(IX+$01)   ; {If the entity has remaining animation passes, jump to #R$E43C;
 $E424 AND A           ; otherwise fall through to remove it.
 $E425 JP NZ,$E43C     ; }
 $E428 LD HL,$C42C     ; {Decrement the active entity count at #N$C42C and the total wave
 $E42B DEC (HL)        ; enemy count at #R$C41C; write handler #R$E41C and jump to #R$E419.
 $E42C LD HL,$C41C     ;
 $E42F DEC (HL)        ;
 $E430 LD DE,$E41C     ; }
 $E433 LD (IX-$01),D   ;
 $E436 LD (IX-$02),E   ;
 $E439 JP $E419        ;
; Entity still has passes remaining: increment the animation counters,
; spawn a cluster entity with handler #R$E520 into the entity list, and
; re-enter the movement update loop at #R$E3AB.
@label=Process_Tracked_Enemy_Entity_Promote
*$E43C LD (IX+$00),$14 ; {Set the animation byte to #N$14, decrement the remaining pass
 $E440 DEC (IX+$01)    ; count, and increment the active count at #N$C42C and #R$C41C.
 $E443 LD HL,$C42D     ;
 $E446 INC (HL)        ;
 $E447 LD HL,$C41C     ;
 $E44A INC (HL)        ; }
 $E44B LD HL,($C509)   ; {Load the entity list write pointer from *#R$C509 and write the
 $E44E LD DE,$E520     ; #R$E520 handler.
 $E451 LD (HL),E       ;
 $E452 INC HL          ; }
 $E453 LD (HL),D       ; {Write the entity type (#N$1C), Y and X coordinates from the
 $E454 INC HL          ; current entity into the new cluster record.
 $E455 LD (HL),$1C     ;
 $E457 INC HL          ;
 $E458 LD B,(IX+$03)   ;
 $E45B LD (HL),B       ;
 $E45C INC HL          ;
 $E45D LD C,(IX+$05)   ;
 $E460 LD (HL),C       ; }
 $E461 PUSH HL         ; {Stash #REGhl, set colour #N$45 in #REGb', draw the
 $E462 DEC HL          ; entity colour slot via #R$D637, and restore #REGhl.
 $E463 DEC HL          ;
 $E464 EXX             ;
 $E465 LD B,$45        ;
 $E467 EXX             ;
 $E468 CALL $D637      ; }
 $E46B POP HL          ; {Write the trailing record bytes, advance #REGhl, save the entity
 $E46C INC HL          ; list pointer, write the #N$D1A4 terminator, and jump to #R$E3AB.
 $E46D LD (HL),$05     ;
 $E46F INC HL          ;
 $E470 LD (HL),$09     ;
 $E472 INC HL          ;
 $E473 LD (HL),$00     ;
 $E475 INC HL          ;
 $E476 LD (HL),$19     ;
 $E478 INC HL          ;
 $E479 INC HL          ;
 $E47A INC HL          ;
 $E47B LD (HL),$05     ;
 $E47D INC HL          ;
 $E47E LD (HL),$05     ;
 $E480 INC HL          ;
 $E481 INC HL          ;
 $E482 INC HL          ;
 $E483 LD (HL),$FF     ;
 $E485 INC HL          ;
 $E486 LD DE,$D1A4     ;
 $E489 LD ($C509),HL   ;
 $E48C LD (HL),E       ;
 $E48D INC HL          ;
 $E48E LD (HL),D       ; }
 $E48F JP $E3AB        ;

; Tick Entity Colour Timer
;
; Entity handler that drives a per-entity colour timer. Each frame it
; decrements the timer byte; if still non-zero, extracts the animation
; frame index from the low 3 bits and calls #R$CFA4 to refresh the
; entity's attribute colours, then advances the entity pointer by
; #N$0B bytes via #R$E4A2. When the timer reaches zero, falls through
; to #R$E4A7 to erase and retire the entity. Written into entity records
; by #R$E4B9.
@label=Tick_Entity_Colour_Timer
c$E492 DEC (HL)      ; {Decrement the entity timer; if still live, extract the low 3 bits
 $E493 JP Z,$E4A7    ; as the animation frame index and refresh the entity's attribute colours
 $E496 LD A,(HL)     ; via #R$CFA4.
 $E497 INC HL        ;
 $E498 AND $07       ;
 $E49A EXX           ;
 $E49B LD B,A        ;
 $E49C EXX           ;
 $E49D PUSH HL       ;
 $E49E CALL $CFA4    ;
 $E4A1 POP HL        ; }
; This entry point is used by the routine at #R$E520.
@label=Tick_Entity_Colour_Timer_Advance
*$E4A2 LD DE,$000B   ; {Advance the entity pointer by #N$0B bytes and return.
 $E4A5 ADD HL,DE     ;
 $E4A6 RET           ; }

; Retire Expired Entity
;
; Used by the routine at #R$E492.
; .
; Erases the entity sprite via #R$D630, writes the #R$E41C advance
; handler to the entity record (retiring the entity from active update
; processing), and returns through #R$E4B4. Reached when a colour timer
; spawned by #R$E4B9 expires.
@label=Retire_Expired_Entity
c$E4A7 PUSH HL       ; {Stash #REGhl, advance one byte, and erase the sprite
 $E4A8 INC HL        ; via #R$D630.
 $E4A9 CALL $D630    ; }
 $E4AC POP HL        ; {Write the #R$E41C handler to the entity record and
 $E4AD DEC HL        ; advance.
 $E4AE LD DE,$E41C   ;
 $E4B1 LD (HL),D     ; }
 $E4B2 DEC HL        ;
 $E4B3 LD (HL),E     ;
; This entry point is used by the routines at #R$E520 and #R$E6B4.
@label=Retire_Expired_Entity_Advance
*$E4B4 LD DE,$000E   ; {Advance the entity pointer by #N$0E bytes and return.
 $E4B7 ADD HL,DE     ;
 $E4B8 RET           ; }

; Kill Tracked Enemy Entity
;
; Used by the routine at #R$E360.
; .
; Kill path reached when no collision-free slot is available for a
; tracked enemy. Steps back six bytes to the entity position fields,
; erases the sprite via #R$C84F, removes the entity record from the
; list via #R$D5B4, and erases the spawn buffer via #R$C949. Decrements
; the active entity count at #N$C42C and the total wave enemy count at
; #R$C41C. Initialises a dying-state colour timer via #R$D9C4, writes
; a replacement #R$E492 entity record at the same position, and scores
; #N$10 BCD points. Refreshes the colour bar via #R$CD34.
@label=Kill_Tracked_Enemy_Entity
c$E4B9 LD DE,$0006   ; {Step back six bytes to the entity position, erase the sprite
 $E4BC AND A         ; via #R$C84F, and restore #REGhl.
 $E4BD SBC HL,DE     ;
 $E4BF PUSH HL       ;
 $E4C0 CALL $C84F    ; }
 $E4C3 POP HL        ; {Remove the entity from the list via #R$D5B4 and erase the spawn
 $E4C4 CALL $D5B4    ; buffer via #R$C949.}
 $E4C7 EXX           ; {Decrement the active count at #N$C42C and the wave enemy count
 $E4C8 LD HL,$C511   ; at #R$C41C.
 $E4CB CALL $C949    ; }
 $E4CE LD HL,$C42C   ; {Initialise a dying entity state via #R$D9C4 with code
 $E4D1 DEC (HL)      ; #N$02.
 $E4D2 LD HL,$C41C   ; }
 $E4D5 DEC (HL)      ; {Write handler #R$E492 at #R$C50F and set the entity timer to
 $E4D6 LD E,$02      ; #N$32 frames.
 $E4D8 CALL $D9C4    ;
 $E4DB LD DE,$E492   ;
 $E4DE LD HL,($C50F) ; }
 $E4E1 DEC HL        ; {Copy the entity Y and X position data and set the colour timer
 $E4E2 LD (HL),D     ; initial value.
 $E4E3 DEC HL        ;
 $E4E4 LD (HL),E     ;
 $E4E5 INC HL        ;
 $E4E6 INC HL        ;
 $E4E7 LD (HL),$32   ;
 $E4E9 INC HL        ; }
 $E4EA LD (HL),$14   ; {Point #REGhl back to the Y position, set colour #COLOUR$47 in
 $E4EC INC HL        ; #REGb', and draw via #R$D637.
 $E4ED LD D,H        ;
 $E4EE LD E,L        ;
 $E4EF INC DE        ;
 $E4F0 LD A,(DE)     ;
 $E4F1 LD (HL),A     ;
 $E4F2 INC HL        ;
 $E4F3 INC DE        ;
 $E4F4 INC DE        ;
 $E4F5 LD A,(DE)     ;
 $E4F6 LD (HL),A     ;
 $E4F7 DEC HL        ;
 $E4F8 DEC HL        ;
 $E4F9 EXX           ;
 $E4FA LD B,$47      ;
 $E4FC EXX           ;
 $E4FD CALL $D637    ; }
; Update the player's BCD score by #N$10 points and propagate any
; carry through the higher-order score digits.
 $E500 LD HL,$C405   ; {Add #N$10 BCD to the units score at #N$C405 and propagate carry
 $E503 LD A,(HL)     ; through two further score digits.
 $E504 ADD A,$10     ;
 $E506 DAA           ;
 $E507 LD (HL),A     ;
 $E508 JP NC,$E51A   ;
 $E50B DEC HL        ;
 $E50C LD A,(HL)     ; }
 $E50D ADD A,$01     ;
 $E50F DAA           ;
 $E510 LD (HL),A     ;
 $E511 JP NC,$E51A   ;
 $E514 DEC HL        ;
 $E515 LD A,(HL)     ;
 $E516 ADD A,$01     ;
 $E518 DAA           ;
 $E519 LD (HL),A     ;
@label=Kill_Tracked_Enemy_Score_Bar
*$E51A CALL $CD34    ; {Refresh the colour bar via #R$CD34 and advance via
 $E51D JP $E419      ; #R$E419.}

; Process Cluster Entity
;
; Per-frame entity handler for the cluster entities spawned when a
; tracked wave enemy promotes. Advances three bytes to a countdown timer,
; decrements it, and redraws the entity via #R$CFA4 while the timer is
; still running. When the timer reaches zero, calls #R$D630 to erase
; the entity sprite. If the animation pass counter (two bytes back) is
; also exhausted, detaches the entity and scores; otherwise increments
; the pass counter, redraws via #R$D637, sets the animation delay to
; #N$04, and jumps to #R$E4A2. On further passes the handler transitions
; to #R$E56D, which searches for player contact via #R$CD18 and triggers
; a kill via #R$E6F7 if found, or else applies directional movement
; toward the player and draws via #R$C856.
@label=Process_Cluster_Entity
c$E520 INC HL        ; {Advance three bytes to the countdown timer, decrement it, and
 $E521 INC HL        ; check for expiry.
 $E522 INC HL        ;
 $E523 DEC (HL)      ;
 $E524 DEC HL        ;
 $E525 DEC HL        ;
 $E526 DEC HL        ; }
 $E527 JP Z,$E536    ; {Timer still running: redraw the entity via #R$CFA4 and
 $E52A EXX           ; advance.
 $E52B LD B,$45      ;
 $E52D EXX           ; }
 $E52E PUSH HL       ;
 $E52F CALL $CFA4    ;
 $E532 POP HL        ;
 $E533 JP $E4B4      ;
@label=Process_Cluster_Entity_Expired
*$E536 PUSH HL       ; {Timer expired: erase the entity sprite via #R$D630.
 $E537 CALL $D630    ;
 $E53A POP HL        ;
 $E53B INC (HL)      ; }
 $E53C LD A,(HL)     ; {Check the pass counter; jump to #R$E553 if the maximum pass
 $E53D CP $1F        ; count (#N$1F) is reached.
 $E53F JP Z,$E553    ; }
 $E542 PUSH HL       ; {Increment the pass counter, redraw the entity via #R$D637, and
 $E543 EXX           ; write animation delay #N$04.
 $E544 LD B,$45      ;
 $E546 EXX           ;
 $E547 CALL $D637    ;
 $E54A POP HL        ;
 $E54B INC HL        ; }
 $E54C INC HL        ; {Jump to #R$E4A2 to advance the entity pointer.
 $E54D INC HL        ;
 $E54E LD (HL),$04   ; }
 $E550 JP $E4A2      ;
@label=Process_Cluster_Entity_Transition
*$E553 DEC HL        ; {Write handler #R$E56D and redraw the entity via #R$D637; set
 $E554 DEC HL        ; the animation byte to #N$0B.
 $E555 LD DE,$E56D   ;
 $E558 LD (HL),E     ;
 $E559 INC HL        ;
 $E55A LD (HL),D     ;
 $E55B INC HL        ;
 $E55C PUSH HL       ;
 $E55D EXX           ;
 $E55E LD B,$45      ;
 $E560 EXX           ;
 $E561 CALL $D637    ;
 $E564 POP HL        ; }
 $E565 INC HL        ;
 $E566 INC HL        ;
 $E567 INC HL        ;
 $E568 LD (HL),$0B   ;
 $E56A DEC HL        ;
 $E56B DEC HL        ;
 $E56C DEC HL        ;
@label=Process_Cluster_Entity_Homing
 $E56D INC HL        ; {Increment the animation counter and check for overflow; jump to
 $E56E LD A,(HL)     ; #R$E5B8 if the counter wraps.
 $E56F INC A         ;
 $E570 JP Z,$E5B8    ; }
 $E573 PUSH HL       ; {Stash #REGhl, step back one byte, and erase the entity sprite
 $E574 DEC HL        ; via #R$D630.
 $E575 CALL $D630    ;
 $E578 POP HL        ; }
 $E579 EXX           ; {Search for a player-contact slot via #R$CD18, then jump to #R$E6F7
 $E57A CALL $CD18    ; if player contact is detected.
 $E57D JP C,$E6F7    ; }
; Entity not touching the player: erase the sprite again, score
; #N$02 BCD, and update the colour bar.
 $E580 LD DE,$0006   ; {Step back six bytes, erase the sprite via #R$C84F, and restore
 $E583 AND A         ; #REGhl.
 $E584 SBC HL,DE     ;
 $E586 PUSH HL       ;
 $E587 CALL $C84F    ;
 $E58A POP HL        ; }
 $E58B CALL $D5B4    ; Remove the entity from the list via #R$D5B4.
 $E58E LD DE,$C405   ; {Add #N$02 BCD to the low score digit at #N$C405 and propagate
 $E591 LD A,(DE)     ; carry through two further score digits.
 $E592 ADD A,$02     ;
 $E594 DAA           ;
 $E595 LD (DE),A     ;
 $E596 JP NC,$E5A8   ;
 $E599 DEC DE        ;
 $E59A LD A,(DE)     ;
 $E59B ADD A,$01     ;
 $E59D DAA           ;
 $E59E LD (DE),A     ;
 $E59F JP NC,$E5A8   ; }
 $E5A2 DEC DE        ;
 $E5A3 LD A,(DE)     ;
 $E5A4 ADD A,$01     ;
 $E5A6 DAA           ;
 $E5A7 LD (DE),A     ;
@label=Process_Cluster_Entity_Score_Bar
*$E5A8 EXX           ; {Update the colour bar via #R$CD34, decrement the active count at
 $E5A9 PUSH HL       ; #N$C42D and #R$C41C, restore #REGhl, and mark the entity slot as
 $E5AA CALL $CD34    ; finished.
 $E5AD LD HL,$C42D   ;
 $E5B0 DEC (HL)      ;
 $E5B1 LD HL,$C41C   ;
 $E5B4 DEC (HL)      ;
 $E5B5 POP HL        ; }
 $E5B6 LD (HL),$FF   ;
@label=Process_Cluster_Entity_Advance
*$E5B8 INC HL        ; {Advance four bytes and check the secondary timer byte.
; This entry point is used by the routine at #R$E6F7.
@label=Process_Cluster_Entity_Next
*$E5B9 INC HL        ;
 $E5BA INC HL        ;
 $E5BB INC HL        ;
 $E5BC LD A,(HL)     ;
 $E5BD AND A         ; }
 $E5BE JP Z,$E61C    ; {Decrement the secondary timer; if it reaches zero, erase the
 $E5C1 DEC (HL)      ; entity sprite via #R$C84F; then jump to #R$E61C.
 $E5C2 JP NZ,$E5CE   ;
 $E5C5 PUSH HL       ;
 $E5C6 INC HL        ;
 $E5C7 CALL $C84F    ; }
 $E5CA POP HL        ;
 $E5CB JP $E61C      ;
@label=Process_Cluster_Entity_Move
*$E5CE INC HL        ; {Move to the entity position bytes, switch to alternate registers,
 $E5CF INC HL        ; and set the player Y address in alternate #REGhl; trigger death via
 $E5D0 EXX           ; #R$D2BC if touching.
 $E5D1 LD HL,$C4D4   ;
 $E5D4 EXX           ;
 $E5D5 CALL $C6DA    ;
 $E5D8 JP NC,$D2BC   ; }
 $E5DB DEC HL        ; {Step back four bytes and stash the entity pointer.
 $E5DC DEC HL        ;
 $E5DD DEC HL        ;
 $E5DE PUSH HL       ;
 $E5DF DEC HL        ; }
 $E5E0 CALL $C84F    ; {Step back, erase the sprite via #R$C84F, and search for a player
 $E5E3 POP HL        ; slot via #R$CD18; jump to #R$E6C4 if player contact.
 $E5E4 EXX           ;
 $E5E5 CALL $CD18    ;
 $E5E8 JP C,$E6C4    ;
 $E5EB LD DE,$0006   ; }
 $E5EE SBC HL,DE     ; {Step back six bytes, erase the entity via #R$C84F, score #N$25
 $E5F0 PUSH HL       ; BCD against the six-byte score at #N$C406, and propagate carry.
 $E5F1 CALL $C84F    ;
 $E5F4 POP HL        ;
 $E5F5 CALL $D5B4    ; }
 $E5F8 LD HL,$C406   ;
 $E5FB LD A,(HL)     ;
 $E5FC ADD A,$25     ;
 $E5FE DAA           ;
 $E5FF LD (HL),A     ;
 $E600 JP NC,$E610   ;
 $E603 LD B,$03      ;
@label=Process_Cluster_Entity_Score_Carry
*$E605 DEC HL        ; {Propagate BCD carry through #REGb higher-order score
 $E606 LD A,(HL)     ; digits.
 $E607 ADD A,$01     ;
 $E609 DAA           ;
 $E60A LD (HL),A     ;
 $E60B JP NC,$E610   ;
 $E60E DJNZ $E605    ; }
@label=Process_Cluster_Entity_Bar
*$E610 CALL $CD34    ; {Refresh the colour bar via #R$CD34, switch to alternate registers,
 $E613 EXX           ; and step back #REGde bytes to the entity record start.
 $E614 JP $E61A      ;
 $E617 DEC HL        ;
 $E618 DEC HL        ;
 $E619 DEC HL        ; }
@label=Process_Cluster_Entity_Seek_Y
*$E61A DEC HL        ; {Step back two more bytes to the entity handler field.
 $E61B DEC HL        ; }
@label=Process_Cluster_Entity_Seek
*$E61C LD D,H        ; {Load the Y and X position bytes and compute the signed Y offset
 $E61D LD E,L        ; from the player's Y coordinate at #N$C4D4.
 $E61E DEC DE        ;
 $E61F DEC DE        ;
 $E620 DEC DE        ;
 $E621 DEC DE        ;
 $E622 LD A,(DE)     ;
 $E623 INC A         ;
 $E624 JP Z,$E6B4    ;
 $E627 LD (HL),$37   ; }
 $E629 INC HL        ; {Compute the signed Y and X distances from the player, halve each
 $E62A INC HL        ; distance five times to form a velocity nudge, and negate if negative.
 $E62B PUSH HL       ;
 $E62C LD A,(DE)     ;
 $E62D LD C,A        ;
 $E62E LD B,$00      ;
 $E630 LD A,($C4D4)  ;
 $E633 LD L,A        ;
 $E634 LD H,$00      ;
 $E636 AND A         ;
 $E637 SBC HL,BC     ;
 $E639 BIT 0,H       ;
 $E63B LD A,L        ;
 $E63C JP Z,$E641    ;
 $E63F NEG           ; }
*$E641 SRL A         ;
 $E643 SRL A         ;
 $E645 SRL A         ;
 $E647 SRL A         ;
 $E649 BIT 0,H       ;
 $E64B JP Z,$E650    ;
 $E64E NEG           ;
@label=Process_Cluster_Entity_Seek_X
*$E650 EX AF,AF'     ; {Compute the X nudge from the player's X coordinate at #N$C4D5 in
 $E651 INC DE        ; the same way.
 $E652 LD A,(DE)     ;
 $E653 LD C,A        ;
 $E654 LD B,$00      ;
 $E656 LD A,($C4D5)  ;
 $E659 LD L,A        ;
 $E65A LD H,$00      ;
 $E65C AND A         ;
 $E65D SBC HL,BC     ;
 $E65F BIT 0,H       ;
 $E661 LD A,L        ;
 $E662 JP Z,$E667    ;
 $E665 NEG           ;
*$E667 SRL A         ;
 $E669 SRL A         ;
 $E66B SRL A         ;
 $E66D SRL A         ;
 $E66F BIT 0,H       ;
 $E671 JP Z,$E676    ;
 $E674 NEG           ;
*$E676 LD C,A        ;
 $E677 EX AF,AF'     ;
 $E678 LD B,A        ;
 $E679 POP HL        ; }
@label=Process_Cluster_Entity_Chase
*$E67A OR C          ; {If both nudge components are zero, replace them with a small
 $E67B JP NZ,$E691   ; random drift.
 $E67E CALL $D1BF    ; }
 $E681 AND $03       ;
 $E683 SUB $01       ;
 $E685 LD C,A        ;
 $E686 CALL $D1BF    ;
 $E689 AND $03       ;
 $E68B SUB $02       ;
 $E68D LD B,A        ;
 $E68E JP $E67A      ;
@label=Process_Cluster_Entity_Apply
*$E691 DEC DE        ; {Add the Y nudge offset #N$03 to the Y position; advance #REGde
 $E692 LD A,(DE)     ; and #REGhl.
 $E693 ADD A,$03     ;
 $E695 LD (HL),A     ; }
 $E696 INC DE        ; {Add the X nudge offset #N$02 to the X position and
 $E697 INC HL        ; advance.
 $E698 LD A,(DE)     ;
 $E699 ADD A,$02     ;
 $E69B LD (HL),A     ;
 $E69C INC HL        ;
 $E69D INC HL        ; }
 $E69E INC HL        ; {Write the computed Y and X nudge bytes to the record and stash
 $E69F LD (HL),B     ; #REGhl.
 $E6A0 INC HL        ;
 $E6A1 LD (HL),C     ;
 $E6A2 PUSH HL       ;
 $E6A3 LD DE,$0006   ; }
 $E6A6 AND A         ; {Step back six bytes, set colour #COLOUR$47 in #REGb', draw
 $E6A7 SBC HL,DE     ; via #R$C856, and advance two bytes before returning.
 $E6A9 EXX           ;
 $E6AA LD B,$47      ;
 $E6AC EXX           ;
 $E6AD CALL $C856    ;
 $E6B0 POP HL        ;
 $E6B1 INC HL        ;
 $E6B2 INC HL        ;
 $E6B3 RET           ; }

; Retire Cluster Entity
;
; Used by the routine at #R$E520.
; .
; Reached when the cluster entity's secondary animation timer has
; expired and the entity handler address has wrapped. Steps back seven
; bytes, writes the #R$E4B4 handler to the entity record, and advances
; via #R$E4B4. Transitions the entity out of the homing phase into the
; final retire countdown.
@label=Retire_Cluster_Entity
c$E6B4 LD DE,$0007   ; {Step back seven bytes and write the #R$E4B4 handler.
 $E6B7 AND A         ;
 $E6B8 SBC HL,DE     ; }
 $E6BA LD DE,$E4B4   ; {Advance the entity pointer and fall through to #R$E4B4.
 $E6BD LD (HL),E     ;
 $E6BE INC HL        ;
 $E6BF LD (HL),D     ;
 $E6C0 INC HL        ;
 $E6C1 JP $E4B4      ; }

; Apply Entity Velocity
;
; Used by the routine at #R$E520.
; .
; Applies a pre-computed velocity nudge (#REGbc) to the Y and X
; position bytes of the entity record, clamping each to the play area
; bounds, and redraws the entity via #R$C856. Called as the contact
; handler from #R$E520 when a cluster entity reaches the player.
@label=Apply_Entity_Velocity
c$E6C4 EXX           ; {Switch to alternate registers, save the entity position pointer,
 $E6C5 LD D,H        ; and load the Y and X position bytes.
 $E6C6 LD E,L        ;
 $E6C7 INC DE        ;
 $E6C8 INC DE        ;
 $E6C9 INC DE        ;
 $E6CA INC DE        ;
 $E6CB LD A,(DE)     ;
 $E6CC ADD A,(HL)    ; }
 $E6CD CP $10        ; {Test and apply the Y nudge; clamp Y to #N$10-#N$B3 and write
 $E6CF JP C,$E6D8    ; back.
 $E6D2 CP $B3        ;
 $E6D4 JP NC,$E6D8   ;
 $E6D7 LD (HL),A     ; }
@label=Apply_Entity_Velocity_X
*$E6D8 INC HL        ; {Test and apply the X nudge; clamp X to #N$08-#N$F3 and write
 $E6D9 INC DE        ; back.
 $E6DA LD A,(DE)     ;
 $E6DB ADD A,(HL)    ;
 $E6DC CP $08        ;
 $E6DE JP C,$E6E7    ;
 $E6E1 CP $F3        ;
 $E6E3 JP NC,$E6E7   ;
 $E6E6 LD (HL),A     ; }
@label=Apply_Entity_Velocity_Draw
*$E6E7 DEC HL        ; {Step back two bytes, set colour #COLOUR$47 in #REGb', and
 $E6E8 DEC HL        ; draw the entity via #R$C856.
 $E6E9 PUSH DE       ;
 $E6EA EXX           ;
 $E6EB LD B,$47      ;
 $E6ED EXX           ; }
 $E6EE CALL $C856    ; {Restore #REGde, copy to #REGhl, advance two bytes, and
 $E6F1 POP DE        ; return.
 $E6F2 LD H,D        ;
 $E6F3 LD L,E        ;
 $E6F4 INC HL        ;
 $E6F5 INC HL        ; }
 $E6F6 RET           ;

; Process Player Tracking Enemy
;
; Used by the routine at #R$E520.
; .
; Per-frame entity handler for the slow player-tracking enemy. Tests
; player contact via #R$C6DA; triggers death via #R$D2BC if touching.
; Computes the signed Y and X distance from the player at #N$C4D4 and
; #N$C4D5, halves it five times to derive a velocity nudge, and negates
; if the enemy is above or to the left of the player. Reads the entity
; facing byte; on a random 1-in-8192 chance sets it to #N$1A (freeze
; state). If the facing is #N$1A, flips both velocity components and
; tests for a 1-in-256 chance to clear the freeze. Applies the computed
; Y and X nudge to the entity position, clamping to the play area, and
; draws the entity via #R$D637.
@label=Process_Player_Tracking_Enemy
c$E6F7 LD HL,$C4D4   ; {Set the player Y address in alternate #REGhl and test player
 $E6FA EXX           ; contact via #R$C6DA; trigger death via #R$D2BC if touching.
 $E6FB CALL $C6DA    ; }
 $E6FE JP NC,$D2BC   ; {Step back three bytes to the entity Y position and load the
 $E701 DEC HL        ; player Y coordinate at #N$C4D4.
 $E702 DEC HL        ;
 $E703 DEC HL        ;
 $E704 LD C,(HL)     ;
 $E705 EX DE,HL      ; }
 $E706 LD A,($C4D4)  ;
 $E709 LD L,A        ; {Compute the signed Y nudge: subtract the entity Y from the
 $E70A LD H,$00      ; player Y, halve five times, and negate if the entity is above the
 $E70C LD B,$00      ; player.
 $E70E AND A         ;
 $E70F SBC HL,BC     ;
 $E711 BIT 0,H       ;
 $E713 LD A,L        ;
 $E714 JP Z,$E719    ;
 $E717 NEG           ; }
@label=Process_Player_Tracking_Enemy_Nudge_Y
*$E719 SRL A         ; {Scale the Y nudge and restore its sign.
 $E71B SRL A         ;
 $E71D SRL A         ;
 $E71F SRL A         ;
 $E721 SRL A         ;
 $E723 BIT 0,H       ;
 $E725 JP Z,$E72A    ;
 $E728 NEG           ; }
@label=Process_Player_Tracking_Enemy_Nudge_X
*$E72A EX AF,AF'     ; {Compute the signed X nudge from the player X coordinate at
 $E72B LD A,($C4D5)  ; #N$C4D5 in the same way.
 $E72E LD L,A        ;
 $E72F LD H,$00      ;
 $E731 INC DE        ;
 $E732 LD A,(DE)     ;
 $E733 LD C,A        ;
 $E734 LD B,$00      ;
 $E736 AND A         ;
 $E737 SBC HL,BC     ;
 $E739 BIT 0,H       ;
 $E73B LD A,L        ;
 $E73C JP Z,$E741    ;
 $E73F NEG           ;
*$E741 SRL A         ;
 $E743 SRL A         ;
 $E745 SRL A         ;
 $E747 SRL A         ;
 $E749 SRL A         ;
 $E74B BIT 0,H       ;
 $E74D JP Z,$E752    ;
 $E750 NEG           ; }
@label=Process_Player_Tracking_Enemy_Face
*$E752 LD B,A        ; {Store the scaled Y nudge in #REGb and X nudge in #REGc; step
 $E753 EX AF,AF'     ; back to the entity facing byte.
 $E754 LD C,A        ;
 $E755 EX DE,HL      ;
 $E756 DEC HL        ;
 $E757 DEC HL        ;
 $E758 LD A,(HL)     ;
 $E759 CP $1A        ; }
 $E75B JP Z,$E773    ; {Read the facing byte; if #N$1A, jump to #R$E773; otherwise
 $E75E CALL $D1BF    ; test a 1-in-8192 random chance (#R$D1BF twice, masked to #N$1F and
 $E761 AND $1F       ; #N$3F) to set the facing to #N$1A (freeze).
 $E763 JP NZ,$E785   ;
 $E766 CALL $D1BF    ;
 $E769 AND $3F       ;
 $E76B JP NZ,$E785   ;
 $E76E LD (HL),$1A   ;
 $E770 JP $E785      ; }
@label=Process_Player_Tracking_Enemy_Freeze
*$E773 LD A,B        ; {Facing is #N$1A (frozen): negate both velocity components;
 $E774 NEG           ; test a 1-in-256 chance to promote the facing to #N$1F (thaw).
 $E776 LD B,A        ;
 $E777 LD A,C        ;
 $E778 NEG           ;
 $E77A LD C,A        ;
 $E77B CALL $D1BF    ;
 $E77E CP $F0        ;
 $E780 JP NZ,$E785   ;
 $E783 LD (HL),$1F   ; }
@label=Process_Player_Tracking_Enemy_Move
*$E785 INC HL        ; {Apply the Y nudge to the entity Y position; clamp to #N$10-#N$AD
 $E786 LD A,C        ; and write back.
 $E787 ADD A,(HL)    ;
 $E788 CP $10        ;
 $E78A JP C,$E793    ;
 $E78D CP $AD        ;
 $E78F JP NC,$E793   ;
 $E792 LD (HL),A     ; }
@label=Process_Player_Tracking_Enemy_Move_X
*$E793 INC HL        ; {Apply the X nudge to the entity X position; clamp to #N$08-#N$EF
 $E794 LD A,B        ; and write back.
 $E795 ADD A,(HL)    ;
 $E796 CP $08        ;
 $E798 JP C,$E7A1    ;
 $E79B CP $EF        ;
 $E79D JP NC,$E7A1   ;
 $E7A0 LD (HL),A     ; }
@label=Process_Player_Tracking_Enemy_Draw
*$E7A1 PUSH HL       ; {Stash #REGhl, step back two bytes, set colour #N$45 in alternate
 $E7A2 DEC HL        ; #REGb, draw the entity via #R$D637, restore #REGhl, and advance via
 $E7A3 DEC HL        ; #R$E5B9.
 $E7A4 EXX           ;
 $E7A5 LD B,$45      ;
 $E7A7 EXX           ;
 $E7A8 CALL $D637    ;
 $E7AB POP HL        ; }
 $E7AC JP $E5B9      ;

; Direction Animation Offset Table
;
; Eight 4-byte entries (one per direction #N$00-#N$07) used by
; #R$E31C and #R$E346. Each entry holds a Y delta, an X delta, and two
; further bytes that are copied verbatim into the entity spawn buffer.
; Indexed as table + (direction × 4).
@label=Direction_Animation_Offset_Table
b$E7AF DEFB $06,$06,$03,$03,$05,$05,$05,$05
 $E7B7 DEFB $04,$04,$07,$07,$03,$03,$09,$09
 $E7BF DEFB $02,$02,$0A,$0A,$02,$02,$0B,$0B
 $E7C7 DEFB $01,$01,$0D,$0D,$00,$00,$0F,$0F

; Spawn Tracked Enemy Entities
;
; Used by the routine at #R$E863.
; .
; Initialises the tracked-enemy active count at #N$C42D to zero, copies
; the per-wave count byte into #N$C42C and adds it to the total wave
; enemy count at #R$C41C, then stashes the wave data pointer. If the
; count is zero, jumps to #R$E855; otherwise loops #REGb times: writes
; a 14-byte entity record (handler #R$E360, entity type #N$B0, random
; type variant, random screen position via #R$E2C8, three initial bytes
; from the wave data for velocity seeds, and #N$FF as the terminator)
; into the entity list via *#R$C509, spawning each entity via #R$C950.
; Closes the entity list with the #N$D1A4 terminator.
@label=Spawn_Tracked_Enemy_Entities
c$E7CF XOR A         ; {Clear #N$C42D, copy the spawn count into #N$C42C, and accumulate
 $E7D0 LD ($C42D),A  ; it into the wave enemy count at #R$C41C.
 $E7D3 LD A,(HL)     ;
 $E7D4 LD ($C42C),A  ;
 $E7D7 PUSH AF       ; }
 $E7D8 LD B,A        ; {Stash the wave data pointer, load the entity list write pointer,
 $E7D9 LD A,($C41C)  ; and jump to #R$E855 if the count is zero.
 $E7DC ADD A,B       ;
 $E7DD LD ($C41C),A  ;
 $E7E0 POP AF        ; }
 $E7E1 INC HL        ;
 $E7E2 AND A         ;
 $E7E3 PUSH HL       ;
 $E7E4 LD HL,($C509) ;
; This entry point is used by the routine at #R$9063.
*$E7E7 JP Z,$E855    ;
 $E7EA LD B,A        ;
@label=Spawn_Tracked_Enemy_Entities_Record
*$E7EB PUSH BC       ; {Write the #R$E360 handler and entity type #N$B0 to the entity
 $E7EC LD DE,$E360   ; list record.
 $E7EF LD (HL),E     ;
 $E7F0 INC HL        ;
 $E7F1 LD (HL),D     ;
 $E7F2 INC HL        ;
 $E7F3 LD (HL),$B0   ;
 $E7F5 INC HL        ; }
 $E7F6 LD (HL),$04   ; {Generate a random entity type variant via #R$D1BF.
 $E7F8 INC HL        ; }
 $E7F9 CALL $D1BF    ; {Mask to 2 bits for the type variant and add #N$28.
 $E7FC AND $03       ;
 $E7FE ADD A,$28     ; }
 $E800 LD (HL),A     ; {Write the entity type variant and advance.
 $E801 INC HL        ; }
 $E802 PUSH HL       ; {Point #REGhl at the spawn buffer, write the type variant, and
 $E803 LD HL,$C511   ; call #R$E2C8 to generate a valid random screen position.
 $E806 LD (HL),A     ;
 $E807 INC HL        ;
 $E808 CALL $E2C8    ;
 $E80B LD DE,$C53B   ; }
 $E80E LDD           ; {Copy three bytes from the wave data at #N$C53B using LDD×4 and
 $E810 LDD           ; apply the direction delta via #R$E346.
 $E812 LDD           ;
 $E814 PUSH HL       ;
 $E815 LDD           ;
 $E817 LD A,(HL)     ;
 $E818 LD (DE),A     ;
 $E819 EX DE,HL      ;
 $E81A CALL $E346    ; }
 $E81D EXX           ; {Set colour #N$42 in #REGb' and spawn the entity via
 $E81E LD B,$42      ; #R$C950.
 $E820 EXX           ;
 $E821 CALL $C950    ; }
 $E824 POP HL        ; {Write three velocity seed bytes, initial deltas, and the #N$FF
 $E825 POP DE        ; record terminator; loop back to #R$E7EB for the next entity.
 $E826 XOR A         ;
 $E827 LDI           ;
 $E829 LD (DE),A     ;
 $E82A INC DE        ;
 $E82B LDI           ;
 $E82D LD (DE),A     ;
 $E82E INC DE        ;
 $E82F PUSH DE       ;
 $E830 CALL $D1A8    ;
 $E833 LD DE,$0000   ;
 $E836 CALL $E2FD    ;
 $E839 POP DE        ; }
 $E83A EX DE,HL      ;
 $E83B LD (HL),D     ;
 $E83C INC HL        ;
 $E83D LD (HL),E     ;
 $E83E INC HL        ;
 $E83F PUSH HL       ;
 $E840 CALL $D1A8    ;
 $E843 LD DE,$0000   ;
 $E846 CALL $E2FD    ;
 $E849 POP DE        ;
 $E84A EX DE,HL      ;
 $E84B LD (HL),D     ;
 $E84C INC HL        ;
 $E84D LD (HL),E     ;
 $E84E INC HL        ;
 $E84F LD (HL),$FF   ;
 $E851 INC HL        ;
 $E852 POP BC        ;
 $E853 DJNZ $E7EB    ;
@label=Spawn_Tracked_Enemy_Entities_Terminate
*$E855 LD DE,$D1A4   ; {Save the entity list pointer to *#R$C509 and write the #N$D1A4
 $E858 LD ($C509),HL ; terminator.
 $E85B LD (HL),E     ;
 $E85C INC HL        ; }
 $E85D LD (HL),D     ; {Write #N$FF and advance #REGhl.
 $E85E INC HL        ; }
 $E85F LD (HL),$FF   ; {Restore the wave data pointer and return.
 $E861 POP HL        ; }
 $E862 RET           ;

; Evaluate and Spawn Tracked Enemies
;
; Used by the routine at #R$D24C.
; .
; Entry point called from #R$D24C. Reads the tracked enemy active count
; at #N$C42C; if non-zero, jumps immediately to the spawn step at
; #R$E879. Otherwise checks #N$C42D; if zero, also jumps to #R$E879.
; If #N$C42D is non-zero, halves it twice: if the result is still
; non-zero, jumps to #R$E879; otherwise increments #REGa to #N$01 and
; falls through to store the spawn count and call #R$E7CF.
@label=Evaluate_And_Spawn_Tracked_Enemies
c$E863 LD A,($C42C)  ; {If the tracked enemy active count at #N$C42C is non-zero, skip
 $E866 AND A         ; to #R$E879.
 $E867 JP NZ,$E879   ;
 $E86A LD A,($C42D)  ; }
 $E86D AND A         ; {If the set count at #N$C42D is also zero, skip to
 $E86E JP Z,$E879    ; #R$E879.}
 $E871 SRL A         ; {Halve #N$C42D twice; if the result is still non-zero, skip to
 $E873 SRL A         ; #R$E879.
 $E875 JP NZ,$E879   ; }
 $E878 INC A         ; Set spawn count to 1.
@label=Evaluate_And_Spawn_Tracked_Enemies_Go
*$E879 LD ($C42C),A  ; Store the spawn count at #N$C42C.
 $E87C CALL $E7CF    ; {Call #R$E7CF to spawn the tracked enemy wave and
 $E87F INC HL        ; advance.}
 $E880 RET           ;

; Process Wall Bouncing Enemy
;
; Per-frame handler for the wall-bouncing enemy. If the wave start
; delay is still counting down, advances to the next entity record without
; processing. Otherwise checks for player contact via #R$CD18 and triggers
; player death via #R$D2BC if the bouncer is touching. If the bouncer is
; already dying, skips to the draw step. Searches the wave enemy list for
; a collision via #R$E262; if none is found, defers to #R$EA17. On a hit,
; decrements a countdown timer; when it expires the bouncer erases itself,
; nudges one step toward the player, picks a new heading, and redraws.
;
; HL Entity record pointer
;
; If the wave is still warming up, skip ahead without processing.
@label=Process_Wall_Bouncing_Enemy
c$E881 LD A,($C533)  ; {If the wave start delay at #R$C533 is non-zero, skip to
 $E884 AND A         ; #R$E90F.
 $E885 JP NZ,$E90F   ; }
; Check whether the player is touching the bouncer and kill them if so.
 $E888 INC HL        ; {Advance to the velocity pair.
 $E889 INC HL        ; }
 $E88A EXX           ; Switch to alternate registers.
 $E88B CALL $CD18    ; Search for a contact slot via #R$CD18.
 $E88E JP NC,$E974   ; Jump to #R$E974 if player contact is confirmed.
 $E891 LD HL,$C4D4   ; {Load the player position from #R$C4D4 and test overlap
 $E894 CALL $C6DA    ; via #R$C6DA.}
 $E897 JP NC,$D2BC   ; Kill the player via #R$D2BC if the overlap test
                     ; confirmed contact.
 $E89A EXX           ; {Switch back and step three bytes toward the entity
 $E89B DEC HL        ; record start.
 $E89C DEC HL        ;
 $E89D DEC HL        ; }
; If the bouncer is already dying, skip directly to the draw step.
 $E89E DEC HL        ; {If the bouncer is already dying (bit 0 of active flag),
 $E89F DEC HL        ; skip to #R$E90F.
 $E8A0 LD A,(HL)     ;
 $E8A1 SRL A         ;
 $E8A3 JR C,$E90F    ; }
; Search the wave enemy list for an enemy the bouncer has hit.
 $E8A5 INC HL        ; {Step ahead and search the wave enemy list for a
 $E8A6 INC HL        ; collision via #R$E262.
 $E8A7 CALL $E262    ; }
 $E8AA JP NC,$EA17   ; Jump to #R$EA17 if no wave enemy collision was detected.
 $E8AD EXX           ; {Switch to alternate registers and step back to the
 $E8AE DEC HL        ; bounce timer.}
; Tick down the bounce countdown; erase and redirect when it expires.
 $E8AF DEC HL        ; {Step to the bounce timer and subtract #N$04.
 $E8B0 LD A,(HL)     ;
 $E8B1 SUB $04       ;
 $E8B3 LD (HL),A     ; }
 $E8B4 JR NZ,$E90F   ; If the countdown has not reached zero, skip to #R$E90F.
 $E8B6 LD (HL),$0C   ; Reset the bounce countdown to #N$0C.
 $E8B8 INC HL        ; {Erase the bouncer sprite via #R$C949, preserving the
 $E8B9 PUSH HL       ; entity pointer.
 $E8BA CALL $C949    ;
 $E8BD POP HL        ;
 $E8BE INC HL        ; }
; Step the bouncer one pixel toward the player and pick a new heading.
 $E8BF LD A,($C4D4)  ; {Measure the signed Y distance to the player at #R$C4D4.
 $E8C2 SUB (HL)      ; }
 $E8C3 JR Z,$E8CB    ; {Set the Y step: #N$01 (player below), #N$FF (player
 $E8C5 LD A,$01      ; above), or #N$00.
 $E8C7 JR NC,$E8CB   ;
 $E8C9 LD A,$FF      ; }
@label=Process_Wall_Bouncing_Enemy_Step_Y
*$E8CB LD B,A        ; {Store the Y step in #REGb, apply it to the Y position,
 $E8CC ADD A,(HL)    ; and advance.
 $E8CD LD (HL),A     ;
 $E8CE INC HL        ; }
 $E8CF LD A,($C4D5)  ; {Measure the signed X distance to the player at #R$C4D5.
 $E8D2 SUB (HL)      ; }
 $E8D3 JR Z,$E8DB    ; {Set the X step: #N$01 (player right), #N$FF (player
 $E8D5 LD A,$01      ; left), or #N$00.
 $E8D7 JR NC,$E8DB   ;
 $E8D9 LD A,$FF      ; }
@label=Process_Wall_Bouncing_Enemy_Step_X
*$E8DB LD C,A        ; {Store the X step in #REGc, apply it to the X position, and pack both
 $E8DC ADD A,(HL)    ; step signs into a 4-bit direction code.
 $E8DD LD (HL),A     ;
 $E8DE LD A,C        ;
 $E8DF AND $03       ;
 $E8E1 RLA           ;
 $E8E2 RLA           ; }
; Apply the new heading: look up the direction colour and redraw.
 $E8E3 LD C,A        ; {Pack the Y and X step signs into a 4-bit direction
 $E8E4 LD A,B        ; code.
 $E8E5 AND $03       ;
 $E8E7 OR C          ;
 $E8E8 LD C,A        ;
 $E8E9 LD B,$00      ; }
 $E8EB EX DE,HL      ; {Look up the heading colour from the direction table at
 $E8EC LD HL,$EAF7   ; #R$EAF7.
 $E8EF ADD HL,BC     ;
 $E8F0 LD A,(HL)     ;
 $E8F1 PUSH DE       ;
 $E8F2 DEC DE        ; }
 $E8F3 DEC DE        ; {Write the heading colour to the entity record.
 $E8F4 LD (DE),A     ; }
 $E8F5 LD A,($C4E5)  ; {Look up the animation frame colour from the cycle table
 $E8F8 AND $07       ; at #R$EA0F.
 $E8FA LD C,A        ;
 $E8FB LD B,$00      ;
 $E8FD LD HL,$EA0F   ;
 $E900 ADD HL,BC     ;
 $E901 LD A,(HL)     ; }
 $E902 EX DE,HL      ; {Restore the entity pointer, set the frame colour in #REGb', and
 $E903 EXX           ; respawn the bouncer via #R$C950.
 $E904 LD B,A        ;
 $E905 EXX           ;
 $E906 CALL $C950    ; }
 $E909 POP HL        ; Restore the entity pointer from the stack.
 $E90A INC HL        ; {Advance four bytes to the next entity record.
 $E90B INC HL        ;
 $E90C INC HL        ;
 $E90D INC HL        ; }
 $E90E RET           ; Return.
; This entry point is used by the routine at #R$EA17.
; .
; Bouncer skipped: look up the animation colour and redraw without moving.
@label=Process_Wall_Bouncing_Enemy_Advance
*$E90F INC HL        ; {Advance one byte, stash the pointer, and read the frame
 $E910 PUSH HL       ; index from #R$C4E5.
 $E911 LD A,($C4E5)  ;
 $E914 AND $07       ;
 $E916 LD C,A        ;
 $E917 LD B,$00      ; }
 $E919 EX DE,HL      ; {Look up the animation colour from #R$EA0F and set it in
 $E91A LD HL,$EA0F   ; #REGb'.
 $E91D ADD HL,BC     ;
 $E91E LD A,(HL)     ;
 $E91F EX DE,HL      ;
 $E920 EXX           ;
 $E921 LD B,A        ;
 $E922 EXX           ; }
 $E923 CALL $D004    ; Draw the bouncer in its current position via #R$D004.
 $E926 POP HL        ; Restore the entity pointer from the stack.
 $E927 LD DE,$0006   ; {Step six bytes to the next entity record.
 $E92A ADD HL,DE     ; }
 $E92B RET           ; Return.

; Spawn Wall Bouncing Enemies
;
; Used by the routine at #R$D24C.
; .
; Called from #R$D24C. Reads the wall-bouncing enemy spawn count from
; *#REGhl and stores it at #R$C42F. Returns immediately if the count is
; zero. Otherwise adds the count to the wave enemy total at #R$C41C and
; spawns #REGb bouncers, writing each entity record (handler #R$E881,
; entity type #N$04, random screen position via #R$E2C8, and state bytes
; #N$0F and #N$0A) into the entity list at *#R$C509. Closes the list
; with #R$D1A4 and restores the wave data pointer.
;
; HL Wave data pointer
@label=Spawn_Wall_Bouncing_Enemies
c$E92C LD A,(HL)     ; {Read the spawn count from the wave data and store it at
 $E92D LD ($C42F),A  ; #R$C42F.}
 $E930 INC HL        ; Advance past the spawn count byte.
 $E931 AND A         ; {Return if no bouncers need spawning.
 $E932 RET Z         ; }
; Update the wave enemy total and load the entity list write pointer.
 $E933 LD B,A        ; {Add the spawn count to the wave enemy total at #R$C41C.
 $E934 LD A,($C41C)  ;
 $E937 ADD A,B       ;
 $E938 LD ($C41C),A  ; }
 $E93B PUSH HL       ; Stash the wave data pointer on the stack.
 $E93C LD HL,($C509) ; Load the entity list write pointer from #R$C509.
; Write the entity record and spawn the bouncer at a random position.
@label=Spawn_Wall_Bouncing_Enemies_Record
*$E93F LD DE,$E881   ; {Write the entity handler address #R$E881 into the first
 $E942 LD (HL),E     ; two bytes.
 $E943 INC HL        ;
 $E944 LD (HL),D     ; }
 $E945 INC HL        ; {Write entity type #N$04 and initial state byte #N$26 to
 $E946 LD (HL),$04   ; the record.
 $E948 INC HL        ;
 $E949 LD (HL),$26   ;
 $E94B INC HL        ; }
 $E94C PUSH BC       ; Stash the spawn loop counter on the stack.
 $E94D CALL $E2C8    ; Generate a random spawn position via #R$E2C8.
 $E950 DEC HL        ; Step back to the Y position field.
 $E951 PUSH HL       ; Stash #REGhl on the stack.
 $E952 DEC HL        ; {Step back three bytes and set spawn colour #COLOUR$41
 $E953 DEC HL        ; in #REGb'.
 $E954 DEC HL        ;
 $E955 EXX           ;
 $E956 LD B,$41      ;
 $E958 EXX           ; }
 $E959 CALL $C950    ; Spawn the bouncer in the generated position via #R$C950.
 $E95C POP HL        ; Restore the position pointer from the stack.
 $E95D LD (HL),$0F   ; {Write the active state byte #N$0F and advance.
 $E95F INC HL        ; }
 $E960 LD (HL),$0A   ; {Write the bounce counter #N$0A and advance.
 $E962 INC HL        ; }
 $E963 LD (HL),$FF   ; {Write the end-of-record marker #N$FF and advance.
 $E965 INC HL        ; }
 $E966 POP BC        ; Restore the spawn loop counter from the stack.
 $E967 DJNZ $E93F    ; Loop back to #R$E93F until all bouncers are spawned.
; Save the entity list pointer and write the list terminator.
 $E969 LD ($C509),HL ; Save the updated entity list write pointer to #R$C509.
 $E96C LD DE,$D1A4   ; {Write the list terminator address #R$D1A4 to *#REGhl.
 $E96F LD (HL),E     ;
 $E970 INC HL        ;
 $E971 LD (HL),D     ; }
 $E972 POP HL        ; Restore the wave data pointer from the stack.
 $E973 RET           ; Return.

; Kill Wall Bouncing Enemy
;
; Used by the routine at #R$E881.
; .
; Reached when a wall-bouncing enemy makes contact with the player.
; Saves the entity position in #R$C4DA, erases the sprite via #R$C84F,
; and removes the entity from the list via #R$D5B1. Decrements the wave
; enemy total at #R$C41C and the bouncing enemy count at #R$C42F. Triggers
; the border colour effect via #R$D9C4 and awards #N$05 BCD points.
; Refreshes the colour bar, double-erases the sprite via #R$C949 and
; #R$DAAF, writes the dying handler #R$E9CC into the record, and returns.
;
; .
;
; Save the entity position and remove the bouncer from the enemy list.
@label=Kill_Wall_Bouncing_Enemy
c$E974 LD DE,$0006   ; {Step back six bytes to the entity position.
 $E977 SBC HL,DE     ; }
 $E979 LD ($C4DA),HL ; Save the entity position in #R$C4DA.
 $E97C CALL $C84F    ; Call #R$C84F to erase the bouncer sprite.
 $E97F CALL $D5B1    ; Call #R$D5B1 to remove the bouncer from the entity list.
; Decrement the wave enemy and bouncing enemy counts.
 $E982 LD HL,$C41C   ; {Decrement the wave enemy total at #R$C41C.
 $E985 DEC (HL)      ; }
 $E986 LD HL,$C42F   ; {Decrement the bouncing enemy count at #R$C42F.
 $E989 DEC (HL)      ; }
; Trigger the border colour flash and award five BCD points for the kill.
 $E98A LD E,$00      ; {Call #R$D9C4 to trigger the border colour effect.
 $E98C CALL $D9C4    ; }
 $E98F LD HL,$C405   ; {Add #N$05 BCD points to the units score digit at
 $E992 LD A,(HL)     ; #R$C403(#N$C405).
 $E993 ADD A,$05     ;
 $E995 DAA           ;
 $E996 LD (HL),A     ;
 $E997 JR NC,$E9A7   ; }
 $E999 DEC HL        ; {Propagate the BCD carry through the tens and hundreds
 $E99A LD A,(HL)     ; score digits.
 $E99B ADD A,$01     ;
 $E99D DAA           ;
 $E99E LD (HL),A     ;
 $E99F JR NC,$E9A7   ;
 $E9A1 DEC HL        ;
 $E9A2 LD A,(HL)     ;
 $E9A3 ADD A,$01     ;
 $E9A5 DAA           ;
 $E9A6 LD (HL),A     ; }
; Refresh the colour bar and set up the dying animation handler.
@label=Kill_Wall_Bouncing_Enemy_Spawn
*$E9A7 CALL $CD34    ; Call #R$CD34 to refresh the colour bar.
 $E9AA LD B,$02      ; Load #INK$02 into #REGb.
 $E9AC EXX           ; Switch to alternate registers.
 $E9AD DEC HL        ; Step back to the entity position field.
 $E9AE LD ($C50F),HL ; Save the position pointer at #R$C50F.
 $E9B1 CALL $C949    ; Call #R$C949 to erase the sprite.
 $E9B4 LD HL,($C50F) ; Reload the position pointer from #R$C50F.
 $E9B7 CALL $DAAF    ; Call #R$DAAF to XOR-erase the sprite.
 $E9BA LD HL,($C50F) ; Reload the position pointer from #R$C50F.
; Install the dying animation handler and advance past the entity record.
 $E9BD DEC HL        ; {Step back and set the death timer to #N$02.
 $E9BE LD (HL),$02   ; }
 $E9C0 DEC HL        ; {Write the dying handler address #R$E9CC into the entity
 $E9C1 LD DE,$E9CC   ; record.
 $E9C4 LD (HL),D     ;
 $E9C5 DEC HL        ;
 $E9C6 LD (HL),E     ; }
 $E9C7 LD DE,$0009   ; {Step nine bytes forward to the next entity slot.
 $E9CA ADD HL,DE     ; }
 $E9CB RET           ; Return.

; Animate Wall Bouncing Enemy Death
;
; Per-frame death handler for a wall-bouncing enemy, written by
; #R$E974. Each frame, XOR-draws the entity using the stored animation
; colour, then increments the death animation counter. When it reaches
; #N$0F, writes #R$E02C as the retire handler and jumps to it. Otherwise
; loads the counter into #REGb', reads the entity Y position, selects a
; scroll offset (#N$F8 within the play area, #N$F0 near the ceiling),
; updates the Y position, XOR-erases the entity, and jumps to #R$E094.
;
; HL Entity record pointer
;
; XOR-draw the entity with the stored animation colour.
@label=Animate_Wall_Bouncing_Enemy_Death
c$E9CC LD A,(HL)     ; {Load the animation colour from the entity record into
 $E9CD EXX           ; #REGb'.
 $E9CE LD B,A        ;
 $E9CF EXX           ; }
 $E9D0 PUSH HL       ; Stash the entity pointer on the stack.
 $E9D1 INC HL        ; {Step to the draw position and call #R$DAAF to XOR-draw
 $E9D2 CALL $DAAF    ; the entity.}
 $E9D5 POP HL        ; Restore the entity pointer from the stack.
; Increment the death counter and retire when it reaches #N$0F.
 $E9D6 INC (HL)      ; {Increment the counter and jump to #R$EA03 when it
 $E9D7 LD A,(HL)     ; reaches #N$0F.
 $E9D8 CP $0F        ;
 $E9DA JR Z,$EA03    ; }
; Load the new frame colour and read the entity Y position.
 $E9DC EXX           ; {Set the frame colour in #REGb' and read the entity Y
 $E9DD LD B,A        ; position.
 $E9DE EXX           ;
 $E9DF INC HL        ;
 $E9E0 INC HL        ;
 $E9E1 LD A,(HL)     ; }
; Select the scroll offset based on the Y position.
 $E9E2 CP $18        ; {Jump to #R$E9EE if the entity is within the play area.
 $E9E4 JR NC,$E9EE   ; }
 $E9E6 CP $AB        ; {Load zero scroll offset and jump to #R$EA01 if the
 $E9E8 LD A,$00      ; ceiling boundary is exceeded.
 $E9EA JR NC,$EA01   ; }
 $E9EC JR $E9F6      ; Jump to #R$E9F6 to apply the scroll offset.
; Choose the scroll speed based on distance from the ceiling.
@label=Animate_Wall_Bouncing_Enemy_Death_Scroll
*$E9EE CP $AE        ; {Select scroll offset #N$F8 if within bounds, or #N$F0 if near
 $E9F0 LD A,$F8      ; the ceiling.
 $E9F2 JR C,$E9F6    ;
 $E9F4 LD A,$F0      ; }
; Apply the scroll offset, XOR-erase the entity, and advance.
@label=Animate_Wall_Bouncing_Enemy_Death_Apply
*$E9F6 ADD A,(HL)    ; {Apply the scroll offset to the Y position and call #R$DAAF to
 $E9F7 LD (HL),A     ; XOR-erase the entity.
 $E9F8 DEC HL        ;
 $E9F9 PUSH HL       ;
 $E9FA CALL $DAAF    ; }
 $E9FD POP HL        ; Restore the entity pointer from the stack.
 $E9FE JP $E094      ; Jump to #R$E094 to advance the entity pointer.
@label=Animate_Wall_Bouncing_Enemy_Death_Ceil
*$EA01 DEC HL        ; {Step back to the entity handler field.
 $EA02 DEC HL        ; }
; Write the retire handler and jump to it.
@label=Animate_Wall_Bouncing_Enemy_Death_End
*$EA03 LD DE,$E02C   ; {Write the retire handler address #R$E02C into the
 $EA06 DEC HL        ; entity record.
 $EA07 LD (HL),D     ;
 $EA08 DEC HL        ;
 $EA09 LD (HL),E     ;
 $EA0A INC HL        ;
 $EA0B INC HL        ; }
 $EA0C JP $E02C      ; Jump to #R$E02C.

; Enemy Colour Cycle Table
;
; Eight attribute bytes used by #R$E881 and #R$E9CC to set the entity
; display colour on each animation frame. Indexed by the low 3 bits of
; the colour cycle counter at #N$C4E5.
@label=Enemy_Colour_Cycle_Table
b$EA0F DEFB $41      ; #COLOUR(#PEEK(#PC)).
 $EA10 DEFB $43      ; #COLOUR(#PEEK(#PC)).
 $EA11 DEFB $45      ; #COLOUR(#PEEK(#PC)).
 $EA12 DEFB $47      ; #COLOUR(#PEEK(#PC)).
 $EA13 DEFB $45      ; #COLOUR(#PEEK(#PC)).
 $EA14 DEFB $43      ; #COLOUR(#PEEK(#PC)).
 $EA15 DEFB $41      ; #COLOUR(#PEEK(#PC)).
 $EA16 DEFB $41      ; #COLOUR(#PEEK(#PC)).

; Handle Enemy Collision Chain
;
; Used by the routine at #R$E881.
; .
; Reached from #R$E881 when the bouncer finds no collision partner.
; Flags the entity as active, reads the entity type and state, decrements
; the slot count at #R$C427, and installs the retire handler #R$E02C.
; Then appends a replacement entity record (handler #R$EA6E) to the entity
; list at *#R$C509, writes the list terminator #R$D1A4, and jumps to
; #R$E90F to redraw without moving.
;
; HL Entity record pointer
;
; Flag the bouncer as active and save the entity record pointer.
@label=Handle_Enemy_Collision_Chain
c$EA17 EXX           ; Switch to alternate registers.
 $EA18 DEC HL        ; {Step back five bytes to the entity active flag.
 $EA19 DEC HL        ;
 $EA1A DEC HL        ;
 $EA1B DEC HL        ;
 $EA1C DEC HL        ; }
 $EA1D LD (HL),$01   ; Set the entity active flag to #N$01.
 $EA1F PUSH HL       ; Stash the entity record pointer on the stack.
 $EA20 EXX           ; Switch to main registers.
; Read the entity state and extract the type index.
 $EA21 DEC HL        ; {Step back through the record and read the entity type into
 $EA22 DEC HL        ; #REGb and the count into #REGc.
 $EA23 LD B,(HL)     ;
 $EA24 DEC HL        ;
 $EA25 LD C,(HL)     ; }
 $EA26 DEC HL        ; {Read the entity state byte into #REGa, write the countdown
 $EA27 LD A,(HL)     ; timer #N$0F, and stash the record pointer.
 $EA28 LD (HL),$0F   ;
 $EA2A PUSH HL       ; }
 $EA2B LD E,A        ; {Extract the entity type index (upper nibble of #REGa)
 $EA2C SRL E         ; into #REGde.
 $EA2E SRL E         ;
 $EA30 SRL E         ;
 $EA32 SRL E         ;
 $EA34 LD D,$00      ; }
; Decrement the slot count and install the retire handler.
 $EA36 LD HL,$C427   ; {Look up the slot count at #R$C427 and decrement it.
 $EA39 ADD HL,DE     ;
 $EA3A DEC (HL)      ; }
 $EA3B POP HL        ; Restore the entity record pointer from the stack.
 $EA3C DEC HL        ; {Step back to the retire handler field.
 $EA3D DEC HL        ; }
 $EA3E LD DE,$E02C   ; {Write the retire handler #R$E02C into the entity
 $EA41 LD (HL),D     ; record.
 $EA42 DEC HL        ;
 $EA43 LD (HL),E     ; }
; Open a new entity record for the replacement handler.
 $EA44 LD HL,($C509) ; {Load the entity list write pointer from #R$C509 and write the
 $EA47 LD DE,$EA6E   ; #R$EA6E handler and state byte #N$23.
 $EA4A LD (HL),E     ;
 $EA4B INC HL        ;
 $EA4C LD (HL),D     ;
 $EA4D INC HL        ;
 $EA4E LD (HL),$23   ;
 $EA50 INC HL        ; }
; Write the entity fields and save the list pointer.
 $EA51 LD (HL),A     ; {Write the entity state, count, type, and count to the
 $EA52 INC HL        ; replacement record.
 $EA53 LD (HL),C     ;
 $EA54 INC HL        ;
 $EA55 LD (HL),B     ;
 $EA56 INC HL        ;
 $EA57 LD (HL),C     ;
 $EA58 INC HL        ; }
 $EA59 POP DE        ; Restore the entity record pointer from the stack.
 $EA5A LD (HL),E     ; {Write the entity record pointer into the replacement record
 $EA5B INC HL        ; and save the updated list pointer to #R$C509.
 $EA5C LD (HL),D     ;
 $EA5D INC HL        ;
 $EA5E LD ($C509),HL ; }
; Close the entity list and advance to the draw step.
 $EA61 LD DE,$D1A4   ; {Write the list terminator #R$D1A4 and end marker #N$FF.
 $EA64 LD (HL),E     ;
 $EA65 INC HL        ;
 $EA66 LD (HL),D     ;
 $EA67 INC HL        ;
 $EA68 LD (HL),$FF   ; }
 $EA6A EXX           ; {Switch to alternate registers and jump to #R$E90F.
 $EA6B JP $E90F      ; }

; Process Replacement Enemy Entity
;
; Per-frame handler for the replacement entity spawned by #R$EA17.
; Jumps to #R$EB07 if the countdown has already expired. Otherwise
; locates the associated entity record pointer and jumps to #R$EAD0 to
; retire if the associated record is in settled state (#N$02). Decrements
; the countdown and calls #R$C950 to erase. If the countdown is still
; non-zero, applies a random X nudge (±7) and spawns via #R$C950. If the
; countdown reaches zero, copies entity data, resets state, and spawns
; via #R$EAA3. When settled, installs the retire handler #R$E003.
;
; HL Entity record pointer
;
; Test the countdown and locate the associated entity record.
@label=Process_Replacement_Enemy_Entity
c$EA6E LD A,(HL)     ; {Jump to #R$EB07 if the entity countdown has already
 $EA6F AND A         ; expired.
 $EA70 JP Z,$EB07    ; }
 $EA73 LD B,H        ; {Save the entity pointer in #REGbc and load the associated
 $EA74 LD C,L        ; entity record pointer from offset #N$0005.
 $EA75 LD DE,$0005   ;
 $EA78 ADD HL,DE     ;
 $EA79 LD E,(HL)     ;
 $EA7A INC HL        ;
 $EA7B LD D,(HL)     ; }
 $EA7C LD A,(DE)     ; {Read the associated entity state, restore #REGhl, and jump
 $EA7D CP $02        ; to #R$EAD0 if settled (#N$02).
 $EA7F LD H,B        ;
 $EA80 LD L,C        ;
 $EA81 JR Z,$EAD0    ; }
 $EA83 DEC (HL)      ; Decrement the entity countdown.
; Erase the entity with colour #COLOUR$42.
 $EA84 PUSH HL       ; Stash the entity pointer on the stack.
 $EA85 INC HL        ; Advance to the entity position.
 $EA86 EXX           ; {Load #COLOUR$42 into #REGb'.
 $EA87 LD B,$42      ;
 $EA89 EXX           ; }
 $EA8A CALL $C950    ; Call #R$C950 to erase the entity.
 $EA8D POP HL        ; Restore the entity pointer from the stack.
; Test the countdown and branch.
 $EA8E LD A,(HL)     ; {Jump to #R$EAB2 if the countdown has reached zero.
 $EA8F AND A         ;
 $EA90 JR Z,$EAB2    ; }
 $EA92 INC HL        ; {Advance two bytes into the entity record.
 $EA93 INC HL        ; }
; Apply a random X nudge to the entity position.
 $EA94 INC HL        ; {Advance two more bytes to the X position field.
 $EA95 INC HL        ; }
 $EA96 CALL $D1BF    ; Call #R$D1BF to generate a random byte.
 $EA99 AND %00001111 ; Mask to the lower four bits.
 $EA9B SUB $07       ; Subtract #N$07 to produce a nudge in the range
                     ; #N$F9–#N$07.
 $EA9D ADD A,(HL)    ; {Apply the nudge to the entity X position and step back two
 $EA9E DEC HL        ; bytes.
 $EA9F DEC HL        ;
 $EAA0 LD (HL),A     ; }
 $EAA1 DEC HL        ; Step back one more byte to the entity record position
                     ; field.
 $EAA2 PUSH HL       ; Stash the entity record pointer on the stack.
; Generate a random spawn colour and spawn the entity.
@label=Process_Replacement_Enemy_Entity_Spawn
*$EAA3 EXX           ; Switch to alternate registers.
 $EAA4 CALL $D1BF    ; Call #R$D1BF to generate a random colour byte.
 $EAA7 AND %00111000 ; Mask to bits 3–5 to select the spawn colour.
 $EAA9 LD B,A        ; {Load the colour into #REGb and switch to main
 $EAAA EXX           ; registers.}
 $EAAB CALL $C950    ; Call #R$C950 to spawn the entity.
 $EAAE POP HL        ; Restore the entity record pointer from the stack.
 $EAAF JP $E094      ; Jump to #R$E094 to advance the entity pointer.
; Copy entity data and reset the settle state.
@label=Process_Replacement_Enemy_Entity_Settle
*$EAB2 INC HL        ; {Step two bytes ahead, copy #REGhl to #REGde, step two more,
 $EAB3 INC HL        ; and copy one byte to the destination.
 $EAB4 LD D,H        ;
 $EAB5 LD E,L        ;
 $EAB6 INC HL        ;
 $EAB7 INC HL        ;
 $EAB8 LDI           ; }
 $EABA LD C,(HL)     ; {Read the countdown into #REGc, reset it to #N$0A, advance,
 $EABB LD (HL),$0A   ; and read the type byte into #REGb.
 $EABD INC HL        ;
 $EABE LD B,(HL)     ; }
 $EABF LD (HL),$FF   ; {Reset the type field to #N$FF, write state value #N$0F to
 $EAC1 INC DE        ; *#REGde and #N$0C to *#REGbc.
 $EAC2 LD A,$0F      ;
 $EAC4 LD (DE),A     ;
 $EAC5 LD A,$0C      ;
 $EAC7 LD (BC),A     ; }
 $EAC8 DEC DE        ; {Step #REGde back three bytes, stash #REGde, exchange
 $EAC9 DEC DE        ; #REGde and #REGhl, and jump to #R$EAA3.
 $EACA DEC DE        ;
 $EACB PUSH DE       ;
 $EACC EX DE,HL      ;
 $EACD JP $EAA3      ; }
; Write the retire handler, erase the sprite, draw, and return.
@label=Process_Replacement_Enemy_Entity_Retire
*$EAD0 LD DE,$E003   ; {Write the retire handler #R$E003 and state byte #N$32 into
 $EAD3 DEC HL        ; the entity record.
 $EAD4 LD (HL),D     ;
 $EAD5 DEC HL        ;
 $EAD6 LD (HL),E     ;
 $EAD7 INC HL        ;
 $EAD8 INC HL        ;
 $EAD9 LD (HL),$32   ;
 $EADB INC HL        ; }
 $EADC PUSH HL       ; Stash the entity pointer on the stack.
 $EADD CALL $C949    ; Call #R$C949 to erase the entity sprite.
 $EAE0 POP HL        ; Restore the entity pointer from the stack.
 $EAE1 LD (HL),$0F   ; Write the state timer #N$0F.
 $EAE3 PUSH HL       ; Stash the entity pointer on the stack.
 $EAE4 EXX           ; {Load #COLOUR$47 into #REGb'.
 $EAE5 LD B,$47      ;
 $EAE7 EXX           ; }
 $EAE8 CALL $D637    ; Call #R$D637 to draw the entity.
 $EAEB POP HL        ; Restore the entity pointer from the stack.
 $EAEC INC HL        ; {Advance one byte and copy #REGhl to #REGde.
 $EAED LD D,H        ;
 $EAEE LD E,L        ; }
 $EAEF INC HL        ; {Step four bytes to the end-marker field.
 $EAF0 INC HL        ;
 $EAF1 INC HL        ;
 $EAF2 INC HL        ; }
 $EAF3 LD (HL),$FF   ; Write the end marker #N$FF.
 $EAF5 INC HL        ; Advance to the next entity slot.
 $EAF6 RET           ; Return.

; Enemy Direction Code Table
;
; Sixteen direction-code bytes used by #R$E881 to map a packed
; 4-bit direction index (Y-sign × 4 | X-sign) to a colour attribute byte
; written into the wall-bouncing enemy record. Indexed as table + BC
; where BC = (Y_direction & #N$03) | (X_direction << 2).
@label=Enemy_Direction_Code_Table
b$EAF7 DEFB $25,$26,$24,$24,$25,$25,$24,$25
 $EAFF DEFB $27,$27,$27,$27,$27,$27,$24,$27

; Process Final Phase Enemy Entity
;
; Used by the routine at #R$EA6E.
; .
; Per-frame handler for the final phase of a wall-bouncing enemy,
; reached from #R$EA6E when the replacement entity countdown expires.
; Spawns the entity with colour #INK$07, calls #R$CD18 to search for a
; player-contact slot, and jumps to #R$EB7B if none is found. Calls
; #R$C6DA to test player contact and jumps to #R$D2BC to kill the
; player if touching. Steps back to the direction field and generates a
; random value; keeps the current direction if below #N$F0, otherwise
; picks a new direction, wraps it within #N$33, and writes it back.
; Looks up Y and X deltas from #R$EBB4 (direction & #N$03 × 2),
; validates the new position within the play area, and spawns the
; entity. If no contact slot is found, erases the sprite, removes the
; entity from the list, awards BCD score, and writes the retire handler.
;
; HL Entity record pointer
;
; Advance past the countdown byte and spawn with white colour.
@label=Process_Final_Phase_Enemy_Entity
c$EB07 INC HL        ; Advance past the countdown field.
 $EB08 PUSH HL       ; Stash the entity pointer on the stack.
 $EB09 EXX           ; {Load #INK$07 into #REGb'.
 $EB0A LD B,$07      ;
 $EB0C EXX           ; }
 $EB0D CALL $C950    ; Call #R$C950 to spawn the entity.
 $EB10 POP HL        ; Restore the entity pointer from the stack.
 $EB11 INC HL        ; {Advance one byte and switch to alternate registers.
 $EB12 EXX           ; }
; Search for a player-contact slot and test overlap.
 $EB13 CALL $CD18    ; {Call #R$CD18 to search for a player-contact slot and jump to
 $EB16 JP NC,$EB7B   ; #R$EB7B if none is found.}
 $EB19 LD HL,$C4D4   ; {Load the player position at #R$C4D4 and call #R$C6DA to test
 $EB1C CALL $C6DA    ; overlap.}
 $EB1F JP NC,$D2BC   ; Jump to #R$D2BC to kill the player if contact is
                     ; confirmed.
 $EB22 EXX           ; Switch to main registers.
; Step back to the direction field and pick or keep a direction.
 $EB23 DEC HL        ; {Step back three bytes to the direction field.
 $EB24 DEC HL        ;
 $EB25 DEC HL        ; }
 $EB26 CALL $D1BF    ; Call #R$D1BF to generate a random value.
 $EB29 CP $F0        ; {Keep the current direction if the value is below #N$F0.
 $EB2B JP C,$EB38    ; }
; Increment and mask the direction byte.
@label=Process_Final_Phase_Enemy_Entity_Retry
*$EB2E DEC HL        ; {Step back to the direction field, load it, and
 $EB2F LD A,(HL)     ; increment it.
 $EB30 INC A         ; }
 $EB31 AND %00110011 ; Mask the direction within #N$33.
 $EB33 LD (HL),A     ; {Write the new direction, advance, and jump to #R$EB3B.
 $EB34 INC HL        ;
 $EB35 JP $EB3B      ; }
@label=Process_Final_Phase_Enemy_Entity_Keep
*$EB38 DEC HL        ; {Step back to the direction field, load it, and advance.
 $EB39 LD A,(HL)     ;
 $EB3A INC HL        ; }
; Look up movement deltas and validate the new position.
@label=Process_Final_Phase_Enemy_Entity_Apply
*$EB3B EX DE,HL      ; Exchange #REGde and #REGhl.
 $EB3C AND %00000011 ; Mask the direction to the low 2 bits.
 $EB3E SLA A         ; {Double the index, load the movement table base at #R$EBB4,
 $EB40 LD C,A        ; and step to the entry.
 $EB41 LD B,$00      ;
 $EB43 LD HL,$EBB4   ;
 $EB46 ADD HL,BC     ; }
 $EB47 EX DE,HL      ; {Add the Y delta to the entity Y position and jump to #R$EB2E
 $EB48 LD A,(DE)     ; if outside #N$10–#N$AA.
 $EB49 ADD A,(HL)    ;
 $EB4A CP $AB        ;
 $EB4C JP NC,$EB2E   ;
 $EB4F CP $10        ;
 $EB51 JP C,$EB2E    ; }
 $EB54 LD C,A        ; Save the validated Y position in #REGc.
 $EB55 INC HL        ; {Advance to the X position, apply the X delta, and jump to
 $EB56 INC DE        ; #R$EB63 if outside the play area.
 $EB57 LD A,(DE)     ;
 $EB58 ADD A,(HL)    ;
 $EB59 CP $F1        ;
 $EB5B JP NC,$EB63   ;
 $EB5E CP $08        ;
 $EB60 JP NC,$EB67   ; }
@label=Process_Final_Phase_Enemy_Entity_X_Retry
*$EB63 DEC HL        ; {Step back one byte and jump to #R$EB2E to retry.
 $EB64 JP $EB2E      ; }
; Write the validated coordinates and spawn with a random colour.
@label=Process_Final_Phase_Enemy_Entity_Write
*$EB67 LD (HL),A     ; {Write the validated X and Y coordinates to the entity
 $EB68 DEC HL        ; record.
 $EB69 LD (HL),C     ;
 $EB6A DEC HL        ; }
 $EB6B PUSH HL       ; Stash the entity pointer on the stack.
 $EB6C EXX           ; Switch to alternate registers.
 $EB6D CALL $D1BF    ; Call #R$D1BF to generate a random colour byte.
 $EB70 AND %00111000 ; Mask to bits 3–5 to select the spawn colour.
 $EB72 LD B,A        ; {Load the colour into #REGb and switch to main
 $EB73 EXX           ; registers.}
 $EB74 CALL $C950    ; Call #R$C950 to spawn the entity.
 $EB77 POP HL        ; Restore the entity pointer from the stack.
 $EB78 JP $E094      ; Jump to #R$E094 to advance the entity pointer.
; Erase the entity, remove it from the list, and award the score.
@label=Process_Final_Phase_Enemy_Entity_Kill
*$EB7B LD DE,$0006   ; {Step back six bytes to the entity record and save the address
 $EB7E SBC HL,DE     ; in #R$C4DA.
 $EB80 LD ($C4DA),HL ; }
 $EB83 CALL $C84F    ; Call #R$C84F to erase the entity sprite.
 $EB86 CALL $D5B1    ; Call #R$D5B1 to remove the entity from the list.
 $EB89 LD E,$00      ; {Load code #N$00 and call #R$D9C4 to initialise the entity
 $EB8B CALL $D9C4    ; state.}
; Increment the BCD score and propagate carry to higher digits.
 $EB8E LD HL,$C405   ; {Load #R$C405, add #N$01 BCD, write it back, and jump to
 $EB91 LD A,(HL)     ; #R$EBA6 if no carry.
 $EB92 ADD A,$01     ;
 $EB94 DAA           ;
 $EB95 LD (HL),A     ;
 $EB96 JR NC,$EBA6   ; }
 $EB98 DEC HL        ; {Carry to the tens digit: load, add #N$01 BCD, write back, and
 $EB99 LD A,(HL)     ; jump to #R$EBA6 if no carry.
 $EB9A ADD A,$01     ;
 $EB9C DAA           ;
 $EB9D LD (HL),A     ;
 $EB9E JR NC,$EBA6   ; }
 $EBA0 DEC HL        ; {Carry to the hundreds digit: load, add #N$01 BCD, and write
 $EBA1 LD A,(HL)     ; back.
 $EBA2 ADD A,$01     ;
 $EBA4 DAA           ;
 $EBA5 LD (HL),A     ; }
; Refresh the colour bar and write the retire handler.
@label=Process_Final_Phase_Enemy_Entity_Score_Bar
*$EBA6 CALL $CD34    ; Call #R$CD34 to refresh the colour bar.
 $EBA9 EXX           ; Switch to main registers.
 $EBAA DEC HL        ; {Step back three bytes to the entity handler field.
 $EBAB DEC HL        ;
 $EBAC DEC HL        ; }
 $EBAD LD DE,$E02C   ; {Write the retire handler #R$E02C into the entity
 $EBB0 LD (HL),D     ; record.
 $EBB1 DEC HL        ;
 $EBB2 LD (HL),E     ; }
 $EBB3 RET           ; Return.

; Enemy Movement Delta Table
;
; Four 2-byte entries (Y delta, X delta) used by #R$EB07 to move the
; final-phase enemy one step in one of four diagonal directions. Indexed
; as table + (direction & #N$03) × 2. The four entries encode movement
; by 3 pixels: up-left (#N$FD, #N$00), right (#N$00, #N$03), down
; (#N$03, #N$00), and left (#N$00, #N$FD).
@label=Enemy_Movement_Delta_Table
b$EBB4 DEFB $FD,$00
 $EBB6 DEFB $00,$03
 $EBB8 DEFB $03,$00
 $EBBA DEFB $00,$FD

; Game Entry Point
;
; Used by the routines at #R$C400, #R$C713 and #R$D367.
@label=GameEntryPoint
c$EBBC LD SP,$5FFE   ; #REGsp=#N$5FFE.
 $EBBF DI            ; Disable interrupts.
 $EBC0 LD A,$08      ; {Write #N$08 to *#R$8FF2.
 $EBC2 LD ($8FF2),A  ; }
 $EBC5 JP $F4EC      ; Jump to #R$F4EC.

; Display High Score Entry Screen
;
; Used by the routines at #R$ED71 and #R$F4EC.
; .
; Initialises the high score entry screen: clears the display, prints the
; option header from #R$EE66, and renders the current score entries with
; their cursor markers. Runs a #N$4B-frame input loop allowing keyboard and
; joystick adjustment of the three score entry fields via #R$EDAA and
; #R$EDDD. After name entry, redraws the final score table and cycles the
; display for #N$32 frames before jumping to the attract mode at #R$F4EC.
@label=Display_High_Score_Entry_Screen
c$EBC8 XOR A         ; {Clear the display with attribute #INK$00 via #R$ECA4.
 $EBC9 CALL $ECA4    ; }
 $EBCC CALL $F09D    ; Initialise the scrolling display via #R$F09D.
 $EBCF CALL $F0EE    ; Advance the colour cycle via #R$F0EE.
 $EBD2 LD HL,$EE66   ; {Call #R$9006 using #R$EE66.
 $EBD5 CALL $9006    ; }
 $EBD8 LD A,$06      ; {Write #N$06 to *#R$C500.
 $EBDA LD ($C500),A  ; }
 $EBDD LD A,$46      ; {Write #N$46 to *#R$C501.
 $EBDF LD ($C501),A  ; }
 $EBE2 LD A,$04      ; {Write #N$04 to *#R$C502.
 $EBE4 LD ($C502),A  ; }
 $EBE7 LD A,($C4FD)  ; Load the first score entry cursor from #R$C4FD.
 $EBEA LD B,$19      ; Set the column position to #N$19.
 $EBEC CALL $ECCA    ; Render the first score entry character via #R$ECCA.
 $EBEF LD A,($C4FE)  ; Load the second score entry cursor from #R$C4FE.
 $EBF2 CALL $ECD5    ; Highlight the second score entry character via #R$ECD5.
 $EBF5 LD A,($C4FF)  ; Load the third score entry cursor from #R$C4FF.
 $EBF8 LD B,$49      ; Set the column position to #N$49.
 $EBFA CALL $ECCA    ; Render the third score entry character via #R$ECCA.
 $EBFD XOR A         ; Clear #REGa.
 $EBFE LD B,$99      ; Set the column position to #N$99.
 $EC00 CALL $ECCA    ; Clear the bottom score entry position via #R$ECCA.
 $EC03 EXX           ; Switch to the alternate registers.
 $EC04 LD B,$4B      ; Set the name entry frame counter to #N$4B in #REGb'.
; Per-frame name entry loop: services controls and handles character
; selection for all three score entry fields each frame.
@label=High_Score_Entry_Loop
*$EC06 EXX           ; Switch back to the main registers for this frame.
 $EC07 LD C,$64      ; Set the frame delay count to #N$64.
 $EC09 CALL $ECDE    ; Run the per-frame timing delay via #R$ECDE.
 $EC0C CALL $ECE6    ; Check for the BREAK key combination via #R$ECE6.
 $EC0F CALL $ECFB    ; Check for the S key via #R$ECFB.
 $EC12 CALL $ED10    ; Check for tape save/load keys (J/L) via #R$ED10.
 $EC15 CALL $ED7C    ; Read the joystick input via #R$ED7C.
 $EC18 LD DE,$C500   ; Point #REGde to the score entry columns at #R$C500.
 $EC1B LD IX,$C503   ; Point #REGix to the score entry parameters at #R$C503.
 $EC1F CALL $ED93    ; Update the score display via #R$ED93.
 $EC22 CALL $F0EE    ; Advance the colour cycle via #R$F0EE.
 $EC25 CALL $028E    ; #HTML(Call <a
                     ; href="https://skoolkit.ca/disassemblies/rom/hex/asm/028E.html">KEY_SCAN</a>.)
 $EC28 JR NZ,$EC71   ; Skip character field handling if no player input is
                     ; registered.
 $EC2A INC E         ; Advance the character selection index.
 $EC2B JR Z,$EC71    ; Skip to #R$EC71 if the selection index has overflowed.
 $EC2D DEC E         ; Step the selection index back by one.
 $EC2E LD B,$02      ; Set the field count to #N$02.
 $EC30 LD A,($C500)  ; {Load the first cursor column from #R$C500 into #REGc.
 $EC33 LD C,A        ; }
 $EC34 LD A,($C4FD)  ; {Load the first cursor position from #R$C4FD into #REGd.
 $EC37 LD D,A        ; }
 $EC38 LD IX,$EE28   ; Point #REGix to the first character table at #R$EE28.
 $EC3C CALL $EDAA    ; Adjust the first score entry field via #R$EDAA.
 $EC3F LD A,D        ; {Write the updated first cursor position back to
 $EC40 LD ($C4FD),A  ; #R$C4FD.}
 $EC43 JR Z,$EC71    ; Skip to #R$EC71 if only the first field was updated.
 $EC45 LD B,$09      ; Set the field count to #N$09.
 $EC47 LD A,($C501)  ; {Load the second cursor column from #R$C501 into #REGc.
 $EC4A LD C,A        ; }
 $EC4B LD A,($C4FE)  ; {Load the second cursor position from #R$C4FE into
 $EC4E LD D,A        ; #REGd.}
 $EC4F LD IX,$EE2E   ; Point #REGix to the second character table at #R$EE2E.
 $EC53 CALL $EDDD    ; Adjust the second score entry field via #R$EDDD.
 $EC56 LD A,D        ; {Write the updated second cursor position back to
 $EC57 LD ($C4FE),A  ; #R$C4FE.}
 $EC5A JR Z,$EC71    ; Skip to #R$EC71 if only the second field was updated.
 $EC5C LD B,$06      ; Set the field count to #N$06.
 $EC5E LD A,($C502)  ; {Load the third cursor column from #R$C502 into #REGc.
 $EC61 LD C,A        ; }
 $EC62 LD A,($C4FF)  ; {Load the third cursor position from #R$C4FF into #REGd.
 $EC65 LD D,A        ; }
 $EC66 LD IX,$EE49   ; Point #REGix to the third character table at #R$EE49.
 $EC6A CALL $EDAA    ; Adjust the third score entry field via #R$EDAA.
 $EC6D LD A,D        ; {Write the updated third cursor position back to
 $EC6E LD ($C4FF),A  ; #R$C4FF.}
@label=High_Score_Entry_Loop_End
*$EC71 EXX           ; Switch to the alternate registers.
 $EC72 DJNZ $EC06    ; Decrement the frame counter and loop back to #R$EC06.
 $EC74 EXX           ; Switch back to the main registers.
; This entry point is used by the routine at #R$ED10.
; .
; Name entry complete: clear the display and redraw the final score table
; before the display cycling phase.
@label=High_Score_Display
*$EC75 XOR A         ; {Clear the display with attribute #INK$00 via #R$ECA4.
 $EC76 CALL $ECA4    ; }
 $EC79 CALL $F09D    ; Initialise the scrolling display via #R$F09D.
 $EC7C CALL $F0EE    ; Advance the colour cycle via #R$F0EE.
 $EC7F CALL $F3AE    ; Render the high score table via #R$F3AE.
 $EC82 EXX           ; Switch to the alternate registers.
 $EC83 LD B,$32      ; Set the display frame counter to #N$32 in #REGb'.
; Per-frame display cycling loop: services controls and colour attributes
; for #N$32 frames before returning to the attract mode.
@label=High_Score_Display_Loop
*$EC85 EXX           ; Switch back to the main registers for this frame.
 $EC86 LD C,$64      ; Set the frame delay count to #N$64.
 $EC88 CALL $ECDE    ; Run the per-frame timing delay via #R$ECDE.
 $EC8B CALL $ECE6    ; Check for the BREAK key combination via #R$ECE6.
 $EC8E CALL $ECFB    ; Check for the S key via #R$ECFB.
 $EC91 CALL $ED10    ; Check for tape save/load keys (J/L) via #R$ED10.
 $EC94 CALL $ED71    ; Restart the high score display if any key is held via
                     ; #R$ED71.
 $EC97 CALL $ED7C    ; Read the joystick input via #R$ED7C.
 $EC9A CALL $F0EE    ; Advance the colour cycle via #R$F0EE.
 $EC9D EXX           ; Switch to the alternate registers.
 $EC9E DJNZ $EC85    ; Decrement the frame counter and loop back to #R$EC85.
 $ECA0 EXX           ; Switch back to the main registers.
 $ECA1 JP $F4EC      ; Jump to the attract mode loop at #R$F4EC.

; Initialise Display and Set Border
;
; Used by the routines at #R$EBC8 and #R$ED10.
; .
; Clears the display pixel area (#N$4000-#N$57FF) to black and fills
; the 768 attribute cells with the byte in #REGa, then derives the border
; colour from #REGa's paper bits and updates both BORDCR (#N$5C48) and
; the ULA border port (#N$FE).
;
; A Attribute byte for the display fill
@label=Initialise_Display_And_Border
c$ECA4 LD HL,$4000   ; {Set up to clear the pixel area (#N$4000-#N$57FF,
 $ECA7 LD DE,$4001   ; #N$1800 bytes).
 $ECAA LD BC,$1800   ; }
 $ECAD LD (HL),$00   ; {Clear the first pixel byte and fill the remaining display
 $ECAF LDIR          ; pixels to black via LDIR.}
 $ECB1 LD BC,$0300   ; Set the attribute fill count to #N$0300 cells.
 $ECB4 LD (HL),A     ; {Seed the first attribute cell with #REGa and fill all #N$0300
 $ECB5 LDIR          ; attribute cells via LDIR.}
 $ECB7 AND %00111000 ; Isolate the paper colour bits from the attribute.
 $ECB9 BIT 5,A       ; {Skip to #R$ECBF if the paper colour is in the upper range
 $ECBB JR NZ,$ECBF   ; (#N$04-#N$07).}
 $ECBD XOR %00000111 ; Complement the ink colour bits to contrast with dark
                     ; paper.
@label=Set_Border_Colour
*$ECBF LD ($5C48),A  ; #HTML(Write the background colour to *<a
                     ; href="https://skoolkid.github.io/rom/asm/5C48.html">BORDCR</a>.)
 $ECC2 AND %00111000 ; Re-isolate the paper colour bits.
 $ECC4 RRCA          ; {Shift the paper colour into the low 3 bits.
 $ECC5 RRCA          ;
 $ECC6 RRCA          ; }
 $ECC7 OUT ($FE),A   ; Write the paper colour to the ULA border port #N$FE.
 $ECC9 RET           ; Return.
; This entry point is used by the routine at #R$EBC8.
; .
; Alternate entry: compute a score character position as #REGa × 8 +
; #REGb and highlight its attribute row via #R$EE0B and #R$EE1D.
@label=Render_Score_Character
*$ECCA ADD A,A       ; {Compute the character position index as #REGa × 8 +
 $ECCB ADD A,A       ; #REGb.
 $ECCC ADD A,A       ;
 $ECCD ADD A,B       ; }
 $ECCE CALL $EE0B    ; Calculate the attribute cell address for this position via
                     ; #R$EE0B.
 $ECD1 CALL $EE1D    ; Highlight the score entry row with bright white via
                     ; #R$EE1D.
 $ECD4 RET           ; Return.
; This entry point is used by the routine at #R$EBC8.
; .
; Alternate entry: highlight a single score entry attribute cell on
; row #N$59 directly, using #REGa × 2 + 1 as the cell offset.
@label=Highlight_Score_Entry_Cell
*$ECD5 ADD A,A       ; {Compute the attribute cell offset as #REGa × 2 + 1.
 $ECD6 ADD A,$01     ;
 $ECD8 LD L,A        ; }
 $ECD9 LD H,$59      ; {Write #COLOUR$47 to attribute row #N$59 at the computed
 $ECDB LD (HL),$47   ; offset.}
 $ECDD RET           ; Return.

; Display Loop Delay
;
; Used by the routines at #R$EBC8 and #R$ED10.
; .
; Busy-wait timing delay used by the attract mode and high score display
; loops. Each call resets #REGb to #N$00 and spins the inner busy-wait
; #N$100 times; #REGc controls the outer repetition count. Callers set
; #REGc to #N$64 before the call, giving 100 outer passes of 256 inner
; spins each.
@label=Display_Loop_Delay
c$ECDE LD B,$00      ; Set the inner loop counter to #N$00, giving #N$100
                     ; busy-wait spins.
@label=Display_Loop_Delay_Inner
*$ECE0 DJNZ $ECE0    ; Spin until the inner loop counter reaches zero.
 $ECE2 DEC C         ; {Decrement the outer pass count in #REGc and loop back
 $ECE3 JR NZ,$ECE0   ; to #R$ECE0.}
 $ECE5 RET           ; Return.

; Check BREAK Key
;
; Used by the routines at #R$EBC8, #R$ED10 and #R$F4EC.
; .
; Checks whether the BREAK key combination (CAPS SHIFT + SPACE) is held
; while *#N$FFFF equals #N$63. Called during the attract mode loop and option
; screens. If both conditions are met, the ROM error handler is invoked via
; RST #N$08 (parameter #N$14), which jumps via ERRSP (#N$5C3D) to reset the
; machine.
@label=CheckBreakKey
c$ECE6 LD A,($FFFF)  ; {Return if *#N$FFFF is not equal to #N$63.
 $ECE9 CP $63        ;
 $ECEB RET NZ        ; }
; Read both halves of the BREAK key combination. Keyboard bits are
; active-low (#N$00 when pressed); OR-ing the two readings and masking to
; bit 0 gives #N$00 only when both keys are held simultaneously.
 $ECEC LD BC,$FEFE   ; {Read from the keyboard;
 $ECEF IN E,(C)      ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$FE | CAPS SHIFT | Z | X | C | V }
                     ; TABLE#}
 $ECF1 LD B,$7F      ; {Read from the keyboard;
 $ECF3 IN A,(C)      ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$7F | SPACE | FULL-STOP | M | N | B }
                     ; TABLE#}
 $ECF5 OR E          ; OR with the CAPS SHIFT reading; bit 0 is #N$00 only if
                     ; both are pressed.
 $ECF6 AND %00000001 ; Keep only bit 0.
 $ECF8 RET NZ        ; Return if CAPS SHIFT and SPACE are not both held (BREAK
                     ; not detected).
; Both conditions confirmed; trigger the ROM error handler which jumps via
; ERRSP (#N$5C3D) to reset the machine.
 $ECF9 RST $08       ; #HTML(Run the ERROR_1 routine:
                     ; <a rel="noopener nofollow" href="https://skoolkit.ca/disassemblies/rom/hex/asm/0008.html">RST #N$08</a>.)
 $ECFA DEFB $14      ; Error code: #N$14 ("BREAK into program").

; Check S Key During Display
;
; Used by the routines at #R$EBC8 and #R$F4EC.
; .
; Reads keyboard row #N$FD (A-S-D-F-G) during the high score display loops.
; Forces the upper three bits high and checks for the S key alone. If S is
; the only key held, discards the caller's return address and jumps to the
; tape load continuation handler at #R$D3F8 with the header parameters from
; #R$C4FD and #R$C4FE. Returns normally if no matching key is detected.
@label=Check_S_Key_During_Display
c$ECFB LD A,$FD      ; {Read from the keyboard;
 $ECFD IN A,($FE)    ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$FD | A | S | D | F | G }
                     ; TABLE#}
 $ECFF OR %11100000  ; Force bits 5-7 high.
 $ED01 CP $FD        ; {Return if the S key is not the only key pressed.
 $ED03 RET NZ        ; }
 $ED04 POP HL        ; Discard the caller's return address from the stack.
 $ED05 LD A,($C4FD)  ; {Load the tape header byte from #R$C4FD into #REGb.
 $ED08 LD B,A        ; }
 $ED09 LD A,($C4FE)  ; {Load the tape header byte from #R$C4FE into #REGe.
 $ED0C LD E,A        ; }
 $ED0D JP $D3F8      ; Jump to the tape load continuation at #R$D3F8.

; Save Or Load High Scores
;
; Used by the routines at #R$EBC8 and #R$F4EC.
; .
; Checks whether J (save) or L (load) is held on keyboard row #N$BF. On
; J, saves the #N$012D-byte score table from #R$F1AB to tape. On L, loads
; from tape into the buffer at #R$6100; a successful load copies the buffer
; to the live score data and restarts the display. A failed load shows a
; tape error message — or a wrong-game warning if a Moon Patrol score table
; was detected — then waits for a keypress before returning.
@label=Save_Or_Load_High_Scores
c$ED10 LD A,$BF      ; {Read from the keyboard;
 $ED12 IN A,($FE)    ; #TABLE(default,centre,centre,centre,centre,centre,centre)
 $ED14 CPL           ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$BF | ENTER | L | K | J | H }
                     ; TABLE#}
 $ED15 AND %00001010 ; Isolate the L (bit 1) and J (bit 3) keys.
 $ED17 RET Z         ; Return if neither tape key is pressed.
 $ED18 LD DE,$012D   ; Set the score table byte count to #N$012D.
 $ED1B BIT 1,A       ; Test whether the L key is held for a tape load.
 $ED1D LD A,$6B      ; {Set the tape data type identifier to #N$6B and jump to #R$ED2A
 $ED1F JR NZ,$ED2A   ; if the L key is held.}
; J key path: save the score table to tape.
 $ED21 LD IX,$F1AB   ; Point #REGix to the score table at #R$F1AB for the tape
                     ; save.
 $ED25 CALL $04C2    ; Save #N$012D bytes to tape via SA_BYTES (#N$04C2).
 $ED28 DI            ; {Disable interrupts and return.
 $ED29 RET           ; }
; L key path: load a score table from tape into the buffer at #R$6100.
@label=Load_High_Score_Table
*$ED2A SCF           ; Set the carry flag to signal a data block load to
                     ; LD_BYTES.
 $ED2B LD IX,$6100   ; Point #REGix to the score reception buffer at #R$6100.
 $ED2F CALL $0556    ; Load #N$012D bytes from tape via LD_BYTES (#N$0556).
 $ED32 POP DE        ; Restore #REGde from the stack.
 $ED33 DI            ; Disable interrupts.
 $ED34 JR C,$ED63    ; Jump to #R$ED63 if the tape load succeeded.
; Load failed: select the appropriate error message.
 $ED36 LD A,L        ; Read the tape data type marker returned by the load.
 $ED37 LD HL,$EFBC   ; Point #REGhl to the tape error message at #R$EFBC.
 $ED3A CP $6C        ; {Jump to #R$ED41 if the marker is not the Moon Patrol identifier
 $ED3C JR NZ,$ED41   ; #N$6C.}
 $ED3E LD HL,$EFDD   ; Select the wrong-game warning at #R$EFDD.
@label=Show_Tape_Message
*$ED41 PUSH HL       ; Stash the message pointer on the stack.
 $ED42 XOR A         ; Clear #REGa to prepare for display reinitialisation.
 $ED43 CALL $ECA4    ; Reinitialise the display via #R$ECA4.
 $ED46 CALL $F09D    ; Call #R$F09D.
 $ED49 CALL $F0EE    ; Call #R$F0EE.
 $ED4C POP HL        ; Restore the message pointer from the stack.
 $ED4D CALL $9006    ; Print the tape status message via #R$9006.
@label=Tape_Message_Loop
*$ED50 LD C,$64      ; Set the frame delay count to #N$64.
 $ED52 CALL $ECDE    ; Call #R$ECDE.
 $ED55 CALL $ED7C    ; Call #R$ED7C.
 $ED58 CALL $F0EE    ; Call #R$F0EE.
 $ED5B CALL $ECE6    ; Check the BREAK key via #R$ECE6.
 $ED5E CALL $ED71    ; Abort if any key is pressed via #R$ED71.
 $ED61 JR $ED50      ; Loop back to #R$ED50.
; Load succeeded: copy the freshly loaded data from the tape reception
; buffer into the live score table.
@label=Install_Loaded_Score_Table
*$ED63 LD HL,$6100   ; {Set up the score table copy: source #R$6100, destination
 $ED66 LD DE,$F1AB   ; #R$F1AB, length #N$012D bytes.
 $ED69 LD BC,$012D   ; }
 $ED6C LDIR          ; Copy the loaded score table into the live high score
                     ; data.
 $ED6E JP $EC75      ; Jump to #R$EC75 to restart the high score display.

; Check Any Key During Display
;
; Used by the routines at #R$EBC8, #R$ED10 and #R$F4EC.
; .
; Reads all keyboard rows simultaneously (port #N$FE with selector #N$00)
; during the high score display loop. Forces the upper three bits high; if
; any key is pressed, increments #REGa past #N$FF, discards the caller's
; return address, and restarts the high score display at #R$EBC8. Returns
; normally if no keys are held.
@label=Check_Any_Key_During_Display
c$ED71 XOR A         ; {Read all keyboard rows simultaneously.
 $ED72 IN A,($FE)    ; }
 $ED74 OR %11100000  ; Force bits 5-7 high.
 $ED76 INC A         ; {Return if no keys are pressed (#REGa wraps to #N$00).
 $ED77 RET Z         ; }
 $ED78 POP HL        ; Discard the caller's return address from the stack.
 $ED79 JP $EBC8      ; Restart the high score display at #R$EBC8.

; Scan and Cycle Screen Attributes
;
; Used by the routines at #R$EBC8 and #R$ED10.
; .
; Scans the entire screen attribute area from #N$5800 to #N$5AFF,
; comparing each attribute byte against the colour substitution table at
; #R$EE49(#N$EE5B). Any matching byte is replaced with its table-defined
; counterpart. Called each frame during the high score display loops to
; cycle the colour state of the score cells.
@label=Scan_And_Cycle_Screen_Attributes
c$ED7C LD DE,$5800   ; Point #REGde to the start of the attribute area at
                     ; #N$5800.
@label=Scan_Attr_Loop
*$ED7F LD A,(DE)     ; Load the current attribute byte from the display.
 $ED80 LD HL,$EE5B   ; {Set up to search for this attribute in the substitution table
 $ED83 LD BC,$000A   ; at #R$EE49(#N$EE5B).}
 $ED86 CPIR          ; Search for the attribute in the substitution table.
 $ED88 JR NZ,$ED8C   ; Skip replacement if the attribute was not found.
 $ED8A LD A,(HL)     ; {Replace the attribute with its substitution byte.
 $ED8B LD (DE),A     ; }
@label=Scan_Attr_Next
*$ED8C INC DE        ; Advance to the next attribute cell.
 $ED8D LD A,D        ; {Check if the scan has reached the end of the attribute
 $ED8E CP $5B        ; area.}
 $ED90 JR NZ,$ED7F   ; Loop back to #R$ED7F until all attribute cells are
                     ; processed.
 $ED92 RET           ; Return.

; Scan Score Display Attributes
;
; Used by the routine at #R$EBC8.
; .
; Scans a contiguous block of attribute cells from #REGde to #REGix,
; applying the same colour substitution as #R$ED7C. Called during the name
; entry phase to keep the score display colours consistent.
;
; DE Start attribute address
; IX End attribute address (exclusive)
@label=Scan_Score_Display_Attributes
c$ED93 LD A,(DE)     ; Load the current attribute byte from #REGde.
 $ED94 LD HL,$EE5B   ; {Set up to search for this attribute in the substitution table
 $ED97 LD BC,$000A   ; at #R$EE49(#N$EE5B).}
 $ED9A CPIR          ; Search for the attribute in the substitution table.
 $ED9C JR NZ,$EDA0   ; Skip replacement if the attribute was not found.
 $ED9E LD A,(HL)     ; {Replace the attribute with its substitution byte.
 $ED9F LD (DE),A     ; }
@label=Scan_Score_Attr_Next
*$EDA0 INC DE        ; Advance to the next attribute cell.
 $EDA1 PUSH IX       ; {Copy the end address from #REGix to #REGhl.
 $EDA3 POP HL        ; }
 $EDA4 AND A         ; {Clear carry and test whether the range is exhausted.
 $EDA5 SBC HL,DE     ; }
 $EDA7 JR NZ,$ED93   ; Loop back to #R$ED93 until all cells in the range are
                     ; processed.
 $EDA9 RET           ; Return.

; Adjust Score Field Cursor
;
; Used by the routine at #R$EBC8.
; .
; Adjusts the cursor within a score entry digit field. Searches for the
; current column position in the character table at #REGix via #R$EE02; if
; found and within range, updates #REGe to the new column, calculates the
; attribute address via #R$EE0B, writes highlight attributes for both the
; old and new cursor positions via #R$EE1D, then fills the column bytes for
; the updated field.
;
; B Entry count for table search
; C Cursor colour byte
; D Cursor upper bound
; E Current cursor column
; IX Score entry character table
@label=Adjust_Score_Field_Cursor
c$EDAA PUSH IX       ; {Copy the character table pointer from #REGix to #REGhl.
 $EDAC POP HL        ; }
 $EDAD LD A,E        ; Load the current cursor column from #REGe.
 $EDAE PUSH BC       ; {Stash the field count on the stack and search for the current
 $EDAF CALL $EE02    ; column in the table via #R$EE02.}
 $EDB2 POP BC        ; Restore the field count from the stack.
 $EDB3 RET NZ        ; Return if the current position is not found in the
                     ; table.
 $EDB4 INC HL        ; {Load the next cursor position from the table and check it
 $EDB5 LD A,(HL)     ; against the upper bound in #REGd.
 $EDB6 CP D          ; }
 $EDB7 RET Z         ; Return if the cursor is already at its maximum.
 $EDB8 LD E,A        ; Update the cursor column in #REGe.
 $EDB9 INC HL        ; {Advance and load the screen position byte from the
 $EDBA LD A,(HL)     ; table entry.}
 $EDBB PUSH DE       ; {Stash the cursor state on the stack and calculate the new
 $EDBC CALL $EE0B    ; attribute cell address via #R$EE0B.}
 $EDBF POP DE        ; Restore the cursor state from the stack.
 $EDC0 CALL $EE1D    ; Write the highlight attributes for the new cursor position via
                     ; #R$EE1D.
 $EDC3 PUSH IX       ; {Reload the character table pointer from #REGix to
 $EDC5 POP HL        ; #REGhl.}
 $EDC6 INC HL        ; Advance to the second table entry.
 $EDC7 LD A,D        ; {Load the upper bound from #REGd and search for it in the table
 $EDC8 CALL $EE02    ; via #R$EE02.}
 $EDCB INC HL        ; {Advance and load the screen position byte from the
 $EDCC LD A,(HL)     ; table entry.}
 $EDCD PUSH DE       ; {Stash the cursor state on the stack and calculate the previous
 $EDCE CALL $EE0B    ; attribute cell address via #R$EE0B.}
 $EDD1 POP DE        ; Restore the cursor state from the stack.
 $EDD2 INC HL        ; {Advance past the table position bytes.
 $EDD3 INC HL        ; }
 $EDD4 LD B,$1C      ; Set the attribute fill count to #N$1C.
@label=Score_Field_Fill_Loop
*$EDD6 LD (HL),C     ; {Write the cursor colour to each attribute cell and loop until
 $EDD7 INC HL        ; #N$1C cells are filled.
 $EDD8 DJNZ $EDD6    ; }
 $EDDA LD D,E        ; Copy the updated cursor column from #REGe to #REGd.
 $EDDB XOR A         ; {Clear #REGa and return to signal the field was updated.
 $EDDC RET           ; }

; Adjust Name Entry Cursor
;
; Used by the routine at #R$EBC8.
; .
; Adjusts the cursor within the name entry character field. Searches for
; the current character position in the table at #REGix via #R$EE02; if
; found and within range, updates #REGe, writes #COLOUR$47 to the new
; character's attribute cell on the #N$59 row directly, then updates the
; previous character's attribute. Simpler than #R$EDAA as it addresses the
; attribute row without calling #R$EE0B.
;
; B Entry count for table search
; C Cursor colour byte
; D Cursor upper bound
; E Current character position
; IX Name entry character table
@label=Adjust_Name_Entry_Cursor
c$EDDD PUSH IX       ; {Copy the character table pointer from #REGix to #REGhl.
 $EDDF POP HL        ; }
 $EDE0 LD A,E        ; Load the current character position from #REGe.
 $EDE1 PUSH BC       ; {Stash the field count on the stack and search for the current
 $EDE2 CALL $EE02    ; position in the table via #R$EE02.}
 $EDE5 POP BC        ; Restore the field count from the stack.
 $EDE6 RET NZ        ; Return if the current position is not found.
 $EDE7 INC HL        ; {Load the next character position from the table and check it
 $EDE8 LD A,(HL)     ; against the upper bound in #REGd.
 $EDE9 CP D          ; }
 $EDEA RET Z         ; Return if the cursor is at its maximum.
 $EDEB LD E,A        ; Update the character position in #REGe.
 $EDEC INC HL        ; {Advance and read the attribute column offset.
 $EDED LD L,(HL)     ; }
 $EDEE LD H,$59      ; {Set the attribute row to #N$59 and write #COLOUR$47 to
 $EDF0 LD (HL),$47   ; highlight the new character position.}
 $EDF2 PUSH IX       ; {Reload the character table pointer from #REGix to
 $EDF4 POP HL        ; #REGhl.}
 $EDF5 INC HL        ; Advance to the second table entry.
 $EDF6 LD A,D        ; {Load the upper bound from #REGd and search for it in the table
 $EDF7 CALL $EE02    ; via #R$EE02.}
 $EDFA INC HL        ; {Advance and read the previous attribute column offset.
 $EDFB LD L,(HL)     ; }
 $EDFC LD H,$59      ; {Set the attribute row to #N$59 and write the cursor colour to
 $EDFE LD (HL),C     ; the previous character position.}
 $EDFF LD D,E        ; Copy the updated character position from #REGe to #REGd.
 $EE00 XOR A         ; {Clear #REGa and return to signal the character was
 $EE01 RET           ; updated.}

; Search Score Entry Table
;
; Used by the routines at #R$EDAA and #R$EDDD.
; .
; Searches a 3-byte-strided table at #REGhl for the value in #REGa,
; scanning up to #REGb entries. Returns with the Z flag set and #REGhl
; pointing to the matched entry if found, or the Z flag clear if not found.
;
; A Byte to search for
; B Entry count
; HL Table pointer
@label=Search_Score_Entry_Table
c$EE02 CP (HL)       ; {Return if the current table entry matches.
 $EE03 RET Z         ; }
 $EE04 INC HL        ; {Advance #REGhl by 3 bytes to the next table entry.
 $EE05 INC HL        ;
 $EE06 INC HL        ; }
 $EE07 DJNZ $EE02    ; Decrement the entry count and loop back to #R$EE02.
 $EE09 DEC B         ; {Exhaust the search count and return without a match.
 $EE0A RET           ; }

; Calculate Attribute Cell Address
;
; Used by the routines at #R$ECA4 and #R$EDAA.
; .
; Looks up a character index in the word table at #N$4600 to find its
; pixel row address, then converts that address to the corresponding
; attribute cell in the range #N$5800-#N$5BFF by shifting the screen row
; right by 3 and combining with #N$58. Called by #R$EDAA to position score
; entry highlight attributes.
;
; A Character index
@label=Calculate_Attr_Cell_Address
c$EE0B LD H,$46      ; {Look up the character index in the word table at #N$4600 and
 $EE0D LD L,A        ; load the pixel row address into #REGhl.
 $EE0E ADD HL,HL     ;
 $EE0F LD E,(HL)     ;
 $EE10 INC HL        ;
 $EE11 LD D,(HL)     ;
 $EE12 EX DE,HL      ; }
 $EE13 LD A,H        ; {Convert the pixel row address to the attribute cell address in
 $EE14 RRCA          ; the range #N$5800-#N$5BFF.
 $EE15 RRCA          ;
 $EE16 RRCA          ;
 $EE17 AND $03       ;
 $EE19 OR $58        ;
 $EE1B LD H,A        ; }
 $EE1C RET           ; Return.

; Highlight Score Entry Row
;
; Used by the routines at #R$ECA4 and #R$EDAA.
; .
; Writes #COLOUR$47 (bright white on black) to #N$1C consecutive
; attribute cells from #REGhl. Called to highlight a complete score entry
; row when the cursor moves.
;
; HL Pointer to the attribute area (advanced by 2 before writing)
@label=Highlight_Score_Entry_Row
c$EE1D INC HL        ; {Skip past the table position bytes and set the fill count to
 $EE1E INC HL        ; #N$1C.
 $EE1F LD A,$1C      ; }
@label=Score_Row_Highlight_Loop
*$EE21 LD (HL),$47   ; {Write #COLOUR$47 to each attribute cell and loop until #N$1C
 $EE23 INC HL        ; cells are highlighted.
 $EE24 DEC A         ;
 $EE25 JR NZ,$EE21   ; }
 $EE27 RET           ; Return.

; Data block at EE28
b$EE28 DEFB $1A,$01,$21,$05,$02,$29

; Data block at EE2E
b$EE2E DEFB $24,$01,$03,$1C,$02,$05,$14,$03
 $EE36 DEFB $07,$0C,$04,$09,$04,$05,$0B,$03
 $EE3E DEFB $06,$0D,$0B,$07,$0F,$13,$08,$11
 $EE46 DEFB $1B,$09,$13

; Score Entry Field Three Table
;
; Six 3-byte entries used by #R$EDAA to adjust the third score entry
; field cursor. Each entry holds: cursor column value, upper bound, and
; screen position byte for attribute address calculation via #R$EE0B.
; Followed immediately by the five find-replace colour substitution pairs
; at #R$EE5B, read each frame by #R$ED7C and #R$ED93.
@label=Score_Entry_Field_Three_Table
b$EE49 DEFB $1F,$01,$51,$17,$02,$59,$0F,$03
 $EE51 DEFB $61,$07,$04,$69,$00,$05,$71,$11
 $EE59 DEFB $06,$79
@label=Colour_Substitution_Table
 $EE5B DEFB $44,$04,$46,$06,$42,$41,$43,$03
 $EE63 DEFB $05,$45
 $EE65 DEFB $44

; Messaging: Select Options
@label=Messaging_SelectOptions
t$EE66 DEFB $11,$00                               ; Set PAPER:
                                                  ; #INK(#PEEK(#PC+$01)).
 $EE68 DEFB $18,$10                               ; Set left margin:
                                                  ; #N(#PEEK(#PC+$01)).
 $EE6A DEFB $19,$F0                               ; Set right margin:
                                                  ; #N(#PEEK(#PC+$01)).
 $EE6C DEFB $1A,$01                               ; Select font:
                                                  ; #N(#PEEK(#PC+$01)).
 $EE6E DEFB $10,$01                               ; Set INK:
                                                  ; #INK(#PEEK(#PC+$01)).
 $EE70 DEFB $13,$01                               ; BRIGHT:
                                                  ; #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $EE72 DEFB $16,$54,$11                           ; PRINT AT
                                                  ; #N(#PEEK(#PC+$01)),
                                                  ; #N(#PEEK(#PC+$02)).
 $EE75 DEFM "SELECT OPTIONS:"
 $EE84 DEFB $10,$06                               ; Set INK:
                                                  ; #INK(#PEEK(#PC+$01)).
 $EE86 DEFB $13,$00                               ; BRIGHT:
                                                  ; #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $EE88 DEFB $16,$10,$21                           ; PRINT AT
                                                  ; #N(#PEEK(#PC+$01)),
                                                  ; #N(#PEEK(#PC+$02)).
 $EE8B DEFM "O One Player"
 $EE97 DEFB $0D                                   ; NEWLINE.
 $EE98 DEFM "T Two Player"
 $EEA4 DEFB $13                                   ; BRIGHT:
                                                  ; #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $EEA5 DEFB $01,$16,$10                           ; PRINT AT
                                                  ; #N(#PEEK(#PC+$01)),
                                                  ; #N(#PEEK(#PC+$02)).
 $EEA8 DEFM "9  Select Start Wave:"
 $EEBD DEFB $0D                                   ; NEWLINE.
 $EEBE DEFM "  1  2  3  4  5  6  7  8  9"
 $EED9 DEFB $10,$04                               ; Set INK:
                                                  ; #INK(#PEEK(#PC+$01)).
 $EEDB DEFB $13,$00                               ; BRIGHT:
                                                  ; #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $EEDD DEFB $16,$10,$51                           ; PRINT AT
                                                  ; #N(#PEEK(#PC+$01)),
                                                  ; #N(#PEEK(#PC+$02)).
 $EEE0 DEFM "Z Sinclair with 1 Joystick"
 $EEFA DEFB $0D                                   ; NEWLINE.
 $EEFB DEFM "X Kempston Joystick"
 $EF0E DEFB $0D                                   ; NEWLINE.
 $EF0F DEFM "C Cursor Joystick"
 $EF20 DEFB $0D                                   ; NEWLINE.
 $EF21 DEFM "V Old-type Fuller Box with Joystick"
 $EF44 DEFB $0D                                   ; NEWLINE.
 $EF45 DEFM "B Sinclair with 2 Joysticks"
 $EF60 DEFB $0D                                   ; NEWLINE.
 $EF61 DEFM "K Keyboard"
 $EF6B DEFB $0D                                   ; NEWLINE.
 $EF6C DEFM "   A=Down, Q=Up"
 $EF7B DEFB $0D                                   ; NEWLINE.
 $EF7C DEFM "   O=Left, P=Right"
 $EF8E DEFB $13,$01                               ; BRIGHT:
                                                  ; #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $EF90 DEFB $16,$10,$99                           ; PRINT AT
                                                  ; #N(#PEEK(#PC+$01)),
                                                  ; #N(#PEEK(#PC+$02)).
 $EF93 DEFM "S Start Game"
 $EF9F DEFB $0D                                   ; NEWLINE.
 $EFA0 DEFM "H Hold/Restart"
 $EFAE DEFB $0D                                   ; NEWLINE.
 $EFAF DEFM "F Abort Game"
 $EFBB DEFB $1F                                   ; Terminator.

; Messaging: Tape Error
@label=Messaging_TapeError
t$EFBC DEFB $10,$04                     ; Set INK: #INK(#PEEK(#PC+$01)).
 $EFBE DEFB $16,$38,$5C                 ; PRINT AT #N(#PEEK(#PC+$01)),
                                        ; #N(#PEEK(#PC+$02)).
 $EFC1 DEFB $1A,$01                     ; Select font: #N(#PEEK(#PC+$01)).
 $EFC3 DEFM "Tape error - hit any key."
 $EFDC DEFB $1F                         ; Terminator.

; Messaging: High Score Error
@label=Messaging_HighScoreError
t$EFDD DEFB $10,$07                                                             ; Set INK:
                                                                                ; #INK(#PEEK(#PC+$01)).
 $EFDF DEFB $13,$01                                                             ; BRIGHT:
                                                                                ; #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $EFE1 DEFB $16,$13,$50                                                         ; PRINT AT
                                                                                ; #N(#PEEK(#PC+$01)),
                                                                                ; #N(#PEEK(#PC+$02)).
 $EFE4 DEFB $18,$13                                                             ; Set left
                                                                                ; margin:
                                                                                ; #N(#PEEK(#PC+$01)).
 $EFE6 DEFB $1A,$01                                                             ; Select
                                                                                ; font:
                                                                                ; #N(#PEEK(#PC+$01)).
 $EFE8 DEFM "WARNING-"                                                          ; #FONT$8100,attr=$47(WARNING-)(warning)
 $EFF0 DEFB $10,$04                                                             ; Set INK:
                                                                                ; #INK(#PEEK(#PC+$01)).
 $EFF2 DEFM "You have attempted to load an Atarisoft Moon Patrol Hi-score tabl" ; {#FONT$8100,attr=$44(You
 $F033 DEFM "e."                                                                ; have
                                                                                ; attempted
                                                                                ; to load an
                                                                                ; Atarisoft
                                                                                ; Moon
                                                                                ; Patrol
                                                                                ; Hi-score
                                                                                ; table.)(moon-patrol)
                                                                                ; }
 $F035 DEFB $17,$48                                                             ; TAB:
                                                                                ; #N(#PEEK(#PC+$01)).
 $F037 DEFM "Please try again!!!"                                               ; #FONT$8100,attr=$44(Please
                                                                                ; try
                                                                                ; again!!!)(try-again)
 $F04A DEFB $18,$10                                                             ; Set left
                                                                                ; margin:
                                                                                ; #N(#PEEK(#PC+$01)).
 $F04C DEFB $1F                                                                 ; Terminator.

; Fill Row
;
; Used by the routine at #R$F063.
; .
; Writes the current border colour to #REGd cells starting at
; (H=column, L=row), advancing one column right per cell. Called by
; #R$F063 to paint the top and bottom horizontal edges of each colour ring.
;
; HL Starting cell coordinate (H = column, L = row)
; D Number of cells to fill
@label=Fill_Row
c$F04D LD E,D        ; Copy the cell count to the loop register.
@label=Fill_Row_Loop
*$F04E PUSH HL       ; {Stash the cell coordinate on the stack and plot the
 $F04F CALL $8D80    ; border colour.}
 $F052 POP HL        ; {Restore the cell coordinate and advance one column
 $F053 INC H         ; right.}
 $F054 DEC E         ; {Repeat for each remaining cell.
 $F055 JR NZ,$F04E   ; }
 $F057 RET           ; Return.

; Fill Column
;
; Used by the routine at #R$F063.
; .
; Writes the current border colour to #REGd cells starting at
; (H=column, L=row), advancing one row down per cell. Called by #R$F063 to
; paint the left and right vertical edges of each colour ring.
;
; HL Starting cell coordinate (H = column, L = row)
; D Number of cells to fill
@label=Fill_Column
c$F058 LD E,D        ; Copy the cell count to the loop register.
@label=Fill_Column_Loop
*$F059 PUSH HL       ; {Stash the cell coordinate on the stack and plot the
 $F05A CALL $8D80    ; border colour.}
 $F05D POP HL        ; {Restore the cell coordinate and advance one row down.
 $F05E INC L         ; }
 $F05F DEC E         ; {Repeat for each remaining cell.
 $F060 JR NZ,$F059   ; }
 $F062 RET           ; Return.

; Draw Colour Ring
;
; Used by the routine at #R$F092.
; .
; Draws one rectangular colour ring with its top-left corner at column
; #REGb, row #REGc. The horizontal edges span columns #REGb to #N$FF-#REGb
; and are drawn via #R$F04D; the vertical edges span rows #REGc to
; #N$BF-#REGc and are drawn via #R$F058.
;
; BC Corner offset (B = column, C = row)
;
; Draw the top and bottom horizontal edges.
@label=Draw_Colour_Ring
c$F063 LD H,B        ; {Load the corner position into #REGhl and copy the
 $F064 LD L,C        ; column to #REGa.
 $F065 LD A,B        ; }
 $F066 SLA A         ; {Calculate the horizontal edge length as #N$100 minus 2 times
 $F068 NEG           ; the column offset.
 $F06A LD D,A        ; }
 $F06B PUSH BC       ; {Stash the corner, draw the top edge rightward via #R$F04D,
 $F06C CALL $F04D    ; and restore.
 $F06F POP BC        ; }
 $F070 LD H,B        ; {Set the position to the bottom edge at row #N$BF minus
 $F071 LD A,$BF      ; #REGc.
 $F073 SUB C         ;
 $F074 LD L,A        ; }
 $F075 PUSH BC       ; {Stash the corner, draw the bottom edge rightward via #R$F04D,
 $F076 CALL $F04D    ; and restore.
 $F079 POP BC        ; }
; Draw the left and right vertical edges.
 $F07A LD H,B        ; {Reset the corner position and calculate the vertical edge length
 $F07B LD L,C        ; as #N$C0 minus 2 times the row offset.
 $F07C LD E,C        ;
 $F07D SLA E         ;
 $F07F LD A,$C0      ;
 $F081 SUB E         ;
 $F082 LD D,A        ; }
 $F083 PUSH BC       ; {Stash the corner, draw the left edge downward via #R$F058,
 $F084 CALL $F058    ; and restore.
 $F087 POP BC        ; }
 $F088 LD L,C        ; {Set the position to the right edge at column #N$FF
 $F089 LD A,B        ; minus #REGb.
 $F08A CPL           ;
 $F08B LD H,A        ; }
 $F08C PUSH BC       ; {Stash the corner, draw the right edge downward via #R$F058,
 $F08D CALL $F058    ; and restore.
 $F090 POP BC        ; }
 $F091 RET           ; Return.

; Draw Concentric Rings
;
; Used by the routine at #R$F09D.
; .
; Draws #REGd nested rectangular colour rings, each one cell inward
; from the last, by calling #R$F063 with incrementing corner offsets.
;
; BC Starting corner offset (B = column, C = row)
; D Number of rings to draw
@label=Draw_Concentric_Rings
c$F092 PUSH DE       ; {Stash the ring counter, draw the current colour ring via
 $F093 CALL $F063    ; #R$F063, and restore.
 $F096 POP DE        ; }
 $F097 INC C         ; {Move the corner one cell inward on each side.
 $F098 INC B         ; }
 $F099 DEC D         ; {Repeat for each remaining ring.
 $F09A JR NZ,$F092   ; }
 $F09C RET           ; Return.

; Draw Colour Border
;
; Used by the routines at #R$EBC8 and #R$ED10.
; .
; Draws two sets of four concentric colour rings to build the screen
; colour border: four rings from the outer edge at (#N$00, #N$00), then
; four more from the inner edge at (#N$08, #N$08).
@label=Draw_Colour_Border
c$F09D LD BC,$0000   ; {Draw #N$04 concentric rings from the outer screen edge.
 $F0A0 LD D,$04      ;
 $F0A2 CALL $F092    ; }
 $F0A5 LD BC,$0808   ; {Draw #N$04 concentric rings starting #N$08 cells
 $F0A8 LD D,$04      ; inward.
 $F0AA CALL $F092    ; }
 $F0AD RET           ; Return.

; Fill Border Attributes
;
; Used by the routine at #R$F0EE.
; .
; Writes the two-colour attribute border frame to attribute RAM at
; #N$5800, using #REGd as the outer border colour and #REGe as the inner
; border colour. The outer colour fills a two-cell-wide band around the
; edge; the inner colour fills the adjacent band one cell inside that.
;
; D Outer border attribute byte
; E Inner border attribute byte
@label=Fill_Border_Attributes
c$F0AE LD HL,$5800   ; Point #REGhl to the start of the attribute area at
                     ; #N$5800.
; Fill the top two-row border band.
 $F0B1 LD B,$21      ; Set the outer top row cell count to #N$21.
@label=Fill_Border_Top_Outer_Loop
*$F0B3 LD (HL),D     ; {Write the outer border colour to #N$21 consecutive
 $F0B4 INC HL        ; cells.
 $F0B5 DJNZ $F0B3    ; }
 $F0B7 LD B,$1E      ; Set the inner top row cell count to #N$1E.
@label=Fill_Border_Top_Inner_Loop
*$F0B9 LD (HL),E     ; {Write the inner border colour to the next #N$1E cells.
 $F0BA INC HL        ;
 $F0BB DJNZ $F0B9    ; }
 $F0BD LD (HL),D     ; {Write the outer border colour to close the inner top
 $F0BE INC HL        ; row.}
; Fill the #N$14 inner rows with border cells on each side.
 $F0BF LD A,$14      ; Set the inner row counter to #N$14.
@label=Fill_Border_Inner_Row_Loop
*$F0C1 LD (HL),D     ; {Write the outer border colour to the left border cell.
 $F0C2 INC HL        ; }
 $F0C3 LD (HL),E     ; {Write the inner border colour and skip #N$1D cells across the
 $F0C4 LD BC,$001D   ; inner area.
 $F0C7 ADD HL,BC     ; }
 $F0C8 LD (HL),E     ; {Write the inner border colour to the last inner cell.
 $F0C9 INC HL        ; }
 $F0CA LD (HL),D     ; {Write the outer border colour to the right border cell.
 $F0CB INC HL        ; }
 $F0CC DEC A         ; {Repeat for each inner row.
 $F0CD JR NZ,$F0C1   ; }
; Fill the bottom two-row border band.
 $F0CF LD (HL),D     ; {Write the outer border colour to close the last inner
 $F0D0 INC HL        ; row.}
 $F0D1 LD B,$1E      ; Set the inner bottom row cell count to #N$1E.
@label=Fill_Border_Bottom_Inner_Loop
*$F0D3 LD (HL),E     ; {Write the inner border colour to the next #N$1E cells.
 $F0D4 INC HL        ;
 $F0D5 DJNZ $F0D3    ; }
 $F0D7 LD B,$21      ; Set the outer bottom row cell count to #N$21.
@label=Fill_Border_Bottom_Outer_Loop
*$F0D9 LD (HL),D     ; {Write the outer border colour to #N$21 consecutive
 $F0DA INC HL        ; cells.
 $F0DB DJNZ $F0D9    ; }
 $F0DD RET           ; Return.

; Border Colour Pairs
;
; Eight outer/inner attribute-byte pairs for the screen border colour
; cycle. Each word is read by #R$F0EE and passed as #REGde to #R$F0AE.
@label=Table_Border_Colour_Pairs
g$F0DE DEFW $2C08
 $F0E0 DEFW $2102
 $F0E2 DEFW $0813
 $F0E4 DEFW $021E
 $F0E6 DEFW $1337
 $F0E8 DEFW $1E3D
 $F0EA DEFW $372C
 $F0EC DEFW $3D21

; Cycle Border Colour
;
; Used by the routines at #R$EBC8 and #R$ED10.
; .
; Advances the border colour cycle one step and redraws the attribute
; border frame. Reads the current step from #R$C508, decrements it
; (wrapping at 0 back to 7), looks up the outer/inner attribute pair from
; #R$F0DE, and calls #R$F0AE to repaint the border.
@label=Cycle_Border_Colour
c$F0EE LD A,($C508)  ; {Read and decrement the border colour step from #R$C508.
 $F0F1 DEC A         ; }
 $F0F2 AND %00000111 ; Mask the step to the range 0–7.
 $F0F4 LD ($C508),A  ; Store the updated step back to #R$C508.
 $F0F7 SLA A         ; {Double the step to a word offset and index into the colour pair
 $F0F9 LD C,A        ; table at #R$F0DE.
 $F0FA LD B,$00      ;
 $F0FC LD HL,$F0DE   ;
 $F0FF ADD HL,BC     ; }
 $F100 LD D,(HL)     ; {Load the outer (#REGd) and inner (#REGe) attribute bytes from
 $F101 INC HL        ; the table.
 $F102 LD E,(HL)     ; }
 $F103 CALL $F0AE    ; Redraw the screen border with the new colour pair via
                     ; #R$F0AE.
 $F106 RET           ; Return.

; Print BCD Score
;
; Used by the routines at #R$F2F9 and #R$F3AE.
; .
; Prints a BCD-encoded score of #REGb bytes from (HL) as decimal
; digits on screen, suppressing leading zeros. Each zero nibble advances
; the column by #REGc without printing; once a non-zero digit is found,
; all remaining digits are printed. Each digit is positioned using an AT
; sequence (#N$16) via #R$8DCC; #REGd is the starting column, #REGe is
; the row, and #REGd advances by #REGc after each digit.
;
; HL Pointer to the BCD score data
; B Number of BCD bytes
; C Column step between digits
; D Starting column position
; E Row position
@label=Print_BCD_Score
c$F107 LD B,$04      ; Set the BCD byte count to #N$04.
; This entry point is used by the routine at #R$F2F9.
; .
; Leading zero suppression: skip zero nibbles, advancing the column.
@label=Print_BCD_Score_Suppress_Loop
*$F109 LD A,(HL)     ; {Read the high nibble of the current score byte; jump to
 $F10A SRL A         ; #R$F130 to print it if non-zero.
 $F10C SRL A         ;
 $F10E SRL A         ;
 $F110 SRL A         ;
 $F112 JR NZ,$F130   ; }
 $F114 LD A,D        ; {Advance the column position past the suppressed high
 $F115 ADD A,C       ; digit.
 $F116 LD D,A        ; }
 $F117 LD A,B        ; {Jump to print the units digit via #R$F147 if this is the
 $F118 CP $01        ; last byte.
 $F11A JR Z,$F147    ; }
 $F11C LD A,(HL)     ; Read the current score byte for the low nibble check.
 $F11D AND %00001111 ; Isolate the low nibble.
 $F11F JR NZ,$F14A   ; Jump to print it via #R$F14A if non-zero.
 $F121 LD A,D        ; {Advance the column position past the suppressed low
 $F122 ADD A,C       ; digit.
 $F123 LD D,A        ; }
 $F124 INC HL        ; {Move to the next score byte and repeat.
 $F125 DJNZ $F109    ; }
; Digit print loop: print both nibbles of each remaining byte.
@label=Print_BCD_Score_Print_Loop
*$F127 LD A,(HL)     ; {Read the high nibble of the current score byte.
 $F128 SRL A         ;
 $F12A SRL A         ;
 $F12C SRL A         ;
 $F12E SRL A         ; }
@label=Print_High_Digit
*$F130 ADD A,$30     ; {Convert to ASCII and stash the digit character on the
 $F132 PUSH AF       ; stack.}
 $F133 LD A,$16      ; {Position the cursor at column #REGd, row #REGe via #R$8DCC
 $F135 CALL $8DCC    ; and print the digit character.
 $F138 LD A,D        ;
 $F139 CALL $8DCC    ;
 $F13C LD A,E        ;
 $F13D CALL $8DCC    ;
 $F140 POP AF        ;
 $F141 CALL $8DCC    ; }
 $F144 LD A,D        ; {Advance the column position.
 $F145 ADD A,C       ;
 $F146 LD D,A        ; }
@label=Read_Low_Digit
*$F147 LD A,(HL)     ; Read the current score byte for the low nibble.
 $F148 AND %00001111 ; Isolate the low nibble.
@label=Print_Low_Digit
*$F14A ADD A,$30     ; {Convert to ASCII and stash the digit character on the
 $F14C PUSH AF       ; stack.}
 $F14D LD A,$16      ; {Position the cursor at column #REGd, row #REGe via #R$8DCC
 $F14F CALL $8DCC    ; and print the digit character.
 $F152 LD A,D        ;
 $F153 CALL $8DCC    ;
 $F156 LD A,E        ;
 $F157 CALL $8DCC    ;
 $F15A POP AF        ;
 $F15B CALL $8DCC    ; }
 $F15E LD A,D        ; {Advance the column position.
 $F15F ADD A,C       ;
 $F160 LD D,A        ; }
 $F161 INC HL        ; {Move to the next score byte and repeat.
 $F162 DJNZ $F127    ; }
 $F164 RET           ; Return.

