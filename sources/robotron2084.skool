 $F2F8 DEFB $1F               ; Terminator.

; Draw Score Entry
;
; Used by the routine at #R$F3AE.
; .
; Draws one score entry on the high score screen. Given the screen
; position in #REGde and the name data in #REGhl, prints the rank number
; from #R$C503, a closing parenthesis, the three-character name, then
; the full score digits via #R$F107. The alternate entry at #R$F343
; uses tighter row spacing and a smaller column advance for the All
; Time Heroes table.
;
; DE Screen position (row in #REGd, column in #REGe)
; HL Points to the three-character name for this score entry
@label=Draw_Score_Entry
c$F2F9 LD B,$01      ; {Set the rank digit count and row stride.
 $F2FB LD C,$06      ; }
 $F2FD PUSH HL       ; {Stash the name pointer and screen position on the
 $F2FE PUSH DE       ; stack.}
 $F2FF LD HL,$C503   ; {Call #R$F109 using #R$C503.
 $F302 CALL $F109    ; }
 $F305 POP DE        ; {Restore the screen position and name pointer from the
 $F306 POP HL        ; stack.}
 $F307 LD A,$16      ; {Position the cursor and print the closing parenthesis
 $F309 CALL $8DCC    ; character.
 $F30C LD A,D        ;
 $F30D ADD A,$0C     ;
 $F30F CALL $8DCC    ;
 $F312 LD A,E        ;
 $F313 CALL $8DCC    ;
 $F316 LD A,$29      ;
 $F318 CALL $8DCC    ; }
 $F31B LD A,$16      ; {Position the cursor for the score entry name.
 $F31D CALL $8DCC    ;
 $F320 LD A,D        ;
 $F321 ADD A,$13     ;
 $F323 CALL $8DCC    ;
 $F326 LD A,E        ;
 $F327 CALL $8DCC    ; }
 $F32A LD B,$03      ; Set the name character loop counter.
@label=Draw_Score_Entry_Name_Loop
*$F32C LD A,(HL)     ; {Print the next character of the name.
 $F32D INC HL        ;
 $F32E CALL $8DCC    ; }
 $F331 DJNZ $F32C    ; Repeat for the three-character name.
 $F333 PUSH DE       ; {Save the screen position and advance the row for the
 $F334 LD A,$2D      ; score digits.
 $F336 ADD A,D       ;
 $F337 LD D,A        ;
 $F338 LD C,$06      ; }
 $F33A CALL $F107    ; Print the score digits via #R$F107.
 $F33D POP DE        ; {Restore the position and advance the column for the
 $F33E LD A,$08      ; next entry.
 $F340 ADD A,E       ;
 $F341 LD E,A        ; }
 $F342 RET           ; Return.
; This entry point is used by the routine at #R$F3AE.
; .
; Compact variant for the All Time Heroes table; uses a row stride
; of #N$04 and a column advance of #N$06 for tighter spacing.
@label=Draw_Score_Entry_Compact
*$F343 LD B,$01      ; {Set the rank digit count and row stride.
 $F345 LD C,$04      ; }
 $F347 PUSH HL       ; {Stash the name pointer and screen position on the
 $F348 PUSH DE       ; stack.}
 $F349 LD HL,$C503   ; {Call #R$F109 using #R$C503.
 $F34C CALL $F109    ; }
 $F34F POP DE        ; {Restore the screen position and name pointer from the
 $F350 POP HL        ; stack.}
 $F351 LD A,$16      ; {Position the cursor and print the closing parenthesis
 $F353 CALL $8DCC    ; character.
 $F356 LD A,D        ;
 $F357 ADD A,$08     ;
 $F359 CALL $8DCC    ;
 $F35C LD A,E        ;
 $F35D CALL $8DCC    ;
 $F360 LD A,$29      ;
 $F362 CALL $8DCC    ; }
 $F365 LD A,$16      ; {Position the cursor for the score entry name.
 $F367 CALL $8DCC    ;
 $F36A LD A,D        ;
 $F36B ADD A,$0D     ;
 $F36D CALL $8DCC    ;
 $F370 LD A,E        ;
 $F371 CALL $8DCC    ; }
 $F374 LD B,$03      ; Set the name character loop counter.
@label=Draw_Score_Entry_Compact_Name_Loop
*$F376 LD A,(HL)     ; {Print the next character of the name.
 $F377 INC HL        ;
 $F378 CALL $8DCC    ; }
 $F37B DJNZ $F376    ; Repeat for the three-character name.
 $F37D PUSH DE       ; {Save the screen position and advance the row for the
 $F37E LD A,$1F      ; score digits.
 $F380 ADD A,D       ;
 $F381 LD D,A        ;
 $F382 LD C,$04      ; }
 $F384 CALL $F107    ; Print the score digits via #R$F107.
 $F387 POP DE        ; {Restore the position and advance the column for the
 $F388 LD A,$06      ; next entry.
 $F38A ADD A,E       ;
 $F38B LD E,A        ; }
 $F38C RET           ; Return.

; Messaging: All Time Heroes
@label=Messaging_AllTimeHeroes
t$F38D DEFB $13,$01           ; BRIGHT: #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $F38F DEFB $16,$50,$48       ; PRINT AT #N(#PEEK(#PC+$01)),
                              ; #N(#PEEK(#PC+$02)).
 $F392 DEFB $10,$01           ; Set INK: #INK(#PEEK(#PC+$01)).
 $F394 DEFM "ALL TIME HEROES"
 $F3A3 DEFB $16,$13,$50       ; PRINT AT #N(#PEEK(#PC+$01)),
                              ; #N(#PEEK(#PC+$02)).
 $F3A6 DEFB $10,$06           ; Set INK: #INK(#PEEK(#PC+$01)).
 $F3A8 DEFB $13,$00           ; BRIGHT: #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $F3AA DEFM "1) "
 $F3AD DEFB $1F               ; Terminator.

; Display High Score Screen
;
; Used by the routine at #R$EBC8.
; .
; Displays the high score screen. Prints the five current game scores
; as Robotron Heroes using #R$F2F9, then a second group of five using the
; same routine. Next prints the All Time Heroes table: the top record
; holder name and score are shown at the top, followed by #N$27 all-time
; entries printed in three BCD-indexed columns via #R$F343. Ends with the
; save and load prompt from #R$F45A.
@label=Display_High_Score_Screen
c$F3AE LD HL,$F2D8   ; {Call #R$9006 using #R$F2D8.
 $F3B1 CALL $9006    ; }
 $F3B4 LD A,$01      ; {Set the starting score index and screen position.
 $F3B6 LD D,$1A      ;
 $F3B8 LD E,$1C      ; }
 $F3BA LD HL,$F165   ; Point to #R$F165.
@label=Display_High_Score_Screen_Loop1
*$F3BD LD ($C503),A  ; Set the current score entry index.
 $F3C0 PUSH AF       ; Stash the entry index on the stack.
 $F3C1 CALL $F2F9    ; Draw this score entry.
 $F3C4 POP AF        ; Restore the entry index from the stack.
 $F3C5 INC A         ; Advance to the next score entry.
 $F3C6 CP $06        ; {Repeat until all five entries have been drawn.
 $F3C8 JR NZ,$F3BD   ; }
; Print the second group of five current game scores.
 $F3CA LD D,$89      ; {Set the screen position for the second group of five
 $F3CC LD E,$1C      ; scores.}
@label=Display_High_Score_Screen_Loop2
*$F3CE PUSH AF       ; Stash the entry index on the stack.
 $F3CF CP $0A        ; {Skip the score index remap if not at the tenth entry.
 $F3D1 JR NZ,$F3D5   ; }
 $F3D3 LD A,$10      ; Remap the tenth entry index for display.
@label=Display_High_Score_Screen_Remap
*$F3D5 LD ($C503),A  ; Set the (possibly remapped) entry index.
 $F3D8 CALL $F2F9    ; Draw this score entry.
 $F3DB POP AF        ; Restore the entry index from the stack.
 $F3DC INC A         ; Advance to the next score entry.
 $F3DD CP $0B        ; {Repeat until all ten entries have been drawn.
 $F3DF JR NZ,$F3CE   ; }
; Print the All Time Heroes rankings.
 $F3E1 LD HL,$F38D   ; {Call #R$9006 using #R$F38D.
 $F3E4 CALL $9006    ; }
 $F3E7 LD HL,$F1AB   ; {Call #R$9006 using #R$F1AB.
 $F3EA CALL $9006    ; }
 $F3ED INC HL        ; {Advance past the message and load the top record score.
 $F3EE LD DE,($8000) ; }
 $F3F2 LD A,D        ; {Adjust the display row for the top score entry.
 $F3F3 ADD A,$06     ;
 $F3F5 LD D,A        ; }
 $F3F6 LD C,$06      ; {Print the top score position label.
 $F3F8 CALL $F107    ; }
 $F3FB LD A,$28      ; {Print the opening parenthesis of the record holder
 $F3FD CALL $8DCC    ; name.}
 $F400 LD B,$03      ; Set the name character loop counter.
@label=Display_High_Score_Screen_Name_Loop
*$F402 LD A,(HL)     ; {Load and print each character of the record holder's
 $F403 INC HL        ; name.
 $F404 CALL $8DCC    ; }
 $F407 DJNZ $F402    ; Repeat for the three-character name.
 $F409 LD A,$29      ; {Print the closing parenthesis.
 $F40B CALL $8DCC    ; }
 $F40E LD A,$1A      ; {Send the font select control code.
 $F410 CALL $8DCC    ; }
 $F413 LD A,$00      ; {Send the font parameter byte.
 $F415 CALL $8DCC    ; }
; Print the all-time score entries across three columns.
 $F418 LD A,$02      ; {Set the starting BCD index and position for the first
 $F41A LD D,$14      ; column.
 $F41C LD E,$59      ; }
@label=Display_High_Score_Screen_Col1
*$F41E LD ($C503),A  ; Set the score entry index.
 $F421 PUSH AF       ; Stash the entry index on the stack.
 $F422 CALL $F343    ; Draw this all-time score entry.
 $F425 POP AF        ; Restore the entry index from the stack.
 $F426 ADD A,$01     ; {Advance the BCD index; check if the first column is
 $F428 DAA           ; complete.
 $F429 CP $15        ; }
 $F42B JR NZ,$F41E   ; Repeat for the next entry until the first column is
                     ; done.
 $F42D LD D,$5E      ; {Set the screen position for the second score column.
 $F42F LD E,$59      ; }
@label=Display_High_Score_Screen_Col2
*$F431 LD ($C503),A  ; Set the score entry index.
 $F434 PUSH AF       ; Stash the entry index on the stack.
 $F435 CALL $F343    ; Draw this all-time score entry.
 $F438 POP AF        ; Restore the entry index from the stack.
 $F439 ADD A,$01     ; {Advance the BCD index; check if the second column is
 $F43B DAA           ; complete.
 $F43C CP $28        ; }
 $F43E JR NZ,$F431   ; Repeat for the next entry until the second column is
                     ; done.
 $F440 LD D,$AA      ; {Set the screen position for the third score column.
 $F442 LD E,$59      ; }
@label=Display_High_Score_Screen_Col3
*$F444 LD ($C503),A  ; Set the score entry index.
 $F447 PUSH AF       ; Stash the entry index on the stack.
 $F448 CALL $F343    ; Draw this all-time score entry.
 $F44B POP AF        ; Restore the entry index from the stack.
 $F44C ADD A,$01     ; {Advance the BCD index; check if the third column is
 $F44E DAA           ; complete.
 $F44F CP $41        ; }
 $F451 JR NZ,$F444   ; Repeat for the next entry until the third column is
                     ; done.
 $F453 LD HL,$F45A   ; {Call #R$9006 using #R$F45A.
 $F456 CALL $9006    ; }
 $F459 RET           ; Return.

; Messaging: Save / Load
@label=Messaging_SaveLoad
t$F45A DEFB $16,$18,$A9                            ; PRINT AT
                                                   ; #N(#PEEK(#PC+$01)),
                                                   ; #N(#PEEK(#PC+$02)).
 $F45D DEFB $10,$01                                ; Set INK:
                                                   ; #INK(#PEEK(#PC+$01)).
 $F45F DEFB $13,$01                                ; BRIGHT:
                                                   ; #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $F461 DEFB $1A,$01                                ; Select font:
                                                   ; #N(#PEEK(#PC+$01)).
 $F463 DEFM "'J' TO SAVE HIGH SCORES,'L' TO LOAD."
 $F487 DEFB $1F                                    ; Terminator.

; Draw Colour Flash Rectangle
;
; Used by the routine at #R$F5DA.
; .
; Renders one frame of the extra life colour flash animation. The
; frame index in #REGa controls the inset from the edges: #N$0B paints a
; narrow band near the centre of the attribute area; #N$00 fills the full
; screen border. Each call fills the top row, the left and right border
; cells of each middle row, and the bottom row with the flash colour.
;
; A Frame index (#N$00-#N$0B); lower values produce a wider rectangle
@label=Draw_Colour_Flash_Rectangle
c$F488 LD HL,$5800   ; Point to the start of the attribute area.
 $F48B LD C,A        ; {Copy the frame index to #REGbc and #REGde.
 $F48C LD B,$00      ;
 $F48E LD E,A        ;
 $F48F LD D,$00      ; }
 $F491 SLA E         ; {Shift #REGde left by #N$05 to compute the attribute row
 $F493 RL D          ; offset.
 $F495 SLA E         ;
 $F497 RL D          ;
 $F499 SLA E         ;
 $F49B RL D          ;
 $F49D SLA E         ;
 $F49F RL D          ;
 $F4A1 SLA E         ;
 $F4A3 RL D          ; }
 $F4A5 ADD HL,DE     ; {Point to the starting attribute cell for this frame.
 $F4A6 ADD HL,BC     ; }
 $F4A7 PUSH HL       ; Stash the starting attribute address on the stack.
 $F4A8 LD A,$20      ; {Calculate the top row fill width and set the loop
 $F4AA SUB C         ; counter.
 $F4AB SUB C         ;
 $F4AC LD B,A        ; }
 $F4AD LD ($C506),A  ; Save the row fill width.
 $F4B0 LD A,($C507)  ; Load the flash colour.
; Fill the top row of the rectangle.
@label=Draw_Colour_Flash_Rectangle_Top
*$F4B3 LD (HL),A     ; {Fill the top row with the flash colour.
 $F4B4 INC HL        ;
 $F4B5 DJNZ $F4B3    ; }
 $F4B7 POP HL        ; {Restore the row pointer and advance to the next
 $F4B8 LD DE,$0020   ; attribute row.
 $F4BB ADD HL,DE     ; }
 $F4BC LD A,$16      ; {Calculate the middle row count; jump to #R$F4E0 if
 $F4BE SUB C         ; none.
 $F4BF SUB C         ;
 $F4C0 JR Z,$F4E0    ; }
 $F4C2 LD B,A        ; Set the middle section row counter.
 $F4C3 LD A,($C506)  ; {Calculate the stride to the far border cell and save
 $F4C6 DEC A         ; it.
 $F4C7 LD E,A        ;
 $F4C8 LD D,$00      ;
 $F4CA LD ($C504),DE ; }
 $F4CE LD A,($C507)  ; Load the flash colour.
; For each middle row, paint the left and right border cells.
@label=Draw_Colour_Flash_Rectangle_Middle
*$F4D1 PUSH HL       ; {Paint the left and right border cells and advance to
 $F4D2 LD (HL),A     ; the next row.
 $F4D3 LD DE,($C504) ;
 $F4D7 ADD HL,DE     ;
 $F4D8 LD (HL),A     ;
 $F4D9 POP HL        ;
 $F4DA LD DE,$0020   ;
 $F4DD ADD HL,DE     ;
 $F4DE DJNZ $F4D1    ; }
; Fill the bottom row of the rectangle.
@label=Draw_Colour_Flash_Rectangle_Bottom
*$F4E0 LD A,($C506)  ; {Set up to fill the bottom row with the flash colour.
 $F4E3 LD B,A        ;
 $F4E4 LD A,($C507)  ; }
@label=Draw_Colour_Flash_Rectangle_Bottom_Fill
*$F4E7 LD (HL),A     ; {Fill the bottom row with the flash colour.
 $F4E8 INC HL        ;
 $F4E9 DJNZ $F4E7    ; }
 $F4EB RET           ; Return.

; Attract Mode Loop
;
; Used by the routines at #R$EBBC and #R$EBC8.
; .
; Clears the playfield, sets the background colour to #COLOUR$46, draws
; the title screen layout, and loads the strip blit parameters, then counts
; down #N$32 frames. Each frame checks for BREAK, S key and tape key
; presses, advances the title animation and colour cycle, then jumps to
; the high score entry screen at #R$EBC8 when the counter reaches zero.
@label=Attract_Mode_Loop
c$F4EC CALL $D070    ; Clear the playfield and reset sprite state via #R$D070.
 $F4EF LD A,$46      ; {Call #R$D07E using #COLOUR$46.
 $F4F1 CALL $D07E    ; }
 $F4F4 CALL $F83C    ; Draw the title screen layout via #R$F83C.
 $F4F7 CALL $F637    ; Load the title strip blit parameters via #R$F637.
 $F4FA LD A,$32      ; Initialise the attract mode frame counter to #N$32.
@label=Attract_Mode_Frame_Loop
*$F4FC LD ($C4F8),A  ; Write the frame counter to *#R$C4F8.
 $F4FF CALL $ECE6    ; Check for the BREAK key combination via #R$ECE6.
 $F502 CALL $ECFB    ; Check for the S key via #R$ECFB.
 $F505 CALL $ED10    ; Check for tape save/load keys (J/L) via #R$ED10.
 $F508 CALL $ED71    ; Restart the high score display if any key is held via
                     ; #R$ED71.
 $F50B CALL $F7EE    ; Advance the title screen animation frame via #R$F7EE.
 $F50E CALL $F51D    ; Advance the title screen colour cycle via #R$F51D.
 $F511 CALL $F5A0    ; Step the attribute colour ring via #R$F5A0.
 $F514 LD A,($C4F8)  ; Load the attract mode frame counter from *#R$C4F8.
 $F517 DEC A         ; Decrement the attract mode frame counter.
 $F518 JR NZ,$F4FC   ; Loop back to #R$F4FC until the counter reaches zero.
 $F51A JP $EBC8      ; Jump to the high score entry screen at #R$EBC8.

; Advance Colour Cycle
;
; Used by the routine at #R$F4EC.
; .
; Advances the colour cycling animation by one step. Scans all 768
; screen attribute cells and replaces cells matching #N$47 with the next
; colour from the sequence at #R$F54D, then immediately replaces all cells
; matching the following entry with #N$47 to prime the next cycle step.
@label=Advance_Colour_Cycle
c$F51D LD HL,($F554) ; Load the colour cycle table pointer.
 $F520 LD E,(HL)     ; Read the replacement colour from the current table
                     ; entry.
 $F521 LD A,$47      ; {Set the attribute value to be replaced.
 $F523 LD D,A        ; }
 $F524 CALL $F53B    ; Scan the attribute area and apply the colour
                     ; replacement.
 $F527 LD HL,($F554) ; {Re-read and advance the colour cycle pointer.
 $F52A INC HL        ; }
@label=Advance_Colour_Cycle_Next
*$F52B LD ($F554),HL ; Save the updated colour cycle pointer.
 $F52E LD A,(HL)     ; {Read the next table entry and check for the end
 $F52F CP $FF        ; sentinel.
 $F531 LD D,A        ; }
 $F532 LD E,$47      ; {Set up to restore the marker colour and scan again.
 $F534 JR NZ,$F53B   ; }
 $F536 LD HL,$F54D   ; {Reset the colour cycle pointer to the table start.
 $F539 JR $F52B      ; }
; This entry point is used by the routine at #R$F5A0.
; .
; Scan all 768 screen attribute cells and replace any cell colour
; matching the target with the replacement colour.
@label=Advance_Colour_Cycle_Scan
*$F53B LD HL,$5800   ; {Set up to scan all 768 screen attribute cells.
 $F53E LD BC,$0300   ; }
@label=Advance_Colour_Cycle_Scan_Loop
*$F541 CP (HL)       ; {Skip the cell if it does not match the target colour.
 $F542 JR NZ,$F545   ; }
 $F544 LD (HL),E     ; Write the replacement colour to this attribute cell.
@label=Advance_Colour_Cycle_Loop_Next
*$F545 DEC BC        ; {Advance to the next cell and reload the target colour.
 $F546 LD A,B        ;
 $F547 OR C          ;
 $F548 INC HL        ;
 $F549 LD A,D        ; }
 $F54A JR NZ,$F541   ; Loop back until all attribute cells are scanned.
 $F54C RET           ; Return.

; Colour Cycle Table
;
; Sequence of ZX Spectrum attribute byte values used to drive the
; colour cycling animation. Each byte specifies the colour to write;
; #N$FF is the end-of-sequence sentinel that resets the pointer to the
; table start.
@label=Colour_Cycle_Table
b$F54D DEFB $01,$05,$02,$04,$03,$06,$FF

; Screen Colour Cycle Pointer
;
; Self-modifying pointer into #R$F54D. Holds the address of the
; next colour cycle entry to apply on the next call to #R$F51D.
@label=Screen_Colour_Cycle_Pointer
g$F554 DEFW $F54D

; Data block at F556
b$F556 DEFB $00,$00

; Intro Sprite Table
;
; Table of #N$17 three-byte entries describing the position of each
; sprite on the intro screen. Each entry holds the Y pixel row at +#N$00,
; the X byte column at +#N$01, and the attribute byte at +#N$02.
@label=Intro_Sprite_Table
b$F558 DEFB $06,$00,$04
 $F55B DEFB $03,$00,$08
 $F55E DEFB $04,$00,$0C
 $F561 DEFB $02,$00,$10
 $F564 DEFB $05,$00,$14
 $F567 DEFB $01,$00,$18
 $F56A DEFB $06,$00,$1C
 $F56D DEFB $03,$20,$1C
 $F570 DEFB $04,$40,$1C
 $F573 DEFB $02,$60,$1C
 $F576 DEFB $05,$80,$1C
 $F579 DEFB $01,$A0,$1C
 $F57C DEFB $06,$A0,$18
 $F57F DEFB $03,$A0,$14
 $F582 DEFB $04,$A0,$10
 $F585 DEFB $02,$A0,$0C
 $F588 DEFB $05,$A0,$08
 $F58B DEFB $01,$A0,$04
 $F58E DEFB $06,$A0,$00
 $F591 DEFB $03,$80,$00
 $F594 DEFB $04,$60,$00
 $F597 DEFB $02,$40,$00
 $F59A DEFB $05,$20,$00
 $F59D DEFB $01

; Intro Colour Cycle Pointer
@label=Intro_Colour_Cycle_Pointer
g$F59E DEFW $F5B7

; Advance Intro Colour Cycle
;
; Used by the routine at #R$F4EC.
; .
; Advances the intro screen colour cycling effect by one step.
; Reads source and replacement colours from #R$F5B7 via the pointer at
; #R$F59E, then scans all 768 attribute cells and replaces every cell
; matching the source colour with the replacement.
@label=Advance_Intro_Colour_Cycle
c$F5A0 LD HL,($F59E) ; {Load the colour cycle pointer and read the source
 $F5A3 LD D,(HL)     ; colour.
 $F5A4 INC HL        ; }
@label=Advance_Intro_Colour_Cycle_Read
*$F5A5 LD A,(HL)     ; {Read the next cycle entry; jump to #R$F5AF if not the
 $F5A6 CP $FF        ; end.
 $F5A8 JR NZ,$F5AF   ; }
 $F5AA LD HL,$F5B7   ; {Reset the colour cycle pointer to the table start.
 $F5AD JR $F5A5      ; }
@label=Advance_Intro_Colour_Cycle_Apply
*$F5AF LD E,A        ; {Set up the replacement and source colours.
 $F5B0 LD A,D        ; }
 $F5B1 LD ($F59E),HL ; Save the updated colour cycle pointer.
 $F5B4 JP $F53B      ; Scan the attribute area and apply the colour swap.

; Intro Colour Cycle Table
;
; Sequence of ZX Spectrum attribute byte values cycling the intro
; screen display colours. Consecutive bytes form source/replacement pairs;
; #N$FF is the end sentinel that wraps the pointer to the table start.
@label=Intro_Colour_Cycle_Table
b$F5B7 DEFB $42      ; #COLOUR(#PEEK(#PC)).
 $F5B8 DEFB $43      ; #COLOUR(#PEEK(#PC)).
 $F5B9 DEFB $46      ; #COLOUR(#PEEK(#PC)).
 $F5BA DEFB $FF      ; Terminator.

; Advance Flash Colour Cycle
;
; Used by the routine at #R$F5DA.
; .
; Advances the extra life colour flash display by one step. Scans all
; 768 attribute cells and replaces each colour with its successor in the
; cycle table at #R$F5D2, rotating the screen through blue, green, cyan,
; white, yellow, magenta, and red on successive calls.
@label=Advance_Flash_Colour_Cycle
c$F5BB LD DE,$5800   ; Point to the start of the attribute area.
@label=Advance_Flash_Colour_Cycle_Scan
*$F5BE LD A,(DE)     ; Read the current attribute cell colour.
 $F5BF LD HL,$F5D2   ; Point to the colour cycle table.
 $F5C2 LD BC,$0007   ; Set the cycle table scan length.
 $F5C5 CPIR          ; Scan the table for a matching colour entry.
 $F5C7 JR NZ,$F5CB   ; Jump to #R$F5CB if no matching entry was found.
 $F5C9 LD A,(HL)     ; {Replace the attribute cell with the next colour in the
 $F5CA LD (DE),A     ; cycle.}
@label=Advance_Flash_Colour_Cycle_Next
*$F5CB INC DE        ; Advance to the next attribute cell.
 $F5CC LD A,D        ; {Loop back until the entire attribute area has been
 $F5CD CP $5B        ; processed.
 $F5CF JR NZ,$F5BE   ; }
 $F5D1 RET           ; Return.

; Flash Colour Cycle Table
;
; Seven-step colour rotation table used by #R$F5BB. Each byte maps to
; the next in the cycle: blue (#N$09) to green (#N$24) to cyan (#N$2D)
; to white (#N$3F) to yellow (#N$36) to magenta (#N$1B) to red (#N$12)
; and back to blue. The eighth byte repeats the first to wrap the cycle.
@label=Flash_Colour_Cycle_Table
b$F5D2 DEFB $09      ; #COLOUR(#PEEK(#PC)).
 $F5D3 DEFB $24      ; #COLOUR(#PEEK(#PC)).
 $F5D4 DEFB $2D      ; #COLOUR(#PEEK(#PC)).
 $F5D5 DEFB $3F      ; #COLOUR(#PEEK(#PC)).
 $F5D6 DEFB $36      ; #COLOUR(#PEEK(#PC)).
 $F5D7 DEFB $1B      ; #COLOUR(#PEEK(#PC)).
 $F5D8 DEFB $12      ; #COLOUR(#PEEK(#PC)).
 $F5D9 DEFB $09      ; #COLOUR(#PEEK(#PC)).

; Extra Life Flash Effect
;
; Used by the routine at #R$C5C1.
; .
; Creates the extra life award flash effect. Sets the attribute fill
; colour to #N$12 and runs #N$0C screen-flash frames, each calling #R$F488
; to repaint the attribute area and #R$F5BB to advance the colour cycling
; animation. The screen is then wiped by #R$D070 and a second pass of
; #N$0C frames plays with the colour cleared.
@label=Extra_Life_Flash
c$F5DA LD A,$12      ; Set the screen flash colour.
 $F5DC LD ($C507),A  ; Write the flash colour to the attribute fill register.
 $F5DF LD A,$0B      ; Set the flash loop counter.
@label=Extra_Life_Flash_Loop1
*$F5E1 PUSH AF       ; Stash the loop counter on the stack.
 $F5E2 CALL $F488    ; Repaint the display with the flash colour.
 $F5E5 CALL $F5BB    ; Advance the colour cycling animation.
 $F5E8 POP AF        ; Restore the loop counter from the stack.
 $F5E9 DEC A         ; {Decrease the loop counter and loop back for the next
 $F5EA CP $FF        ; frame.
 $F5EC JR NZ,$F5E1   ; }
; Wipe the screen, clear the flash colour and run a second pass.
 $F5EE CALL $D070    ; Wipe the screen.
 $F5F1 LD A,$00      ; {Clear the attribute fill register.
 $F5F3 LD ($C507),A  ; }
 $F5F6 LD A,$0B      ; Set the second loop counter.
@label=Extra_Life_Flash_Loop2
*$F5F8 PUSH AF       ; Stash the loop counter on the stack.
 $F5F9 CALL $F488    ; Repaint the display with the cleared colour.
 $F5FC CALL $F5BB    ; Advance the colour cycling animation.
 $F5FF POP AF        ; Restore the loop counter from the stack.
 $F600 DEC A         ; {Decrease the loop counter and loop back for the next
 $F601 CP $FF        ; frame.
 $F603 JR NZ,$F5F8   ; }
 $F605 RET           ; Return.

; OR Blit Title Strips
;
; Used by the routine at #R$F637.
; .
; OR-blits horizontal strips of bitmap data from the source pointer in #REGhl
; into the screen buffer, using the four-byte parameter block at #R$C4F9–#R$C4FC.
; *#R$C4F9 seeds the outer strip counter in #REGb; *#R$C4FA drives the screen row
; lookup (with #N$8C00 / #N$8D style indexing); *#R$C4FB is the byte count per strip
; (LDIR length); the loop runs until #REGb reaches *#R$C4FC after each pass.
; Called from #R$F637 with #REGhl pointing at ROM graphics (#R$6D7D and #R$7005).
;
; HL Pointer to source bitmap data in ROM
@label=BlitTitleStrips
c$F606 LD A,($C4F9)  ; {#REGb=*#R$C4F9 (initial strip index for #REGb).
 $F609 LD B,A        ; }
@label=BlitTitleStrips_Strip
*$F60A PUSH BC       ; Stash #REGbc on the stack (strip index and loop state).
 $F60B PUSH HL       ; Stash #REGhl on the stack (source pointer for this
                     ; strip).
; Derive a screen destination from *#R$C4FA and the screen row address
; lookup table; combine with the next source byte and OR into the low byte of
; the destination address.
 $F60C LD L,B        ; #REGl=#REGb (strip index into the row term).
 $F60D LD B,$45      ; #REGb=#N$45 (row address table high-byte base, rotated
                     ; with *#R$C4FA).
 $F60F LD A,($C4FA)  ; {#REGc=*#R$C4FA (row / band parameter).
 $F612 LD C,A        ; }
 $F613 SLA C         ; {Shift #REGc left; rotate into #REGb (table pointer high
 $F615 RL B          ; byte #N$8C / #N$8D).}
 $F617 LD H,$46      ; #REGh=#N$46 (row address table base high byte).
 $F619 SLA L         ; {Shift #REGl left through #REGh (index into the row
 $F61B RL H          ; address table).}
 $F61D LD A,(HL)     ; #REGa=*(#REGhl) (low byte of the screen row base
                     ; address).
 $F61E INC HL        ; Advance #REGhl.
 $F61F LD H,(HL)     ; #REGh=*(#REGhl) (high byte of the screen row base
                     ; address).
 $F620 LD L,A        ; #REGl=#REGa (full row base address in #REGhl).
 $F621 LD A,(BC)     ; #REGa=*(#REGbc) (source bitmap byte).
 $F622 OR L          ; OR with #REGl (low byte of the screen address).
 $F623 LD L,A        ; Write merged low byte back to #REGl.
 $F624 POP DE        ; Restore destination pointer into #REGde from the stack.
 $F625 EX DE,HL      ; Swap #REGde and #REGhl (destination now in #REGhl).
 $F626 LD B,$00      ; Clear #REGb (high byte of LDIR length).
 $F628 LD A,($C4FB)  ; {#REGc=*#R$C4FB (bytes to OR along this strip).
 $F62B LD C,A        ; }
 $F62C LDIR          ; LDIR copies #REGbc bytes from the source bitmap (#REGhl)
                     ; into the strip at #REGde.
 $F62E POP BC        ; Restore #REGbc from the stack.
 $F62F INC B         ; Advance the strip index #REGb by one.
 $F630 LD A,($C4FC)  ; #REGa=*#R$C4FC (terminal strip index).
 $F633 CP B          ; Compare #REGa with #REGb.
 $F634 JR NZ,$F60A   ; Loop back to #R$F60A until all strips for this bitmap
                     ; are done.
 $F636 RET           ; Return.

; Draw Attract Title
;
; Used by the routine at #R$F4EC.
; .
; Attract-mode title setup after the screen is cleared: writes two parameter
; sets to #R$C4F9–#R$C4FC and OR-blits ROM logos from #R$6D7D and #R$7005 via
; #R$F606, fills #N$C0 attribute cells from #N$5920 with #INK$06 (yellow ink on black
; paper), then prints #R$F670 (copyright / Williams credits) via #R$9006. Called
; from #R$F4EC after #R$F83C.
@label=DrawAttractTitle
c$F637 LD HL,$C4F9   ; #REGhl=#R$C4F9 (parameter block).
; First bitmap: parameters #N$28, #N$20, #N$18, #N$43 then source #R$6D7D.
 $F63A LD (HL),$28   ; Write #N$28 to *#R$C4F9.
 $F63C INC HL        ; {Write #N$20 to *#R$C4FA.
 $F63D LD (HL),$20   ; }
 $F63F INC HL        ; {Write #N$18 to *#R$C4FB.
 $F640 LD (HL),$18   ; }
 $F642 INC HL        ; {Write #N$43 to *#R$C4FC.
 $F643 LD (HL),$43   ; }
 $F645 LD HL,$6D7D   ; #REGhl=#R$6D7D (first title / logo bitmap in ROM).
 $F648 CALL $F606    ; Call #R$F606.
 $F64B LD HL,$C4F9   ; Write #N$4A to *#R$C4F9.
; Second bitmap: parameters #N$4A, #N$58, #N$0A, #N$69 then source #R$7005.
 $F64E LD (HL),$4A   ;
 $F650 INC HL        ; {Write #N$58 to *#R$C4FA.
 $F651 LD (HL),$58   ; }
 $F653 INC HL        ; {Write #N$0A to *#R$C4FB.
 $F654 LD (HL),$0A   ; }
 $F656 INC HL        ; {Write #N$69 to *#R$C4FC.
 $F657 LD (HL),$69   ; }
 $F659 LD HL,$7005   ; #REGhl=#R$7005 (second title / logo bitmap in ROM).
 $F65C CALL $F606    ; Call #R$F606.
; Attribute band for the credits line (#N$C0 cells, attribute #INK$06).
 $F65F LD HL,$5920   ; #REGhl=#N$5920 (start within the attribute file
                     ; #N$5800–#N$5AFF).
 $F662 LD B,$C0      ; Set a loop counter in #REGb for #N$C0 attributes.
@label=DrawAttractTitle_FillAttrs
*$F664 LD (HL),$06   ; Write #INK$06 (#N$06) to *#REGhl.
 $F666 INC HL        ; Advance #REGhl.
 $F667 DJNZ $F664    ; Decrease counter and loop back to #R$F664 until the band
                     ; is filled.
 $F669 LD HL,$F670   ; {Call #R$9006 using #R$F670.
 $F66C CALL $9006    ; }
 $F66F RET           ; Return.

; Messaging: Credits
@label=Messaging_Credits
t$F670 DEFB $1A,$01                               ; Select font:
                                                  ; #N(#PEEK(#PC+$01)).
 $F672 DEFB $10,$05                               ; Set INK:
                                                  ; #INK(#PEEK(#PC+$01)).
 $F674 DEFB $11,$00                               ; Set PAPER:
                                                  ; #INK(#PEEK(#PC+$01)).
 $F676 DEFB $12,$00                               ; FLASH:
                                                  ; #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $F678 DEFB $13,$00                               ; BRIGHT:
                                                  ; #MAP(#PEEK(#PC+$01))(OFF,1:ON).
 $F67A DEFB $16,$20,$6E                           ; PRINT AT
                                                  ; #N(#PEEK(#PC+$01)),
                                                  ; #N(#PEEK(#PC+$02)).
 $F67D DEFM $7F," ATARI 1984 ALL RIGHTS RESERVED"
 $F69D DEFB $10,$04                               ; Set INK:
                                                  ; #INK(#PEEK(#PC+$01)).
 $F69F DEFB $16,$20,$7E                           ; PRINT AT
                                                  ; #N(#PEEK(#PC+$01)),
                                                  ; #N(#PEEK(#PC+$02)).
 $F6A2 DEFM "DESIGNED BY WILLIAMS ELECTRONICS"
 $F6C2 DEFB $1F                                   ; Terminator.

; Read Control Input
;
; Used by the routine at #R$CB4F.
; .
; Reads the active control input for the current control mode stored in
; *#R$C4FF. Scales the mode index to a word offset, loads the handler address
; from the table at #R$F6DD, pushes #R$F6D8 as the return address, and jumps
; to the handler. Each handler reads one or more hardware ports and returns
; the direction and fire bits in #REGa. The common landing pad at #R$F6D8
; masks the result to five bits and stores it in #REGb and #REGc.
;
; O:A Active-low direction and fire bits in the lower five bits
; O:B Copy of #REGa; the #N$F7FE row result in split keyboard mode
; O:C Copy of #REGa; the #N$EFFE row result in split keyboard mode
@label=Read_Control_Input
c$F6C3 LD HL,$F6DD   ; {Point to the handler table at #R$F6DD and zero #REGd.
 $F6C6 LD D,$00      ; }
 $F6C8 LD A,($C4FF)  ; {Scale *#R$C4FF to a zero-based word table offset in
 $F6CB DEC A         ; #REGe.
 $F6CC ADD A,A       ;
 $F6CD LD E,A        ; }
 $F6CE ADD HL,DE     ; {Load the handler address from the table.
 $F6CF LD E,(HL)     ;
 $F6D0 INC HL        ;
 $F6D1 LD D,(HL)     ;
 $F6D2 EX DE,HL      ; }
 $F6D3 LD DE,$F6D8   ; {Push the return address.
 $F6D6 PUSH DE       ; }
 $F6D7 JP (HL)       ; Dispatch to the control handler.

; Common Control Input Return
;
; Common control input return routine.
@label=Read_Control_Input_Return
c$F6D8 AND %00011111 ; Keep only the lower five control bits.
 $F6DA LD B,A        ; {Copy the masked input bits to #REGb and #REGc.
 $F6DB LD C,A        ; }
 $F6DC RET           ; Return.

; Control Handler Table
;
; Six-entry word table of control handler addresses, indexed by control
; mode.
@label=Control_Handler_Table
w$F6DD DEFW $F6E9
 $F6DF DEFW $F704
 $F6E1 DEFW $F71E
 $F6E3 DEFW $F73D
 $F6E5 DEFW $F6EE
 $F6E7 DEFW $F752

; Read Keyboard Combined
;
; Control mode #N$01: reads both keyboard rows via #R$F6FA and ANDs
; them together before returning to #R$F6D8.
@label=Read_Control_Keyboard_Combined
c$F6E9 CALL $F6FA    ; Call #R$F6FA to read both keyboard rows.
 $F6EC AND C         ; Combine the two row results.
 $F6ED RET           ; Return to #R$F6D8.

; Read Keyboard Split
;
; Control mode #N$05: reads both keyboard rows separately, returning
; the #N$F7FE row in #REGb and the #N$EFFE row in #REGc.
@label=Read_Control_Keyboard_Split
c$F6EE CALL $F6FA    ; Call #R$F6FA to read both keyboard rows.
 $F6F1 AND %00011111 ; Mask the #N$F7FE row result to five bits.
 $F6F3 LD B,A        ; {Copy the #N$F7FE row result to #REGb and load the
 $F6F4 LD A,C        ; #N$EFFE row.}
 $F6F5 AND %00011111 ; Mask the #N$EFFE row result to five bits.
 $F6F7 LD C,A        ; Store the masked #N$EFFE row result in #REGc.
 $F6F8 POP HL        ; Discard the stacked return address.
 $F6F9 RET           ; Return.

; Read Keyboard Rows
;
; Used by the routines at #R$F6E9 and #R$F6EE.
; .
; Shared keyboard row subroutine. Reads port #N$EFFE into #REGc and
; port #N$F7FE into #REGa.
@label=Read_Keyboard_Rows
c$F6FA LD A,$EF      ; {Read from the keyboard;
 $F6FC IN A,($FE)    ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$EF | 0 | 9 | 8 | 7 | 6 }
                     ; TABLE#}
 $F6FE LD C,A        ; Stash the #N$EFFE row result in #REGc.
 $F6FF LD A,$F7      ; {Read from the keyboard;
 $F701 IN A,($FE)    ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$F7 | 1 | 2 | 3 | 4 | 5 }
                     ; TABLE#}
 $F703 RET           ; Return.

; Read Control Kempston
;
; Control mode #N$02: reads Kempston joystick port #N$1F, remaps the
; active-high bits to the game's active-low five-bit format.
@label=Read_Control_Kempston
c$F704 IN A,($1F)    ; Read the Kempston joystick port.
 $F706 LD B,$00      ; Zero the bit accumulator.
 $F708 RRA           ; {Shuffle the Kempston active-high direction and fire bits into the
 $F709 RR B          ; game's active-low format.
 $F70B RRA           ;
 $F70C RL B          ;
 $F70E RL B          ;
 $F710 RRA           ;
 $F711 RL B          ;
 $F713 RRA           ;
 $F714 RL B          ;
 $F716 RRA           ;
 $F717 RL B          ; }
 $F719 LD A,B        ; {Transfer the remapped bits to #REGa and invert to
 $F71A CPL           ; active-low.}
 $F71B OR %11100000  ; Force the upper three bits high to match the
                     ; inactive-key state.
 $F71D RET           ; Return to #R$F6D8.

; Read Control Sinclair
;
; Control mode #N$03: reads keyboard ports #N$F7FE and #N$EFFE four
; times, extracting one direction or fire bit from each read.
@label=Read_Control_Sinclair
c$F71E LD BC,$F7FE   ; {Read from the keyboard;
 $F721 IN A,(C)      ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$F7 | 1 | 2 | 3 | 4 | 5 }
                     ; TABLE#}
 $F723 OR %11101111  ; Isolate bit 4 from the first row.
 $F725 LD E,A        ; Save the masked result.
 $F726 LD B,$EF      ; {Read from the keyboard;
 $F728 IN A,(C)      ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$EF | 0 | 9 | 8 | 7 | 6 }
                     ; TABLE#}
 $F72A OR %11111110  ; Isolate bit 0 from the second row.
 $F72C AND E         ; {Merge with and save the accumulated result.
 $F72D LD E,A        ; }
 $F72E IN A,(C)      ; Read from the keyboard;
                     ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$EF | 0 | 9 | 8 | 7 | 6 }
                     ; TABLE#
 $F730 OR %11100111  ; Isolate bits 3 and 4 from this read.
 $F732 RRCA          ; {Shift the isolated bits into position.
 $F733 RRCA          ; }
 $F734 AND E         ; {Merge with and save the accumulated result.
 $F735 LD E,A        ; }
 $F736 IN A,(C)      ; Read from the keyboard;
                     ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$EF | 0 | 9 | 8 | 7 | 6 }
                     ; TABLE#
 $F738 OR %11111011  ; Isolate bit 2 from this read.
 $F73A RLCA          ; {Shift into position and merge with the accumulated
 $F73B AND E         ; result.}
 $F73C RET           ; Return to #R$F6D8.

; Read Control Fuller
;
; Control mode #N$04: reads the Fuller Box joystick port #N$7F (active-
; high bits; fire is at bit 7) and remaps direction and fire bits to the
; game's active-low format.
@label=Read_Control_Fuller
c$F73D IN A,($7F)    ; Read from the joystick;
                     ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$7F | UP | DOWN | LEFT | RIGHT | - }
                     ; TABLE#
 $F73F OR %01110000  ; Mask to the relevant direction bits.
 $F741 LD B,A        ; {Save the raw input and rotate one position.
 $F742 RLCA          ; }
 $F743 OR %11111000  ; Force the upper five bits high.
 $F745 LD C,A        ; Save the rotated result.
 $F746 LD A,B        ; Reload the raw input.
 $F747 OR %11110111  ; Isolate bit 3 from the raw input.
 $F749 AND C         ; Merge with the rotated result.
 $F74A LD C,A        ; Save the combined result.
 $F74B LD A,B        ; Reload the raw input.
 $F74C OR %11111011  ; Isolate bit 2 from the raw input.
 $F74E RLCA          ; {Shift the bit into position.
 $F74F RLCA          ; }
 $F750 AND C         ; Merge with the combined result.
 $F751 RET           ; Return to #R$F6D8.

; Read Control Cursor
;
; Cursor keyboard control: reads the Q (up), A (down), O (left) and P
; (right) keys from ports #N$FBFE, #N$FDFE and #N$DFFE, combining the four
; direction bits into the control byte.
@label=Read_Control_Cursor
c$F752 LD BC,$FDFE   ; {Read from the keyboard;
 $F755 IN A,(C)      ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$FD | A | S | D | F | G }
                     ; TABLE#}
 $F757 OR %11111110  ; Isolate bit 0 from the first row.
 $F759 RLCA          ; Shift the bit into position.
 $F75A LD E,A        ; Save the partial result.
 $F75B LD B,$FB      ; Switch to keyboard port #N$FBFE.
 $F75D IN A,(C)      ; Read keyboard port #N$FBFE.
 $F75F OR %11111110  ; Isolate bit 0 from the second row.
 $F761 AND E         ; Merge with the first row result.
 $F762 RLCA          ; {Shift and save the combined result.
 $F763 LD E,A        ; }
 $F764 LD B,$DF      ; Switch to keyboard port #N$DFFE.
 $F766 IN A,(C)      ; Read keyboard port #N$DFFE.
 $F768 OR %11111100  ; Isolate bits 0 and 1 from the third row.
 $F76A RLCA          ; {Shift the bits into position.
 $F76B RLCA          ;
 $F76C RLCA          ; }
 $F76D AND E         ; Merge with the accumulated result.
 $F76E RET           ; Return to #R$F6D8.

; XOR Blit Sprite
;
; Used by the routines at #R$F7EE and #R$F83C.
; .
; Takes the two-byte position entry at #REGhl (byte #N$00 = Y pixel row,
; byte #N$01 = X byte column) and the attribute byte in #REGe (shadow;
; bit 7 set = erase mode, bit 7 clear = draw mode). Computes each screen
; pixel address by reading the row base from the screen row lookup table at #N$8C00
; (indexed by Y) and adding the X column byte offset stored in shadow #REGd.
; XORs #N$04 bytes of the fixed bitmap at #N$6CFC into consecutive screen pixel
; memory for each of #N$20 pixel rows (#N$04 attribute-cell rows of #N$08 pixel
; rows each). After the first pixel row of each attribute-cell row, derives the
; attribute memory high byte from the pixel address high byte and writes the
; attribute byte to #N$04 consecutive attribute cells — suppressed in erase mode.
;
; HL Pointer to the two-byte position entry (Y pixel row at +0, X byte column
; .  at +1)
;
; Initialise the bitmap source (#REGhl=#N$6CFC via EX DE,HL) and compute #REGix
; into the screen row lookup table at #N$8C00, indexed by the Y pixel row. The row is
; shifted left into the lookup table index directly (#REGix=#N$8C00 + Y × #N$02). Store
; the X column byte offset in shadow #REGd and set the outer loop count
; (#REGc=#N$04, shadow, one iteration per attribute-cell row of #N$08 pixel rows).
@label=XorBlitSprite
c$F76F LD DE,$6CFC    ; #REGde=#N$6CFC (bitmap source base address; becomes
                      ; #REGhl via EX DE,HL).
 $F772 LD B,$46       ; #REGb=#N$46 (initial high byte; becomes #N$8C or #N$8D
                      ; after RL #REGb).
 $F774 LD C,(HL)      ; #REGc=Y pixel row (byte #N$00 of the position entry).
 $F775 INC HL         ; Advance #REGhl to byte #N$01 (X byte column).
 $F776 SLA C          ; SLA #REGc; carry = bit 7 of Y (selects high byte #N$8C
                      ; or #N$8D).
 $F778 RL B           ; RL #REGb; #REGb=#N$8C (or #N$8D if carry set) — high
                      ; byte of lookup table pointer.
 $F77A PUSH BC        ; Stash #REGbc on the stack.
 $F77B LD A,(HL)      ; #REGa=X byte column (byte #N$01 of the position entry).
 $F77C EXX            ; Switch to the shadow registers.
 $F77D LD D,A         ; #REGd=X byte column offset (held in shadow across all
                      ; loop iterations).
 $F77E EXX            ; Switch back to the normal registers.
 $F77F POP IX         ; POP #REGix; #REGix=#N$8C00 + Y × #N$02 (pointer into
                      ; the screen row address table).
 $F781 EX DE,HL       ; #REGhl=#N$6CFC (bitmap source pointer); #REGde=old
                      ; #REGhl (discarded).
 $F782 EXX            ; Switch to the shadow registers.
 $F783 LD C,$04       ; #REGc=#N$04 (shadow, outer loop count: #N$04
                      ; attribute-cell rows).
 $F785 EXX            ; Switch back to the normal registers.
; Outer loop (#N$04 iterations, one per attribute-cell row of #N$08 pixel rows).
; Compute the screen pixel address for the first row of this attribute cell:
; read shadow #REGd (X column), add the lookup table low byte from *(#REGix) to give
; #REGe, then read the lookup table high byte from *(#REGix+#N$01) into #REGd. Advance
; #REGix by two to the next lookup table entry.
@label=XorBlitSprite_OuterLoop
*$F786 EXX            ; Switch to the shadow registers.
 $F787 LD A,D         ; #REGa=#REGd (X byte column offset).
 $F788 EXX            ; Switch back to the normal registers.
 $F789 ADD A,(IX+$00) ; #REGa += *(#REGix) (row table low byte); low byte of
                      ; screen pixel address.
 $F78C INC IX         ; Advance #REGix to the lookup table high byte.
 $F78E LD E,A         ; #REGe=#REGa (low byte of screen pixel address).
 $F78F LD D,(IX+$00)  ; #REGd=*(#REGix) (row table high byte of screen pixel
                      ; address).
 $F792 INC IX         ; Advance #REGix to the next lookup table entry.
; XOR #N$04 consecutive bytes of the bitmap at (#REGhl)–(#REGhl+#N$03) into
; screen pixel memory at (#REGde)–(#REGde+#N$03), advancing both pointers.
 $F794 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F795 XOR (HL)       ;
 $F796 LD (DE),A      ;
 $F797 INC DE         ;
 $F798 INC HL         ; }
 $F799 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F79A XOR (HL)       ;
 $F79B LD (DE),A      ;
 $F79C INC DE         ;
 $F79D INC HL         ; }
 $F79E LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F79F XOR (HL)       ;
 $F7A0 LD (DE),A      ;
 $F7A1 INC HL         ;
 $F7A2 INC DE         ; }
 $F7A3 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGhl.
 $F7A4 XOR (HL)       ;
 $F7A5 LD (DE),A      ;
 $F7A6 INC HL         ; }
; Derive the attribute memory address high byte from the current pixel address
; high byte in #REGd. Three right-rotations expose the screen-third index in
; bits #N$00–#N$01; OR with #N$58 gives the attribute area high byte (#N$58–#N$5B).
 $F7A7 LD A,D         ; {#REGd = (RRCA × #N$03 of #REGd) AND #N$03 OR #N$58
 $F7A8 RRCA           ; (attribute address high byte).
 $F7A9 RRCA           ;
 $F7AA RRCA           ;
 $F7AB AND $03        ;
 $F7AD OR $58         ;
 $F7AF LD D,A         ; }
; Test the erase-mode flag (bit 7 of shadow #REGe). If set, skip writing
; the attribute byte so that the background colour is preserved during erase.
 $F7B0 EXX            ; {Switch to shadow; #REGa=#REGe (attribute byte); switch
 $F7B1 LD A,E         ; back.
 $F7B2 EXX            ; }
 $F7B3 BIT 7,A        ; Test bit 7 of #REGa (erase-mode flag).
 $F7B5 JR NZ,$F7BE    ; If in erase mode, jump to #R$F7BE (skip attribute
                      ; write).
 $F7B7 LD (DE),A      ; {Write attribute byte to (#REGde), (#REGde−#N$01),
 $F7B8 DEC DE         ; (#REGde−#N$02) and (#REGde−#N$03).
 $F7B9 LD (DE),A      ;
 $F7BA DEC DE         ;
 $F7BB LD (DE),A      ;
 $F7BC DEC DE         ;
 $F7BD LD (DE),A      ; }
@label=XorBlitSprite_InnerSetup
*$F7BE EXX            ; {Switch to shadow; #REGb=#N$07 (remaining pixel rows in
 $F7BF LD B,$07       ; this attribute-cell row); switch back.
 $F7C1 EXX            ; }
; Inner loop (#N$07 iterations, one per remaining pixel row in this attribute-cell
; row). Compute the screen address from the lookup table and XOR #N$04 bitmap bytes into
; pixel memory. No attribute write.
@label=XorBlitSprite_InnerLoop
*$F7C2 EXX            ; Switch to the shadow registers.
 $F7C3 LD A,D         ; #REGa=#REGd (X byte column offset).
 $F7C4 EXX            ; Switch back to the normal registers.
 $F7C5 ADD A,(IX+$00) ; #REGa += *(#REGix) (row table low byte for this pixel
                      ; row).
 $F7C8 INC IX         ; Advance #REGix to the lookup table high byte.
 $F7CA LD E,A         ; #REGe=#REGa (low byte of screen pixel address).
 $F7CB LD D,(IX+$00)  ; #REGd=*(#REGix) (row table high byte of screen pixel
                      ; address).
 $F7CE INC IX         ; Advance #REGix to the next lookup table entry.
 $F7D0 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F7D1 XOR (HL)       ;
 $F7D2 LD (DE),A      ;
 $F7D3 INC DE         ;
 $F7D4 INC HL         ; }
 $F7D5 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F7D6 XOR (HL)       ;
 $F7D7 LD (DE),A      ;
 $F7D8 INC DE         ;
 $F7D9 INC HL         ; }
 $F7DA LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F7DB XOR (HL)       ;
 $F7DC LD (DE),A      ;
 $F7DD INC HL         ;
 $F7DE INC DE         ; }
 $F7DF LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGhl.
 $F7E0 XOR (HL)       ;
 $F7E1 LD (DE),A      ;
 $F7E2 INC HL         ; }
 $F7E3 EXX            ; {Switch to shadow; decrement #REGb (inner pixel row
 $F7E4 DEC B          ; counter); switch back.
 $F7E5 EXX            ; }
 $F7E6 JR NZ,$F7C2    ; Loop back to #R$F7C2 until all #N$07 pixel rows are
                      ; blitted.
 $F7E8 EXX            ; {Switch to shadow; decrement #REGc (outer attribute-row
 $F7E9 DEC C          ; counter); switch back.
 $F7EA EXX            ; }
 $F7EB JR NZ,$F786    ; Loop back to #R$F786 until all #N$04 attribute-cell
                      ; rows are blitted.
 $F7ED RET            ; Return.

; Animate Intro Sprites
;
; Used by the routine at #R$F4EC.
; .
; Iterates over the #N$18 three-byte entries in the sprite table at #R$F558
; (Y pixel row at +#N$00, X byte column at +#N$01, attribute byte at +#N$02) to
; animate the border march effect on the intro screen. For each entry, erases
; the sprite at its current position (calls #R$F76F with bit 7 of #REGe set
; in shadow to suppress attribute writes), advances the position by one step
; along a rectangular path (#N$08 pixel rows vertically or #N$01 byte column
; horizontally: right across Y=#N$00, down the right side at X=#N$1C, left
; across Y=#N$A0, up the left side at X=#N$00), then redraws the sprite at the
; new position (calls #R$F76F with bit 7 clear to write the attribute).
; Called once per frame by the attract mode loop at #R$F4EC.
@label=AnimateIntroSprites
c$F7EE LD B,$18      ; #REGb=#N$18 (loop counter: #N$24 sprite entries).
 $F7F0 LD HL,$F558   ; #REGhl=#R$F558 (attribute byte position of the first
                     ; entry).
@label=AnimateIntroSprites_Loop
*$F7F3 LD A,(HL)     ; #REGa=attribute byte from the current entry.
 $F7F4 EXX           ; {Switch to shadow; #REGe=attribute byte; SET bit 7
 $F7F5 LD E,A        ; (erase-mode flag for #R$F76F); switch back.
 $F7F6 SET 7,E       ;
 $F7F8 EXX           ; }
 $F7F9 DEC HL        ; {Back #REGhl two bytes to the Y pixel row (start of
 $F7FA DEC HL        ; entry).}
 $F7FB PUSH HL       ; {Stash #REGhl (entry start) and #REGbc on the stack.
 $F7FC PUSH BC       ; }
 $F7FD CALL $F76F    ; Call #R$F76F to erase the sprite at its current
                     ; position.
 $F800 POP BC        ; {Restore #REGbc and #REGhl (entry start).
 $F801 POP HL        ; }
; Advance the sprite position by one step along the rectangular border path.
; Y pixel row is at *(#REGhl), X byte column at *(#REGhl+#N$01). Steps are
; #N$08 pixel rows vertically or #N$01 byte column horizontally. Wraps at
; X=#N$1C (right boundary, drop down a row) and Y=#N$A0 (bottom boundary,
; scroll left).
 $F802 XOR A         ; #REGa=#N$00.
 $F803 CP (HL)       ; {If Y position (*#REGhl) = #N$00, jump to #R$F821 (top
 $F804 JR Z,$F821    ; row: scroll X instead of Y).}
 $F806 INC HL        ; {Read X position (*(#REGhl+#N$01)) and compare with
 $F807 CP (HL)       ; #N$00; restore #REGhl.
 $F808 DEC HL        ; }
 $F809 JR NZ,$F811   ; If X!=#N$00, jump to #R$F811.
 $F80B LD A,(HL)     ; {Y −= #N$08 (on left side, scroll up); jump to #R$F829.
 $F80C SUB $08       ;
 $F80E LD (HL),A     ;
 $F80F JR $F829      ; }
@label=AnimateIntroSprites_CheckBoundary
*$F811 LD A,$A0      ; {#REGa=#N$A0; compare with Y position.
 $F813 CP (HL)       ; }
 $F814 JR NZ,$F81B   ; If Y!=#N$A0, jump to #R$F81B (not at bottom boundary,
                     ; scroll down).
 $F816 INC HL        ; {X−− (at bottom boundary, scroll left); jump to #R$F828.
 $F817 DEC (HL)      ;
 $F818 JR $F828      ; }
@label=AnimateIntroSprites_DropRow
*$F81A DEC HL        ; Back #REGhl to the Y byte.
@label=AnimateIntroSprites_ScrollDown
*$F81B LD A,(HL)     ; {Y += #N$08 (scroll down); jump to #R$F829.
 $F81C ADD A,$08     ;
 $F81E LD (HL),A     ;
 $F81F JR $F829      ; }
; Top row (Y=#N$00): if X has reached the right boundary (#N$1C), drop a row
; (Y+=#N$08); otherwise scroll right (X++).
@label=AnimateIntroSprites_ScrollX
*$F821 INC HL        ; {Read X (*(#REGhl+#N$01)); if X=#N$1C jump to #R$F81A
 $F822 LD A,(HL)     ; (drop a row); otherwise X++.
 $F823 CP $1C        ;
 $F825 JR Z,$F81A    ; }
 $F827 INC (HL)      ; X++ (scroll right).
@label=AnimateIntroSprites_RestoreHL
*$F828 DEC HL        ; Restore #REGhl to the Y byte position.
@label=AnimateIntroSprites_Draw
*$F829 PUSH HL       ; {Stash #REGhl (entry start) and #REGbc on the stack.
 $F82A PUSH BC       ; }
 $F82B EXX           ; {Switch to shadow; RES bit 7 of #REGe (clear erase-mode
 $F82C RES 7,E       ; flag for draw pass); switch back.
 $F82E EXX           ; }
 $F82F CALL $F76F    ; Call #R$F76F to draw the sprite at the updated position.
 $F832 POP BC        ; {Restore #REGbc and #REGhl (entry start).
 $F833 POP HL        ; }
 $F834 INC HL        ; {Advance #REGhl by #N$05 to the attribute byte of the
 $F835 INC HL        ; next entry.
 $F836 INC HL        ;
 $F837 INC HL        ;
 $F838 INC HL        ; }
 $F839 DJNZ $F7F3    ; Decrease counter and loop back to #R$F7F3.
 $F83B RET           ; Return.

; Draw Intro Sprites
;
; Used by the routine at #R$F4EC.
; .
; Iterates over the #N$18 three-byte entries in the sprite table at #R$F558
; (Y pixel row at +#N$00, X byte column at +#N$01, attribute byte at +#N$02),
; calling #R$F76F once per entry to draw each sprite in its initial position.
; Called once during attract-mode setup at #R$F4EC before the animation loop
; begins.
@label=DrawIntroSprites
c$F83C LD B,$18      ; #REGb=#N$18 (loop counter: #N$24 sprite entries).
 $F83E LD HL,$F558   ; #REGhl=#R$F558 (attribute byte position of the first
                     ; entry).
@label=DrawIntroSprites_Loop
*$F841 LD A,(HL)     ; #REGa=attribute byte from the current entry.
 $F842 EXX           ; Switch to the shadow registers.
 $F843 LD E,A        ; #REGe=attribute byte (passed to #R$F76F as the draw-mode
                     ; attribute).
 $F844 EXX           ; Switch back to the normal registers.
 $F845 PUSH BC       ; {Stash #REGbc and #REGhl on the stack.
 $F846 PUSH HL       ; }
 $F847 DEC HL        ; {Back #REGhl two bytes to the Y pixel row (start of
 $F848 DEC HL        ; entry).}
 $F849 CALL $F76F    ; Call #R$F76F to draw the sprite at the position held in
                     ; the current entry.
 $F84C POP HL        ; {Restore #REGhl and #REGbc from the stack.
 $F84D POP BC        ; }
 $F84E INC HL        ; {Advance #REGhl by three to the attribute byte of the
 $F84F INC HL        ; next entry.
 $F850 INC HL        ; }
 $F851 DJNZ $F841    ; Decrease counter and loop back to #R$F841.
 $F853 RET           ; Return.

