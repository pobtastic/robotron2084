 $C8FA LD (HL),A     ;
 $C8FB EX DE,HL      ; }
 $C8FC EXX           ; {Fetch the column offset from alternate #REGc.
 $C8FD LD A,C        ;
 $C8FE EXX           ; }
 $C8FF ADD A,(HL)    ; {Compute the sixth screen row address from the entity
 $C900 LD E,A        ; record.
 $C901 INC HL        ;
 $C902 LD D,(HL)     ;
 $C903 INC HL        ; }
 $C904 LD A,(BC)     ; {XOR-render 2 sprite bytes at the sixth screen row and
 $C905 EX DE,HL      ; restore.
 $C906 XOR (HL)      ;
 $C907 LD (HL),A     ;
 $C908 INC BC        ;
 $C909 INC HL        ;
 $C90A LD A,(BC)     ;
 $C90B INC BC        ;
 $C90C XOR (HL)      ;
 $C90D LD (HL),A     ;
 $C90E EX DE,HL      ; }
 $C90F EXX           ; {Fetch the column offset from alternate #REGc.
 $C910 LD A,C        ;
 $C911 EXX           ; }
 $C912 ADD A,(HL)    ; {Compute the seventh screen row address from the entity
 $C913 LD E,A        ; record.
 $C914 INC HL        ;
 $C915 LD D,(HL)     ;
 $C916 INC HL        ; }
 $C917 LD A,(BC)     ; {XOR-render 2 sprite bytes at the seventh screen row and
 $C918 EX DE,HL      ; restore the entity record pointer.
