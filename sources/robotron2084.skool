 $F6FC IN A,($FE)    ;
 $F6FE LD C,A        ;
 $F6FF LD A,$F7      ;
 $F701 IN A,($FE)    ;
 $F703 RET           ;
 $F704 IN A,($1F)    ;
 $F706 LD B,$00      ;
 $F708 RRA           ;
 $F709 RR B          ;
 $F70B RRA           ;
 $F70C RL B          ;
 $F70E RL B          ;
 $F710 RRA           ;
 $F711 RL B          ;
 $F713 RRA           ;
 $F714 RL B          ;
 $F716 RRA           ;
 $F717 RL B          ;
 $F719 LD A,B        ;
 $F71A CPL           ;
 $F71B OR $E0        ;
 $F71D RET           ;
 $F71E LD BC,$F7FE   ;
 $F721 IN A,(C)      ;
 $F723 OR $EF        ;
 $F725 LD E,A        ;
 $F726 LD B,$EF      ;
 $F728 IN A,(C)      ;
 $F72A OR $FE        ;
 $F72C AND E         ;
 $F72D LD E,A        ;
 $F72E IN A,(C)      ;
 $F730 OR $E7        ;
 $F732 RRCA          ;
 $F733 RRCA          ;
 $F734 AND E         ;
 $F735 LD E,A        ;
 $F736 IN A,(C)      ;
 $F738 OR $FB        ;
 $F73A RLCA          ;
 $F73B AND E         ;
 $F73C RET           ;
 $F73D IN A,($7F)    ;
 $F73F OR $70        ;
 $F741 LD B,A        ;
 $F742 RLCA          ;
 $F743 OR $F8        ;
 $F745 LD C,A        ;
 $F746 LD A,B        ;
 $F747 OR $F7        ;
 $F749 AND C         ;
