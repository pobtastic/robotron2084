; Routine at ECA4
;
; Used by the routines at #R$EBC8 and #R$ED10.
c$ECA4 LD HL,$4000   ; #REGhl=#N$4000.
 $ECA7 LD DE,$4001   ; #REGde=#N$4001 (screen buffer location).
 $ECAA LD BC,$1800   ; #REGbc=#N$1800.
 $ECAD LD (HL),$00   ; Write #N$00 to *#REGhl.
 $ECAF LDIR          ; LDIR.
 $ECB1 LD BC,$0300   ; #REGbc=#N$0300.
 $ECB4 LD (HL),A     ; Write #REGa to *#REGhl.
 $ECB5 LDIR          ; LDIR.
 $ECB7 AND %00111000 ; Keep only bits 3-5.
 $ECB9 BIT 5,A       ; Test bit 5 of #REGa.
 $ECBB JR NZ,$ECBF   ; Jump to #R$ECBF if ?? is not equal to #N$00.
 $ECBD XOR %00000111 ; Flip bits 0-2.
*$ECBF LD ($5C48),A  ; #HTML(Write #REGa to *<a
                     ; href="https://skoolkid.github.io/rom/asm/5C48.html">BORDCR</a>.)
 $ECC2 AND %00111000 ; Keep only bits 3-5.
 $ECC4 RRCA          ; {Rotate right with carry three positions.
 $ECC5 RRCA          ;
 $ECC6 RRCA          ; }
 $ECC7 OUT ($FE),A   ; Set border to the colour held by #REGa.
 $ECC9 RET           ; Return.
; This entry point is used by the routine at #R$EBC8.
