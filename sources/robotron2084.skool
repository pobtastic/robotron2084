 $C91D LD A,(BC)     ;
 $C91E INC BC        ;
 $C91F XOR (HL)      ;
 $C920 LD (HL),A     ;
 $C921 EX DE,HL      ; }
; Row 8: XOR-render the final sprite row and write the entity colour
; to the flanking attribute cells if in draw mode.
 $C922 EXX           ; {Fetch the column offset from alternate #REGc.
 $C923 LD A,C        ;
 $C924 EXX           ; }
 $C925 ADD A,(HL)    ; {Compute the eighth screen row address from the entity
 $C926 LD E,A        ; record.
 $C927 INC HL        ;
 $C928 LD D,(HL)     ;
 $C929 INC HL        ; }
 $C92A LD A,(BC)     ; {XOR-render 2 sprite bytes at the eighth screen row.
 $C92B EX DE,HL      ;
 $C92C XOR (HL)      ;
 $C92D LD (HL),A     ;
 $C92E INC BC        ;
 $C92F INC HL        ;
 $C930 LD A,(BC)     ;
 $C931 INC BC        ;
 $C932 XOR (HL)      ;
 $C933 LD (HL),A     ; }
 $C934 EXX           ; {Return without writing attributes if in erase mode.
 $C935 LD A,D        ;
 $C936 AND A         ;
 $C937 EXX           ;
 $C938 RET Z         ; }
 $C939 LD A,H        ; {Convert the screen address high byte to an attribute
 $C93A RRCA          ; address.
 $C93B RRCA          ;
 $C93C RRCA          ; }
 $C93D AND %00000011 ; Mask to the attribute page bits.
 $C93F OR %01011000  ; Set the attribute area high byte.
 $C941 LD H,A        ; Update #REGh to point into attribute RAM.
 $C942 EXX           ; {Fetch the entity colour via #REGb' and write it to
 $C943 LD A,B        ; the first attribute cell.
 $C944 EXX           ;
 $C945 LD (HL),A     ; }
 $C946 DEC HL        ; {Write the entity colour to the second attribute cell.
 $C947 LD (HL),A     ; }
 $C948 RET           ; Return.

; Erase Wide Entity Sprite
;
; Used by the routines at #R$E003, #R$E1B6, #R$E22A, #R$E360, #R$E4B9, #R$E881,
; #R$E974 and #R$EA6E.
; .
; Entry point for erasing a wide entity sprite. Sets erase mode then
; falls through to #R$C954. In erase mode the attribute write is skipped.
@label=Erase_Wide_Entity_Sprite
c$C949 EXX           ; {Set erase mode (attribute write disabled).
 $C94A LD D,$00      ;
 $C94C EXX           ; }
 $C94D JP $C954      ; Jump to #R$C954.

; Draw Wide Entity Sprite
;
; Used by the routines at #R$CD34, #R$E003, #R$E122, #R$E1B6, #R$E360, #R$E7CF,
; #R$E881, #R$E92C, #R$EA6E and #R$EB07.
; .
; Draws or erases a wide entity's sprite on the display. #R$C950 sets
; draw mode so the entity colour is written to the attribute area. #R$C949
; sets erase mode and skips the attribute write. Both paths enter #R$C954,
; which reads the entity type to look up sprite data from #R$C60C, computes
; the screen position from the Y and X bytes, then XOR-blends sixteen pixel
; rows of sprite data onto the display across three bytes (24 pixels) wide.
;
; HL Entity record pointer
@label=Draw_Wide_Entity_Sprite
c$C950 EXX           ; {Set draw mode (attribute write enabled).
 $C951 LD D,$01      ;
 $C953 EXX           ; }
; This entry point is used by the routine at #R$C949.
@label=Draw_Wide_Entity_Sprite_Render
*$C954 LD B,H        ; {Copy the entity record pointer to #REGbc.
 $C955 LD C,L        ; }
 $C956 LD E,(HL)     ; {Look up the sprite data address for this entity type.
 $C957 SLA E         ;
 $C959 LD D,$00      ;
 $C95B LD HL,$C60C   ;
 $C95E ADD HL,DE     ;
 $C95F LD E,(HL)     ;
 $C960 INC HL        ;
 $C961 LD D,(HL)     ; }
 $C962 LD H,B        ; {Copy the entity record pointer from #REGbc.
 $C963 LD L,C        ; }
 $C964 INC HL        ; {Read the entity's Y position and form the pixel row
 $C965 LD B,$46      ; address.
 $C967 LD C,(HL)     ;
 $C968 SLA C         ;
 $C96A RL B          ;
 $C96C PUSH BC       ; }
 $C96D INC HL        ; {Read the X position and extract the byte column and bit
 $C96E LD A,(HL)     ; offset.
 $C96F AND A         ;
 $C970 LD HL,$0000   ;
 $C973 RRA           ;
 $C974 RR L          ;
 $C976 RRA           ;
 $C977 RR L          ;
 $C979 RRA           ;
 $C97A RR L          ; }
 $C97C EXX           ; {Save the pixel bit offset in the shadow register.
 $C97D LD C,A        ;
 $C97E EXX           ; }
 $C97F LD A,L        ; {Compute the sprite pixel data address and add the
 $C980 RRCA          ; column offset.
 $C981 ADD A,L       ;
 $C982 LD L,A        ;
 $C983 LD A,H        ;
 $C984 ADC A,$00     ;
 $C986 LD H,A        ;
 $C987 ADD HL,DE     ; }
 $C988 LD B,H        ; {Copy the sprite data pointer to #REGbc.
 $C989 LD C,L        ; }
 $C98A POP HL        ; Restore the pixel row address from the stack.
 $C98B EXX           ; {Read the pixel bit offset from the shadow register.
 $C98C LD A,C        ;
 $C98D EXX           ; }
; Render the sprite row by row. Each row XOR-blends three bytes of
; pixel data onto the display. After every ninth row the entity's colour
; is written to three screen attribute cells.
