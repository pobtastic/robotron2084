 $CB27 LD D,(HL)     ;
 $CB28 INC HL        ;
 $CB29 EX DE,HL      ;
 $CB2A LD A,(BC)     ;
 $CB2B XOR (HL)      ;
 $CB2C LD (HL),A     ;
 $CB2D INC BC        ;
 $CB2E INC HL        ;
 $CB2F LD A,(BC)     ;
 $CB30 XOR (HL)      ;
 $CB31 LD (HL),A     ;
 $CB32 INC BC        ;
 $CB33 INC HL        ;
 $CB34 LD A,(BC)     ;
 $CB35 XOR (HL)      ;
 $CB36 LD (HL),A     ;
 $CB37 INC BC        ; }
 $CB38 EXX           ; {Return if in erase mode (skip the final attribute
 $CB39 LD A,D        ; write).
 $CB3A AND A         ;
 $CB3B EXX           ;
 $CB3C RET Z         ; }
 $CB3D LD A,H        ; {Compute the attribute area address from the current
 $CB3E RRCA          ; screen row.
 $CB3F RRCA          ;
 $CB40 RRCA          ; }
 $CB41 AND %00000011 ; Keep only the row address bits.
 $CB43 OR %01011000  ; Set the attribute memory flag.
 $CB45 LD H,A        ; {Write the entity's colour to three attribute cells and
 $CB46 EXX           ; return.
 $CB47 LD A,B        ;
 $CB48 EXX           ;
 $CB49 LD (HL),A     ;
 $CB4A DEC HL        ;
 $CB4B LD (HL),A     ;
 $CB4C DEC HL        ;
 $CB4D LD (HL),A     ;
 $CB4E RET           ; }

; Main Game Loop
;
; Used by the routine at #R$D24C.
; .
; Wave-active game loop entry, called from #R$D24C once the entity list
; and playfield are ready. Initialises the player's starting screen position
; and frame counters, copies the sprite template via #R$D519, then falls
; into the per-frame control poll at #R$CB67. Each frame: reads
; the controller via #R$F6C3, moves and redraws the player sprite, spawns
; one new entity every three frames adjacent to the player, dispatches all
; active entity handlers via #R$C702, updates the colour bar and protection
; checks, then loops back to #R$CB67.
;
; .
;
; Initialise the player's screen position and frame counters for the
; start of the wave.
@label=Main_Game_Loop
c$CB4F LD HL,$C4D4   ; {Point #REGhl at #R$C4D4 and set the starting screen
 $CB52 LD (HL),$5C   ; row to #N$5C.
 $CB54 INC HL        ; }
 $CB55 LD (HL),$7D   ; {Set the starting screen column to #N$7D and reset the wave-start
 $CB57 LD A,$1A      ; delay counter at #R$C533 to #N$1A.
 $CB59 LD ($C533),A  ; }
 $CB5C LD A,$0F      ; {Set the animation frame counters at #R$C534 and #R$C536 to #N$0F
 $CB5E LD ($C534),A  ; and copy the sprite template via #R$D519.
 $CB61 LD ($C536),A  ;
 $CB64 CALL $D519    ; }
; This entry point is used by the routine at #R$CD34.
; .
; Per-frame start: check whether the wave is still active before
; processing input.
@label=Main_Loop_Poll
*$CB67 LD A,($C533)  ; {If the wave-start delay counter at #R$C533 is non-zero, jump to
 $CB6A AND A         ; #R$CF33 (wave-end / game-over handling).
 $CB6B JP NZ,$CF33   ; }
; This entry point is used by the routine at #R$CD34.
; .
; Read the controller and map the input to player movement directions.
@label=Main_Loop_Frame
*$CB6E CALL $F6C3    ; Read the controller state via #R$F6C3.
 $CB71 LD A,C        ; {Apply vertical input processing via #R$CE9D and store the result
 $CB72 CALL $CE9D    ; in #REGc.
 $CB75 LD C,A        ; }
 $CB76 LD A,B        ; {Apply horizontal input processing via #R$CE72 and store the result
 $CB77 CALL $CE72    ; in #REGb.
 $CB7A LD B,A        ; }
 $CB7B CP $0F        ; {If the direction is neutral (#N$0F), skip to #R$CB82.
 $CB7D JR Z,$CB82    ; }
 $CB7F LD ($C518),A  ; Store the updated X direction at #R$C518.
@label=Main_Loop_Update_Y
*$CB82 LD A,C        ; {If the vertical direction changed, store it at #R$C517.
 $CB83 CP $0F        ;
 $CB85 JR Z,$CB8A    ;
 $CB87 LD ($C517),A  ; }
; Move the player sprite if a direction was input. Neutral direction
; (#N$0F) means no movement — skip directly to entity spawning.
@label=Main_Loop_Move_Player
*$CB8A LD A,B        ; {If no horizontal direction, skip to #R$CBD3.
 $CB8B CP $0F        ;
 $CB8D JR Z,$CBD3    ; }
 $CB8F LD E,A        ; {Build the sprite frame word offset from the X direction and stash
 $CB90 SLA E         ; it; point #REGhl at #R$C4D3 and erase the current player
 $CB92 LD D,$00      ; sprite via #R$D630.
 $CB94 PUSH DE       ;
 $CB95 LD HL,$C4D3   ; }
 $CB98 CALL $D630    ; Erase the current player sprite via #R$D630.
 $CB9B POP DE        ; {Look up the movement delta for the current direction in the table
 $CB9C LD HL,$C6AE   ; at #R$C6AE; add the Y delta to #R$C4D4.
 $CB9F ADD HL,DE     ;
 $CBA0 EX DE,HL      ;
 $CBA1 LD HL,$C4D4   ;
 $CBA4 LD A,(DE)     ;
 $CBA5 ADD A,(HL)    ;
 $CBA6 CP $10        ;
 $CBA8 JR C,$CBAF    ; }
 $CBAA CP $AD        ; {Reject the Y move if the new position is above the playfield top
 $CBAC JR NC,$CBAF   ; or below the bottom edge.}
 $CBAE LD (HL),A     ; Write the updated Y position.
@label=Main_Loop_Clamp_X
*$CBAF INC HL        ; {Add the X delta to #R$C4D5.
 $CBB0 INC DE        ;
 $CBB1 LD A,(DE)     ;
 $CBB2 ADD A,(HL)    ;
 $CBB3 CP $08        ; }
 $CBB5 JR C,$CBBC    ; {Reject the X move if the new position is past the left
 $CBB7 CP $F2        ; edge.}
 $CBB9 JR NC,$CBBC   ; Reject the X move if past the right edge.
 $CBBB LD (HL),A     ; Write the updated X position.
; Select the sprite frame for the new direction and redraw the player.
@label=Main_Loop_Update_Sprite
*$CBBC LD A,($C518)  ; {Look up the sprite frame index for the current X direction in
 $CBBF LD E,A        ; #R$D620; write it to #R$C4D3.
 $CBC0 LD D,$00      ;
 $CBC2 LD HL,$D620   ;
 $CBC5 ADD HL,DE     ;
 $CBC6 EX DE,HL      ;
 $CBC7 LD A,(DE)     ;
 $CBC8 LD HL,$C4D3   ;
 $CBCB LD (HL),A     ; }
 $CBCC EXX           ; {Set the player colour to #COLOUR$47 in #REGb' and redraw the
 $CBCD LD B,$47      ; player sprite via #R$D637.
 $CBCF EXX           ;
 $CBD0 CALL $D637    ; }
; Every three frames spawn one new entity adjacent to the player.
@label=Main_Loop_Entity_Spawn
*$CBD3 LD HL,$C4CF   ; {Decrement the entity spawn timer at #R$C4CF.
 $CBD6 DEC (HL)      ; }
 $CBD7 JP NZ,$CC5C   ; If the timer has not reached zero, skip to #R$CC5C.
 $CBDA LD (HL),$03   ; Reset the spawn timer to #N$03.
 $CBDC LD HL,($C4D1) ; {Load the entity list end pointer from #R$C4D1 and write the
 $CBDF LD DE,$D5DD   ; movement handler address #R$D5DD to the entity list.}
 $CBE2 LD (HL),E     ; {Advance past the handler address word in the entity
 $CBE3 INC HL        ; list.
 $CBE4 LD (HL),D     ;
 $CBE5 INC HL        ; }
 $CBE6 LD ($C4DA),HL ; Save the entity record write pointer to #R$C4DA.
 $CBE9 LD A,($C517)  ; Load the Y direction index from #R$C517.
 $CBEC EX DE,HL      ; {Index the entity type table at #R$D4F1 by Y direction and write
 $CBED LD C,A        ; the entity type to the entity record.
 $CBEE LD B,$00      ;
 $CBF0 LD HL,$D4F1   ;
 $CBF3 ADD HL,BC     ;
 $CBF4 EX DE,HL      ;
 $CBF5 LD A,(DE)     ;
 $CBF6 LD (HL),A     ; }
 $CBF7 INC HL        ; Advance to the next entity record field.
 $CBF8 LD A,($C517)  ; {Load the Y direction again, scale it to a byte offset (×8), and
 $CBFB LD C,A        ; look up the sprite pixel offsets in #R$C7CF.
 $CBFC SLA C         ;
 $CBFE SLA C         ;
 $CC00 SLA C         ; }
 $CC02 LD B,$00      ; {Clear the high byte of the offset and index into
 $CC04 EX DE,HL      ; #R$C7CF.
 $CC05 LD HL,$C7CF   ; }
 $CC08 ADD HL,BC     ; Add the direction offset to the sprite data base
                     ; address.
 $CC09 LD A,($C4D4)  ; {Compute the entity's initial Y position from #R$C4D4
 $CC0C ADD A,(HL)    ; plus the sprite Y offset; write both bytes to the entity record.
 $CC0D LD (DE),A     ;
 $CC0E INC HL        ;
 $CC0F INC DE        ;
 $CC10 LD A,($C4D5)  ; }
 $CC13 ADD A,(HL)    ; {Write the X position bytes derived from #R$C4D5.
 $CC14 LD (DE),A     ;
 $CC15 INC HL        ;
 $CC16 INC DE        ; }
 $CC17 LD A,($C4D4)  ; {Add the sprite Y check offset to the player Y position and reject
 $CC1A ADD A,(HL)    ; the spawn if the result is above the playfield top edge.
 $CC1B CP $10        ; }
 $CC1D JR C,$CC7C    ; {Reject the spawn if the Y position is below the playfield bottom
 $CC1F CP $B8        ; edge (#N$B8).}
 $CC21 JR NC,$CC7C   ; Reject if below the bottom edge.
 $CC23 LD (DE),A     ; {Write the validated Y position field to the entity
 $CC24 INC HL        ; record.
 $CC25 INC DE        ; }
 $CC26 LD A,($C4D5)  ; {Check the X position is within the playfield horizontal bounds
 $CC29 ADD A,(HL)    ; (#N$08–#N$F7).
 $CC2A CP $08        ; }
 $CC2C JR C,$CC7C    ; {Reject the spawn if the X position is past the left
 $CC2E CP $F8        ; edge.}
 $CC30 JR NC,$CC7C   ; Reject if past the right edge.
 $CC32 LD (DE),A     ; {Write the validated X position field to the entity
 $CC33 INC HL        ; record.
 $CC34 INC DE        ; }
 $CC35 LD BC,$0004   ; {Copy the remaining four entity record bytes via LDIR.
 $CC38 LDIR          ; }
 $CC3A EX DE,HL      ; {Mark the end of the entity record and update the entity list end
 $CC3B LD (HL),$FF   ; pointer at #R$C4D1.
 $CC3D INC HL        ;
 $CC3E LD ($C4D1),HL ; }
 $CC41 LD E,$01      ; {Initialise the entity via #R$D9C4.
 $CC43 CALL $D9C4    ; }
 $CC46 LD HL,($C4DA) ; {Reload the entity record pointer from #R$C4DA
 $CC49 EXX           ; and set the entity colour to #COLOUR$47 in #REGb'.
 $CC4A LD B,$47      ;
 $CC4C EXX           ; }
 $CC4D CALL $C856    ; Draw the spawned entity sprite via #R$C856.
 $CC50 LD HL,($C4D1) ; Reload the entity list end pointer from #R$C4D1.
@label=Main_Loop_Write_Terminator
*$CC53 LD DE,$CE62   ; {Write the playfield entity handler #N$CE62 and the #N$FF sentinel
 $CC56 LD (HL),E     ; as the entity list terminator.
 $CC57 INC HL        ;
 $CC58 LD (HL),D     ;
 $CC59 INC HL        ;
 $CC5A LD (HL),$FF   ; }
; Dispatch all active entity handlers, update animation and colour bar.
@label=Main_Loop_Entity_Update
*$CC5C LD HL,$6100   ; Set #REGhl to the start of the entity list at #R$6100.
 $CC5F CALL $C702    ; Dispatch all entity handlers in the list via #R$C702.
 $CC62 LD HL,($C51B) ; {Decrement the animation counter at #R$C51B if it is
 $CC65 LD A,H        ; non-zero.
 $CC66 OR L          ;
 $CC67 JR Z,$CC6D    ;
 $CC69 DEC HL        ;
 $CC6A LD ($C51B),HL ; }
@label=Main_Loop_Colour_Bar_Update
*$CC6D CALL $C713    ; {Update the colour bar via #R$C713, run the protection check via
 $CC70 CALL $C5C1    ; #R$C5C1, and call the game state update via #R$D9E0.
 $CC73 CALL $D9E0    ; }
 $CC76 CALL $C5EF    ; {Run the copy protection gate via #R$C5EF and loop back to
 $CC79 JP $CB67      ; #R$CB67.}
; Out-of-bounds abort: the new entity would fall outside the playfield.
; Skip the spawn but still write the entity list terminator.
@label=Main_Loop_Abort_Spawn
*$CC7C LD HL,($C4D1) ; {Reload the entity list end pointer from #R$C4D1 and jump to
 $CC7F JR $CC53      ; #R$CC53.}

; Draw Spawned Entity
;
; Used by the routines at #R$CCE9 and #R$D0F0.
; .
; Reads the sprite type and screen address from the entity record at
; #REGhl, looks up the sprite pixel data in #R$C60C, then XOR-blits eight
; pixel rows onto the screen. Falls through to #R$CCBD
; to write the entity's attribute colour from the colour cycle table.
; Called immediately after a new entity is written to the entity list.
@label=Draw_Spawned_Entity
c$CC81 LD A,(HL)     ; {Read the entity sprite type into #REGa and the screen address
 $CC82 INC HL        ; into #REGde.
 $CC83 LD E,(HL)     ;
 $CC84 INC HL        ;
 $CC85 LD D,(HL)     ;
 $CC86 INC HL        ; }
 $CC87 LD B,H        ; {Stash the entity record pointer in #REGbc and double the sprite
 $CC88 LD C,L        ; type to form the lookup word offset.
 $CC89 PUSH BC       ;
 $CC8A ADD A,A       ;
 $CC8B LD C,A        ; }
 $CC8C LD B,$00      ; {Index the sprite data table at #R$C60C and restore the entity
 $CC8E LD HL,$C60C   ; record pointer from the stack.
 $CC91 ADD HL,BC     ;
 $CC92 POP BC        ; }
 $CC93 LD A,(HL)     ; {Load the sprite pixel data address into #REGhl.
 $CC94 INC HL        ;
 $CC95 LD H,(HL)     ;
 $CC96 LD L,A        ; }
 $CC97 LD A,(DE)     ; {XOR-blit eight pixel rows of sprite data onto the
 $CC98 XOR (HL)      ; screen.
 $CC99 LD (DE),A     ;
 $CC9A INC HL        ;
 $CC9B INC D         ;
 $CC9C LD A,(DE)     ;
 $CC9D XOR (HL)      ;
 $CC9E LD (DE),A     ;
 $CC9F INC HL        ;
 $CCA0 INC D         ;
 $CCA1 LD A,(DE)     ;
 $CCA2 XOR (HL)      ;
 $CCA3 LD (DE),A     ;
 $CCA4 INC HL        ;
 $CCA5 INC D         ;
 $CCA6 LD A,(DE)     ;
 $CCA7 XOR (HL)      ;
 $CCA8 LD (DE),A     ;
 $CCA9 INC HL        ;
 $CCAA INC D         ;
 $CCAB LD A,(DE)     ;
 $CCAC XOR (HL)      ;
 $CCAD LD (DE),A     ;
 $CCAE INC HL        ;
 $CCAF INC D         ;
 $CCB0 LD A,(DE)     ;
 $CCB1 XOR (HL)      ;
 $CCB2 LD (DE),A     ;
 $CCB3 INC HL        ;
 $CCB4 INC D         ;
 $CCB5 LD A,(DE)     ;
 $CCB6 XOR (HL)      ;
 $CCB7 LD (DE),A     ;
 $CCB8 INC HL        ;
 $CCB9 INC D         ;
 $CCBA LD A,(DE)     ;
 $CCBB XOR (HL)      ;
 $CCBC LD (DE),A     ; }
; This entry point is used by the routine at #R$CCCE.
; .
; Write the entity's current colour from the colour cycle table to the
; attribute cell at the entity's screen position.
@label=Draw_Spawned_Entity_Attribute
*$CCBD LD A,(BC)     ; {Read the low byte of the attribute cell address from the entity
 $CCBE INC BC        ; record into #REGl.
 $CCBF LD L,A        ;
 $CCC0 LD A,(BC)     ; }
 $CCC1 LD H,A        ; Form the attribute cell address high byte in #REGh.
 $CCC2 LD DE,($C4E5) ; {Load the current colour byte from the colour cycle table at #R$C4E5
 $CCC6 DEC DE        ; and write it to the attribute cell.
 $CCC7 LD A,(DE)     ;
 $CCC8 LD (HL),A     ; }
 $CCC9 LD H,B        ; {Write the colour, restore the entity record pointer, advance past
 $CCCA LD L,C        ; two fields, and return.
 $CCCB INC HL        ;
 $CCCC INC HL        ; }
 $CCCD RET           ; Return.

; Primary Enemy Entity Handler
;
; Entity handler stored in primary wave enemy records. Called once per
; frame by the entity dispatcher in #R$C702. Searches the entity list for a
; collision-free position via #R$CD18. If a free position exists, hands off
; to #R$CCE9 to draw the entity and detect contact with other
; enemies. Otherwise checks whether the enemy touches the player via #R$C6DA;
; if the player is hit, the death transition fires via #R$D2BC.
@label=Primary_Enemy_Entity_Handler
c$CCCE EXX           ; {Switch to alternate registers and search the entity list for a
 $CCCF CALL $CD18    ; free slot via #R$CD18; restore main registers.
 $CCD2 EXX           ; }
 $CCD3 JR NC,$CCE9   ; If a free slot was found, hand off to #R$CCE9.
 $CCD5 EXX           ; {Load the player's screen position into alternate
 $CCD6 LD HL,$C4D4   ; #REGhl.
 $CCD9 EXX           ; }
 $CCDA CALL $C6DA    ; Test whether the enemy's bounds overlap the player via
                     ; #R$C6DA.
 $CCDD JP NC,$D2BC   ; If the player is hit, trigger the death transition via
                     ; #R$D2BC.
 $CCE0 INC HL        ; {Advance the entity list pointer four bytes and save it
 $CCE1 INC HL        ; in #REGbc.
 $CCE2 INC HL        ;
 $CCE3 INC HL        ;
 $CCE4 LD B,H        ;
 $CCE5 LD C,L        ; }
 $CCE6 JP $CCBD      ; Write the entity's attribute colour via #R$CCBD.

; Process Enemy Entity
;
; Used by the routine at #R$CCCE.
; .
; Draws a wave enemy entity's sprite, updates its handler to the entity
; update completion routine, then checks for contact with the player. If the
; enemy touches the player, the entity is erased, removed from the list, the
; wave enemy count is decremented, and execution returns to the dispatcher.
@label=Process_Enemy_Entity
c$CCE9 PUSH HL       ; {Stash the entity record pointer, advance four bytes to the screen
 $CCEA INC HL        ; address field, and draw the entity sprite via #R$CC81.
 $CCEB INC HL        ;
 $CCEC INC HL        ;
 $CCED INC HL        ;
 $CCEE CALL $CC81    ; }
 $CCF1 POP HL        ; {Restore the entity record pointer, step back to the handler field,
 $CCF2 DEC HL        ; and write the entity update completion address #R$CD13.
 $CCF3 DEC HL        ;
 $CCF4 LD DE,$CD13   ;
 $CCF7 LD (HL),E     ;
 $CCF8 INC HL        ;
 $CCF9 LD (HL),D     ;
 $CCFA INC HL        ; }
 $CCFB EXX           ; {Switch to alternate registers, subtract 6 from the entity list
 $CCFC LD DE,$0006   ; position to locate the record within the list.
 $CCFF SBC HL,DE     ; }
 $CD01 PUSH HL       ; {Stash the record position, erase the entity sprite via #R$C84F,
 $CD02 CALL $C84F    ; and restore the position.
 $CD05 POP HL        ; }
 $CD06 LD ($C4DA),HL ; {Save the record pointer to #R$C4DA and remove
 $CD09 CALL $D5B1    ; the entity from the list via #R$D5B1.}
 $CD0C LD HL,$C423   ; {Decrement the wave enemy count at #R$C423 and set
 $CD0F DEC (HL)      ; the entity colour to #COLOUR$47 in #REGb'.
 $CD10 LD B,$47      ; }
 $CD12 EXX           ; Return to the main register set.

; Advance Entity Pointer
;
; Used by the routine at #R$D5B1.
; .
; Written into entity records as the per-frame handler once an entity
; has been processed. Advances #REGhl by #N$0A bytes to step past the
; current record and returns to the entity dispatcher.
@label=Advance_Entity_Pointer
c$CD13 LD DE,$000A   ; {Add #N$0A to #REGhl to step past the current entity
 $CD16 ADD HL,DE     ; record.}
 $CD17 RET           ; Return to the entity dispatcher.

; Find Colliding Entity
;
; Used by the routines at #R$CCCE, #R$CD34, #R$E360, #R$E520, #R$E881 and
; #R$EB07.
; .
; Walks the entity list from #R$6000, testing each record's bounds
; against the current entity via #R$C6DA. Returns without carry if no
; collision is found (list exhausted). Returns with carry set if the current
; entity's position overlaps another entity's bounds.
@label=Find_Colliding_Entity
c$CD18 LD HL,$6000   ; Point #REGhl to the start of the entity list at #R$6000.
@label=Find_Colliding_Entity_Check
*$CD1B INC HL        ; {Skip the handler address and read the state byte. If it is the
 $CD1C INC HL        ; #N$FF sentinel, set carry and return (end of list reached).
 $CD1D LD A,(HL)     ;
 $CD1E CP $FF        ;
 $CD20 SCF           ;
 $CD21 RET Z         ; }
 $CD22 INC HL        ; {Advance past three more bytes and test this entity's bounds
 $CD23 INC HL        ; against the current position via #R$C6DA.
 $CD24 INC HL        ;
 $CD25 CALL $C6DA    ; }
 $CD28 EXX           ; {Adjust alternate #REGhl back by three and return without carry
 $CD29 DEC HL        ; if the bounds do not overlap.
 $CD2A DEC HL        ;
 $CD2B DEC HL        ;
 $CD2C EXX           ; }
 $CD2D RET NC        ; {Advance four bytes to the next entity record.
 $CD2E INC HL        ;
 $CD2F INC HL        ;
 $CD30 INC HL        ;
 $CD31 INC HL        ; }
 $CD32 JR $CD1B      ; Check the next entity.

; Clear Colour Bar Column
;
; Used by the routines at #R$E003, #R$E4B9, #R$E520, #R$E974 and #R$EB07.
; .
; Clears a seven-column, six-pixel-row strip from the screen pixel
; area at the column position held in #R$C420, then jumps to #R$C544
; to redraw the column.
@label=Clear_Colour_Bar_Column
c$CD34 LD B,$06      ; {Prepare to clear six pixel rows of the colour bar
 $CD36 LD H,$42      ; column.}
; For each row, point to the target column and zero seven pixel cells.
@label=Clear_Colour_Bar_Column_Row
*$CD38 LD A,($C420)  ; {Point to the colour bar column in the current pixel
 $CD3B LD L,A        ; row.}
 $CD3C XOR A         ; {Zero seven pixel cells at the column position.
 $CD3D LD (HL),A     ;
 $CD3E INC HL        ;
 $CD3F LD (HL),A     ;
 $CD40 INC HL        ;
 $CD41 LD (HL),A     ;
 $CD42 INC HL        ;
 $CD43 LD (HL),A     ;
 $CD44 INC HL        ;
 $CD45 LD (HL),A     ;
 $CD46 INC HL        ;
 $CD47 LD (HL),A     ;
 $CD48 INC HL        ;
 $CD49 LD (HL),A     ; }
 $CD4A INC H         ; {Advance to the next pixel row and repeat until all six
 $CD4B DJNZ $CD38    ; are cleared.}
 $CD4D JP $C544      ; Jump to #R$C544 to redraw the display column.
 $CD50 LD A,($C533)  ;
 $CD53 AND A         ;
 $CD54 JP NZ,$E0A8   ;
 $CD57 CALL $D1BF    ;
 $CD5A AND $0F       ;
 $CD5C INC A         ;
 $CD5D LD ($C4F6),HL ;
 $CD60 LD B,A        ;
 $CD61 LD A,($C51C)  ;
 $CD64 SUB B         ;
 $CD65 JP NC,$CD98   ;
 $CD68 INC HL        ;
 $CD69 CALL $D630    ;
 $CD6C LD HL,($C4F6) ;
 $CD6F INC HL        ;
 $CD70 INC HL        ;
 $CD71 LD A,($C4D4)  ;
 $CD74 SUB (HL)      ;
 $CD75 LD A,($C426)  ;
 $CD78 JR NC,$CD7C   ;
 $CD7A NEG           ;
*$CD7C ADD A,(HL)    ;
 $CD7D LD (HL),A     ;
 $CD7E INC HL        ;
 $CD7F LD A,($C4D5)  ;
 $CD82 SUB (HL)      ;
 $CD83 LD A,($C426)  ;
 $CD86 JR NC,$CD8A   ;
 $CD88 NEG           ;
*$CD8A ADD A,(HL)    ;
 $CD8B LD (HL),A     ;
 $CD8C DEC HL        ;
 $CD8D DEC HL        ;
 $CD8E EXX           ;
 $CD8F LD B,$46      ;
 $CD91 EXX           ;
 $CD92 CALL $D637    ;
 $CD95 LD HL,($C4F6) ;
*$CD98 INC HL        ;
 $CD99 INC HL        ;
 $CD9A EXX           ;
 $CD9B CALL $CD18    ;
 $CD9E JR NC,$CDAD   ;
 $CDA0 LD HL,$C4D4   ;
 $CDA3 EXX           ;
 $CDA4 CALL $C6DA    ;
 $CDA7 JP NC,$D2BC   ;
 $CDAA INC HL        ;
 $CDAB INC HL        ;
 $CDAC RET           ;
*$CDAD LD DE,$0006   ;
 $CDB0 SBC HL,DE     ;
 $CDB2 LD ($C4DA),HL ;
 $CDB5 CALL $C84F    ;
 $CDB8 CALL $D5B1    ;
 $CDBB LD HL,$C41C   ;
 $CDBE DEC (HL)      ;
