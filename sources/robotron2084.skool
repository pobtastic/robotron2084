; XOR Blit Sprite
;
; Used by the routines at #R$F7EE and #R$F83C.
; .
; Takes the two-byte position entry at #REGhl (byte #N$00 = Y pixel row,
; byte #N$01 = X byte column) and the attribute byte in #REGe (shadow;
; bit 7 set = erase mode, bit 7 clear = draw mode). Computes each screen
; pixel address by reading the row base from the screen row LUT at #N$8C00
; (indexed by Y) and adding the X column byte offset stored in shadow #REGd.
; XORs #N$04 bytes of the fixed bitmap at #N$6CFC into consecutive screen pixel
; memory for each of #N$20 pixel rows (#N$04 attribute-cell rows of #N$08 pixel
; rows each). After the first pixel row of each attribute-cell row, derives the
; attribute memory high byte from the pixel address high byte and writes the
; attribute byte to #N$04 consecutive attribute cells — suppressed in erase mode.
;
; HL Pointer to the two-byte position entry (Y pixel row at +0, X byte column
; .  at +1)
;
; Initialise the bitmap source (#REGhl=#N$6CFC via EX DE,HL) and compute #REGix
; into the screen row LUT at #N$8C00, indexed by the Y pixel row. The row is
; shifted left into the LUT index directly (#REGix=#N$8C00 + Y × #N$02). Store
; the X column byte offset in shadow #REGd and set the outer loop count
; (#REGc=#N$04, shadow, one iteration per attribute-cell row of #N$08 pixel rows).
@label=XorBlitSprite
c$F76F LD DE,$6CFC    ; #REGde=#N$6CFC (bitmap source base address; becomes
                      ; #REGhl via EX DE,HL).
 $F772 LD B,$46       ; #REGb=#N$46 (initial high byte; becomes #N$8C or #N$8D
                      ; after RL #REGb).
 $F774 LD C,(HL)      ; #REGc=Y pixel row (byte #N$00 of the position entry).
 $F775 INC HL         ; Advance #REGhl to byte #N$01 (X byte column).
 $F776 SLA C          ; SLA #REGc; carry = bit 7 of Y (selects high byte #N$8C
                      ; or #N$8D).
 $F778 RL B           ; RL #REGb; #REGb=#N$8C (or #N$8D if carry set) — high
                      ; byte of LUT pointer.
 $F77A PUSH BC        ; Stash #REGbc on the stack.
 $F77B LD A,(HL)      ; #REGa=X byte column (byte #N$01 of the position entry).
 $F77C EXX            ; Switch to the shadow registers.
 $F77D LD D,A         ; #REGd=X byte column offset (held in shadow across all
                      ; loop iterations).
 $F77E EXX            ; Switch back to the normal registers.
 $F77F POP IX         ; POP #REGix; #REGix=#N$8C00 + Y × #N$02 (pointer into
                      ; the screen row LUT).
 $F781 EX DE,HL       ; #REGhl=#N$6CFC (bitmap source pointer); #REGde=old
                      ; #REGhl (discarded).
 $F782 EXX            ; Switch to the shadow registers.
 $F783 LD C,$04       ; #REGc=#N$04 (shadow, outer loop count: #N$04
                      ; attribute-cell rows).
 $F785 EXX            ; Switch back to the normal registers.
; Outer loop (#N$04 iterations, one per attribute-cell row of #N$08 pixel rows).
; Compute the screen pixel address for the first row of this attribute cell:
; read shadow #REGd (X column), add the LUT low byte from *(#REGix) to give
; #REGe, then read the LUT high byte from *(#REGix+#N$01) into #REGd. Advance
; #REGix by two to the next LUT entry.
@label=XorBlitSprite_OuterLoop
*$F786 EXX            ; Switch to the shadow registers.
 $F787 LD A,D         ; #REGa=#REGd (X byte column offset).
 $F788 EXX            ; Switch back to the normal registers.
 $F789 ADD A,(IX+$00) ; #REGa += *(#REGix) (LUT low byte); low byte of screen
                      ; pixel address.
 $F78C INC IX         ; Advance #REGix to the LUT high byte.
 $F78E LD E,A         ; #REGe=#REGa (low byte of screen pixel address).
 $F78F LD D,(IX+$00)  ; #REGd=*(#REGix) (high byte of screen pixel address from
                      ; LUT).
 $F792 INC IX         ; Advance #REGix to the next LUT entry.
; XOR #N$04 consecutive bytes of the bitmap at (#REGhl)–(#REGhl+#N$03) into
; screen pixel memory at (#REGde)–(#REGde+#N$03), advancing both pointers.
 $F794 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F795 XOR (HL)       ;
 $F796 LD (DE),A      ;
 $F797 INC DE         ;
 $F798 INC HL         ; }
 $F799 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F79A XOR (HL)       ;
 $F79B LD (DE),A      ;
 $F79C INC DE         ;
 $F79D INC HL         ; }
 $F79E LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F79F XOR (HL)       ;
 $F7A0 LD (DE),A      ;
 $F7A1 INC HL         ;
 $F7A2 INC DE         ; }
 $F7A3 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGhl.
 $F7A4 XOR (HL)       ;
 $F7A5 LD (DE),A      ;
 $F7A6 INC HL         ; }
; Derive the attribute memory address high byte from the current pixel address
; high byte in #REGd. Three right-rotations expose the screen-third index in
; bits #N$00–#N$01; OR with #N$58 gives the attribute area high byte (#N$58–#N$5B).
 $F7A7 LD A,D         ; {#REGd = (RRCA × #N$03 of #REGd) AND #N$03 OR #N$58
 $F7A8 RRCA           ; (attribute address high byte).
 $F7A9 RRCA           ;
 $F7AA RRCA           ;
 $F7AB AND $03        ;
 $F7AD OR $58         ;
 $F7AF LD D,A         ; }
; Test the erase-mode flag (bit 7 of shadow #REGe). If set, skip writing
; the attribute byte so that the background colour is preserved during erase.
 $F7B0 EXX            ; {Switch to shadow; #REGa=#REGe (attribute byte); switch
 $F7B1 LD A,E         ; back.
 $F7B2 EXX            ; }
 $F7B3 BIT 7,A        ; Test bit 7 of #REGa (erase-mode flag).
 $F7B5 JR NZ,$F7BE    ; If in erase mode, jump to #R$F7BE (skip attribute
                      ; write).
 $F7B7 LD (DE),A      ; {Write attribute byte to (#REGde), (#REGde−#N$01),
 $F7B8 DEC DE         ; (#REGde−#N$02) and (#REGde−#N$03).
 $F7B9 LD (DE),A      ;
 $F7BA DEC DE         ;
 $F7BB LD (DE),A      ;
 $F7BC DEC DE         ;
 $F7BD LD (DE),A      ; }
@label=XorBlitSprite_InnerSetup
*$F7BE EXX            ; {Switch to shadow; #REGb=#N$07 (remaining pixel rows in
 $F7BF LD B,$07       ; this attribute-cell row); switch back.
 $F7C1 EXX            ; }
; Inner loop (#N$07 iterations, one per remaining pixel row in this attribute-cell
; row). Compute the screen address from the LUT and XOR #N$04 bitmap bytes into
; pixel memory. No attribute write.
@label=XorBlitSprite_InnerLoop
*$F7C2 EXX            ; Switch to the shadow registers.
 $F7C3 LD A,D         ; #REGa=#REGd (X byte column offset).
 $F7C4 EXX            ; Switch back to the normal registers.
 $F7C5 ADD A,(IX+$00) ; #REGa += *(#REGix) (LUT low byte for this pixel row).
 $F7C8 INC IX         ; Advance #REGix to the LUT high byte.
 $F7CA LD E,A         ; #REGe=#REGa (low byte of screen pixel address).
 $F7CB LD D,(IX+$00)  ; #REGd=*(#REGix) (high byte of screen pixel address from
                      ; LUT).
 $F7CE INC IX         ; Advance #REGix to the next LUT entry.
 $F7D0 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F7D1 XOR (HL)       ;
 $F7D2 LD (DE),A      ;
 $F7D3 INC DE         ;
 $F7D4 INC HL         ; }
 $F7D5 LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F7D6 XOR (HL)       ;
 $F7D7 LD (DE),A      ;
 $F7D8 INC DE         ;
 $F7D9 INC HL         ; }
 $F7DA LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGde and #REGhl.
 $F7DB XOR (HL)       ;
 $F7DC LD (DE),A      ;
 $F7DD INC HL         ;
 $F7DE INC DE         ; }
 $F7DF LD A,(DE)      ; {*(#REGde) ^= *(#REGhl); advance #REGhl.
 $F7E0 XOR (HL)       ;
 $F7E1 LD (DE),A      ;
 $F7E2 INC HL         ; }
 $F7E3 EXX            ; {Switch to shadow; decrement #REGb (inner pixel row
 $F7E4 DEC B          ; counter); switch back.
 $F7E5 EXX            ; }
 $F7E6 JR NZ,$F7C2    ; Loop back to #R$F7C2 until all #N$07 pixel rows are
                      ; blitted.
 $F7E8 EXX            ; {Switch to shadow; decrement #REGc (outer attribute-row
 $F7E9 DEC C          ; counter); switch back.
 $F7EA EXX            ; }
 $F7EB JR NZ,$F786    ; Loop back to #R$F786 until all #N$04 attribute-cell
                      ; rows are blitted.
 $F7ED RET            ; Return.

; Animate Intro Sprites
;
; Used by the routine at #R$F4EC.
; .
; Iterates over the #N$18 three-byte entries in the sprite table at #R$F558
; (Y pixel row at +#N$00, X byte column at +#N$01, attribute byte at +#N$02) to
; animate the border march effect on the intro screen. For each entry, erases
; the sprite at its current position (calls #R$F76F with bit 7 of #REGe set
; in shadow to suppress attribute writes), advances the position by one step
; along a rectangular path (#N$08 pixel rows vertically or #N$01 byte column
; horizontally: right across Y=#N$00, down the right side at X=#N$1C, left
; across Y=#N$A0, up the left side at X=#N$00), then redraws the sprite at the
; new position (calls #R$F76F with bit 7 clear to write the attribute).
; Called once per frame by the attract mode loop at #R$F4EC.
@label=AnimateIntroSprites
c$F7EE LD B,$18      ; #REGb=#N$18 (loop counter: #N$24 sprite entries).
 $F7F0 LD HL,$F558   ; #REGhl=#R$F558 (attribute byte position of the first
                     ; entry).
@label=AnimateIntroSprites_Loop
*$F7F3 LD A,(HL)     ; #REGa=attribute byte from the current entry.
 $F7F4 EXX           ; {Switch to shadow; #REGe=attribute byte; SET bit 7
 $F7F5 LD E,A        ; (erase-mode flag for #R$F76F); switch back.
 $F7F6 SET 7,E       ;
 $F7F8 EXX           ; }
 $F7F9 DEC HL        ; {Back #REGhl two bytes to the Y pixel row (start of
 $F7FA DEC HL        ; entry).}
 $F7FB PUSH HL       ; {Stash #REGhl (entry start) and #REGbc on the stack.
 $F7FC PUSH BC       ; }
 $F7FD CALL $F76F    ; Call #R$F76F to erase the sprite at its current
                     ; position.
 $F800 POP BC        ; {Restore #REGbc and #REGhl (entry start).
 $F801 POP HL        ; }
; Advance the sprite position by one step along the rectangular border path.
; Y pixel row is at *(#REGhl), X byte column at *(#REGhl+#N$01). Steps are
; #N$08 pixel rows vertically or #N$01 byte column horizontally. Wraps at
; X=#N$1C (right boundary, drop down a row) and Y=#N$A0 (bottom boundary,
; scroll left).
 $F802 XOR A         ; #REGa=#N$00.
 $F803 CP (HL)       ; {If Y position (*#REGhl) = #N$00, jump to #R$F821 (top
 $F804 JR Z,$F821    ; row: scroll X instead of Y).}
 $F806 INC HL        ; {Read X position (*(#REGhl+#N$01)) and compare with
 $F807 CP (HL)       ; #N$00; restore #REGhl.
 $F808 DEC HL        ; }
 $F809 JR NZ,$F811   ; If X!=#N$00, jump to #R$F811.
 $F80B LD A,(HL)     ; {Y −= #N$08 (on left side, scroll up); jump to #R$F829.
 $F80C SUB $08       ;
 $F80E LD (HL),A     ;
 $F80F JR $F829      ; }
@label=AnimateIntroSprites_CheckBoundary
*$F811 LD A,$A0      ; {#REGa=#N$A0; compare with Y position.
 $F813 CP (HL)       ; }
 $F814 JR NZ,$F81B   ; If Y!=#N$A0, jump to #R$F81B (not at bottom boundary,
                     ; scroll down).
 $F816 INC HL        ; {X−− (at bottom boundary, scroll left); jump to #R$F828.
 $F817 DEC (HL)      ;
 $F818 JR $F828      ; }
@label=AnimateIntroSprites_DropRow
*$F81A DEC HL        ; Back #REGhl to the Y byte.
@label=AnimateIntroSprites_ScrollDown
*$F81B LD A,(HL)     ; {Y += #N$08 (scroll down); jump to #R$F829.
 $F81C ADD A,$08     ;
 $F81E LD (HL),A     ;
 $F81F JR $F829      ; }
; Top row (Y=#N$00): if X has reached the right boundary (#N$1C), drop a row
; (Y+=#N$08); otherwise scroll right (X++).
@label=AnimateIntroSprites_ScrollX
*$F821 INC HL        ; {Read X (*(#REGhl+#N$01)); if X=#N$1C jump to #R$F81A
 $F822 LD A,(HL)     ; (drop a row); otherwise X++.
 $F823 CP $1C        ;
 $F825 JR Z,$F81A    ; }
 $F827 INC (HL)      ; X++ (scroll right).
@label=AnimateIntroSprites_RestoreHL
*$F828 DEC HL        ; Restore #REGhl to the Y byte position.
@label=AnimateIntroSprites_Draw
*$F829 PUSH HL       ; {Stash #REGhl (entry start) and #REGbc on the stack.
 $F82A PUSH BC       ; }
 $F82B EXX           ; {Switch to shadow; RES bit 7 of #REGe (clear erase-mode
 $F82C RES 7,E       ; flag for draw pass); switch back.
 $F82E EXX           ; }
 $F82F CALL $F76F    ; Call #R$F76F to draw the sprite at the updated position.
 $F832 POP BC        ; {Restore #REGbc and #REGhl (entry start).
 $F833 POP HL        ; }
 $F834 INC HL        ; {Advance #REGhl by #N$05 to the attribute byte of the
 $F835 INC HL        ; next entry.
 $F836 INC HL        ;
 $F837 INC HL        ;
 $F838 INC HL        ; }
 $F839 DJNZ $F7F3    ; Decrease counter and loop back to #R$F7F3.
 $F83B RET           ; Return.

; Draw Intro Sprites
;
; Used by the routine at #R$F4EC.
; .
; Iterates over the #N$18 three-byte entries in the sprite table at #R$F558
; (Y pixel row at +#N$00, X byte column at +#N$01, attribute byte at +#N$02),
; calling #R$F76F once per entry to draw each sprite in its initial position.
; Called once during attract-mode setup at #R$F4EC before the animation loop
; begins.
@label=DrawIntroSprites
c$F83C LD B,$18      ; #REGb=#N$18 (loop counter: #N$24 sprite entries).
 $F83E LD HL,$F558   ; #REGhl=#R$F558 (attribute byte position of the first
                     ; entry).
@label=DrawIntroSprites_Loop
*$F841 LD A,(HL)     ; #REGa=attribute byte from the current entry.
 $F842 EXX           ; Switch to the shadow registers.
 $F843 LD E,A        ; #REGe=attribute byte (passed to #R$F76F as the draw-mode
                     ; attribute).
 $F844 EXX           ; Switch back to the normal registers.
 $F845 PUSH BC       ; {Stash #REGbc and #REGhl on the stack.
 $F846 PUSH HL       ; }
 $F847 DEC HL        ; {Back #REGhl two bytes to the Y pixel row (start of
 $F848 DEC HL        ; entry).}
 $F849 CALL $F76F    ; Call #R$F76F to draw the sprite at the position held in
                     ; the current entry.
 $F84C POP HL        ; {Restore #REGhl and #REGbc from the stack.
 $F84D POP BC        ; }
 $F84E INC HL        ; {Advance #REGhl by three to the attribute byte of the
 $F84F INC HL        ; next entry.
 $F850 INC HL        ; }
 $F851 DJNZ $F841    ; Decrease counter and loop back to #R$F841.
 $F853 RET           ; Return.

