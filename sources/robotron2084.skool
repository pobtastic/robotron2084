 $D311 CALL $D07E    ; }
 $D314 JP $D325      ; Jump to #R$D325.

; Render HUD
;
; Used by the routines at #R$D0F0 and #R$D367.
; .
; Clears the screen buffer, sets a white background, triggers the wave
; indicator animation (#R$D570), and redraws the attribute bar (#R$C713)
; before falling through to #R$D325. Scores (#R$C544) and lives (#R$C794)
; are then rendered for each player in turn by swapping state with #R$D08B;
; the "WAVE" label and wave number (#R$D0A7) are printed last for player 1.
@label=RenderHUD
c$D317 CALL $D070    ; Call #R$D070.
 $D31A LD A,$07      ; {Call #R$D07E using #INK$07.
 $D31C CALL $D07E    ; }
 $D31F CALL $D570    ; Call #R$D570.
 $D322 CALL $C713    ; Call #R$C713.
; This entry point is used by the routine at #R$D30C.
; .
; Shared entry point, also reached from #R$D30C via JP (which clears the
; screen and sets the background but skips the wave animation and attribute
; bar setup). Renders scores and lives for player 1, then swaps to player 2.
@label=RenderHUD_Draw
*$D325 CALL $C544    ; Call #R$C544.
 $D328 CALL $C794    ; Call #R$C794.
; Swap to player 2 to render their score, lives and wave number.
 $D32B CALL $D08B    ; Call #R$D08B.
 $D32E CALL $C544    ; Call #R$C544.
 $D331 CALL $C794    ; Call #R$C794.
 $D334 CALL $D0A7    ; Call #R$D0A7.
; Swap back to player 1; print the "WAVE" label and player 1's wave number,
; then redraw the attribute bar to complete the HUD.
 $D337 CALL $D08B    ; Call #R$D08B.
 $D33A LD HL,$D0E6   ; {Call #R$9006 using #R$D0E6.
 $D33D CALL $9006    ; }
 $D340 CALL $D0A7    ; Call #R$D0A7.
 $D343 CALL $C713    ; Call #R$C713.
 $D346 RET           ; Return.

; Messaging: Player
@label=Messaging_Player
t$D347 DEFB $10,$07     ; Set INK: #INK(#PEEK(#PC+$01)).
 $D349 DEFB $11,$00     ; Set PAPER: #INK(#PEEK(#PC+$01)).
 $D34B DEFB $16,$68,$56 ; PRINT AT #N(#PEEK(#PC+$01)), #N(#PEEK(#PC+$02)).
 $D34E DEFM "PLAYER "
 $D355 DEFB $1F         ; Terminator.

; Messaging: Game Over
@label=Messaging_GameOver
t$D356 DEFB $10,$07     ; Set INK: #INK(#PEEK(#PC+$01)).
 $D358 DEFB $11,$00     ; Set PAPER: #INK(#PEEK(#PC+$01)).
 $D35A DEFB $16,$65,$5E ; PRINT AT #N(#PEEK(#PC+$01)), #N(#PEEK(#PC+$02)).
 $D35D DEFM "GAME OVER"
 $D366 DEFB $1F         ; Terminator.

; Player Death
;
; Used by the routine at #R$D3F8.
; .
; Handles a lost life and game-over flow: optional HUD and "PLAYER" messaging,
; decrementing #R$C415, calling #R$D24C to re-stage the wave, swapping players with
; #R$D08B, printing "GAME OVER" when no lives remain, and either returning to the
; attract mode at #R$EBBC or looping. A lookup table at #R$D3E4 (read from #R$D400)
; supplies a start pointer stored at #R$C519; #R$ECFB jumps to #R$D3F8 after a
; successful tape load. Clears player state at #R$C403, wave and score fields, and
; applies #R$D481 (reset margins) when starting a fresh game.
@label=PlayerDeath
c$D367 LD A,($C532)    ; #REGa=*#R$C532 (death-sequence mode; #N$01 = skip the
                       ; intro HUD/delay).
 $D36A CP $01          ; Compare with #N$01.
 $D36C JR Z,$D38B      ; If set, jump to #R$D38B to decrement #R$C415
                       ; immediately.
; Full death sequence: redraw the HUD (#R$D317), print #R$D347 ("PLAYER") via
; #R$9006, then print the current player digit from *#R$C41F as ASCII (#N$30–#N$39).
 $D36E CALL $D317      ; Call #R$D317.
 $D371 LD HL,$D347     ; {Call #R$9006 using #R$D347.
 $D374 CALL $9006      ; }
 $D377 LD A,($C41F)    ; #REGa=*#R$C41F (player index for the digit).
 $D37A ADD A,%00110000 ; Convert to ASCII ("#CHR$30"–"#CHR$39").
 $D37C CALL $8DCC      ; Call #R$8DCC (print dispatch).
 $D37F LD B,$20        ; Inner delay loop count #N$20 (#REGb=#N$20).
@label=PlayerDeath_IntroDelay
*$D381 PUSH BC         ; Stash #REGbc on the stack.
 $D382 CALL $DAA3      ; Call #R$DAA3 (short delay).
 $D385 CALL $C713      ; Call #R$C713 (attribute bar).
 $D388 POP BC          ; Restore #REGbc from the stack.
 $D389 DJNZ $D381      ; Decrease counter and loop back to #R$D381 until the
                       ; intro delay finishes.
; See #POKE(infinite-lives)(Infinite Lives (Final Version)).
@label=PlayerDeath_LoseLife
*$D38B LD HL,$C415     ; #REGhl=#R$C415 (lives counter).
 $D38E DEC (HL)        ; Decrease *#REGhl (lose one life).
 $D38F CALL $D24C      ; Call #R$D24C (re-stage the wave / death handling).
 $D392 LD A,($C415)    ; {Jump to #R$D3A7 if *#R$C415 shows no lives are left.
 $D395 AND A           ;
 $D396 JR Z,$D3A7      ; }
; Lives remain: swap to the other player and continue if two-player mode.
 $D398 CALL $D08B      ; Call #R$D08B.
; If not two-player, jump back to #R$D367 for the same player.
 $D39B LD A,($C41E)    ; {Jump back to #R$D367 if *#R$C41E is not set.
 $D39E CP $01          ;
 $D3A0 JR NZ,$D367     ; }
 $D3A2 CALL $D08B      ; Call #R$D08B (swap back).
 $D3A5 JR $D367        ; Jump back to #R$D367.
; No lives left: redraw the HUD, then either the "PLAYER" line or straight to
; "GAME OVER" depending on *#R$C532, with a longer delay loop.
@label=PlayerDeath_GameOver
*$D3A7 CALL $D317      ; Call #R$D317.
 $D3AA LD A,($C532)    ; {Jump to #R$D3BF if *#R$C532 is #N$01.
 $D3AD CP $01          ;
 $D3AF JR Z,$D3BF      ; }
 $D3B1 LD HL,$D347     ; {Call #R$9006 using #R$D347.
 $D3B4 CALL $9006      ; }
 $D3B7 LD A,($C41F)    ; #REGa=*#R$C41F.
 $D3BA ADD A,%00110000 ; Convert to ASCII.
 $D3BC CALL $8DCC      ; Call #R$8DCC.
@label=PlayerDeath_GameOverDelay
*$D3BF LD HL,$D356     ; {Call #R$9006 using #R$D356.
 $D3C2 CALL $9006      ; }
 $D3C5 LD B,$29        ; Longer delay loop count #N$29 (#REGb=#N$29).
@label=PlayerDeath_GameOverDelayLoop
*$D3C7 PUSH BC         ; Stash #REGbc on the stack.
 $D3C8 CALL $DAA3      ; Call #R$DAA3.
 $D3CB CALL $C713      ; Call #R$C713.
 $D3CE POP BC          ; Restore #REGbc from the stack.
 $D3CF DJNZ $D3C7      ; Decrease counter and loop back to #R$D3C7.
; Set *#R$C41E to #N$01, swap players with #R$D08B, then branch on the flag
; read back from *#R$C41E.
 $D3D1 LD A,$01        ; {Write #N$01 to *#R$C41E.
 $D3D3 LD ($C41E),A    ; }
 $D3D6 CALL $D08B      ; Call #R$D08B.
 $D3D9 LD A,($C41E)    ; {Jump to #R$EBBC if *#R$C41E is #N$01 (attract mode).
 $D3DC CP $01          ;
 $D3DE JP Z,$EBBC      ; }
 $D3E1 JP $D367        ; Jump back to #R$D367.

; Game status buffer entry at D3E4
g$D3E4 DEFB $F9,$DD,$0D,$DE,$27,$DE,$41,$DE
 $D3EC DEFB $5B,$DE,$75,$DE,$8F,$DE,$A6,$DE
 $D3F4 DEFB $C0,$DE,$DA,$DE

; Player Death: Tape Load Continue
;
; Used by the routine at #R$ECFB.
;
; B Scratch (from the tape block header at *#R$C4FD).
; E Scratch (from the tape block header at *#R$C4FE).
;
; This routine is called after a successful tape load.
@label=PlayerDeath_TapeLoadContinue
c$D3F8 LD A,($C4FE)  ; Load #REGa with *#R$C4FE.
 $D3FB DEC A         ; Decrease #REGa by one.
 $D3FC ADD A,A       ; {#REGe=#REGa multiplied by #N$02.
 $D3FD LD E,A        ; }
 $D3FE LD D,$00      ; #REGd=#N$00 (high byte of index).
 $D400 LD HL,$D3E4   ; #REGhl=#R$D3E4 (base of the lookup table).
 $D403 ADD HL,DE     ; Add #REGde into #REGhl (index into the table).
 $D404 LD A,(HL)     ; #REGa=*(#REGhl) (low byte of the table word).
 $D405 INC HL        ; Advance #REGhl.
 $D406 LD H,(HL)     ; #REGh=*(#REGhl) (high byte of the table word).
 $D407 LD L,A        ; #REGl=#REGa (little-endian word in #REGhl).
 $D408 LD ($C519),HL ; Write the pointer to *#R$C519.
 $D40B LD A,B        ; {Write #REGb (variant/ slot) to *#R$C532.
 $D40C LD ($C532),A  ; }
 $D40F LD A,($C416)  ; {Jump to #R$D41B if *#R$C416 is at the maximum wave.
 $D412 CP $3C        ;
 $D414 JR Z,$D41B    ; }
 $D416 PUSH BC       ; Stash #REGbc on the stack.
 $D417 CALL $D08B    ; Call #R$D08B.
 $D41A POP BC        ; Restore #REGbc from the stack.
; Set the starting lives.
@label=PlayerDeath_InitMaxWave
*$D41B LD A,$03      ; {Write #N$03 to *#R$C415.
 $D41D LD ($C415),A  ; }
 $D420 XOR A         ; {Write #N$00 to *#R$C41E.
 $D421 LD ($C41E),A  ; }
 $D424 LD A,$44      ; {Write #COLOUR$44 (#N$44) to; #LIST
 $D426 LD ($C42E),A  ; { *#R$C42E }
 $D429 LD ($C46E),A  ; { *#R$C46E }
                     ; LIST#}
 $D42C LD A,B        ; {Jump to #R$D442 (margins + clear) if this is player
 $D42D CP $01        ; #N$01.
 $D42F JR Z,$D442    ; }
 $D431 CALL $D08B    ; Call #R$D08B.
 $D434 LD A,$03      ; {Write #N$03 to *#R$C415.
 $D436 LD ($C415),A  ; }
 $D439 XOR A         ; {Write #N$00 to *#R$C41E.
 $D43A LD ($C41E),A  ; }
 $D43D LD A,$44      ; {Write #COLOUR$44 (#N$44) to *#R$C42E.
 $D43F LD ($C42E),A  ; }
@label=PlayerDeath_NewGameSetup
*$D442 LD HL,$D481   ; {Call #R$9006 using #R$D481.
 $D445 CALL $9006    ; }
 $D448 XOR A         ; #REGa=#N$00.
 $D449 LD B,$02      ; Outer loop: two player slots (#REGb=#N$02).
@label=PlayerDeath_ClearPlayerSlot
*$D44B LD HL,$C403   ; #REGhl=#R$C403 (player 1 state block).
 $D44E LD C,$04      ; Clear #N$04 bytes per slot (#REGc=#N$04).
@label=PlayerDeath_ClearPlayerBytes
*$D450 LD (HL),A     ; Write #REGa to *#REGhl.
 $D451 INC HL        ; Advance #REGhl.
 $D452 DEC C         ; Decrease #REGc.
 $D453 JR NZ,$D450   ; Loop back to #R$D450 until the slot prefix is cleared.
 $D455 LD ($C408),A  ; Write #REGa to *#R$C408.
 $D458 LD ($C41C),A  ; Write #REGa to *#R$C41C.
 $D45B LD HL,$C418   ; #REGhl=#R$C418.
 $D45E LD (HL),A     ; Write #REGa to *#REGhl.
 $D45F INC HL        ; Advance #REGhl.
 $D460 LD (HL),$02   ; Write #N$02 to *#REGhl.
 $D462 INC HL        ; Advance #REGhl.
 $D463 LD (HL),A     ; Write #REGa to *#REGhl.
 $D464 INC HL        ; Advance #REGhl.
 $D465 LD (HL),A     ; Write #REGa to *#REGhl.
 $D466 LD HL,($C519) ; {Write *#R$C519 to *#R$C409.
 $D469 LD ($C409),HL ; }
 $D46C PUSH BC       ; Stash #REGbc on the stack.
 $D46D CALL $D08B    ; Call #R$D08B.
 $D470 POP BC        ; Restore #REGbc from the stack.
 $D471 DJNZ $D44B    ; Decrease outer counter and loop back to #R$D44B for the
                     ; second player.
 $D473 LD A,($C416)  ; {Jump back to #R$D367 if *#R$C416 is still at the
 $D476 CP $3C        ; maximum wave.
 $D478 JP Z,$D367    ; }
 $D47B CALL $D08B    ; Call #R$D08B.
 $D47E JP $D367      ; Jump back to #R$D367.

; Messaging: Reset Margins
@label=Messaging_ResetMargins
t$D481 DEFB $18,$00  ; Set left margin: #N(#PEEK(#PC+$01)).
 $D483 DEFB $19,$FF  ; Set right margin: #N(#PEEK(#PC+$01)).
 $D485 DEFB $1F      ; Terminator.

