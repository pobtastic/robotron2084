; Initialise Entity State
;
; Used by the routines at #R$CB4F, #R$CD34, #R$E22A, #R$E4B9, #R$E974 and
; #R$EB07.
; .
; Activates an entity state effect by copying a 16-byte
; configuration record from #R$D9EA into the active state slot at
; #R$C521. The entity type code in #REGe selects the record
; (multiplied by #N$10). If #R$C52F is zero, no effect is pending
; and the routine returns immediately without change.
;
; E Entity type code
@label=Initialise_Entity_State
c$D9C4 LD A,($C52F)  ; {Return if no entity state effect is pending.
 $D9C7 AND A         ;
 $D9C8 RET Z         ; }
 $D9C9 SLA E         ; {Multiply the entity type code by #N$10 to form the
 $D9CB SLA E         ; record offset.
 $D9CD SLA E         ;
 $D9CF SLA E         ;
 $D9D1 LD D,$00      ; }
 $D9D3 LD HL,$D9EA   ; {Index into #R$D9EA by offset and set #REGde to #R$C521.
 $D9D6 ADD HL,DE     ;
 $D9D7 LD DE,$C521   ; }
 $D9DA LD BC,$0010   ; {Copy the #N$10-byte effect record to #R$C521.
 $D9DD LDIR          ; }
 $D9DF RET           ; Return.

; Dispatch Entity State Handler
;
; Used by the routine at #R$CB4F.
; .
; Called once per frame by the main game loop at #R$CB4F. Reads the state
; flag at #R$C52F; if #N$02 (complete) returns immediately. Otherwise loads
; the dispatch pointer from #R$C521 and jumps through it to the active entity
; state handler.
@label=Dispatch_Entity_State_Handler
c$D9E0 LD A,($C52F)  ; {Return if the entity state is complete (#N$02).
 $D9E3 CP $02        ;
 $D9E5 RET Z         ; }
 $D9E6 LD HL,($C521) ; {Load the entity state dispatch pointer from #R$C521 and jump
 $D9E9 JP (HL)       ; through it.}

; Entity State Table
;
; Table of 16-byte entity state records indexed by entity type. Each entry
; is copied to #N$C521 by #R$D9C4 on entity placement. The first two bytes of
; each record form the dispatch handler address used by #R$D9E0; the remaining
; 14 bytes are parameters for the active effect.
@label=Entity_State_Table
b$D9EA DEFB $2A,$DA,$E8,$03,$05,$00,$14,$00
 $D9F2 DEFB $0C,$00,$01,$00,$0A,$00,$00,$00
 $D9FA DEFB $66,$DA,$00,$00,$05,$00,$04,$00
 $DA02 DEFB $0C,$00,$05,$00,$00,$00,$01,$00
 $DA0A DEFB $66,$DA,$00,$00,$F5,$00,$0A,$00
 $DA12 DEFB $0C,$00,$FE,$FF,$07,$00,$00,$00
 $DA1A DEFB $66,$DA,$00,$00,$05,$00,$0A,$00
 $DA22 DEFB $0A,$00,$01,$00,$05,$00,$00,$00

; Cycle Border from Screen
;
; Drives the per-frame border colour cycling effect. Reads successive pixel
; bytes from the screen buffer pointer at #N$C523, ANDs each byte with #N$18
; to extract the paper colour bits, and writes the result to the border port
; #N$FE. Between each byte a variable delay is run, its period advanced by the
; step value at #N$C52B. After the outer loop the frame counter at #N$C527 is
; decremented; when it reaches the threshold at #N$C52D, #R$C52F is set to
; #N$01 (step complete). When the frame counter reaches zero, #R$C52F is set
; to #N$02 (all complete). The alternate entry at #R$DA6B drives the same
; counter machinery without sampling screen data, instead XOR-toggling the
; border between two colours.
@label=Cycle_Border_From_Screen
c$DA2A LD HL,($C523) ; {Load the screen data pointer from #N$C523 and the outer loop count
 $DA2D LD A,($C529)  ; from #N$C529 into #REGb.}
 $DA30 LD B,A        ;
@label=Cycle_Border_Loop
*$DA31 LD A,$18      ; {Read the next pixel byte, mask to paper bits with #N$18, and write
 $DA33 AND (HL)      ; to the border port #N$FE.}
 $DA34 OUT ($FE),A   ;
 $DA36 INC HL        ; Advance the screen data pointer.
 $DA37 LD A,($C525)  ; {Load the current delay count from #N$C525 into #REGc.
 $DA3A LD C,A        ; }
@label=Cycle_Border_Delay
*$DA3B DEC C         ; {Busy-wait for the delay period.
 $DA3C JR NZ,$DA3B   ; }
 $DA3E LD C,A        ; {Reload #REGc, add the step increment from #N$C52B, and store the
 $DA3F LD A,($C52B)  ; updated delay back to #N$C525.
 $DA42 ADD A,C       ;
 $DA43 LD ($C525),A  ; }
 $DA46 DJNZ $DA31    ; Loop back to #R$DA31 for the next pixel byte.
 $DA48 LD ($C523),HL ; Save the updated screen data pointer back to #N$C523.
 $DA4B LD A,($C527)  ; {Decrement the frame counter at #N$C527 and jump to #R$DA60 if it
 $DA4E DEC A         ; has reached zero.
 $DA4F JR Z,$DA60    ; }
 $DA51 LD ($C527),A  ; {Save the decremented frame counter; return if it has not yet reached
 $DA54 LD B,A        ; the completion threshold at #N$C52D.
 $DA55 LD A,($C52D)  ;
 $DA58 CP B          ;
 $DA59 RET NZ        ; }
 $DA5A LD A,$01      ; {Set #R$C52F to #N$01 (step complete) and return.
 $DA5C LD ($C52F),A  ;
 $DA5F RET           ; }
@label=Cycle_Border_Complete
*$DA60 LD A,$02      ; {Set #R$C52F to #N$02 (all complete) and return.
 $DA62 LD ($C52F),A  ;
 $DA65 RET           ; }
; Alternate entry: toggle the border colour on each pass without reading
; screen data.
@label=Cycle_Border_Toggle
 $DA66 LD A,($C529)  ; {Load the outer loop count from #N$C529 into #REGb and
 $DA69 LD B,A        ; clear #REGa.
 $DA6A XOR A         ; }
@label=Cycle_Border_Toggle_Loop
*$DA6B XOR %00011000 ; XOR the border value with #N$18 to toggle between two
                     ; colours.
 $DA6D OUT ($FE),A   ; {Write the toggled value to the border port #N$FE and stash it in
 $DA6F LD D,A        ; #REGd.}
 $DA70 LD A,($C525)  ; {Load the delay count from #N$C525 into #REGc.
 $DA73 LD C,A        ; }
@label=Cycle_Border_Toggle_Delay
*$DA74 DEC C         ; {Busy-wait for the delay period.
 $DA75 JR NZ,$DA74   ; }
 $DA77 LD C,A        ; {Reload #REGc, add the step increment from #N$C52B, and store the
 $DA78 LD A,($C52B)  ; updated delay back to #N$C525.
 $DA7B ADD A,C       ;
 $DA7C LD ($C525),A  ; }
 $DA7F LD A,D        ; {Reload the toggled border value from #REGd and loop back to
 $DA80 DJNZ $DA6B    ; #R$DA6B.}
 $DA82 LD A,($C527)  ; {Decrement the frame counter at #N$C527 and jump to #R$DA60 if it
 $DA85 DEC A         ; has reached zero.
 $DA86 JR Z,$DA60    ; }
 $DA88 LD ($C527),A  ; {Save the decremented frame counter; return if it has not yet reached
 $DA8B LD B,A        ; the completion threshold at #N$C52D.
 $DA8C LD A,($C52D)  ;
 $DA8F CP B          ;
 $DA90 RET NZ        ; }
 $DA91 LD A,$01      ; {Set #R$C52F to #N$01 (step complete) and return.
 $DA93 LD ($C52F),A  ;
 $DA96 RET           ; }

; Delay Short
;
; Busy-wait delay: outer loop of #N$0A iterations, inner loop of #N$00
; (256 cycles) each. Stashes and restores #REGbc.
@label=Delay_Short
c$DA97 PUSH BC       ; Stash #REGbc on the stack.
 $DA98 LD C,$0A      ; #REGc=#N$0A (outer loop counter).
@label=Delay_Short_OuterLoop
*$DA9A LD B,$00      ; {Inner loop: spin #REGb from #N$00 (256 iterations per
@label=Delay_Short_InnerLoop
*$DA9C DJNZ $DA9C    ; pass).}
