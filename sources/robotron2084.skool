 $C8DA LD E,A        ; record.
 $C8DB INC HL        ;
 $C8DC LD D,(HL)     ;
 $C8DD INC HL        ; }
 $C8DE LD A,(BC)     ; {XOR-render 2 sprite bytes at the fourth screen row and
 $C8DF EX DE,HL      ; restore.
 $C8E0 XOR (HL)      ;
 $C8E1 LD (HL),A     ;
 $C8E2 INC BC        ;
 $C8E3 INC HL        ;
 $C8E4 LD A,(BC)     ;
