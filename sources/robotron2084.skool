; Reset Print State
;
; Used by the routine at #R$9010.
@label=ResetPrintState
c$9044 LD HL,$8DE3   ; {Write #R$8DE3 to *#R$800A.
 $9047 LD ($800A),HL ; }
 $904A LD HL,$9051   ; {Call #R$9006 using #R$9051.
 $904D CALL $9006    ; }
 $9050 RET           ; Return.

