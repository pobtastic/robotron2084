 $EDD4 LD B,$1C      ;
*$EDD6 LD (HL),C     ;
 $EDD7 INC HL        ;
 $EDD8 DJNZ $EDD6    ;
 $EDDA LD D,E        ;
 $EDDB XOR A         ;
 $EDDC RET           ;
