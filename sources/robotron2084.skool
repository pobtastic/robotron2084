 $EDB9 INC HL        ;
 $EDBA LD A,(HL)     ;
 $EDBB PUSH DE       ;
 $EDBC CALL $EE0B    ;
 $EDBF POP DE        ;
 $EDC0 CALL $EE1D    ;
 $EDC3 PUSH IX       ;
 $EDC5 POP HL        ;
 $EDC6 INC HL        ;
 $EDC7 LD A,D        ;
 $EDC8 CALL $EE02    ;
 $EDCB INC HL        ;
 $EDCC LD A,(HL)     ;
 $EDCD PUSH DE       ;
 $EDCE CALL $EE0B    ;
