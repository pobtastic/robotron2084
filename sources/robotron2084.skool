 $C98E ADD A,(HL)    ; {Blit the first sprite row onto the display.
 $C98F LD E,A        ;
 $C990 INC HL        ;
 $C991 LD D,(HL)     ;
 $C992 INC HL        ;
 $C993 EX DE,HL      ;
 $C994 LD A,(BC)     ;
 $C995 XOR (HL)      ;
 $C996 LD (HL),A     ;
 $C997 INC BC        ;
 $C998 INC HL        ;
 $C999 LD A,(BC)     ;
 $C99A XOR (HL)      ;
 $C99B LD (HL),A     ;
 $C99C INC BC        ;
 $C99D INC HL        ;
 $C99E LD A,(BC)     ;
 $C99F XOR (HL)      ;
 $C9A0 LD (HL),A     ;
 $C9A1 INC BC        ; }
 $C9A2 EXX           ; {Jump to #R$C9B9 if in erase mode (skip the attribute
 $C9A3 LD A,D        ; write).
 $C9A4 AND A         ;
 $C9A5 EXX           ;
 $C9A6 JR Z,$C9B9    ; }
 $C9A8 LD A,H        ; {Compute the attribute area address from the current
 $C9A9 RRCA          ; screen row.
 $C9AA RRCA          ;
 $C9AB RRCA          ; }
