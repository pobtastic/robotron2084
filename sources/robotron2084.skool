; Game Entry Point Alias
@label=GameEntryPointAlias
c$C400 JP $EBBC      ; Jump to #R$EBBC.

; Player 1 State
;
; Root of the active player state block (see #R$D08B / #R$D44B). Leading
; bytes hold the packed score for #R$C544 and the prefix compared in #R$C5C1.
@label=Player_1_State
g$C403 DEFB $00
 $C404 DEFB $00
 $C405 DEFB $00
 $C406 DEFB $00
 $C407 DEFB $FF

; Wave Number
@label=WaveNumber
g$C408 DEFB $01

; Wave Definition Pointer
;
; Pointer to the current entry in the wave definition table. Read by #R$D24C
; to load the enemy count and type for the incoming wave; advanced after each
; wave is staged.
@label=Wave_Definition_Pointer
g$C409 DEFW $0000
 $C40B DEFB $43,$50,$4C,$00,$32,$2D,$09,$4F
 $C413 DEFB $52

; Game status buffer entry at C414
g$C414 DEFB $05

; Lives
@label=Lives
g$C415 DEFB $00

; Wave
@label=Wave
g$C416 DEFB $3C

; Lives Display Vertical Step
;
; Vertical pixel stride between adjacent life icons in #R$C794. Each
; pass advances the vertical seed by this value (#N$06) to space icons
; evenly in the lives display column.
@label=Lives_Display_Vertical_Step
g$C417 DEFB $06

; Extra Life Compare Byte 0
;
; First byte of the four-byte template compared with *#R$C403 in #R$C5C1.
@label=ExtraLifeCompare_b0
g$C418 DEFB $00

; Extra Life Compare Byte 1
;
; Second template byte vs *#R$C404 in #R$C5C1. Also the BCD byte that
; #R$C5C1 adds #N$02 to (carry into *#R$C415). Seeded as #N$02 in #R$D45F.
@label=ExtraLifeCompare_b1
g$C419 DEFB $00

; Extra Life Compare Byte 2
;
