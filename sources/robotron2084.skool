;
; Read the sprite data pointer and compute the screen address origin.
@label=Draw_Wide_Entity_Sprite_Pixels_Only
c$DAAF LD B,H        ; {Stash the entity record pointer in #REGbc.
 $DAB0 LD C,L        ; }
 $DAB1 LD E,(HL)     ; {Read the entity type, double it as an index into #R$C60C, and
 $DAB2 SLA E         ; load the sprite data pointer into #REGde.
 $DAB4 LD D,$00      ;
 $DAB6 LD HL,$C60C   ;
 $DAB9 ADD HL,DE     ;
 $DABA LD E,(HL)     ;
 $DABB INC HL        ;
 $DABC LD D,(HL)     ; }
 $DABD LD H,B        ; {Restore the entity record pointer and advance to the Y
 $DABE LD L,C        ; field.
 $DABF INC HL        ; }
