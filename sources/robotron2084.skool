; Print Player Score
;
; Used by the routines at #R$CD34 and #R$D317.
; .
; Draws the player's score on screen from the packed BCD bytes at
; #R$C403 (two decimal digits per byte), terminated by #N$FF. Each digit
; occupies six screen rows; the display row starts at *#R$C414 and advances
; by #N$06 per digit. All digits are printed at column #N$02 via #R$8DCC.
; After the last digit the score display attributes are refreshed by #R$C71F.
; Called from #R$C84F and #R$D317.
@label=PrintPlayerScore
c$C544 LD A,($C414)  ; {Load the initial display row for this score line into
 $C547 LD C,A        ; #REGc.}
 $C548 LD HL,$C403   ; Point #REGhl at the active player's BCD score at
                     ; #R$C403.
@label=PrintPlayerScore_NextByte
*$C54B LD A,(HL)     ; Read the next byte from the BCD score string.
 $C54C CP $FF        ; {Jump to #R$C5A8 if all score digits have been printed (terminator
 $C54E JP Z,$C5A8    ; #N$FF).}
 $C551 AND %11110000 ; Isolate the tens digit (high BCD nibble).
 $C553 JP NZ,$C568   ; Jump to #R$C568 if the tens digit is non-zero.
 $C556 LD A,C        ; {Advance the display row by #N$06 (skip the blank
 $C557 ADD A,$06     ; tens-digit row).
 $C559 LD C,A        ; }
 $C55A LD A,(HL)     ; Reload the BCD byte to test the units digit.
 $C55B AND %00001111 ; Isolate the units digit (low BCD nibble).
 $C55D JP NZ,$C597   ; Jump to #R$C597 if the units digit is non-zero.
 $C560 LD A,C        ; {Advance the display row by #N$06 (skip the blank
 $C561 ADD A,$06     ; units-digit row).
 $C563 LD C,A        ; }
 $C564 INC HL        ; Advance #REGhl to the next BCD byte.
 $C565 JP $C54B      ; Jump back to #R$C54B to process the next BCD byte.
; The tens digit is non-zero; position the score cursor and print both
; digits of this BCD byte.
@label=PrintPlayerScore_HighNibble
*$C568 LD A,$16      ; {Position the score cursor at row #REGc, column #N$02.
 $C56A CALL $8DCC    ;
 $C56D LD A,C        ;
 $C56E CALL $8DCC    ;
 $C571 LD A,$02      ;
 $C573 CALL $8DCC    ; }
 $C576 LD A,(HL)     ; Reload the BCD byte for digit extraction.
@label=PrintPlayerScore_NextDigitHigh
*$C577 SRL A         ; {Shift #REGa right four places to extract the tens
 $C579 SRL A         ; digit.
 $C57B SRL A         ;
 $C57D SRL A         ; }
 $C57F OR %00110000  ; Convert the tens digit to its ASCII character code.
 $C581 CALL $8DCC    ; Print the tens digit of this score byte.
@label=PrintPlayerScore_PrintLowNibble
*$C584 LD A,(HL)     ; Reload the BCD byte for the units digit.
 $C585 AND %00001111 ; Isolate the units digit (low BCD nibble).
 $C587 OR %00110000  ; Convert the units digit to its ASCII character code.
 $C589 CALL $8DCC    ; Print the units digit of this score byte.
 $C58C INC HL        ; {Advance #REGhl and read the next BCD byte.
 $C58D LD A,(HL)     ; }
 $C58E CP $FF        ; {Jump back to #R$C577 if more score digits remain.
 $C590 JP NZ,$C577   ; }
 $C593 CALL $C71F    ; Call #R$C71F to refresh the score display attributes.
 $C596 RET           ; Return.
; The tens digit is #N$00 but the units digit is non-zero; position
; the score cursor, then jump to #R$C584 to print only the units digit.
@label=PrintPlayerScore_LowNibbleOnly
*$C597 LD A,$16      ; {Position the score cursor at row #REGc, column #N$02.
 $C599 CALL $8DCC    ;
 $C59C LD A,C        ;
 $C59D CALL $8DCC    ;
 $C5A0 LD A,$02      ;
 $C5A2 CALL $8DCC    ; }
 $C5A5 JP $C584      ; Jump to #R$C584 to print the units digit only.
; All BCD bytes printed; place a trailing zero at the last digit row
; (row #REGc - #N$06) and refresh the score display attributes.
@label=PrintPlayerScore_Terminator
*$C5A8 LD A,$16      ; {Position the score cursor at row #REGc - #N$06, column
 $C5AA CALL $8DCC    ; #N$02.
 $C5AD LD A,C        ;
 $C5AE SUB $06       ;
 $C5B0 CALL $8DCC    ;
 $C5B3 LD A,$02      ;
 $C5B5 CALL $8DCC    ; }
 $C5B8 LD A,$30      ; {Print a trailing zero (#N$30) at the final score digit
 $C5BA CALL $8DCC    ; position.}
 $C5BD CALL $C71F    ; Call #R$C71F to refresh the score display attributes.
 $C5C0 RET           ; Return.

; Check Score Award Life
;
; Used by the routine at #R$CB4F.
; .
; Checks whether the player's score has reached the extra-life
; threshold. Compares the four BCD score bytes at #R$C403 against the
; threshold at #R$C418. Returns immediately if the score falls below the
; threshold on any byte. When the threshold is reached, awards one extra
; life, refreshes the life icons, and raises the threshold by BCD #N$02
; ready for the next award. Called from #R$C84F.
;
; .
;
; Compare the four BCD score bytes against the extra-life threshold;
; return if the score is below the threshold on any byte.
@label=CheckScoreAwardLife
c$C5C1 LD DE,$C403   ; Point #REGde at the player's BCD score at #R$C403.
 $C5C4 LD HL,$C418   ; Point #REGhl at the extra-life threshold at #R$C418.
 $C5C7 LD A,(DE)     ; {Return if score byte 0 is below the extra-life
 $C5C8 CP (HL)       ; threshold.
 $C5C9 RET C         ; }
 $C5CA INC HL        ; {Advance to the next score and threshold byte.
 $C5CB INC DE        ; }
 $C5CC LD A,(DE)     ; {Return if score byte 1 is below the extra-life
 $C5CD CP (HL)       ; threshold.
 $C5CE RET C         ; }
 $C5CF INC HL        ; {Advance to the next score and threshold byte.
 $C5D0 INC DE        ; }
 $C5D1 LD A,(DE)     ; {Return if score byte 2 is below the extra-life
 $C5D2 CP (HL)       ; threshold.
 $C5D3 RET C         ; }
 $C5D4 INC HL        ; {Advance to the next score and threshold byte.
 $C5D5 INC DE        ; }
 $C5D6 LD A,(DE)     ; {Return if score byte 3 is below the extra-life
 $C5D7 CP (HL)       ; threshold.
 $C5D8 RET C         ; }
 $C5D9 LD HL,$C415   ; Point #REGhl at the player's life counter at #R$C415.
 $C5DC INC (HL)      ; Award the player one extra life.
 $C5DD CALL $C794    ; Redraw the life icons display.
; Raise the extra-life threshold by BCD #N$02, propagating carry
; from #R$C419 into #R$C418 if needed.
 $C5E0 LD HL,$C419   ; Point #REGhl at the extra-life threshold low byte at
                     ; #R$C419.
 $C5E3 LD A,$02      ; {Add BCD #N$02 to the extra-life threshold low byte.
 $C5E5 ADD A,(HL)    ;
 $C5E6 DAA           ;
 $C5E7 LD (HL),A     ; }
 $C5E8 RET NC        ; Return if the threshold advanced without BCD carry.
 $C5E9 DEC HL        ; Step back to the extra-life threshold high byte at
                     ; #R$C418.
 $C5EA LD A,(HL)     ; {Apply BCD carry to the extra-life threshold high byte.
 $C5EB INC A         ;
 $C5EC DAA           ;
 $C5ED LD (HL),A     ; }
 $C5EE RET           ; Return.
; This entry point is used by the routine at #R$CB4F.
; .
; Copy-protection gate: if no enemies are active (#R$C41C is #N$00)
; jump to #R$C605. Otherwise verify the RAM signature at *#N$FFFF and
; test for an active SPACE keypress; if both match, trigger a fatal error.
@label=CheckScoreAwardLife_SessionGate
*$C5EF LD A,($C41C)  ; Read the active enemy count from #R$C41C.
 $C5F2 AND A         ; {Jump to #R$C605 if no enemies are currently on screen.
 $C5F3 JP Z,$C605    ; }
 $C5F6 LD A,($FFFF)  ; Read the RAM signature from *#N$FFFF.
 $C5F9 CP $63        ; {Return if the RAM signature is not #N$63.
 $C5FB RET NZ        ; }
 $C5FC LD A,$7F      ; {Read from the keyboard;
 $C5FE IN A,($FE)    ; #TABLE(default,centre,centre,centre,centre,centre,centre)
                     ; { =h,r2 Port Number | =h,c5 Bit }
                     ; { =h 0 | =h 1 | =h 2 | =h 3 | =h 4 }
                     ; { #N$7F | SPACE | FULL-STOP | M | N | B }
                     ; TABLE#}
 $C600 RRCA          ; {Return if the SPACE key is not pressed.
 $C601 RET C         ; }
 $C602 EI            ; Enable interrupts.
 $C603 RST $08       ; RST #N$08 (copy-protection error vector).
 $C604 DEFB $FF      ; Error code: #N$FF.
; Restore the stacked register, trigger the extra-life reward, and
; continue with wave handling.
@label=CheckScoreAwardLife_Continue
*$C605 POP DE        ; Restore #REGde (stacked by the caller).
 $C606 CALL $F5DA    ; Trigger the extra-life award sound and effects.
 $C609 JP $D24C      ; Continue with wave and game-flow handling.

