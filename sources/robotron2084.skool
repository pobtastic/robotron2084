 $8C38 DEFB $60,$44,$60,$45,$60,$46,$60,$47
 $8C40 DEFB $80,$40,$80,$41,$80,$42,$80,$43
 $8C48 DEFB $80,$44,$80,$45,$80,$46,$80,$47
 $8C50 DEFB $A0,$40,$A0,$41,$A0,$42,$A0,$43
 $8C58 DEFB $A0,$44,$A0,$45,$A0,$46,$A0,$47
 $8C60 DEFB $C0,$40,$C0,$41,$C0,$42,$C0,$43
 $8C68 DEFB $C0,$44,$C0,$45,$C0,$46,$C0,$47
 $8C70 DEFB $E0,$40,$E0,$41,$E0,$42,$E0,$43
 $8C78 DEFB $E0,$44,$E0,$45,$E0,$46,$E0,$47
 $8C80 DEFB $00,$48,$00,$49,$00,$4A,$00,$4B
 $8C88 DEFB $00,$4C,$00,$4D,$00,$4E,$00,$4F
 $8C90 DEFB $20,$48,$20,$49,$20,$4A,$20,$4B
 $8C98 DEFB $20,$4C,$20,$4D,$20,$4E,$20,$4F
 $8CA0 DEFB $40,$48,$40,$49,$40,$4A,$40,$4B
 $8CA8 DEFB $40,$4C,$40,$4D,$40,$4E,$40,$4F
 $8CB0 DEFB $60,$48,$60,$49,$60,$4A,$60,$4B
 $8CB8 DEFB $60,$4C,$60,$4D,$60,$4E,$60,$4F
 $8CC0 DEFB $80,$48,$80,$49,$80,$4A,$80,$4B
 $8CC8 DEFB $80,$4C,$80,$4D,$80,$4E,$80,$4F
 $8CD0 DEFB $A0,$48,$A0,$49,$A0,$4A,$A0,$4B
 $8CD8 DEFB $A0,$4C,$A0,$4D,$A0,$4E,$A0,$4F
 $8CE0 DEFB $C0,$48,$C0,$49,$C0,$4A,$C0,$4B
 $8CE8 DEFB $C0,$4C,$C0,$4D,$C0,$4E,$C0,$4F
 $8CF0 DEFB $E0,$48,$E0,$49,$E0,$4A,$E0,$4B
 $8CF8 DEFB $E0,$4C,$E0,$4D,$E0,$4E,$E0,$4F
 $8D00 DEFB $00,$50,$00,$51,$00,$52,$00,$53
 $8D08 DEFB $00,$54,$00,$55,$00,$56,$00,$57
 $8D10 DEFB $20,$50,$20,$51,$20,$52,$20,$53
 $8D18 DEFB $20,$54,$20,$55,$20,$56,$20,$57
 $8D20 DEFB $40,$50,$40,$51,$40,$52,$40,$53
 $8D28 DEFB $40,$54,$40,$55,$40,$56,$40,$57
 $8D30 DEFB $60,$50,$60,$51,$60,$52,$60,$53
 $8D38 DEFB $60,$54,$60,$55,$60,$56,$60,$57
 $8D40 DEFB $80,$50,$80,$51,$80,$52,$80,$53
 $8D48 DEFB $80,$54,$80,$55,$80,$56,$80,$57
 $8D50 DEFB $A0,$50,$A0,$51,$A0,$52,$A0,$53
 $8D58 DEFB $A0,$54,$A0,$55,$A0,$56,$A0,$57
 $8D60 DEFB $C0,$50,$C0,$51,$C0,$52,$C0,$53
 $8D68 DEFB $C0,$54,$C0,$55,$C0,$56,$C0,$57
 $8D70 DEFB $E0,$50,$E0,$51,$E0,$52,$E0,$53
 $8D78 DEFB $E0,$54,$E0,$55,$E0,$56,$E0,$57

; Routine at 8D80
;
; Used by the routines at #R$D562, #R$D570 and #R$F04D.
c$8D80 LD B,$45      ;
 $8D82 LD C,H        ;
 $8D83 SLA C         ;
 $8D85 RL B          ;
 $8D87 LD H,$46      ;
 $8D89 SLA L         ;
 $8D8B RL H          ;
 $8D8D LD A,(HL)     ;
 $8D8E INC HL        ;
 $8D8F LD H,(HL)     ;
 $8D90 LD L,A        ;
 $8D91 LD A,(BC)     ;
 $8D92 ADD A,L       ;
 $8D93 LD L,A        ;
 $8D94 INC BC        ;
 $8D95 LD A,(BC)     ;
 $8D96 OR (HL)       ;
 $8D97 LD (HL),A     ;
 $8D98 RET           ;
 $8D99 LD B,$45      ;
 $8D9B LD C,H        ;
 $8D9C SLA C         ;
 $8D9E RL B          ;
 $8DA0 LD H,$46      ;
 $8DA2 SLA L         ;
 $8DA4 RL H          ;
 $8DA6 LD A,(HL)     ;
 $8DA7 INC HL        ;
 $8DA8 LD H,(HL)     ;
 $8DA9 LD L,A        ;
 $8DAA LD A,(BC)     ;
 $8DAB ADD A,L       ;
 $8DAC LD L,A        ;
 $8DAD INC BC        ;
 $8DAE LD A,(BC)     ;
 $8DAF CPL           ;
 $8DB0 AND (HL)      ;
 $8DB1 LD (HL),A     ;
 $8DB2 RET           ;
 $8DB3 LD B,$45      ;
 $8DB5 LD C,H        ;
 $8DB6 SLA C         ;
 $8DB8 RL B          ;
 $8DBA LD H,$46      ;
 $8DBC SLA L         ;
 $8DBE RL H          ;
 $8DC0 LD A,(HL)     ;
 $8DC1 INC HL        ;
 $8DC2 LD H,(HL)     ;
 $8DC3 LD L,A        ;
 $8DC4 LD A,(BC)     ;
 $8DC5 ADD A,L       ;
 $8DC6 LD L,A        ;
 $8DC7 INC BC        ;
 $8DC8 LD A,(BC)     ;
 $8DC9 XOR (HL)      ;
 $8DCA LD (HL),A     ;
 $8DCB RET           ;

; Print Dispatch
;
; Used by the routines at #R$9006, #R$C544, #R$D0A7, #R$D367, #R$F107, #R$F2F9
; and #R$F3AE.
@label=PrintDispatch
c$8DCC PUSH BC       ; Stash #REGbc on the stack.
 $8DCD EXX           ; Switch to the shadow registers.
 $8DCE PUSH HL       ; {Stash #REGhl and #REGix on the stack.
 $8DCF PUSH IX       ; }
 $8DD1 LD IX,$8000   ; #REGix=#R$8000.
 $8DD5 LD HL,$8DDD   ; #REGhl=#R$8DDD.
 $8DD8 PUSH HL       ; Stash #REGhl on the stack.
 $8DD9 LD HL,($800A) ; #REGhl=*#R$800A.
 $8DDC JP (HL)       ; Jump to *#REGhl.
 $8DDD POP IX        ; {Restore #REGix and #REGhl from the stack.
 $8DDF POP HL        ; }
 $8DE0 EXX           ; Switch back to the normal registers.
 $8DE1 POP BC        ; Restore #REGbc from the stack.
 $8DE2 RET           ; Return.

; Print Handler
;
; The default print handler for the state machine pointer at #R$800A. Called on
; initialisation, and restored after each byte is consumed. Dispatches each byte of
; a messaging string to the appropriate action based on its value:
; .
; #TABLE(default,centre,centre)
; { =h Byte | =h Action }
; { #N$20–#N$7F | Print the ASCII character. }
; { #N$80–#N$FF | Replace with #N$21 ("#CHR$21") and print. }
; { #N$0D | Carriage return: reset X to left margin, advance Y by one line. }
; { #N$10–#N$1A | Control code: install a parameter handler into #R$800A. }
; { All others | Replace with #N$3F ("#CHR$3F") and print. }
; TABLE#
;
; A Byte to print or control code
@label=PrintHandler
c$8DE3 CP $80         ; {If the byte is less than #N$80, jump to #R$8DEC.
 $8DE5 JR C,$8DEC     ; }
 $8DE7 LD A,$21       ; Otherwise replace the byte with #N$21 ("#CHR$21").
 $8DE9 JP $8EF7       ; Jump to #R$8EF7 to render the character.
; Dispatch handler for printing.
@label=PrintHandler_Dispatch
*$8DEC CP $20         ; {If the byte is #N$20 or higher (printable ASCII), jump
 $8DEE JP NC,$8EF7    ; to #R$8EF7 to render it.}
 $8DF1 CP $0D         ; {If the byte is a carriage return (#N$0D), jump to
 $8DF3 JR Z,$8E0F     ; #R$8E0F.}
 $8DF5 CP $10         ; {If the byte is less than #N$10, jump to #R$8E29
 $8DF7 JR C,$8E29     ; (unsupported code).}
 $8DF9 CP $1B         ; {If the byte is #N$1B or higher, jump to #R$8E29
 $8DFB JR NC,$8E29    ; (unsupported code).}
; Look up the two-byte handler address from the control code dispatch table at
; #R$8FD0. The code is zero-indexed from #N$10 and doubled since each table entry is
; two bytes wide.
 $8DFD LD HL,$8FD0    ; #REGhl=#R$8FD0 (base of the control code dispatch
                      ; table).
 $8E00 SUB $10        ; Zero-index the control code from #N$10.
 $8E02 LD D,$00       ; {#REGde=zero-indexed control code.
 $8E04 LD E,A         ; }
 $8E05 ADD HL,DE      ; {Double the index (two bytes per table entry).
 $8E06 ADD HL,DE      ; }
 $8E07 LD E,(HL)      ; {Read the handler address from the dispatch table into
 $8E08 INC HL         ; #REGde.
 $8E09 LD D,(HL)      ; }
 $8E0A LD ($800A),DE  ; Write the handler address to #R$800A.
 $8E0E RET            ; Return.
; Carriage return handler: resets the X position to the left margin, then advances
; the Y position by one font line height (wrapping at #N$BC).
@label=PrintHandler_Newline
*$8E0F LD HL,$8001    ; #REGhl=#R$8001 (X position pointer).
 $8E12 LD A,($8005)   ; #REGa=*#R$8005 (left margin X position).
 $8E15 LD (HL),A      ; Write the left margin value to *#REGhl, resetting X to
                      ; the left margin.
 $8E16 DEC HL         ; Decrement #REGhl to point at #R$8000 (Y position).
@label=PrintHandler_AdvanceRow
*$8E17 LD A,(HL)      ; {#REGa=*#REGhl + font line height (*#R$8010).
 $8E18 ADD A,(IX+$10) ; }
 $8E1B CP $BC         ; {Wrap the Y position at #N$BC if it has reached or
 $8E1D JR C,$8E21     ; exceeded that value.}
 $8E1F SUB $BC        ; Subtract #N$BC to wrap Y.
@label=PrintHandler_AdvanceRow_Store
*$8E21 LD (HL),A      ; Write the new Y position back to *#REGhl.
 $8E22 RET            ; Return.
; Parameter handler for unsupported control codes #N$14 and #N$15. Consumes the
; parameter byte by resetting #R$800A to the default handler, then falls through to
; #R$8E29 to print a "#CHR$3F" (#N$3F) placeholder.
@label=PrintHandler_Unsupported
 $8E23 LD HL,$8DE3    ; {Reset #R$800A to #R$8DE3 (default handler).
 $8E26 LD ($800A),HL  ; }
@label=PrintHandler_Invalid
*$8E29 LD A,$3F       ; Replace the byte with #N$3F ("#CHR$3F").
 $8E2B JP $8EF7       ; Jump to #R$8EF7 to render the character.
; Set INK colour parameter handler. Called on the byte immediately following a
; #N$10 (INK) control code. Masks the parameter to the lower three bits (colour
; #N$00–#N$07) and writes it into the INK bits (0–2) of the attribute byte at
; #R$8004.
@label=PrintHandler_Ink
 $8E2E LD B,$08       ; #REGb=#N$08 (mask limit for INK colour range
                      ; #N$00–#N$07).
 $8E30 CALL $8EE6     ; Call #R$8EE6 to reset #R$800A and mask #REGb to the
                      ; colour value.
 $8E33 LD A,($8004)   ; #REGa=*#R$8004 (current attribute byte).
 $8E36 AND %11111000  ; Clear the INK bits (#N$F8 = keep PAPER, BRIGHT, FLASH).
 $8E38 OR B           ; Write the new INK colour into bits 0–2.
 $8E39 LD ($8004),A   ; Write the updated attribute byte back to *#R$8004.
 $8E3C RET            ; Return.
; Set PAPER colour parameter handler. Called on the byte immediately following a
; #N$11 (PAPER) control code. Masks the parameter to the lower three bits (colour
; #N$00–#N$07) and writes it into the PAPER bits (3–5) of the attribute byte at
; #R$8004.
@label=PrintHandler_Paper
 $8E3D LD B,$08       ; #REGb=#N$08 (mask limit for PAPER colour range
                      ; #N$00–#N$07).
 $8E3F CALL $8EE6     ; Call #R$8EE6 to reset #R$800A and mask #REGb to the
                      ; colour value.
 $8E42 LD A,($8004)   ; #REGa=*#R$8004 (current attribute byte).
 $8E45 AND %11000111  ; Clear the PAPER bits (#N$C7 = keep INK, BRIGHT, FLASH).
 $8E47 SLA B          ; {Shift #REGb left three positions to move the colour
 $8E49 SLA B          ; into bits 3–5.
 $8E4B SLA B          ; }
 $8E4D OR B           ; Write the new PAPER colour into bits 3–5.
 $8E4E LD ($8004),A   ; Write the updated attribute byte back to *#R$8004.
 $8E51 RET            ; Return.
; Set FLASH parameter handler. Called on the byte immediately following a #N$12
; (FLASH) control code. Sets or clears bit 7 of the attribute byte at #R$8004.
@label=PrintHandler_Flash
 $8E52 LD B,$02       ; #REGb=#N$02 (mask limit: parameter is #N$00 or #N$01).
 $8E54 CALL $8EE6     ; Call #R$8EE6 to reset #R$800A and mask #REGb to #N$00
                      ; or #N$01.
 $8E57 BIT 0,B        ; Test bit 0 of the masked parameter.
 $8E59 JR Z,$8E60     ; If the parameter is #N$00, jump to #R$8E60 to clear
                      ; FLASH.
 $8E5B SET 7,(IX+$04) ; Set the FLASH bit (7) of the attribute byte at #R$8004.
 $8E5F RET            ; Return.
@label=PrintHandler_Flash_Off
*$8E60 RES 7,(IX+$04) ; Clear the FLASH bit (7) of the attribute byte at
                      ; #N$8004.
 $8E64 RET            ; Return.
; Set BRIGHT parameter handler. Called on the byte immediately following a #N$13
; (BRIGHT) control code. Sets or clears bit 6 of the attribute byte at #N$8004.
@label=PrintHandler_Bright
 $8E65 LD B,$02       ; #REGb=#N$02 (mask limit: parameter is #N$00 or #N$01).
 $8E67 CALL $8EE6     ; Call #R$8EE6 to reset #R$800A and mask #REGb to #N$00
                      ; or #N$01.
 $8E6A BIT 0,B        ; Test bit 0 of the masked parameter.
 $8E6C JR Z,$8E73     ; If the parameter is #N$00, jump to #R$8E73 to clear
                      ; BRIGHT.
 $8E6E SET 6,(IX+$04) ; Set the BRIGHT bit (6) of the attribute byte at
                      ; #N$8004.
 $8E72 RET            ; Return.
@label=PrintHandler_Bright_Off
*$8E73 RES 6,(IX+$04) ; Clear the BRIGHT bit (6) of the attribute byte at
                      ; #N$8004.
 $8E77 RET            ; Return.
; PRINT AT first parameter handler. Called on the byte immediately following a
; #N$16 (PRINT AT) control code. Stores the X (column) parameter to #N$8001 and
; installs #R$8E82 into #R$800A to handle the next byte (the Y position).
@label=PrintHandler_PrintAt_X
 $8E78 LD ($8001),A   ; Write the X column parameter to *#R$8001.
 $8E7B LD HL,$8E82    ; #REGhl=#R$8E82 (Y position parameter handler).
 $8E7E LD ($800A),HL  ; Write #R$8E82 to #R$800A to consume the next (Y) byte.
 $8E81 RET            ; Return.
; PRINT AT second parameter handler. Called on the byte immediately following the
; X parameter. Wraps the Y (row) parameter at #N$BC and stores it to #N$8000 before
; restoring the default handler.
@label=PrintHandler_PrintAt_Y
 $8E82 LD HL,$8DE3    ; {Reset #R$800A to #R$8DE3 (default handler).
 $8E85 LD ($800A),HL  ; }
 $8E88 CP $BC         ; {If the Y parameter is less than #N$BC, jump to
 $8E8A JR C,$8E8E     ; #R$8E8E.}
 $8E8C SUB $BC        ; Subtract #N$BC to wrap the Y position.
@label=PrintHandler_PrintAt_Y_Store
*$8E8E LD ($8000),A   ; Write the Y position to *#R$8000.
 $8E91 RET            ; Return.
; TAB parameter handler. Called on the byte immediately following a #N$17 (TAB)
; control code. Sets the X position (#N$8001) to the parameter value. If the
; parameter is less than the current X position (i.e., the cursor would move left),
; the Y position advances to the next row.
@label=PrintHandler_Tab
 $8E92 LD HL,$8DE3    ; {Reset #R$800A to #R$8DE3 (default handler).
 $8E95 LD ($800A),HL  ; }
 $8E98 LD C,A         ; #REGc=target X position (the TAB parameter).
 $8E99 LD A,($8001)   ; {#REGb=*#R$8001 (current X position).
 $8E9C LD B,A         ; }
 $8E9D LD A,C         ; {#REGa=target X; write target X to *#R$8001.
 $8E9E LD ($8001),A   ; }
 $8EA1 SUB B          ; #REGa=target X − current X.
 $8EA2 RET NC         ; Return if the cursor moved right or stayed (no row
                      ; advance needed).
 $8EA3 LD HL,$8000    ; #REGhl=#N$8000 (Y position pointer).
 $8EA6 CALL $8E17     ; Call #R$8E17 to advance the Y position by one line.
 $8EA9 RET            ; Return.
; Left margin parameter handler. Called on the byte immediately following a #N$18
; control code. Sets the left margin X position at #N$8005 to the lower six bits of
; the parameter.
@label=PrintHandler_LeftMargin
 $8EAA LD B,$40       ; #REGb=#N$40 (mask limit: lower six bits, #N$00–#N$3F).
 $8EAC CALL $8EE6     ; Call #R$8EE6 to reset #R$800A and mask #REGa to the
                      ; lower six bits.
 $8EAF LD ($8005),A   ; Write the masked parameter to *#R$8005 (left margin X
                      ; position).
 $8EB2 RET            ; Return.
; Right margin parameter handler. Called on the byte immediately following a #N$19
; control code. Stores the right margin X position to #N$8006. If the parameter is
; less than #N$80, a wrap flag is set in #N$8007 and #N$80 is OR'd into the value
; before storing.
@label=PrintHandler_RightMargin
 $8EB3 LD HL,$8DE3    ; {Reset #R$800A to #R$8DE3 (default handler).
 $8EB6 LD ($800A),HL  ; }
 $8EB9 CP $80         ; {If the parameter is #N$80 or higher, jump to #R$8EC3
 $8EBB JR NC,$8EC3    ; to store it directly.}
 $8EBD SET 0,(IX+$07) ; Set the wrap flag (bit 0 of *#N$8007).
 $8EC1 OR %10000000   ; OR #N$80 into the parameter.
@label=PrintHandler_RightMargin_Store
*$8EC3 LD ($8006),A   ; Write the parameter to *#R$8006 (right margin X
                      ; position).
 $8EC6 RET            ; Return.
; Select font parameter handler. Called on the byte immediately following a #N$1A
; control code. Copies the six-byte font configuration for the selected font index
; (#N$00–#N$03) from the table at #R$8FE6 into the font state at #N$800C, and
; loads the font bitmap pointer into #N$8008.
@label=PrintHandler_SelectFont
 $8EC7 LD B,$04       ; #REGb=#N$04 (mask limit: font indices #N$00–#N$03).
 $8EC9 CALL $8EE6     ; Call #R$8EE6 to reset #R$800A and mask #REGb to the
                      ; font index.
 $8ECC LD H,$00       ; #REGh=#N$00.
 $8ECE LD L,B         ; #REGl=#REGb (font index as a 16-bit value in #REGhl).
 $8ECF LD DE,$8FE6    ; #REGde=#R$8FE6 (font configuration table base).
; Multiply the font index by #N$08 (the size of each font table entry) to compute
; the byte offset into the font table.
 $8ED2 ADD HL,HL      ; {Multiply #REGhl by #N$08 (three left shifts).
 $8ED3 ADD HL,HL      ;
 $8ED4 ADD HL,HL      ; }
 $8ED5 ADD HL,DE      ; #REGhl=#R$8FE6 + (font index × #N$08) — pointer to the
                      ; selected font entry.
 $8ED6 LD DE,$800C    ; #REGde=#N$800C (font state destination).
 $8ED9 LD BC,$0006    ; #REGbc=#N$0006 (six bytes of font configuration to
                      ; copy).
 $8EDC LDIR           ; Copy six bytes of font configuration to
                      ; #N$800C–#N$8011.
 $8EDE LD E,(HL)      ; {Read the two-byte font bitmap pointer from bytes
 $8EDF INC HL         ; #N$07–#N$08 of the entry.
 $8EE0 LD D,(HL)      ; }
 $8EE1 LD ($8008),DE  ; Write the font bitmap pointer to *#R$8008.
 $8EE5 RET            ; Return.
; Parameter mask and validation utility. Called by control code parameter handlers
; before processing their byte. Resets #R$800A to the default handler (#R$8DE3),
; then masks #REGa to the valid range defined by #REGb (which must be a power of
; two). If the parameter is out of range, sets a flag in #N$8007.
@label=PrintHandler_MaskParam
*$8EE6 LD HL,$8DE3    ; {Reset #R$800A to #R$8DE3 (default handler).
 $8EE9 LD ($800A),HL  ; }
 $8EEC CP B           ; Test whether the parameter (#REGa) is within the valid
                      ; range (#REGb).
 $8EED JR C,$8EF3     ; If the parameter is within range, jump to #R$8EF3.
 $8EEF SET 0,(IX+$07) ; Otherwise set the out-of-range flag (bit 0 of
                      ; *#N$8007).
@label=PrintHandler_MaskParam_Mask
*$8EF3 DEC B          ; Decrement #REGb to form a bitmask (e.g. #N$08 → #N$07 =
                      ; %00000111).
 $8EF4 AND B          ; Mask #REGa to the valid range.
 $8EF5 LD B,A         ; #REGb=masked parameter value.
 $8EF6 RET            ; Return.
; Character renderer. Determines the pixel width of the character, checks whether
; it fits on the current line (inserting a carriage return if not), computes the
; screen address from the current X and Y pixel positions, bit-shifts the character
; bitmap from the font table, ORs it into screen memory row by row, writes the
; attribute byte to the attribute area, and finally advances the X position.
@label=PrintHandler_Render
*$8EF7 LD ($8003),A   ; Store the character code to *#R$8003.
; Select the pixel width for the character. Space (#N$20), "#CHR$49" (#N$49), "#CHR$4D"
; (#N$4D) and "#CHR$57" (#N$57) each have their own width stored in the font state at
; #N$800C. All other printable characters use the normal width.
 $8EFA CP $20         ; {If the character is a space (#N$20), jump to #R$8F07.
 $8EFC JR Z,$8F07     ; }
 $8EFE CP $49         ; {If the character is not "#CHR$49" (#N$49), jump to
 $8F00 JR NZ,$8F0C    ; #R$8F0C.}
 $8F02 LD C,(IX+$0D)  ; #REGc=*#R$800D (narrow width for "#CHR$49").
 $8F05 JR $8F1C       ; Jump to #R$8F1C.
@label=PrintHandler_Render_SpaceWidth
*$8F07 LD C,(IX+$0F)  ; #REGc=*#R$800F (space width).
 $8F0A JR $8F1C       ; Jump to #R$8F1C.
; Check for wide characters: "#CHR$4D" (#N$4D) and "#CHR$57" (#N$57) use the
; wide width.
@label=PrintHandler_Render_WideCheck
*$8F0C CP $4D         ; {If the character is "#CHR$4D" (#N$4D), jump to
 $8F0E JR Z,$8F14     ; #R$8F14.}
 $8F10 CP $57         ; {If the character is not "#CHR$57" (#N$57), jump to
 $8F12 JR NZ,$8F19    ; #R$8F19 (normal width).}
@label=PrintHandler_Render_WideWidth
*$8F14 LD C,(IX+$0E)  ; #REGc=*#R$800E (wide width for "#CHR$4D" and
                      ; "#CHR$57").
 $8F17 JR $8F1C       ; Jump to #R$8F1C.
; All other printable characters use the standard (#REGix+#N$0C) width.
@label=PrintHandler_Render_NormalWidth
*$8F19 LD C,(IX+$0C)  ; #REGc=*#R$800C (normal character width).
; Check whether the character fits within the right margin. If adding the character
; width to the current X position would exceed the right margin stored at #N$8006, a
; carriage return is inserted automatically before rendering.
@label=PrintHandler_Render_LineCheck
*$8F1C LD A,($8001)   ; {#REGb=*#R$8001 (current X position).
 $8F1F LD B,A         ; }
 $8F20 LD A,($8006)   ; #REGa=*#R$8006 (right margin X position).
 $8F23 SUB B          ; {#REGa=right margin − current X − character width.
 $8F24 SUB C          ; }
 $8F25 CALL C,$8E0F   ; Call #R$8E0F if the result is negative (character
                      ; exceeds the right margin).
; Calculate the screen address and sub-byte bit-shift from the current X and Y
; pixel positions. The screen row address LUT (indexed by Y) provides the base pixel
; row address; three right-shifts of X derive the column byte offset and the
; within-byte pixel shift (0–7 bits).
 $8F28 LD A,C         ; #REGa=character width.
 $8F29 EX AF,AF'      ; Stash character width in #REGa'.
 $8F2A LD A,($8000)   ; #REGa=*#R$8000 (Y pixel position).
 $8F2D LD H,$46       ; {#REGhl=screen row address LUT entry for pixel row Y
 $8F2F LD L,A         ; (#N$8C00 + Y × #N$02).
 $8F30 SLA L          ;
 $8F32 RL H           ; }
 $8F34 LD A,($8001)   ; #REGa=*#R$8001 (X pixel position).
 $8F37 AND A          ; {Clear carry; #REGb=#N$00; shift #REGa right three positions with carry into
 $8F38 LD B,$00       ; #REGb, deriving the column byte offset (#REGa=X÷8) and sub-byte pixel bits (low
 $8F3A RRA            ; #N$03 bits of X → #REGb).
 $8F3B RR B           ;
 $8F3D RRA            ;
 $8F3E RR B           ;
 $8F40 RRA            ;
 $8F41 RR B           ; }
 $8F43 RLC B          ; {Rotate #REGb left three positions to place the
 $8F45 RLC B          ; sub-byte offset in bits 0–2.
 $8F47 RLC B          ; }
 $8F49 LD C,A         ; #REGc=column byte offset (X÷8).
 $8F4A LD A,B         ; {Store the sub-byte pixel shift (X mod 8) to *#R$8002.
 $8F4B LD ($8002),A   ; }
 $8F4E LD DE,$8012    ; #REGde=#N$8012 (screen address workspace).
 $8F51 LD B,(IX+$11)  ; #REGb=*#R$8011 (number of character pixel rows).
@label=PrintHandler_Render_AddrLoop
*$8F54 LD A,(HL)      ; {Read each two-byte screen row address from the LUT into the workspace at
 $8F55 ADD A,C        ; #N$8012, adding the column byte offset (#REGc) to the first byte of each pair.
 $8F56 LD (DE),A      ;
 $8F57 INC DE         ;
 $8F58 INC HL         ;
 $8F59 LD A,(HL)      ;
 $8F5A LD (DE),A      ;
 $8F5B INC DE         ;
 $8F5C INC HL         ; }
 $8F5D DJNZ $8F54     ; Decrease the row counter and loop back to #R$8F54 until
                      ; all rows are done.
; Look up the character bitmap in the font table. Each character occupies
; #N$08 bytes at font base pointer + (character code × #N$08).
 $8F5F LD A,($8003)   ; #REGa=*#R$8003 (character code).
 $8F62 LD H,$00       ; {#REGhl=character code as a 16-bit value.
 $8F64 LD L,A         ; }
 $8F65 LD DE,($8008)  ; #REGde=*#R$8008 (font bitmap base pointer).
 $8F69 ADD HL,HL      ; {#REGhl=font base + (character code × #N$08).
 $8F6A ADD HL,HL      ;
 $8F6B ADD HL,HL      ;
 $8F6C ADD HL,DE      ; }
 $8F6D EX DE,HL       ; #REGde=pointer to the character bitmap data.
 $8F6E LD HL,$8022    ; #REGhl=#N$8022 (bit-shift workspace).
 $8F71 LD C,(IX+$11)  ; #REGc=*#R$8011 (number of character pixel rows).
@label=PrintHandler_Render_ShiftLoop
*$8F74 LD A,($8002)   ; #REGb=*#R$8002 (sub-byte pixel shift count);
                      ; #REGa=shift count.
 $8F77 LD B,A         ; #REGb=pixel shift count.
 $8F78 LD A,(DE)      ; {Copy one row of font bitmap data from *#REGde to
 $8F79 LD (HL),A      ; *#REGhl.}
 $8F7A XOR A          ; {If the shift count is #N$00, jump to #R$8F84 (no shift
 $8F7B CP B           ; needed).
 $8F7C JR Z,$8F84     ; }
 $8F7E AND A          ; Clear #REGa (right-hand overflow byte).
@label=PrintHandler_Render_ShiftStep
*$8F7F RR (HL)        ; {Shift *#REGhl right through carry into #REGa,
 $8F81 RRA            ; repeating for each shift step.
 $8F82 DJNZ $8F7F     ; }
@label=PrintHandler_Render_ShiftNext
*$8F84 INC HL         ; Advance #REGhl to the second byte of the workspace
                      ; pair.
 $8F85 LD (HL),A      ; Store the shifted overflow byte (right-hand spill) to
                      ; *#REGhl.
 $8F86 INC HL         ; Advance #REGhl to the next row pair in the workspace.
 $8F87 INC DE         ; Advance #REGde to the next row of font bitmap data.
 $8F88 DEC C          ; Decrease the row counter.
 $8F89 JR NZ,$8F74    ; Loop back to #R$8F74 until all rows have been
                      ; bit-shifted.
; Write the attribute byte to the four attribute cells covering the character.
; Derives the attribute address from the screen pixel address high byte by rotating
; right three times, masking to two bits, and OR-ing with #N$58 ($5800 base).
 $8F8B LD BC,$8022    ; #REGbc=#N$8022 (bit-shifted bitmap workspace pointer).
 $8F8E LD HL,$8012    ; #REGhl=#N$8012 (screen address workspace pointer).
 $8F91 PUSH HL        ; {Stash #REGhl; read the first screen address pair into
 $8F92 LD E,(HL)      ; #REGde.
 $8F93 INC HL         ;
 $8F94 LD D,(HL)      ; }
 $8F95 DEC HL         ; Restore #REGhl from the pair.
 $8F96 EX DE,HL       ; #REGde=screen pixel row address.
 $8F97 LD A,H         ; {Derive the attribute memory high byte from the pixel
 $8F98 RRCA           ; address high byte.
 $8F99 RRCA           ;
 $8F9A RRCA           ;
 $8F9B AND $03        ; }
 $8F9D OR $58         ; #REGh=#N$58 | column third → attribute address high
                      ; byte.
 $8F9F LD H,A         ; #REGh=attribute address high byte.
 $8FA0 LD A,($8004)   ; #REGa=*#R$8004 (attribute byte:
                      ; INK/PAPER/BRIGHT/FLASH).
 $8FA3 LD (HL),A      ; {Write the attribute byte to the two cells at *#REGhl
 $8FA4 INC HL         ; and *(#REGhl+#N$01).
 $8FA5 LD (HL),A      ; }
 $8FA6 LD DE,$001F    ; #REGde=#N$001F (offset to next attribute row).
 $8FA9 ADD HL,DE      ; {Write the attribute byte to the two cells in the
 $8FAA LD (HL),A      ; attribute row below.
 $8FAB INC HL         ;
 $8FAC LD (HL),A      ; }
 $8FAD POP HL         ; Restore the screen address workspace pointer from the
                      ; stack.
 $8FAE EXX            ; {Switch to shadow registers; #REGb=*#R$8011 (pixel row
 $8FAF LD B,(IX+$11)  ; count).}
@label=PrintHandler_Render_BlitLoop
*$8FB2 EXX            ; {Switch back; #REGde=next two-byte screen address from
 $8FB3 LD E,(HL)      ; #N$8012+.
 $8FB4 INC HL         ;
 $8FB5 LD D,(HL)      ;
 $8FB6 INC HL         ; }
 $8FB7 EX DE,HL       ; #REGde=screen pixel row address.
 $8FB8 LD A,(BC)      ; {OR the left bitmap byte from *#REGbc into *#REGde
 $8FB9 OR (HL)        ; (left screen byte).
 $8FBA LD (HL),A      ;
 $8FBB INC BC         ; }
 $8FBC INC HL         ; {Advance #REGhl; OR the right bitmap byte from *#REGbc
 $8FBD LD A,(BC)      ; into *(#REGhl); advance #REGbc.
 $8FBE OR (HL)        ;
 $8FBF LD (HL),A      ;
 $8FC0 INC BC         ; }
 $8FC1 EX DE,HL       ; #REGde=screen address workspace pointer (restore via EX
                      ; DE,HL swap).
 $8FC2 EXX            ; {Switch to shadow registers and loop back to #R$8FB2 until all pixel rows are
 $8FC3 DJNZ $8FB2     ; blitted to screen memory.}
; Advance the X position by the character's pixel width and return.
 $8FC5 EXX            ; {Switch back to main registers; restore character width
 $8FC6 EX AF,AF'      ; from #REGa'.}
 $8FC7 LD C,A         ; #REGc=character width.
 $8FC8 LD A,($8001)   ; #REGa=*#R$8001 (current X position).
 $8FCB ADD A,C        ; #REGa+=character width.
 $8FCC LD ($8001),A   ; Write the new X position to *#R$8001.
 $8FCF RET            ; Return.

; Control Code Dispatch Table
;
; Two-byte handler address table for control codes #N$10–#N$1A, indexed by the
; control code zero-indexed from #N$10. Each entry is the address of the parameter
; handler installed into #R$800A by #R$8DE3.
@label=ControlCode_DispatchTable
g$8FD0 DEFW $8E2E    ; #N$10: INK colour — parameter handler at #R$8E2E.
 $8FD2 DEFW $8E3D    ; #N$11: PAPER colour — parameter handler at #R$8E3D.
 $8FD4 DEFW $8E52    ; #N$12: FLASH — parameter handler at #R$8E52.
 $8FD6 DEFW $8E65    ; #N$13: BRIGHT — parameter handler at #R$8E65.
 $8FD8 DEFW $8E23    ; #N$14: Unsupported — parameter consumed and discarded
                     ; via #R$8E23.
 $8FDA DEFW $8E23    ; #N$15: Unsupported — parameter consumed and discarded
                     ; via #R$8E23.
 $8FDC DEFW $8E78    ; #N$16: PRINT AT column — parameter handler at #R$8E78.
 $8FDE DEFW $8E92    ; #N$17: TAB — parameter handler at #R$8E92.
 $8FE0 DEFW $8EAA    ; #N$18: Set left margin — parameter handler at #R$8EAA.
 $8FE2 DEFW $8EB3    ; #N$19: Set right margin — parameter handler at #R$8EB3.
 $8FE4 DEFW $8EC7    ; #N$1A: Select font — parameter handler at #R$8EC7.

; Font Configuration Table
;
; Font configuration table, indexed by font number (#N$00–#N$03). Each eight-byte
; entry comprises six bytes of font metrics copied to #N$800C–#N$8011 by the select
; font handler at #R$8EC7, followed by a two-byte little-endian pointer to the font
; bitmap data stored at #N$8008.
@label=FontConfig_Table
g$8FE6 DEFB $04,$04,$06,$02,$06,$05 ; Font #N$00: normal width, narrow width ("#CHR$49"), wide width ("#CHR$4D"/ "#CHR$57"), space
                                    ; width, line height, and pixel row count.
 $8FEC DEFB $00,$80                 ; Font #N$00: pointer to font bitmap data.
 $8FEE DEFB $06,$05,$06,$05         ; Font #N$01: normal width, narrow width,
                                    ; wide width, and space width.

; Game status buffer entry at 8FF2
g$8FF2 DEFB $09,$06,$00,$83,$07,$07,$09,$05
 $8FFA DEFB $0A,$08,$00,$86,$08,$08,$08,$08
 $9002 DEFB $08,$08,$00,$3C

; Print Messaging
;
; Used by the routines at #R$9044, #R$D317, #R$D367, #R$D3F8, #R$EBC8, #R$ED10,
; #R$F3AE and #R$F637.
;
; HL Pointer to the messaging string
@label=PrintMessaging
c$9006 LD A,(HL)     ; Fetch the byte from the messaging string.
 $9007 CP $1F        ; {Return if the terminator byte was read (#N$1F).
 $9009 RET Z         ; }
 $900A CALL $8DCC    ; Call #R$8DCC.
 $900D INC HL        ; Increment the messaging pointer by one.
 $900E JR $9006      ; Jump back to #R$9006 to continue printing.

